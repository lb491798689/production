    "multi_column_XVPNng": {
      "type": "multi-column",
      "blocks": {
        "item_HW9V7A": {
          "type": "item",
          "settings": {
            "column_size": "2",
            "title": "Dual fan-based ventilation",
            "heading_tag": "h4",
            "content": "<p>AutoFull M6 Ultra has 3 gears of ventilation, with air volume of 71.8cm3/min tops, Sweating is no longer a worry in hot summer. Cool air helps balance body temperature.</p>",
            "link_url": "",
            "link_text": "",
            "link_style": "link"
          }
        },
        "item_rLARiq": {
          "type": "item",
          "settings": {
            "column_size": "2",
            "title": "Graphene-based warming",
            "heading_tag": "h4",
            "content": "<p>The use of aerospace material - graphene in warming brings warming efficiency to 67%, temperature control at three gears, with ceiling temperature of 50°C, making chill no longer a worry in winter.</p>",
            "link_url": "",
            "link_text": "",
            "link_style": "link"
          }
        }
      },
      "block_order": [
        "item_HW9V7A",
        "item_rLARiq"
      ],
      "disabled": true,
      "settings": {
        "section_id": "",
        "full_width": true,
