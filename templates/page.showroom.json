    "faq_JXi6qh": {
      "type": "faq",
      "blocks": {
        "item_9ieFiL": {
          "type": "item",
          "settings": {
            "title": "Public Transport Directions",
            "content": "<h6><strong>From Braddell MRT</strong></h6><ol><li>Take <strong>Exit A</strong> at Braddell MRT Station.</li><li>Follow the direction of traffic and turn left when you see Block 107.</li><li>Walk straight towards the roundabout and go down the stairs towards Block 206.</li><li>Cut across Block 206 and head towards Block 1008.</li><li>Walk towards the main road and turn left.</li><li>Continue for 150m. <strong>351 On Braddell</strong> will be on your left.</li><li>Enter the compound and register with the security guard.</li><li>Take the lift up to <strong>Level 5</strong>. Welcome to Secretlab!</li></ol><h6><strong>By Bus</strong></h6><ol><li>Alight at <strong>Braddell Road Block 1004</strong>. Bus services available at this stop are <strong>93, 157, and 163</strong>.</li><li>Follow the direction of the traffic and walk for about 200m to <strong>351 On Braddell</strong>.</li><li>Enter the compound and register with the securit</li></ol>"
          }
        },
        "item_D6PkMk": {
          "type": "item",
          "settings": {
            "title": "Driving Directions",
            "content": "<h6>From Braddell Rd</h6><ol><li>Keep left on Braddell Rd. Look out for a signboard with <strong>351 on Braddell</strong> on it.</li><li>Turn left into the entrance of 351 on Braddell.</li><li>Turn left into the compound and head to the Level 2 Carpark.</li><li>Park and take the lift up to <strong>Level 5</strong>. Welcome to Secretlab!</li></ol>"
          }
        },
        "item_YbXiTR": {
          "type": "item",
          "settings": {
            "title": "What can I expect to see at the Autofull Showroom?",
            "content": "<p>We're all about letting you <em>experience</em> the Autofull difference.  Come on down and you'll get to try out our full range of gaming chairs, desks, and accessories firsthand.  Sit in 'em, adjust 'em, feel the premium materials, and see what makes Autofull the ultimate upgrade for your setup.  Our team will also be on hand to answer any questions you have and help you find the perfect gear to level up your game.  Think of it as your chance to get hands-on with greatness!</p>"
          }
        },
        "item_G4Ez6M": {
          "type": "item",
          "settings": {
            "title": "Do I need to book an appointment to visit the Showroom?",
            "content": "<p>While appointments aren't strictly required, we highly recommend booking one, especially if you're planning on visiting during peak hours or want a dedicated consultation with one of our experts.  This way, we can ensure you get the full Autofull experience and have ample time to explore our products. </p>"
          }
        }
      },
