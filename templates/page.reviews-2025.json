    "kik_about_player_3YPcMg": {
      "type": "kik-about-player",
      "blocks": {
        "text_and_image_qtyCBc": {
          "type": "text_and_image",
          "settings": {
            "title": "His Legacy",
            "heading": "",
            "description": "<p>Nikola \"NiKo\" Kovač is widely regarded as one of the greatest players in Counter-Strike history, renowed for his exceptional aim and game sense, and often considered the best rifler of all time. </p>",
            "image": "shopify://shop_images/1600X1600.png",
            "image_width": 400,
            "mobile_image_width": 250
          }
        },
        "stats_naAkJm": {
          "type": "stats",
          "settings": {
            "title": "<p>HIS ACHIEVEMENTS</p>",
            "stat_1": "Top 20",
            "desc_1": "Record for the most consecutive appearances in HLTV’s Top 20 Players of the Year.",
            "stat_2": "BEST PERF.",
            "desc_2": "Best overall performance at a \"Big Event\" in Counter-Strike history.",
            "stat_3": "9 MVPs",
            "desc_3": "9 MVP titles earned throughout his career so far.",
            "stat_4": "",
            "desc_4": "",
