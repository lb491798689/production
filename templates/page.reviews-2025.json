            "desc_6": ""
          }
        },
        "text_and_image_7ALUNe": {
          "type": "text_and_image",
          "settings": {
            "title": "MESSAGE TO FANS",
            "heading": "MY HEARTFELT GRATITUDE",
            "description": "<p>Once again, we’ve defied expectations.<br/><br/>Every match, every round, the world doubted us. But we answered with </p><p>unwavering confidence.</p><p><br/>  From SEA to the global stage, we proved that we belong.</p><p>This journey isn’t just mine—it’s ours. To every fan who stood by me, your support</p><p> fuels every clutch, every victory.<br/><br/>This is more than just a game. It’s a statement. </p><p>And we’re just getting started.</p><p></p>",
            "image": "shopify://shop_images/sign_a3d6761a-94d5-4b52-9a98-a49bd91fad39.jpg",
            "image_width": 130,
            "mobile_image_width": 120
          }
        }
      },
