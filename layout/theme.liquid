      useClassNames: false,
      disableMutationObserver: false,
      debounceDelay: 50,
      throttleDelay: 99
    });
    
    // 修复 body overflow 被设置为 hidden 的问题
    setTimeout(function() {
      if (document.body.style.overflow === 'hidden') {
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
      }
    }, 100);
    
    // 持续监听并修复
    setInterval(function() {
      if (document.body.style.overflow === 'hidden' && !document.querySelector('.modal-open, .drawer-open')) {
        document.body.style.overflow = '';
      }
    }, 500);
  </script>
