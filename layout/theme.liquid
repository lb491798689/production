    <!-- Jingva: 收起 Inbox 默认气泡；仅当访客点击侧边栏等入口后才允许保持展开（避免误触发自动打开 / 关闭按钮被 CSS 误藏） -->
    <script>
      (function() {
        window.__jingvaAllowInboxOpen = false;
        window.__jingvaInboxHasBeenOpened = false;
        window.__jingvaInboxOpenRequestedAt = 0;
        window.__jingvaInboxExpandGraceUntil = 0;

        function findInboxChatEl() {
          var el = document.getElementById('ShopifyChat');
          if (!el) {
            var wrapper = document.getElementById('shopify-chat');
            if (wrapper) el = wrapper.querySelector('inbox-online-store-chat');
          }
          return el || null;
        }

        /* 与 #jingva-sidebar 对齐：避免 Chat 叠在 DOCTOR SAY / 购物车一列上（原 right:20px 会压住侧栏） */
        window.jingvaGetInboxDockLayout = function () {
          var narrow = window.matchMedia('(max-width: 1279px)').matches;
          if (narrow) {
            return {
              right: '78px',
              bottom: '90px',
              maxW: 'min(calc(100vw - 24px), calc(100vw - 92px))',
              maxH: 'min(85vh, calc(100vh - 110px))',
            };
          }
          return {
            right: '132px',
            bottom: '52px',
            maxW: 'min(440px, calc(100vw - 176px))',
            maxH: 'min(620px, calc(100vh - 96px))',
          };
        };

        window.jingvaApplyInboxDockLayout = function (chatEl) {
          if (!chatEl) return;
          var L = window.jingvaGetInboxDockLayout();
          chatEl.style.setProperty('right', L.right, 'important');
          chatEl.style.setProperty('bottom', L.bottom, 'important');
          chatEl.style.setProperty('left', 'auto', 'important');
          chatEl.style.setProperty('top', 'auto', 'important');
          chatEl.style.setProperty('max-width', L.maxW, 'important');
          chatEl.style.setProperty('max-height', L.maxH, 'important');
          chatEl.style.setProperty('box-sizing', 'border-box', 'important');
        };

        function injectHideLauncherWhenClosed(el) {
          if (!el || !el.shadowRoot) return;
          if (el.shadowRoot.querySelector('#jingva-hide-inbox-when-closed')) return;
          var style = document.createElement('style');
          style.id = 'jingva-hide-inbox-when-closed';
          style.textContent =
            ':host([is-open="false"]) button,' +
            ':host([is-open="false"]) [role="button"],' +
            ':host([is-open="false"]) [class*="chat-app"],' +
            ':host([is-open="false"]) [class*="ChatApp"],' +
            ':host([is-open="false"]) .chat-toggle {' +
            'display: none !important; opacity: 0 !important; visibility: hidden !important; pointer-events: none !important;' +
            '}';
          el.shadowRoot.appendChild(style);
        }

        var __jingvaLauncherAlwaysCss =
          '.chat-toggle,' +
          '[class*="chat-toggle"]' +
          ',[class*="chat-app--launcher"]' +
          ',[class*="chat-app__launcher"]' +
          ',[class*="launcher-button"]' +
          ',[class*="floating-bubble"]' +
          ',[class*="FloatingBubble"]' +
          ',[class*="ChatFab"]' +
          ',[class*="chat-fab"]' +
          ',button[aria-label*="Minimize"]' +
          ',button[aria-label*="minimize"]' +
          ' { display: none !important; visibility: hidden !important; opacity: 0 !important; ' +
          'pointer-events: none !important; width: 0 !important; height: 0 !important; ' +
          'overflow: hidden !important; clip-path: inset(50%) !important; ' +
          'position: absolute !important; left: -9999px !important; }';

        function injectHideLauncherAlways(el) {
          if (!el || !el.shadowRoot) return;
          if (window.__jingvaInboxExpandGraceUntil && Date.now() < window.__jingvaInboxExpandGraceUntil) return;
          var sr = el.shadowRoot;
          var style = sr.querySelector('#jingva-hide-launcher-always');
          if (!style) {
            style = document.createElement('style');
            style.id = 'jingva-hide-launcher-always';
            sr.appendChild(style);
          }
          /* 与 is-open 无关；勿用 MutationObserver：更新 style 会再次触发 shadow 变更 → 同步死循环卡死页面 */
          if (style.textContent !== __jingvaLauncherAlwaysCss) {
            style.textContent = __jingvaLauncherAlwaysCss;
          }
        }

        function injectHideLauncherStyles(el) {
          injectHideLauncherWhenClosed(el);
          injectHideLauncherAlways(el);
        }

        function triggerInboxExpand(chatEl) {
          var sr = chatEl && chatEl.shadowRoot;
          if (!sr) return;
          /* Shopify 社区常用：真正展开会话的是 .chat-app 内按钮，而不是只靠 is-open（见论坛 .chat-app>button） */
          var primary = sr.querySelector('.chat-app > button, .chat-app button');
          if (primary) {
            try {
              primary.click();
              return;
            } catch (e0) {}
          }
          var sel = [
            '.chat-toggle',
            '[class*="chat-toggle"]',
            'button[aria-label="Chat"]',
            'button[aria-label="Open chat"]',
            'button[aria-label^="Chat with"]',
            '[class*="ChatButton"]',
            '[class*="chat-button"]',
            '[data-testid="chat-button"]',
            '[data-testid="chat-toggle"]',
          ];
          var i;
          for (i = 0; i < sel.length; i++) {
            var node = sr.querySelector(sel[i]);
            if (node) {
              try {
                node.click();
                return;
              } catch (e) {}
            }
          }
          var buttons = sr.querySelectorAll('button');
          for (i = 0; i < buttons.length; i++) {
            var lab = (buttons[i].getAttribute('aria-label') || '').toLowerCase();
            if (lab.indexOf('close') !== -1) continue;
            if (lab.indexOf('minimize') !== -1) continue;
            if (lab.indexOf('send') !== -1) continue;
            if (lab.indexOf('chat') !== -1 || lab.indexOf('message') !== -1) {
              try {
                buttons[i].click();
                return;
              } catch (e2) {}
            }
          }
        }

        function setInboxPanelOpenClass(on) {
          var root = document.documentElement;
          if (on) root.classList.add('jingva-inbox-panel-open');
          else root.classList.remove('jingva-inbox-panel-open');
        }

        function hideInboxButton() {
          var el = findInboxChatEl();
          if (!el) return;

          injectHideLauncherStyles(el);

          var isOpen = el.getAttribute('is-open') === 'true';

          /* 访客点了打开但脚本尚在等 Inbox 注入：勿强制收起，也不要清掉授权 */
          if (window.__jingvaAllowInboxOpen && !isOpen && !window.__jingvaInboxHasBeenOpened) {
            if (Date.now() - (window.__jingvaInboxOpenRequestedAt || 0) < 15000) {
              return;
            }
            window.__jingvaAllowInboxOpen = false;
          }

          /* 访客已打开过会话又关掉：收回授权并收起 */
          if (window.__jingvaAllowInboxOpen && window.__jingvaInboxHasBeenOpened && !isOpen) {
            window.__jingvaAllowInboxOpen = false;
            window.__jingvaInboxHasBeenOpened = false;
          }

          /* 只有访客主动点了侧边栏等入口后才维持会话窗；否则即便组件短暂 is-open=true 也会立刻收起 */
          if (isOpen && window.__jingvaAllowInboxOpen) {
            setInboxPanelOpenClass(true);
            var wrap = document.getElementById('shopify-chat');
            if (wrap) {
              wrap.style.setProperty('opacity', '1', 'important');
              wrap.style.setProperty('pointer-events', 'auto', 'important');
              wrap.style.setProperty('z-index', '2147483647', 'important');
              wrap.style.setProperty('visibility', 'visible', 'important');
              wrap.style.setProperty('position', 'fixed', 'important');
              wrap.style.setProperty('right', '0', 'important');
              wrap.style.setProperty('bottom', '0', 'important');
            }
            el.style.setProperty('position', 'fixed', 'important');
            window.jingvaApplyInboxDockLayout(el);
            el.style.setProperty('opacity', '1', 'important');
            el.style.setProperty('visibility', 'visible', 'important');
            el.style.setProperty('pointer-events', 'auto', 'important');
            el.style.setProperty('z-index', '2147483647', 'important');
            return;
          }

          setInboxPanelOpenClass(false);
          window.__jingvaInboxExpandGraceUntil = 0;
          el.setAttribute('is-open', 'false');
          el.style.removeProperty('max-width');
          el.style.removeProperty('max-height');
          el.style.setProperty('right', '-9999px', 'important');
          el.style.setProperty('opacity', '0', 'important');
          el.style.setProperty('pointer-events', 'none', 'important');
          el.style.setProperty('visibility', 'hidden', 'important');
          el.style.setProperty('z-index', '-1', 'important');

          var wrapClosed = document.getElementById('shopify-chat');
          if (wrapClosed) {
            ['opacity', 'pointer-events', 'z-index', 'visibility', 'right', 'bottom', 'left', 'top', 'position'].forEach(function (p) {
              wrapClosed.style.removeProperty(p);
            });
          }
        }

        window.jingvaCloseShopifyInbox = function () {
          window.__jingvaAllowInboxOpen = false;
          window.__jingvaInboxHasBeenOpened = false;
          window.__jingvaInboxExpandGraceUntil = 0;
          setInboxPanelOpenClass(false);
          var el = findInboxChatEl();
          if (!el) return;
          el.setAttribute('is-open', 'false');
          el.style.removeProperty('max-width');
          el.style.removeProperty('max-height');
          el.style.setProperty('right', '-9999px', 'important');
          el.style.setProperty('opacity', '0', 'important');
          el.style.setProperty('pointer-events', 'none', 'important');
          el.style.setProperty('visibility', 'hidden', 'important');
          el.style.setProperty('z-index', '-1', 'important');
          var wrapClosed = document.getElementById('shopify-chat');
          if (wrapClosed) {
            ['opacity', 'pointer-events', 'z-index', 'visibility', 'right', 'bottom', 'left', 'top', 'position'].forEach(function (p) {
              wrapClosed.style.removeProperty(p);
            });
          }
        };

        window.jingvaOpenShopifyInbox = function () {
          window.__jingvaAllowInboxOpen = true;
          window.__jingvaInboxOpenRequestedAt = Date.now();

          function applyOpen(chatEl) {
            window.__jingvaInboxExpandGraceUntil = Date.now() + 1100;
            setInboxPanelOpenClass(true);
            var wrap = document.getElementById('shopify-chat');
            if (wrap) {
              wrap.style.setProperty('opacity', '1', 'important');
              wrap.style.setProperty('pointer-events', 'auto', 'important');
              wrap.style.setProperty('z-index', '2147483647', 'important');
              wrap.style.setProperty('visibility', 'visible', 'important');
              wrap.style.setProperty('position', 'fixed', 'important');
              wrap.style.setProperty('right', '0', 'important');
              wrap.style.setProperty('bottom', '0', 'important');
              wrap.style.setProperty('left', 'auto', 'important');
              wrap.style.setProperty('top', 'auto', 'important');
            }
            chatEl.setAttribute('is-open', 'true');
            window.__jingvaInboxHasBeenOpened = true;
            chatEl.style.setProperty('position', 'fixed', 'important');
            window.jingvaApplyInboxDockLayout(chatEl);
            chatEl.style.setProperty('opacity', '1', 'important');
            chatEl.style.setProperty('visibility', 'visible', 'important');
            chatEl.style.setProperty('pointer-events', 'auto', 'important');
            chatEl.style.setProperty('z-index', '2147483647', 'important');
            injectHideLauncherWhenClosed(chatEl);
            triggerInboxExpand(chatEl);
            setTimeout(function () {
              triggerInboxExpand(chatEl);
            }, 0);
            setTimeout(function () {
              triggerInboxExpand(chatEl);
            }, 90);
            setTimeout(function () {
              triggerInboxExpand(chatEl);
            }, 220);
            setTimeout(function () {
              triggerInboxExpand(chatEl);
            }, 450);
            setTimeout(function () {
              triggerInboxExpand(chatEl);
            }, 700);
            setTimeout(function () {
              window.__jingvaInboxExpandGraceUntil = 0;
              injectHideLauncherAlways(chatEl);
            }, 1120);
          }

          function tryOnce() {
            var chatEl = findInboxChatEl();
            if (chatEl) {
              applyOpen(chatEl);
              return true;
            }
            return false;
          }

          if (tryOnce()) return;
          var n = 0;
          var id = setInterval(function () {
            n++;
            if (tryOnce() || n >= 30) clearInterval(id);
          }, 200);
        };

        setInterval(hideInboxButton, 400);
      })();

      (function removeOpIconsManager() {
        function nuke(root) {
          if (!root || !root.querySelectorAll) return;
          var nodes = root.querySelectorAll('[class*="op_icons_manager"], [class*="op-icons-manager"], [id*="op_icons_manager"], [id*="op-icons-manager"]');
          for (var i = 0; i < nodes.length; i++) {
            var el = nodes[i];
            if (el && el.parentNode) el.parentNode.removeChild(el);
          }
        }
        function run() { nuke(document); }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
        var mo = new MutationObserver(function (mutations) {
          for (var i = 0; i < mutations.length; i++) {
            var m = mutations[i];
            for (var j = 0; j < m.addedNodes.length; j++) {
              var n = m.addedNodes[j];
              if (n && n.nodeType === 1) {
                if (n.matches && n.matches('[class*="op_icons_manager"], [class*="op-icons-manager"], [id*="op_icons_manager"], [id*="op-icons-manager"]')) {
                  if (n.parentNode) n.parentNode.removeChild(n);
                } else {
                  nuke(n);
                }
              }
            }
          }
        });
        try { mo.observe(document.documentElement, { childList: true, subtree: true }); } catch (e) {}
        setInterval(run, 1000);
      })();
    </script>
  </body>
  <script>
