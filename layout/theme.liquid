    <!-- Critical CSS -->
    <style>
      /* 与 Figma 抗锯齿口径一致，避免 Chrome/Safari macOS 默认子像素渲染让文字视觉偏粗 */
      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      /* 禁用浏览器字体合成，防止可变字体未完全就位时合成粗体导致 400 看起来像 600 */
      body {
        font-synthesis: none;
        -webkit-font-synthesis: none;
        /* 与 Figma letterSpacing:0 一致，显式 0 而非默认 normal */
        letter-spacing: 0;
        /* 开启 kerning + 合字（Figma 默认开），避免字与字之间看起来偏松 */
        font-kerning: normal;
        font-feature-settings: "kern" 1, "liga" 1, "calt" 1;
        font-variant-ligatures: common-ligatures contextual;
        /* 可变字体的视觉尺寸轴自动匹配（如字体含 opsz 轴） */
        font-optical-sizing: auto;
      }
      .content-over-media {
        opacity: 1;
        transition: opacity 0.3s ease-in-out;
      }
      .content-over-media img {
        width: 100%;
        height: auto;
        display: block;
      }
      .content-over-media picture {
        display: block;
      }
    </style>

