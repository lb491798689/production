        color: inherit !important;
        text-align: center !important;
        text-transform: none !important;
      }

      .jingva-sidebar__btn {
        width: 32.4px !important;
        height: 32.4px !important;
        min-width: 32.4px !important;
        min-height: 32.4px !important;
        padding: 2.7px !important;
        box-shadow: 0 2.7px 8.1px rgba(0, 0, 0, 0.08) !important;
      }

      .jingva-sidebar__btn img {
        width: 16.2px !important;
        height: 16.2px !important;
      }

      #jingva-sidebar-cart img,
