        display: none !important;
      }

      .jingva-sidebar__modal-overlay--mobile.active {
        display: none !important;
      }

      .jingva-sidebar__modal-overlay--desktop {
        display: none !important;
      }

      .jingva-sidebar__modal-overlay--desktop.active {
        display: flex !important;
      }

      .jingva-sidebar__modal {
        border-radius: 8px !important;
        padding: 48px !important;
        gap: 48px !important;
        max-width: 1200px !important;
        width: auto !important;
        flex-direction: row !important;
        align-items: flex-start !important;
      }

      .jingva-sidebar__modal-close {
        top: 24px !important;
        right: 24px !important;
        width: 32px !important;
        height: 32px !important;
        background: transparent !important;
        border: 2px solid #0a0a0a !important;
      }

      .jingva-sidebar__modal-avatar {
        width: 300px !important;
        height: 300px !important;
      }

      .jingva-sidebar__modal-content {
        text-align: left !important;
        gap: 12px !important;
        padding-top: 0 !important;
        max-width: 720px !important;
      }

      .jingva-sidebar__modal-title {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 700 !important;
        font-size: 32px !important;
        line-height: 38px !important;
        text-transform: none !important;
        white-space: pre-line !important;
      }

      .jingva-sidebar__modal-doctor-name {
        font-size: 18px !important;
        line-height: 21.6px !important;
        font-weight: 700 !important;
      }

      .jingva-sidebar__modal-doctor-title {
        font-size: 14px !important;
        line-height: 16.8px !important;
        color: #0a0a0a !important;
        font-weight: 500 !important;
        word-wrap: break-word !important;
      }

      .jingva-sidebar__modal-quote {
        font-size: 12px !important;
        line-height: 14.4px !important;
        color: rgba(26, 26, 26, 0.6) !important;
        font-style: normal !important;
        font-weight: 500 !important;
        word-wrap: break-word !important;
      }
    }

    /* === PC: 1440~2560 === */
    @media screen and (min-width: 1440px) {
      /* 弹窗显示控制 - PC 显示 desktop 弹窗 */
      .jingva-sidebar__modal-overlay--mobile {
        display: none !important;
      }

      .jingva-sidebar__modal-overlay--mobile.active {
        display: none !important;
      }

      .jingva-sidebar__modal-overlay--desktop {
        display: none !important;
      }

      .jingva-sidebar__modal-overlay--desktop.active {
        display: flex !important;
      }

      .jingva-sidebar__modal {
        border-radius: 12px !important;
        padding: 70px 162px 69px !important;
        gap: 85px !important;
        max-width: 1200px !important;
        width: auto !important;
        flex-direction: row !important;
        align-items: flex-start !important;
      }

      .jingva-sidebar__modal-close {
        top: 24px !important;
        right: 24px !important;
        width: 32px !important;
        height: 32px !important;
        background: transparent !important;
        border: 2px solid #0a0a0a !important;
      }

      .jingva-sidebar__modal-avatar-wrap {
        width: 341px !important;
        height: 341px !important;
      }

      .jingva-sidebar__modal-avatar {
        width: 341px !important;
        height: 341px !important;
      }

      .jingva-sidebar__modal-content {
        text-align: left !important;
        gap: 12px !important;
        padding-top: 0 !important;
        max-width: 720px !important;
      }

      .jingva-sidebar__modal-title {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 700 !important;
        font-size: 32px !important;
        line-height: 38px !important;
        text-transform: none !important;
        white-space: pre-line !important;
      }

      .jingva-sidebar__modal-doctor-name {
        font-size: 24px !important;
        line-height: normal !important;
        font-weight: 700 !important;
        color: #000 !important;
      }

      .jingva-sidebar__modal-doctor-title {
        font-family: 'Gabarito', sans-serif !important;
        font-size: 16px !important;
        line-height: normal !important;
        color: #0a0a0a !important;
        font-weight: 500 !important;
        word-wrap: break-word !important;
      }

      .jingva-sidebar__modal-content .jingva-sidebar__modal-quote,
      .jingva-sidebar__modal-content div.jingva-sidebar__modal-quote,
      .jingva-sidebar__modal-content p.jingva-sidebar__modal-quote {
        font-size: 14px !important;
        line-height: normal !important;
        color: rgba(0, 0, 0, 0.60) !important;
        font-style: normal !important;
        font-weight: 500 !important;
        word-wrap: break-word !important;
        margin-top: 12px !important;
      }
    }

    /* 移动端样式调整 (mob: 375-1279px) */
    @media screen and (max-width: 1279px) {
      .jingva-sidebar__modal-overlay {
        padding: 0 !important;
      }

      .jingva-sidebar__modal {
        padding: 33px 24px 31px !important;
        gap: 24px !important;
      }

      .jingva-sidebar {
        right: 16px !important;
        bottom: 40px !important;
      }

      .jingva-sidebar__avatar-wrap {
        gap: 4px !important;
      }

      .jingva-sidebar__modal-avatar-wrap {
        margin: 0 !important;
      }

      .jingva-sidebar__avatar-circle {
        width: 48px !important;
        height: 48px !important;
        background: #DFF0FF !important;
      }

      .jingva-sidebar__modal-content .jingva-sidebar__modal-title {
        margin-bottom: 12px !important;
      }

      .jingva-sidebar__modal-content .jingva-sidebar__modal-title p {
        color: #000 !important;
        font-family: Gabarito !important;
        font-size: 24px !important;
        font-style: normal !important;
        font-weight: 700 !important;
        line-height: normal !important;
      }

      .jingva-sidebar__modal-content p.jingva-sidebar__modal-doctor-name {
        margin-bottom: 24px !important;
      }

      .jingva-sidebar__modal-content div.jingva-sidebar__modal-doctor-title,
      .jingva-sidebar__modal-content p.jingva-sidebar__modal-doctor-title {
        color: #000 !important;
        font-family: 'Gabarito', sans-serif !important;
        font-size: 14px !important;
        font-style: normal !important;
