{%- liquid
  assign sid = section.id
-%}

<div class="jingva-sidebar jingva-sidebar-{{ sid }}" id="jingva-sidebar">
  {% style %}
    /* ===== Floating Sidebar — Figma node 950:8987 & 950:8988 ===== */
    .jingva-sidebar {
      position: fixed !important;
      right: 44px !important;
      bottom: 48px !important;
      top: auto !important;
      transform: none !important;
      z-index: 2147483646 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 12px !important;
      filter: drop-shadow(0px 0px 7px rgba(26, 26, 26, 0.2)) !important;
      visibility: visible !important;
      opacity: 1 !important;
      transition: bottom 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, visibility 0s linear 0s !important;
    }

    /* 向下滚动时整体淡出，停止 1s 后再淡入 */
    .jingva-sidebar.is-scroll-hidden {
      opacity: 0 !important;
      pointer-events: none !important;
      visibility: hidden !important;
      transition: bottom 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, visibility 0s linear 0.3s !important;
    }

    /* ---------- 头像区 ---------- */
    .jingva-sidebar__avatar-wrap {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 12px !important;
      cursor: pointer !important;
    }

    .jingva-sidebar__avatar-circle {
      width: 52px !important;
      height: 52px !important;
      border-radius: 50% !important;
      overflow: hidden !important;
      background: #DFF0FF !important;
      flex-shrink: 0 !important;
    }

    .jingva-sidebar__avatar-circle img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      display: block !important;
    }

    /* doctor say：黑底 + 白色描边。-webkit-text-stroke 在 12px 小字号上渲染糊；改用 8 向 text-shadow 模拟描边，更锐利。 */
    .jingva-sidebar__avatar-label {
      font-family: "OPPO Sans", sans-serif !important;
      font-weight: 700 !important;
      font-size: 12px !important;
      line-height: 14.4px !important;
      color: #000000 !important;
      text-shadow:
        -1px -1px 0 #FFFFFF,
         0   -1px 0 #FFFFFF,
         1px -1px 0 #FFFFFF,
         1px  0   0 #FFFFFF,
         1px  1px 0 #FFFFFF,
         0    1px 0 #FFFFFF,
        -1px  1px 0 #FFFFFF,
        -1px  0   0 #FFFFFF !important;
      -webkit-font-smoothing: antialiased !important;
      -moz-osx-font-smoothing: grayscale !important;
      text-rendering: geometricPrecision !important;
      text-align: center !important;
      text-transform: none !important;
      margin: 0 !important;
      padding: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 0 !important;
    }

    .jingva-sidebar__avatar-label p {
      line-height: 14.4px !important;
      margin: 0 !important;
      padding: 0 !important;
      font-size: 12px !important;
      font-weight: 700 !important;
      font-family: "OPPO Sans", sans-serif !important;
      color: inherit !important;
      text-align: center !important;
      text-transform: none !important;
    }

    /* ---------- 功能按钮组 ---------- */
    .jingva-sidebar__slot {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 9px !important;
    }

    .jingva-sidebar__btn {
      width: 43.2px !important;
      height: 43.2px !important;
      min-width: 43.2px !important;
      min-height: 43.2px !important;
      border-radius: 50% !important;
      background: #ffffff !important;
      border: none !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 0 !important;
      transition: background-color 0.2s ease !important;
      position: relative !important;
      text-decoration: none !important;
      color: #0A0A0A !important;
      overflow: hidden !important;
      visibility: visible !important;
      opacity: 1 !important;
      box-shadow: 0 3.6px 10.8px rgba(0, 0, 0, 0.08) !important;
    }

    .jingva-sidebar__btn:hover {
      background: #E0E0E0 !important;
    }

    .jingva-sidebar__btn img {
      width: 21.6px !important;
      height: 21.6px !important;
      object-fit: contain !important;
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
    }

    #jingva-sidebar-cart img,
    #jingva-sidebar-chat img {
      width: 18px !important;
      height: 18px !important;
    }
    
    /* 确保聊天按钮始终可见 */
    #jingva-sidebar-chat {
      display: flex !important;
      visibility: visible !important;
      opacity: 1 !important;
    }

    /* ---------- 头像弹窗 ---------- */
    .jingva-sidebar__modal-overlay {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      background: rgba(0, 0, 0, 0.6) !important;
      z-index: 2147483647 !important;
      display: none !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 20px !important;
      box-sizing: border-box !important;
    }

    .jingva-sidebar__modal-overlay.active {
      display: flex !important;
    }

    /* === MOB: 375~1279 === (Mobile First) === */
    .jingva-sidebar__modal {
      background: #ffffff !important;
      border-radius: 12px !important;
      padding: 12px 24px 31px !important;
      max-width: 358px !important;
      width: auto !important;
      position: relative !important;
      box-shadow: 0px 8px 32px rgba(0, 0, 0, 0.25) !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 12px !important;
      align-items: center !important;
      box-sizing: border-box !important;
    }

    .jingva-sidebar__modal-close {
      position: absolute !important;
      top: 12px !important;
      right: 16px !important;
      width: 36px !important;
      height: 36px !important;
      background: #ffffff !important;
      border: 2.2px solid #000000 !important;
      border-radius: 50% !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      transition: all 0.2s ease !important;
    }

    .jingva-sidebar__modal-close:hover {
      background: rgba(26, 26, 26, 0.10) !important;
      border-color: transparent !important;
    }

    .jingva-sidebar__modal-avatar-wrap {
      flex-shrink: 0 !important;
      width: 213px !important;
      height: 213px !important;
    }

    .jingva-sidebar__modal-avatar {
      width: 213px !important;
      height: 213px !important;
      border-radius: 50% !important;
      object-fit: cover !important;
      display: block !important;
    }

    .jingva-sidebar__modal-content {
      flex: 1 !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 0px !important;
      text-align: left !important;
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }

    /* Richtext 内部标签样式 */
    .jingva-sidebar__modal-content div,
    .jingva-sidebar__modal-content p,
    .jingva-sidebar__modal-content h1,
    .jingva-sidebar__modal-content h2,
    .jingva-sidebar__modal-content h3,
    .jingva-sidebar__modal-content h4,
    .jingva-sidebar__modal-content h5,
    .jingva-sidebar__modal-content h6,
    .jingva-sidebar__modal-content ul,
    .jingva-sidebar__modal-content ol,
    .jingva-sidebar__modal-content li {
      margin: 0 !important;
      padding: 0 !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }

    /* 确保 richtext 容器的 title/doctor-title/quote div 继承样式 */
    .jingva-sidebar__modal-content .jingva-sidebar__modal-title {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 700 !important;
      font-size: 32px !important;
      line-height: normal !important;
      color: #000 !important;
      margin: 0 0 12px 0 !important;
      padding: 0 !important;
      text-transform: none !important;
      white-space: pre-line !important;
    }

    /* 标题内部 richtext 段落不带额外边距，避免两行之间出现空隙 */
    .jingva-sidebar__modal-content .jingva-sidebar__modal-title div,
    .jingva-sidebar__modal-content .jingva-sidebar__modal-title p {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 700 !important;
      font-size: 32px !important;
      line-height: normal !important;
      color: #000 !important;
      margin: 0 !important;
      padding: 0 !important;
      text-transform: none !important;
      white-space: pre-line !important;
    }

    .jingva-sidebar__modal-content .jingva-sidebar__modal-doctor-title,
    .jingva-sidebar__modal-content .jingva-sidebar__modal-doctor-title div,
    .jingva-sidebar__modal-content .jingva-sidebar__modal-doctor-title p,
    .jingva-sidebar__modal-content .jingva-sidebar__modal-doctor-title br {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 16px !important;
      line-height: normal !important;
      color: #0a0a0a !important;
      margin: 0 !important;
      padding: 0 !important;
      white-space: normal !important;
      word-wrap: break-word !important;
    }

    .jingva-sidebar__modal-content .jingva-sidebar__modal-quote,
    .jingva-sidebar__modal-content .jingva-sidebar__modal-quote div,
    .jingva-sidebar__modal-content .jingva-sidebar__modal-quote p {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 14px !important;
      line-height: normal !important;
      color: rgba(0, 0, 0, 0.60) !important;
      margin: 0 !important;
      padding: 0 !important;
      font-style: normal !important;
      word-wrap: break-word !important;
    }

    .jingva-sidebar__modal-title {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 700 !important;
      font-size: 24px !important;
      line-height: 28px !important;
      color: #0a0a0a !important;
      margin: 0 !important;
      text-transform: none !important;
      white-space: pre-line !important;
    }

    .jingva-sidebar__modal-doctor-name {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 700 !important;
      font-size: 18px !important;
      line-height: 21.6px !important;
      color: #0a0a0a !important;
      margin: 0 0 24px 0 !important;
    }

    .jingva-sidebar__modal-doctor-title {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 14px !important;
      line-height: 16.8px !important;
      color: #0a0a0a !important;
      margin: 0 0 12px 0 !important;
      white-space: normal !important;
      word-wrap: break-word !important;
    }

    .jingva-sidebar__modal-quote {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 12px !important;
      line-height: 14.4px !important;
      color: rgba(26, 26, 26, 0.6) !important;
      margin: 0 !important;
      font-style: normal !important;
      word-wrap: break-word !important;
    }

    /* Richtext 内部 p 标签样式 */
    .jingva-sidebar__modal-content p {
      margin: 0 !important;
      padding: 0 !important;
    }

    /* Mobile 显示 mobile 弹窗 */
    .jingva-sidebar__modal-overlay--mobile {
      display: none !important;
    }

    .jingva-sidebar__modal-overlay--mobile.active {
      display: flex !important;
    }

    .jingva-sidebar__modal-overlay--desktop {
      display: none !important;
    }

    .jingva-sidebar__modal-overlay--desktop.active {
      display: none !important;
    }

    /* === PAD: 1280~1439 === */
    @media screen and (min-width: 1280px) and (max-width: 1439px) {
      /* 弹窗显示控制 - PAD 显示 desktop 弹窗 */
