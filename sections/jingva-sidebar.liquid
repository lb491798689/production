<script>
  (function() {
    // 延迟执行确保 DOM 完全加载
    setTimeout(function() {
      console.log('[Jingva Sidebar] Checking sidebar visibility...');

      var sidebar = document.getElementById('jingva-sidebar');
      if (sidebar) {
        console.log('[Jingva Sidebar] ✓ Sidebar element found');
        console.log('[Jingva Sidebar] Computed styles:', window.getComputedStyle(sidebar).display, window.getComputedStyle(sidebar).visibility);

        // 强制显示
        sidebar.style.setProperty('display', 'flex', 'important');
        sidebar.style.setProperty('visibility', 'visible', 'important');
        sidebar.style.setProperty('opacity', '1', 'important');
      } else {
        console.error('[Jingva Sidebar] ✗ Sidebar element NOT found in DOM');
      }

      var chatBtn = document.getElementById('jingva-sidebar-chat');
      if (chatBtn) {
        console.log('[Jingva Sidebar] ✓ Chat button found');
        console.log('[Jingva Sidebar] Chat button styles:', window.getComputedStyle(chatBtn).display, window.getComputedStyle(chatBtn).visibility);

        // 强制显示聊天按钮
        chatBtn.style.setProperty('display', 'flex', 'important');
        chatBtn.style.setProperty('visibility', 'visible', 'important');
        chatBtn.style.setProperty('opacity', '1', 'important');
      } else {
        console.error('[Jingva Sidebar] ✗ Chat button NOT found');
      }

      var topBtn = document.getElementById('jingva-sidebar-top');
      if (topBtn) {
        console.log('[Jingva Sidebar] ✓ Top button found');
      }

      var cartBtn = document.getElementById('jingva-sidebar-cart');
      if (cartBtn) {
        console.log('[Jingva Sidebar] ✓ Cart button found');
      }
    }, 500);

    // 自动调整侧边栏 bottom 位置以响应 g7-custom-sticky-cart 的显示/隐藏
    function adjustSidebarBottom() {
      var sidebar = document.getElementById('jingva-sidebar');
      var stickyCart = document.querySelector('.g7-custom-sticky-cart');

      if (!sidebar) return;

      var isMobile = window.innerWidth < 1280;
      var defaultBottom = isMobile ? 40 : 48;

      if (stickyCart) {
        var stickyCartStyles = window.getComputedStyle(stickyCart);
        var isVisible = stickyCartStyles.display !== 'none' &&
                       stickyCartStyles.visibility !== 'hidden' &&
                       parseFloat(stickyCartStyles.opacity) > 0;

        if (isVisible) {
          var stickyCartHeight = stickyCart.offsetHeight;
          var newBottom = defaultBottom + stickyCartHeight + 12;
          sidebar.style.setProperty('bottom', newBottom + 'px', 'important');
        } else {
          sidebar.style.setProperty('bottom', defaultBottom + 'px', 'important');
        }
      } else {
        sidebar.style.setProperty('bottom', defaultBottom + 'px', 'important');
      }
    }

    // 使用 MutationObserver 监听 DOM 变化
    var observer = new MutationObserver(function(mutations) {
      adjustSidebarBottom();
    });

    // 开始观察
    observer.observe(document.body, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['style', 'class']
    });

    // 初始调整
    adjustSidebarBottom();
    setTimeout(adjustSidebarBottom, 100);
    setTimeout(adjustSidebarBottom, 500);
    setTimeout(adjustSidebarBottom, 1000);

    // 监听窗口大小变化
    window.addEventListener('resize', function() {
      adjustSidebarBottom();
    });

    // 监听滚动事件
    var scrollTimer;
    window.addEventListener('scroll', function() {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(adjustSidebarBottom, 100);
    }, { passive: true });
    
    // 判断是否为移动端
    function isMobile() {
      return window.innerWidth < 1280;
    }

    // 获取当前应该显示的弹窗
    function getCurrentModal() {
      if (isMobile()) {
        return {
          overlay: document.getElementById('jingva-sidebar-modal-mobile'),
          close: document.getElementById('jingva-sidebar-modal-close-mobile')
        };
      } else {
        return {
          overlay: document.getElementById('jingva-sidebar-modal-desktop'),
          close: document.getElementById('jingva-sidebar-modal-close-desktop')
        };
      }
    }

    // 关闭所有弹窗
    function closeAllModals() {
      var modalMobile = document.getElementById('jingva-sidebar-modal-mobile');
      var modalDesktop = document.getElementById('jingva-sidebar-modal-desktop');
      if (modalMobile) modalMobile.classList.remove('active');
      if (modalDesktop) modalDesktop.classList.remove('active');
    }

    // 头像弹窗
    var avatarBtn = document.getElementById('jingva-sidebar-avatar');
    if (avatarBtn) {
      avatarBtn.addEventListener('click', function() {
        closeAllModals();
        var modal = getCurrentModal();
        if (modal.overlay) {
          modal.overlay.classList.add('active');
        }
      });
    }

    // Mobile 弹窗关闭
    var modalMobile = document.getElementById('jingva-sidebar-modal-mobile');
    var modalCloseMobile = document.getElementById('jingva-sidebar-modal-close-mobile');
    if (modalMobile) {
      if (modalCloseMobile) {
        modalCloseMobile.addEventListener('click', function() {
          modalMobile.classList.remove('active');
        });
      }
      modalMobile.addEventListener('click', function(e) {
        if (e.target === modalMobile) {
          modalMobile.classList.remove('active');
        }
      });
    }

    // Desktop 弹窗关闭
    var modalDesktop = document.getElementById('jingva-sidebar-modal-desktop');
    var modalCloseDesktop = document.getElementById('jingva-sidebar-modal-close-desktop');
    if (modalDesktop) {
      if (modalCloseDesktop) {
        modalCloseDesktop.addEventListener('click', function() {
          modalDesktop.classList.remove('active');
        });
      }
      modalDesktop.addEventListener('click', function(e) {
        if (e.target === modalDesktop) {
          modalDesktop.classList.remove('active');
        }
      });
    }

    // 返回顶部
    var topBtn = document.getElementById('jingva-sidebar-top');
    if (topBtn) {
      topBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // 聊天：自定义 icon = 唯一入口；再次点击关闭（系统悬浮球由 theme 侧隐藏）
    var chatBtn = document.getElementById('jingva-sidebar-chat');
    if (chatBtn) {
      chatBtn.addEventListener('click', function () {
        var inboxHost = document.getElementById('ShopifyChat');
        if (!inboxHost) {
          var w = document.getElementById('shopify-chat');
          if (w) inboxHost = w.querySelector('inbox-online-store-chat');
        }
        if (
          inboxHost &&
          inboxHost.getAttribute('is-open') === 'true' &&
          window.__jingvaAllowInboxOpen
        ) {
          if (typeof window.jingvaCloseShopifyInbox === 'function') {
            window.jingvaCloseShopifyInbox();
          }
          return;
        }
        if (typeof window.jingvaOpenShopifyInbox === 'function') {
          window.jingvaOpenShopifyInbox();
        } else {
          window.__jingvaAllowInboxOpen = true;
          window.__jingvaInboxOpenRequestedAt = Date.now();
          var el = document.getElementById('ShopifyChat');
          if (!el) {
            var wrapper = document.getElementById('shopify-chat');
            if (wrapper) el = wrapper.querySelector('inbox-online-store-chat');
          }
          if (el) {
            document.documentElement.classList.add('jingva-inbox-panel-open');
            el.setAttribute('is-open', 'true');
            window.__jingvaInboxHasBeenOpened = true;
            el.style.setProperty('position', 'fixed', 'important');
            if (typeof window.jingvaApplyInboxDockLayout === 'function') {
              window.jingvaApplyInboxDockLayout(el);
            } else {
              el.style.setProperty('right', '132px', 'important');
              el.style.setProperty('bottom', '52px', 'important');
            }
            el.style.setProperty('opacity', '1', 'important');
            el.style.setProperty('visibility', 'visible', 'important');
            el.style.setProperty('pointer-events', 'auto', 'important');
            el.style.setProperty('z-index', '2147483647', 'important');
          }
        }
      });
    }

    /* ───────── 滚动渐隐渐显：向下滚动淡出，停下 1s 后淡入（PC/MOB 同步） ───────── */
    (function initScrollFade() {
      var sidebarEl = document.getElementById('jingva-sidebar');
      if (!sidebarEl) return;

      var IDLE_DELAY = 1000;       // 停止滚动 1s 后淡入
      var DOWN_THRESHOLD = 4;      // 单帧向下位移超过该阈值视为有效向下滚动
      var lastY = window.pageYOffset || document.documentElement.scrollTop || 0;
      var idleTimer = 0;
      var rafId = 0;
      var hidden = false;

      // 用 inline style 覆盖：上方有 setProperty('opacity','1','important')，必须以同等优先级写入
      function applyHidden() {
        sidebarEl.style.setProperty('opacity', '0', 'important');
        sidebarEl.style.setProperty('pointer-events', 'none', 'important');
        // 不改 visibility，避免抢占其它逻辑；opacity 0 已视觉隐藏
      }
      function applyVisible() {
        sidebarEl.style.setProperty('opacity', '1', 'important');
        sidebarEl.style.setProperty('pointer-events', 'auto', 'important');
      }

      function showSoon() {
        if (idleTimer) clearTimeout(idleTimer);
        idleTimer = setTimeout(function () {
          idleTimer = 0;
          if (hidden) {
            hidden = false;
            applyVisible();
          }
        }, IDLE_DELAY);
      }

      function onScroll() {
        rafId = 0;
        var y = window.pageYOffset || document.documentElement.scrollTop || 0;
        var delta = y - lastY;
        lastY = y;

        if (delta > DOWN_THRESHOLD) {
          if (!hidden) {
            hidden = true;
            applyHidden();
          }
          showSoon();
        }
      }

      window.addEventListener('scroll', function () {
        if (rafId) return;
        rafId = window.requestAnimationFrame(onScroll);
      }, { passive: true });
    })();
  })();
</script>

