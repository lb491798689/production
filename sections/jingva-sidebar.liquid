  {% endstyle %}

  <!-- 头像区域 -->
  <div class="jingva-sidebar__avatar-wrap" id="jingva-sidebar-avatar" role="button" tabindex="0" aria-label="Contact specialist">
    <div class="jingva-sidebar__avatar-circle">
      {% if section.settings.avatar_image %}
        <img src="{{ section.settings.avatar_image | img_url: 'master' }}" alt="Specialist" loading="lazy">
      {% else %}
        <img src="{{ 'sidebar-avatar.png' | asset_url }}" alt="Specialist" loading="lazy">
      {% endif %}
    </div>
    <span class="jingva-sidebar__avatar-label">
      {% if section.settings.avatar_label_line1 != blank %}
        <p>{{ section.settings.avatar_label_line1 }}</p>
      {% endif %}
      {% if section.settings.avatar_label_line2 != blank %}
        <p>{{ section.settings.avatar_label_line2 }}</p>
      {% endif %}
    </span>
  </div>

  <!-- 功能按钮组 -->
  <div class="jingva-sidebar__slot">
    <!-- 返回顶部 -->
    <button class="jingva-sidebar__btn" id="jingva-sidebar-top" aria-label="Back to top">
      <img src="{{ 'sidebar-icon-top.svg' | asset_url }}" alt="Back to top" loading="lazy">
    </button>

    <!-- 购物车 -->
    <a href="/cart" class="jingva-sidebar__btn" id="jingva-sidebar-cart" aria-label="Cart">
      <img src="{{ 'sidebar-icon-cart.svg' | asset_url }}" alt="Cart" loading="lazy">
    </a>

    <!-- 聊天 -->
    <button class="jingva-sidebar__btn" id="jingva-sidebar-chat" aria-label="Chat">
      <img src="{{ 'sidebar-icon-chat.svg' | asset_url }}" alt="Chat" loading="lazy">
    </button>
  </div>
</div>

<!-- 头像弹窗 - Mobile -->
<div class="jingva-sidebar__modal-overlay jingva-sidebar__modal-overlay--mobile" id="jingva-sidebar-modal-mobile">
  <div class="jingva-sidebar__modal">
    <button class="jingva-sidebar__modal-close" id="jingva-sidebar-modal-close-mobile" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none">
        <path d="M19.5553 18.0009L24.4028 22.8485L22.8477 24.4035L18.0002 19.556L13.1526 24.4035L11.5975 22.8485L16.4451 18.0009L11.5975 13.1534L13.1526 11.5983L18.0002 16.4458L22.8477 11.5983L24.4028 13.1534L19.5553 18.0009Z" fill="black"/>
      </svg>
    </button>
