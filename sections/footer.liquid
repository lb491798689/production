<script>
(function() {
  const descriptions = document.querySelectorAll('.custom-text-description p');
  descriptions.forEach(function(p) {
    const html = p.innerHTML;
    const items = html.split('<br>').filter(item => item.trim());
    const newHtml = items.map(function(item, index) {
      const isLast = index === items.length - 1;
      const style = isLast ? 'display:flex;align-items:center;flex-wrap:nowrap;white-space:nowrap;' : 'display:flex;align-items:center;flex-wrap:nowrap;white-space:nowrap;margin-bottom:0px;';
      return '<div style="' + style + '">' + item + '</div>';
    }).join('');
    p.innerHTML = newHtml;
  });
})();
</script>
