      width: 100% !important;
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .footer-v2-menu-header .footer-v2-col-title {
      display: block !important;
      margin-bottom: 0 !important;
      padding: 0 !important;
      font-weight: 700 !important;
      font-size: 16px !important;
      flex: 1 1 auto !important;
