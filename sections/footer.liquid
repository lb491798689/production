    #shopify-section-{{ section.id }} .footer-v2-nav-item .footer-v2-link-list,
    #shopify-section-{{ section.id }} .footer-v2-nav-item .footer-v2-accordion-panel {
      display: none !important;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .footer-v2-nav-item.active .footer-v2-link-list,
    #shopify-section-{{ section.id }} .footer-v2-nav-item.active .footer-v2-accordion-panel {
