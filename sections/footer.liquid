      margin-bottom: 8px;
    }

    #shopify-section-{{ section.id }} .footer-v2-promo {
      margin-bottom: 8px;
    }

    #shopify-section-{{ section.id }} .footer-v2-newsletter-fields {
      border-radius: 8px;
    }

    #shopify-section-{{ section.id }} .footer-v2-newsletter__input {
      min-height: 48px;
    }

    #shopify-section-{{ section.id }} .footer-v2-newsletter__submit {
      min-height: 48px;
      padding: 0 24px;
      border-radius: 0 8px 8px 0;
    }

    #shopify-section-{{ section.id }} .footer-v2-social .social-media,
    #shopify-section-{{ section.id }} .footer-v2-social .social-media--figma {
      gap: 24px;
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .footer-v2-bottom-inner {
      flex-direction: column;
      gap: 24px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .footer-v2-locale-row {
      order: -1;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .footer-v2-locale-pill {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .footer-v2-locale-pill button,
    #shopify-section-{{ section.id }} .footer-v2-locale-pill .localization-selector {
      width: 100%;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .footer-v2-payments-copy {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .footer-v2-payments {
      justify-content: flex-start;
    }
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .footer.footer-v2 {
      padding-top: 80px;
      padding-bottom: 120px;
    }

    #shopify-section-{{ section.id }} .footer-v2__inner {
      padding: 0;
    }

    #shopify-section-{{ section.id }} .footer-v2-hero {
      flex-direction: row;
      justify-content: center;
      align-items: center;
