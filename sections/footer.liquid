      margin-right: 24px;
    }

    #shopify-section-{{ section.id }} .footer-v2-menu-header .footer-v2-accordion-icon {
      display: none !important;
    }

    #shopify-section-{{ section.id }} .footer-v2-menu-header {
      display: block !important;
    }

    #shopify-section-{{ section.id }} .footer-v2-link-list,
    #shopify-section-{{ section.id }} .footer-v2-accordion-panel {
      display: flex !important;
      flex-direction: column;
    }

    #shopify-section-{{ section.id }} .footer-v2-col-title {
      margin-top: 0;
      margin-bottom: 25px !important;
      padding-top: 0;
    }

    #shopify-section-{{ section.id }} .footer-v2-subscribe {
      padding-top: 0;
      margin-top: 0;
      display: flex;
      flex-direction: column;
      flex: 0 0 auto;
      width: 348px;
      max-width: 348px;
    }

    #shopify-section-{{ section.id }} .footer-v2-nav-cluster .footer-v2-nav-item::after {
      content: none !important;
      display: none !important;
