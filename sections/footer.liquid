{% if section.settings.show_back_top %}
  {% style %}
    .scrollToTopBtn {
      background-color: #fff;
      border: none;
      color: #000;
      cursor: pointer;
      font-size: 18px;
      line-height: 48px;
      width: 48px;
      height: 48px;
      position: fixed;
      bottom: 180px;
      right: 34px;
      z-index: 100;
      opacity: 0;
      transform: translateY(100px);
      transition: all 0.5s ease;
    }
    button.scrollToTopBtn span.circle-chevron svg.icon {
      width: 8px;
      height: 14px;
    }
    button.scrollToTopBtn span.circle-chevron {
      rotate: 180deg;
    }
    .showBtn {
      opacity: 1;
      transform: translateY(0);
    }
  {% endstyle %}
{% endif %}

<div class="footer footer-v2">
  <div class="container">
    <div class="footer-v2__inner">
      <div class="footer-v2-hero">
        <img
          class="footer-v2-hero__logo"
          src="{{ 'footer-blade.svg' | asset_url }}"
          alt="{{ shop.name | escape }}"
          width="133"
          height="118"
          loading="lazy">
        <span class="footer-v2-hero__divider" aria-hidden="true"></span>
        <p class="footer-v2-hero__tagline">{{ section.settings.footer_tagline | escape }}</p>
      </div>

      <div class="footer-v2-main">
        <div class="footer-v2-main-row">
          <div class="footer-v2-nav-cluster">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'links' -%}
                  {%- if block.settings.menu != blank -%}
                    <div class="footer-v2-nav-item" {{ block.shopify_attributes }}>
                      <div class="footer-v2-menu-header" style="display:flex!important;flex-direction:row!important;flex-wrap:nowrap!important;align-items:center!important;justify-content:space-between!important;width:100%!important;">
                        {%- if block.settings.show_menu_title -%}
                          <p class="footer-v2-col-title" style="flex:1 1 auto!important;min-width:0!important;">{{ block.settings.menu_title | default: block.settings.menu.title | escape }}</p>
                        {%- endif -%}
                        <span class="footer-v2-accordion-icon" aria-hidden="true">+</span>
                      </div>
                      <ul class="footer-v2-link-list" role="list">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a href="{{ link.url }}" class="inline-block break-all">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>
                  {%- endif -%}
                {%- when 'text' -%}
                  {%- if block.settings.title != blank or block.settings.content != blank or shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                    <div class="footer-v2-nav-item" {{ block.shopify_attributes }}>
                      <div class="footer-v2-menu-header" style="display:flex!important;flex-direction:row!important;flex-wrap:nowrap!important;align-items:center!important;justify-content:space-between!important;width:100%!important;">
                        {%- if block.settings.title != blank -%}
                          <p class="footer-v2-col-title" style="flex:1 1 auto!important;min-width:0!important;">{{ block.settings.title | escape }}</p>
                        {%- endif -%}
                        <span class="footer-v2-accordion-icon" aria-hidden="true">+</span>
                      </div>
                      <div class="footer-v2-accordion-panel">
                        {%- if block.settings.title == 'CUSTOMER SERVICE' -%}
                          <div class="prose custom-text-description">
