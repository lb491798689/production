                          </div>
                        {%- else -%}
                          {%- if block.settings.content != blank -%}
                            <div class="prose custom-text-description">
                              {{- block.settings.content -}}
                            </div>
                          {%- endif -%}
                        {%- endif -%}
                        {%- if shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                          <div class="follow-on-shop">
                            {{- shop | login_button: action: 'follow' -}}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.show_social_icons -%}
                          <div class="footer-v2-social">
                            {%- render 'social-media-figma' -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- when '@app' -%}
                  <div class="footer-v2-nav-item footer-v2-nav-item--app" {{ block.shopify_attributes }}>
                    {%- render block -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          {%- if footer_newsletter_block != blank -%}
            <div class="footer-v2-subscribe" {{ footer_newsletter_block.shopify_attributes }}>
              {%- if section.settings.subscribe_heading != blank -%}
                <p class="footer-v2-subscribe-title">{{ section.settings.subscribe_heading | escape }}</p>
              {%- endif -%}
              {%- if footer_newsletter_block.settings.title != blank -%}
                {%- if footer_newsletter_block.settings.title contains '$10 OFF' -%}
                  {%- assign promo_segments = footer_newsletter_block.settings.title | split: '$10 OFF' -%}
                  <p class="footer-v2-promo">
                    <span>{{ promo_segments[0] | escape }}</span><span class="footer-v2-promo-accent">$10 OFF</span><span>{{ promo_segments[1] | escape }}</span>
                  </p>
                {%- else -%}
                  <p class="footer-v2-promo">{{ footer_newsletter_block.settings.title | escape }}</p>
                {%- endif -%}
              {%- endif -%}

              {%- assign newsletter_form_id = 'footer-newsletter-' | append: section.id -%}
              {%- form 'customer', id: newsletter_form_id, class: 'footer-v2-newsletter-form' -%}
                {%- if form.posted_successfully? -%}
                  {%- capture success_message -%}{{ 'general.newsletter.subscribed_successfully' | t }}{%- endcapture -%}
                  {%- render 'banner', content: success_message, status: 'success' -%}
                {%- else -%}
                  {%- if form.errors -%}
                    {%- capture error_message -%}{{ form.errors.translated_fields['email'] }} {{ form.errors.messages['email'] }}{%- endcapture -%}
                    {%- render 'banner', content: error_message, status: 'error' -%}
                  {%- endif -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="footer-v2-newsletter-fields">
                    <input
                      id="FooterEmail-{{ section.id }}"
                      class="footer-v2-newsletter__input"
                      type="email"
                      name="contact[email]"
                      value="{{ form.email }}"
                      autocomplete="email"
                      required
                      placeholder="{{ section.settings.email_placeholder | escape }}"
                      aria-required="true">
                    <button type="submit" class="footer-v2-newsletter__submit">{{ section.settings.signup_button_label | escape }}</button>
                  </div>
                {%- endif -%}
              {%- endform -%}

              {%- if footer_newsletter_block.settings.content != blank -%}
                <div class="footer-v2-disclaimer prose">
                  {{- footer_newsletter_block.settings.content -}}
                </div>
              {%- endif -%}

              {%- assign show_footer_social = false -%}
              {%- if social_payment_block != blank and social_payment_block.settings.show_social_icons -%}
                {%- assign show_footer_social = true -%}
              {%- elsif social_payment_block == blank and section.settings.show_social_media -%}
                {%- assign show_footer_social = true -%}
              {%- endif -%}
              {%- if show_footer_social -%}
                <div class="footer-v2-social">
                  {%- render 'social-media-figma' -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="footer-v2-bottom">
        <div class="footer-v2-rule" aria-hidden="true">
          <span class="footer-v2-rule__ornament">+</span>
          <span class="footer-v2-rule__line"></span>
          <span class="footer-v2-rule__ornament">+</span>
        </div>
        <div class="footer-v2-bottom-inner">
          <div class="footer-v2-payments-copy">
            <div class="footer-v2-payments" role="list">
              {%- comment -%} Order matches autofull/pay filenames: paypal-1 … apple_pay-11 {%- endcomment -%}
              <img src="{{ 'pay-paypal.svg' | asset_url }}" alt="PayPal" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-klarna.svg' | asset_url }}" alt="Klarna" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-visa.svg' | asset_url }}" alt="Visa" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-mastercard.svg' | asset_url }}" alt="Mastercard" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-maestro.svg' | asset_url }}" alt="Maestro" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-jcb.svg' | asset_url }}" alt="JCB" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-amex.svg' | asset_url }}" alt="American Express" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-diners.svg' | asset_url }}" alt="Diners Club" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-discover.svg' | asset_url }}" alt="Discover" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-googlepay.svg' | asset_url }}" alt="Google Pay" width="38" height="24" loading="lazy">
              <img src="{{ 'pay-applepay.svg' | asset_url }}" alt="Apple Pay" width="38" height="24" loading="lazy">
            </div>
            {%- if section.settings.copyright_line != blank -%}
              {%- assign footer_copy_y = 'now' | date: '%Y' -%}
              <p class="footer-v2-copyright">{{ section.settings.copyright_line | replace: '[year]', footer_copy_y | replace: '[name]', shop.name | escape }}</p>
            {%- else -%}
              <p class="footer-v2-copyright">Copyright © {{ 'now' | date: '%Y' }} {{ shop.name | escape }}, All rights reserved.</p>
            {%- endif -%}
          </div>

          {%- if locale_selector -%}
            <div class="footer-v2-locale-row">
              <div class="footer-v2-locale-pill">
                {%- comment -%}
                  优先级与 header 保持一致：多国家 → country compact 按钮（触发国家/币种选择）；
                  否则若多语言 → locale compact 按钮（触发语言选择）；
                  Popover 向上展开（vertical: start）避免被页面底部裁剪
                {%- endcomment -%}
                {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
                  {%- render 'localization-selector', type: 'country', show_country_name: section.settings.show_country_name, show_country_flag: section.settings.show_country_flag, popover_vertical_position: 'start', popover_horizontal_position: popover_horizontal_position, footer_compact: true -%}
                {%- elsif section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
                  {%- render 'localization-selector', type: 'locale', popover_vertical_position: 'start', popover_horizontal_position: popover_horizontal_position, footer_compact: true -%}
                {%- else -%}
                  {%- comment -%}单语言单国家：保留静态胶囊（无交互）{%- endcomment -%}
                  <div class="af-footer-locale-btn" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;box-sizing:border-box;cursor:default;">
                    {%- render 'af-footer-globe-icon' -%}
                    <span class="af-footer-locale-code" style="font-family:'Gabarito',sans-serif;font-weight:400;font-size:16px;line-height:normal;color:#fafafa;white-space:nowrap;">{{ localization.country.name }}<span class="af-footer-locale-sep"> / </span>{{ localization.language.endonym_name | capitalize }}</span>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {% if section.settings.show_back_top %}
    <button type="button" class="scrollToTopBtn circle-button ring" aria-label="Scroll to top">
      <span class="circle-chevron">{% render 'icon' with 'chevron-right-small', direction_aware: true %}</span>
    </button>
  {% endif %}
</div>

{% if section.settings.show_back_top %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var scrollToTopBtn = document.querySelector('#shopify-section-{{ section.id }} .scrollToTopBtn');
      if (!scrollToTopBtn) return;
      var rootElement = document.documentElement;
      function handleScroll() {
        var scrollTotal = rootElement.scrollHeight - rootElement.clientHeight;
        if (scrollTotal > 0 && rootElement.scrollTop / scrollTotal > 0.8) {
          scrollToTopBtn.classList.add('showBtn');
        } else {
          scrollToTopBtn.classList.remove('showBtn');
        }
      }
      function scrollToTop() {
        rootElement.scrollTo({ top: 0, behavior: 'smooth' });
      }
      scrollToTopBtn.addEventListener('click', scrollToTop);
      document.addEventListener('scroll', handleScroll);
      handleScroll();
    });
  </script>
{% endif %}

