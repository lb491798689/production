{%- assign newsletter_block = section.blocks | where: 'type', 'newsletter' | first -%}
{%- assign kiks_newsletter_block = section.blocks | where: 'type', 'kiks-custom-newsletter' | first -%}
{%- assign footer_newsletter_block = kiks_newsletter_block | default: newsletter_block -%}
{%- assign social_payment_block = section.blocks | where: 'type', 'socialPayment' | first -%}
{%- assign section_identifier = '#shopify-section-' | append: section.id -%}

{%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
  {%- assign locale_selector = true -%}
{%- elsif section.settings.show_country_selector and localization.available_countries.size > 0 -%}
  {%- assign locale_selector = true -%}
{%- else -%}
  {%- assign locale_selector = false -%}
{%- endif -%}
{%- assign popover_horizontal_position = 'end' -%}

{%- assign hero_logo = section.settings.footer_hero_logo -%}
{%- if hero_logo == blank and footer_newsletter_block != blank and footer_newsletter_block.settings.image != blank -%}
  {%- assign hero_logo = footer_newsletter_block.settings.image -%}
{%- endif -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Gabarito:wght@400..700&family=Orbitron:wght@400..900&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    --footer-v2-bg: #0A0A0A;
    --footer-v2-red: #f72136;
    --footer-v2-text: #ffffff;
    --footer-v2-text-dim: rgba(255, 255, 255, 0.8);
    --footer-v2-text-muted: rgba(255, 255, 255, 0.55);
    --footer-v2-pill-bg: #292929;
    --footer-v2-input-bg: #fafafa;
    --footer-v2-placeholder: rgba(10, 10, 10, 0.4);
    --footer-v2-col-gap: 24px;
    --footer-v2-link-gap: 12px;
  }

  #shopify-section-{{ section.id }} .footer.footer-v2 {
    background: var(--footer-v2-bg);
    padding-top: 32px;
    padding-bottom: 64px;
    color: var(--footer-v2-text);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .footer.footer-v2 * {
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .footer.footer-v2 .container {
    margin: 0 auto;
    max-width: none;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2 .prose {
    max-width: none;
  }

  #shopify-section-{{ section.id }} .footer-v2 .prose p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .footer-v2-hero__logo {
    width: 108.203px;
    height: 96px;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .footer-v2-hero__divider {
    display: none;
    width: 0;
    height: 64px;
    border-left: 1px solid rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-hero__tagline {
    margin: 0;
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 28px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--footer-v2-text);
    letter-spacing: 0;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .footer-v2-main {
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .footer-v2-main-row {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-accordion-panel {
    display: flex;
    flex-direction: column;
    gap: var(--footer-v2-link-gap);
  }

  #shopify-section-{{ section.id }} .footer-v2-subscribe {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .footer-v2-col-title {
    margin: 0 0 0 !important;
    padding: 0;
    font-family: 'Orbitron', sans-serif;
    font-weight: 800;
    font-size: 16px;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--footer-v2-text);
    word-break: normal;
  }

  #shopify-section-{{ section.id }} .footer-v2-link-list {
    display: flex;
    flex-direction: column;
    gap: var(--footer-v2-link-gap);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-link-list li {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-link-list a {
    font-family: 'Gabarito', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: normal;
    color: var(--footer-v2-text-dim);
    text-decoration: none;
    display: block;
  }

  #shopify-section-{{ section.id }} .footer-v2-link-list a:hover {
    color: var(--footer-v2-text);
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .footer-v2-nav-item {
    padding: 16px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .footer-v2-nav-item:first-child {
    border-top: none;
    padding-top: 0;
    margin-left: 0 !important;
    margin-right: 24px !important;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .footer-v2-nav-item:first-child {
    padding-left: 0 !important;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .custom-text-description {
    font-family: 'Gabarito', sans-serif;
    font-size: 12px;
    line-height: 1.65;
    color: var(--footer-v2-text-dim);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .custom-text-description p {
    margin: 0;
    line-height: 1.65;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .custom-text-description br {
    display: none;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .custom-text-description svg {
    display: inline-block;
    vertical-align: middle;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-right: 8px;
  }

  #shopify-section-{{ section.id }} .footer-v2-payments-copy {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .follow-on-shop {
    margin-top: 16px;
  }

  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .follow-on-shop shop-login-button,
  #shopify-section-{{ section.id }} .footer-v2-nav-cluster .follow-on-shop button {
    border-radius: 9999px !important;
    min-height: 40px;
    font-family: 'Gabarito', sans-serif;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .footer-v2-subscribe-title {
    margin: 0;
    padding: 0;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 20px;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--footer-v2-text);
    white-space: nowrap;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-promo {
    margin: 20px 0 10px;
    font-family: 'Gabarito', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.4;
    color: var(--footer-v2-text-dim);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .footer-v2-promo-accent {
    color: var(--footer-v2-red);
  }

  #shopify-section-{{ section.id }} .footer-v2-newsletter-fields {
    display: flex;
    align-items: stretch;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    background: var(--footer-v2-input-bg);
    margin-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .footer-v2-newsletter__input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    padding: 0 16px;
    font-family: 'Gabarito', sans-serif;
    font-size: 14px;
    line-height: 1.2;
    color: #0a0a0a;
    min-height: 48px;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .footer-v2-newsletter__input::placeholder {
    color: var(--footer-v2-placeholder);
  }

  #shopify-section-{{ section.id }} .footer-v2-newsletter__submit {
    flex-shrink: 0;
    border: 0;
    cursor: pointer;
    background: #E51300;
    color: var(--footer-v2-input-bg);
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.2;
    text-transform: uppercase;
    padding: 0 24px;
    min-height: 48px;
  }

  #shopify-section-{{ section.id }} .footer-v2-disclaimer {
    margin: 0 0 24px;
    font-family: 'Gabarito', sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: var(--footer-v2-text-dim);
  }

  #shopify-section-{{ section.id }} .footer-v2-disclaimer p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-disclaimer.prose {
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .footer-v2-social .social-media,
  #shopify-section-{{ section.id }} .footer-v2-social .social-media--figma {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .footer-v2-social .social-media li,
  #shopify-section-{{ section.id }} .footer-v2-social .social-media--figma li {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .footer-v2-social .social-media a,
  #shopify-section-{{ section.id }} .footer-v2-social .social-media--figma a {
    display: flex;
    color: var(--footer-v2-text);
  }

  #shopify-section-{{ section.id }} .footer-v2-social .social-media .icon,
  #shopify-section-{{ section.id }} .footer-v2-social .social-media--figma .icon {
    width: 24px;
    height: 24px;
  }

  #shopify-section-{{ section.id }} .footer-v2-rule {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-rule__ornament {
    flex: 0 0 12px;
    width: 12px;
    height: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.35);
    font-size: 12px;
    line-height: 1;
    transform: none;
    user-select: none;
    font-size: 24px;
  }

  #shopify-section-{{ section.id }} .footer-v2-rule__line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
  }

  #shopify-section-{{ section.id }} .footer-v2-bottom {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
    overflow: visible;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .footer-v2-bottom-inner {
    display: flex;
    gap: 24px;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .footer-v2-locale-row {
    order: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-locale-pill {
    background: var(--footer-v2-pill-bg);
    border-radius: 9999px;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .footer-v2-locale-pill .af-footer-locale-btn {
    width: 100%;
    justify-content: center;
    color: #fafafa;
    border: none;
    background: none;
    padding: 0;
    font-family: inherit;
  }

  #shopify-section-{{ section.id }} .footer-v2-locale-pill .af-footer-locale-code {
    font-family: 'Gabarito', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: normal;
    color: #fafafa;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .footer-v2-locale-pill .af-footer-globe-icon {
    flex-shrink: 0;
    display: block;
  }

  #shopify-section-{{ section.id }} .footer-v2-locale-pill button {
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .footer-v2-payments {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .footer-v2-payments img {
    width: 38px;
    height: 24px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .footer-v2-payments li {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .footer-v2-payments .icon--payment,
  #shopify-section-{{ section.id }} .footer-v2-payments svg {
    height: 24px;
    width: auto;
    display: block;
  }

  #shopify-section-{{ section.id }} .footer-v2-copyright {
    margin: 0;
    font-family: 'Gabarito', sans-serif;
    font-size: 12px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--footer-v2-text-dim);
  }

  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .footer.footer-v2 {
      padding-top: 32px;
      padding-bottom: 64px;
    }

    #shopify-section-{{ section.id }} .footer-v2__inner {
      padding: 0 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
    }

    #shopify-section-{{ section.id }} .footer-v2-hero {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .footer-v2-hero__logo {
      width: 108px;
      height: 96px;
    }

    #shopify-section-{{ section.id }} .footer-v2-hero__divider {
      display: none !important;
    }

    #shopify-section-{{ section.id }} .footer-v2-hero__tagline {
      font-size: 32px;
