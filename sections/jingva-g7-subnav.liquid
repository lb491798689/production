{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign product_name = se_stts.product_name
  assign buy_url = se_stts.buy_url
  assign sticky_offset = se_stts.sticky_offset | default: 64
  assign has_buy = false
  if buy_url != blank
    assign has_buy = true
  endif
-%}
{% capture default_sid %}.jingva-g7-subnav-{{ sid }}{% endcapture %}

{%- comment -%}
  jingva-g7-subnav.liquid
  ─────────────────────────────────────────────────────────
  Figma PC  node 2373:1919（AutoFull G7 Copy）— 1920 × 56：
    · 容器: bg #111111, padding 12px 48px, flex space-between, items-center
    · 左侧标题: Gabarito SemiBold 600 / 18px / lh 1.2em / UPPERCASE / #ffffff
    · 菜单链接(5 项 gap 24): Gabarito Regular 400 / 14px / lh 1.2em / capitalize / #ffffff
    · 菜单组↔按钮 gap 24
    · BUY NOW: 122×40, bg #EF000E, radius 8, padding 8 16
        text: Orbitron Bold 700 / 16px / lh 1.2em / UPPERCASE / #FAFAFA

  Figma MOB node 6193:4332 — 390 × 96（两行结构）：
    · 行高 48, bg #000000, padding 12 16, space-between, items-center
    · 行1: 标题 Gabarito 600 / 24px / lh 1.2em / UPPERCASE / #fff
           + 小按钮 91×28 r6 pd 8 12  · text Orbitron 700 / 12px / UPPERCASE / #FAFAFA
    · 行2: 菜单 5 项 gap 24（横向滚动）Gabarito 400 / 16px / lh 1.2em / capitalize / #fff
           + 按钮 103×36 r6 pd 8 12  · text Orbitron 700 / 14px / UPPERCASE / #FAFAFA
  ─────────────────────────────────────────────────────────
  Sticky 实现原理：
    position:sticky 无法跨父容器边界保持固定（父容器只有 subnav 本身高度，
    sticky 会立刻失效）。正确方案：JS 监听 scroll，切换 position:fixed + 占位符防跳动；
    固定后立刻 top:0，无 CSS 过渡，滚动本身的位移即「自然划走」。与主导航互斥见 theme.js StoreHeader。
{%- endcomment -%}

{{- "" -}}
<div
  class="jingva-g7-subnav-{{ sid }}{% unless has_buy %} subnav--no-buy{% endunless %}"
  data-section-id="{{ sid }}"
  id="jingva-g7-subnav-{{ sid }}"
>
  {% style %}
    /* 关键修复 1：去掉 Shopify 外层包裹（.shopify-section）的默认背景。
       否则 subnav 切到 fixed 后，外层仍在文档流里，自带的 var(--background)
       会形成「第二条 bg 条」继续随页滚动 → 视觉上 bg 与菜单分家。
       使用 [id$=...] 兜底，避免 schema class 在某些主题版本未生效时失效。 */
    #shopify-section-{{ section.id }},
    [id$="__{{ section.id }}"],
    .shopify-section--jingva-g7-subnav {
      background: transparent !important;
      background-color: transparent !important;
      /* 确保外层容器在 fixed 后不占据任何视觉空间 */
      min-height: 0 !important;
      height: auto !important;
    }
    
    /* 确保外层容器在 fixed 状态下完全透明且不影响布局 */
    #shopify-section-{{ section.id }}:has({{ default_sid }}.jingva-subnav--fixed) {
      height: 0 !important;
      overflow: visible !important;
    }

    /* MOB：subnav 默认高度为 0，收紧外层 section，避免主题间距叠出白条 */
    @media screen and (max-width: 1279px) {
      #shopify-section-{{ section.id }},
      [id$="__{{ section.id }}"],
      .shopify-section--jingva-g7-subnav {
        margin-block: 0 !important;
        padding-block: 0 !important;
      }
    }

    /* ── 全尺寸通用基底 ───────────────────────────────────────── */
    {{ default_sid }} {
      display: block;
      width: 100%;
      box-sizing: border-box;
      z-index: 1000;
      background-color: #111111;
      /* 默认隐形且不占版面高度（避免页中出现透明空白条）。fixed 后由 .jingva-subnav--fixed 恢复高度。 */
      min-height: 0 !important;
      height: 0 !important;
      overflow: hidden !important;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0s linear 0.3s;
      will-change: opacity, transform;
    }
    {{ default_sid }}.jingva-subnav--fixed {
      height: auto !important;
      overflow: visible !important;
    }
    {{ default_sid }}.jingva-subnav--visible {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0s linear 0s;
    }
    #jingva-g7-subnav-placeholder-{{ sid }} {
      display: none;
      width: 100%;
    }
    {{ default_sid }} .subnav-inner {
      display: flex;
      flex-direction: column;
      width: 100%;
      box-sizing: border-box;
    }

    {%- unless se_stts.show_on_mobile -%}
    /* MOB ≤1279px: 后台未开启则不显示 subnav */
    @media screen and (max-width: 1279px) {
      {{ default_sid }},
      {{ default_sid }} .subnav-inner,
      #jingva-g7-subnav-placeholder-{{ sid }} {
        display: none !important;
      }
      /* 子级已隐藏时，收紧外层 section，避免主题默认间距撑出空白条 */
      #shopify-section-{{ section.id }},
      [id$="__{{ section.id }}"],
      .shopify-section--jingva-g7-subnav {
        margin: 0 !important;
        padding-block: 0 !important;
        padding-inline: 0 !important;
        min-height: 0 !important;
      }
    }
    {%- endunless -%}

    /* ─────────────────────────────────────────────────────────
       MOB ≤1279px — Figma 6193:4332 (390×96 两行)
       ───────────────────────────────────────────────────────── */
    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        background-color: #000000 !important;
      }
      {{ default_sid }}.jingva-subnav--fixed {
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        width: 100% !important;
        transform: none !important;
        z-index: 1001 !important;
        min-height: 96px !important;
      }

      /* Figma 6193:4582: 无 buy now 时移动端为单行结构 (390×48)，隐藏行 1，仅保留菜单链接行 */
      {{ default_sid }}.jingva-subnav--fixed.subnav--no-buy {
        min-height: 48px !important;
      }
      {{ default_sid }}.subnav--no-buy .subnav-row--top {
        display: none !important;
      }

      {{ default_sid }} .subnav-inner {
        flex-direction: column !important;
      }

      /* 行 1 / 行 2 共同 48px 行容器，左右 16，上下 12 */
      {{ default_sid }} .subnav-row {
        display: flex !important;
        align-items: center !important;
        justify-content: space-between !important;
        width: 100% !important;
        height: 48px !important;
        padding: 12px 16px !important;
        box-sizing: border-box !important;
        background-color: #000000 !important;
      }

      /* Figma 6193:4332 行 1 strokeBottomWeight=1, rgba(204,204,204,0.20) — 双行模式下的中间分割线 */
      {{ default_sid }} .subnav-row--top {
        border-bottom: 1px solid rgba(204, 204, 204, 0.20) !important;
      }

      /* 行 1: 标题 Gabarito 500 / 16px / normal / Capitalize / #fff + 小 BUY NOW (91×28) */
      {{ default_sid }} .subnav-row--top .subnav-title {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 500 !important;
        font-size: 16px !important;
        font-style: normal !important;
        line-height: normal !important;
        letter-spacing: 0 !important;
        color: #FFFFFF !important;
        text-transform: none !important;
        white-space: nowrap !important;
        flex-shrink: 0 !important;
        text-decoration: none !important;
      }
      {{ default_sid }} .subnav-row--top .subnav-btn {
        height: 28px !important;
        padding: 0 12px !important;
        border-radius: 6px !important;
      }
      {{ default_sid }} .subnav-row--top .subnav-btn__text {
        font-size: 12px !important;
      }
      /* 行 1 仅显示 标题 + 小 BUY NOW；菜单链接放到行 2，避免重复 */
      {{ default_sid }} .subnav-row--top .subnav-links {
        display: none !important;
      }
      {{ default_sid }} .subnav-row--top .subnav-right {
        display: inline-flex !important;
        align-items: center !important;
        gap: 0 !important;
        flex-shrink: 0 !important;
      }

      /* 行 2: 仅显示菜单（横向滚动），按钮在行 1 已展示 -> 这里隐藏 */
      {{ default_sid }} .subnav-row--bottom {
        justify-content: flex-start !important;
        /* 右侧不留 padding：让菜单一直铺到视口右边缘，下一项可"露头"提示可滚动（Figma 规范） */
        padding-right: 0 !important;
      }
      {{ default_sid }} .subnav-row--bottom .subnav-title,
      {{ default_sid }} .subnav-row--bottom .subnav-btn {
        display: none !important;
      }
      {{ default_sid }} .subnav-row--bottom .subnav-links {
        display: flex !important;
        align-items: center !important;
        gap: 24px !important;
        width: 100% !important;
        overflow-x: auto !important;
        overflow-y: hidden !important;
        -webkit-overflow-scrolling: touch !important;
        scrollbar-width: none !important;
        white-space: nowrap !important;
      }
      {{ default_sid }} .subnav-row--bottom .subnav-links::-webkit-scrollbar {
        display: none !important;
      }
      {{ default_sid }} .subnav-link {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 400 !important;
        font-size: 16px !important;
        line-height: 1.2em !important;
        letter-spacing: 0 !important;
        color: rgba(255, 255, 255, 0.40) !important;
        text-transform: none !important;
        white-space: nowrap !important;
        text-decoration: none !important;
        cursor: pointer !important;
        flex-shrink: 0 !important;
        transition: color 0.22s ease, font-weight 0.22s ease !important;
      }
      {{ default_sid }} .subnav-link.is-active {
        color: #ffffff !important;
        font-weight: 400 !important;
      }
    }

    /* ─────────────────────────────────────────────────────────
       PC ≥1280px — Figma 2373:1919 (1920×56)
       ───────────────────────────────────────────────────────── */
    @media screen and (min-width: 1280px) {
      {{ default_sid }} {
        background-color: #111111 !important;
      }

      {{ default_sid }}.jingva-subnav--fixed {
        min-height: 56px !important;
      }

      {{ default_sid }} .subnav-inner {
        flex-direction: row !important;
        align-items: center !important;
        justify-content: space-between !important;
        height: 56px !important;
        padding: 12px 48px !important;
      }

      /* 行 1 在 PC 等同 inner 主体；行 2 隐藏 */
      {{ default_sid }} .subnav-row {
        display: contents !important;
      }
      {{ default_sid }} .subnav-row--bottom {
        display: none !important;
      }

      /* 左侧产品名称 — Gabarito 600 / 18px / Capitalize / #fff */
      {{ default_sid }} .subnav-row--top .subnav-title {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 600 !important;
        font-size: 18px !important;
        line-height: 1.2em !important;
        letter-spacing: 0 !important;
        color: #ffffff !important;
        text-transform: none !important;
        white-space: nowrap !important;
        flex-shrink: 0 !important;
        text-decoration: none !important;
      }

      /* 右侧: 菜单组 + 按钮 gap 24 */
      {{ default_sid }} .subnav-right {
        display: flex !important;
        align-items: center !important;
        gap: 24px !important;
        flex-shrink: 0 !important;
      }

      /* 菜单链接组 gap 24 — 在 PC 顶行展示 */
      {{ default_sid }} .subnav-row--top .subnav-links {
        display: flex !important;
        align-items: center !important;
        gap: 24px !important;
      }
      {{ default_sid }} .subnav-row--bottom .subnav-links {
        display: none !important;
      }

      /* 菜单项 — Gabarito 400 / 14px / capitalize；未激活 40% 白，激活 #fff */
      {{ default_sid }} .subnav-link {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 400 !important;
        font-size: 14px !important;
        line-height: 1.2em !important;
        letter-spacing: 0 !important;
        color: rgba(255, 255, 255, 0.40) !important;
        text-transform: none !important;
        white-space: nowrap !important;
        text-decoration: none !important;
        cursor: pointer !important;
        position: relative !important;
        transition: color 0.22s ease, font-weight 0.22s ease !important;
      }
      {{ default_sid }} .subnav-link:hover {
        color: rgba(255, 255, 255, 0.85) !important;
      }
      {{ default_sid }} .subnav-link.is-active {
        color: #ffffff !important;
        font-weight: 600 !important;
      }

      /* BUY NOW: 122×40, bg #EF000E, radius 8, padding 8 16 */
      {{ default_sid }} .subnav-row--top .subnav-btn {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        height: 40px !important;
        padding: 8px 16px !important;
        border-radius: 8px !important;
      }
      {{ default_sid }} .subnav-row--top .subnav-btn__text {
        font-size: 16px !important;
      }
    }

    /* ── BUY NOW 公共样式 ─────────────────────────────────── */
    {{ default_sid }} .subnav-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background-color: #EF000E;
      border: none;
      cursor: pointer;
      text-decoration: none;
      flex-shrink: 0;
      transition: background-color 0.22s ease;
      white-space: nowrap;
      box-sizing: border-box;
    }
    {{ default_sid }} .subnav-btn:hover {
      background-color: #F74557;
    }
    /* Figma 规范：color #FAFAFA / text-align center / Orbitron / 16px / normal /
       700 / line-height 120% / uppercase（PC 16px，MOB 行1=12px、行2=14px 由媒体查询覆盖） */
    {{ default_sid }} .subnav-btn__text {
      color: #FAFAFA;
      text-align: center;
      font-family: 'Orbitron', sans-serif;
      font-size: 16px;
      font-style: normal;
      font-weight: 700;
      line-height: 120%;
      letter-spacing: 0;
      text-transform: none;
    }
  {% endstyle %}

  {%- capture nav_links -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'nav_item' -%}
        <a
          class="subnav-link"
          href="#{{ block.settings.anchor_id | escape }}"
          data-anchor="{{ block.settings.anchor_id | escape }}"
          {{ block.shopify_attributes }}
        >{{ block.settings.label | escape }}</a>
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- capture buy_btn -%}
    {%- if buy_url != blank -%}
      <a href="{{ buy_url }}" class="subnav-btn" aria-label="Buy Now">
        <span class="subnav-btn__text">Buy Now</span>
      </a>
    {%- endif -%}
  {%- endcapture -%}

  <div class="subnav-inner">
    {%- comment -%} 行 1: PC 整行(标题+菜单+按钮); MOB 仅(标题+小按钮) {%- endcomment -%}
    <div class="subnav-row subnav-row--top">
      <span class="subnav-title">{{ product_name | escape }}</span>

      <div class="subnav-right">
        <nav class="subnav-links" aria-label="{{ product_name | escape }} navigation">
          {{ nav_links }}
        </nav>
        {{ buy_btn }}
      </div>
    </div>

    {%- comment -%} 行 2: 仅 MOB 显示 — 横向滚动菜单 {%- endcomment -%}
    <div class="subnav-row subnav-row--bottom">
      <nav class="subnav-links" aria-label="{{ product_name | escape }} navigation (mobile)">
        {{ nav_links }}
      </nav>
    </div>
  </div>
</div>

{{- "" -}}
<div id="jingva-g7-subnav-placeholder-{{ sid }}" aria-hidden="true"></div>

<script>
(function () {
  'use strict';

  /* ── 全尺寸执行（手机/PAD/PC） ───────────────────── */
  var subnav      = document.getElementById('jingva-g7-subnav-{{ sid }}');
  var placeholder = document.getElementById('jingva-g7-subnav-placeholder-{{ sid }}');
  if (!subnav || !placeholder) return;

  var isFixed     = false;
  var originalTop = 0; /* subnav 在文档中的原始 Y 坐标 */
  /** 固定瞬间占位符顶边的 viewport Y，用于解除固定判定（避免 header 已 visibility:hidden 后 live headerH 变成 0 误触发 makeRelative） */
  var pinnedChromeBottom = -1;
  /** 解除固定滞回（px）：避免边界上来回切换 fixed / relative */
  var UNSTICK_HYSTERESIS_PX = 14;
  /** 进入固定略晚于触发线（px），与解除滞回形成不对称，减少临界点抖动 */
  var STICK_ENTER_PX = 2;
  var lastWinScrollY = window.pageYOffset || document.documentElement.scrollTop || 0;

  var CLS_FIXED   = 'jingva-subnav--fixed';
  var CLS_VISIBLE = 'jingva-subnav--visible';
  var FADE_MS     = 300;
  var pendingUnfixTimer = 0;

  var SUBNAV_LOCKS_HEADER_ATTR = 'data-jingva-subnav-fixed';

  /*
   * 未固定时：公告栏在文档流中可滚走；顶栏高度 = 视口内 header 区块底边（含仍可见的公告）。
   * 固定后：subnav 独占顶栏 top:0，并通过 data 属性禁止 store-header 在下滑时重新出现（与主导航互斥）。
   */
  function getHeaderHeight() {
    var headerSection = document.querySelector('.shopify-section--header');
    if (headerSection) {
      /* theme.js StoreHeader.hide() 结束时会给 section 设 visibility:hidden；元素仍占位，
         getBoundingClientRect().bottom 仍可能很大 → subnav 的 top 一直被写成「假 header 高度」，出现顶部白条 */
      var cs = window.getComputedStyle(headerSection);
      if (cs.visibility === 'hidden' || cs.display === 'none') return 0;
      var bottom = headerSection.getBoundingClientRect().bottom;
      if (bottom > 0) return Math.round(bottom);
    }
    var ann = document.querySelector('.shopify-section--announcement-bar');
    var hdrInner = document.querySelector('.shopify-section--header .header__wrapper, .header__wrapper');
    var sum = 0;
    if (ann && ann.offsetHeight > 0) sum += ann.offsetHeight;
    if (hdrInner && hdrInner.offsetHeight > 0) sum += hdrInner.offsetHeight;
    if (sum > 0) return sum;

    var candidates = [
      '.shopify-section-group-header-group',
      'sticky-header',
      '.header-wrapper',
      'header[role="banner"]',
      'header'
    ];
    for (var i = 0; i < candidates.length; i++) {
      var el = document.querySelector(candidates[i]);
      if (el && el.offsetHeight > 0) return el.offsetHeight;
    }
    return {{ sticky_offset }};
  }

  /** 锚点滚动 / 高亮：subnav 高度 + 当前可见 header 占位 */
  function getStickyChromeOffset() {
    var subnavH = subnav.offsetHeight || 72;
    return getHeaderHeight() + subnavH;
  }

  /* 固定：data 标记 + store-header.hide(true)。 */
  function lockHeaderForSubnav() {
    document.documentElement.setAttribute(SUBNAV_LOCKS_HEADER_ATTR, '');
    var hdr = document.querySelector('store-header');
    if (hdr && typeof hdr.hide === 'function') hdr.hide(true);
  }

  function unlockHeaderForSubnav() {
    document.documentElement.removeAttribute(SUBNAV_LOCKS_HEADER_ATTR);
    var hdr = document.querySelector('store-header');
    if (hdr && typeof hdr.show === 'function') hdr.show();
  }

  /* ── 记录 subnav 在文档流中的原始位置 ─────────────────────── */
  function calcOriginalTop() {
    /* 未 fixed 时直接读；fixed 后从占位符读 */
    var ref = isFixed ? placeholder : subnav;
    return ref.getBoundingClientRect().top + window.pageYOffset;
  }

  /* ── 切换到 fixed ──────────────────────────────────────────── */
  function makeFixed() {
    /* 若处于"等待淡出后解固"的状态，取消解固，重新显示 */
    if (pendingUnfixTimer) {
      clearTimeout(pendingUnfixTimer);
      pendingUnfixTimer = 0;
    }
    if (isFixed) {
      subnav.classList.add(CLS_VISIBLE);
      return;
    }
    isFixed = true;

    /* 文档流内默认 height:0，offsetHeight 可能为 0 — 用 inner 高度或设计稿回退，避免占位条高度为 0 */
    var innerEl = subnav.querySelector('.subnav-inner');
    var navH = subnav.offsetHeight;
    if (!navH && innerEl) navH = innerEl.offsetHeight;
    if (!navH) {
      navH = window.matchMedia && window.matchMedia('(max-width: 1279px)').matches
        ? (subnav.classList.contains('subnav--no-buy') ? 48 : 96)
        : 56;
    }

    placeholder.style.height  = navH + 'px';
    placeholder.style.display = 'block';

    pinnedChromeBottom = placeholder.getBoundingClientRect().top;

    lockHeaderForSubnav();

    subnav.style.position = 'fixed';
    subnav.style.top      = '0';
    subnav.style.left     = '0';
    subnav.style.right    = '0';
    subnav.style.width    = '100%';
    subnav.style.zIndex   = '1000';
    subnav.classList.add(CLS_FIXED);

    /* 强制 reflow 后再加 visible 类，确保过渡生效 */
    void subnav.offsetWidth;
    subnav.classList.add(CLS_VISIBLE);
  }

  /* ── 恢复到正常文档流 ──────────────────────────────────────── */
  function makeRelative() {
    if (!isFixed) return;
    if (pendingUnfixTimer) return;

    /* 先触发淡出（移除 visible 类），等过渡结束再真正解除 fixed 定位 */
    subnav.classList.remove(CLS_VISIBLE);

    pendingUnfixTimer = setTimeout(function () {
      pendingUnfixTimer = 0;
      isFixed = false;

      unlockHeaderForSubnav();

      pinnedChromeBottom = -1;

      placeholder.style.height  = '0';
      placeholder.style.display = 'none';

      subnav.classList.remove(CLS_FIXED);
      subnav.style.position = '';
      subnav.style.top      = '';
      subnav.style.left     = '';
      subnav.style.right    = '';
      subnav.style.width    = '';
      subnav.style.zIndex   = '';
    }, FADE_MS);
  }

  /* ── 核心滚动判断：实时用 getBoundingClientRect，无跳动 ────── */
  function onScroll() {
    var scrollY = window.pageYOffset || document.documentElement.scrollTop || 0;
    var scrollingUp = scrollY < lastWinScrollY - 0.5;
    lastWinScrollY = scrollY;

    var headerH = getHeaderHeight();

    if (!isFixed) {
      /* 未固定：略晚于触发线再固定，与解除滞回配合减少临界点来回切 */
      var subnavTop = subnav.getBoundingClientRect().top;
      if (subnavTop <= headerH - STICK_ENTER_PX) {
        makeFixed();
        originalTop = placeholder.getBoundingClientRect().top + window.pageYOffset;
      }
    } else {
      /* 已固定：仅在上滑时判断解除，下滑时不应在临界点误触发 */
      var phTop = placeholder.getBoundingClientRect().top;
      var releaseThreshold = pinnedChromeBottom >= 0 ? pinnedChromeBottom : headerH;
      if (scrollingUp && phTop >= releaseThreshold + UNSTICK_HYSTERESIS_PX) {
        makeRelative();
      }
    }
  }

  /* rAF 节流，避免滚动期间 layout 抖动 */
  var fixRaf = 0;
  function onScrollRaf() {
    if (fixRaf) return;
    fixRaf = window.requestAnimationFrame(function () {
      fixRaf = 0;
      onScroll();
    });
  }

  /* ── 初始化 ────────────────────────────────────────────────── */
  originalTop = calcOriginalTop();
  /* 仅在浏览器恢复了滚动位置时立即判定；fresh load (scrollY=0) 跳过，
     避免 hero 图未加载时其高度为 0 导致 subnav 误判贴顶。 */
  if ((window.pageYOffset || document.documentElement.scrollTop || 0) > 0) {
    onScroll();
  }

  window.addEventListener('scroll', onScrollRaf, { passive: true });

  /* 图片加载完成后 hero 高度才稳定，重算 originalTop（不主动 fix） */
  window.addEventListener('load', function () {
    if (!isFixed) originalTop = calcOriginalTop();
  });

  /* ── 窗口尺寸变化处理 ──────────────── */
  window.addEventListener('resize', function () {
    if (!isFixed) originalTop = calcOriginalTop();
    onScroll();
  });

  /* ── 锚点链接列表 ──────────────────────────────────────────── */
  var links = subnav.querySelectorAll('.subnav-link[data-anchor]');
  if (!links.length) return;

  /* 实时查找目标元素：DOM 可能在懒加载场景下后到，每次重新查找更稳健 */
  function resolveTarget(anchorId) {
    if (!anchorId) return null;
    return document.getElementById(anchorId)
      || document.querySelector('[data-anchor-id="' + anchorId + '"]')
      || document.querySelector('section[data-section-id="' + anchorId + '"]');
  }

  function buildSections() {
    var arr = [];
    for (var i = 0; i < links.length; i++) {
      var link = links[i];
      var anchorId = link.getAttribute('data-anchor');
      var el = resolveTarget(anchorId);
      if (el) arr.push({ id: anchorId, element: el, link: link });
    }
    return arr;
  }

  var sectionList = buildSections();

  /* ── 点击锚点：平滑滚动并立即锁定高亮，避免 scroll handler 抖动 ─ */
  var clickLockUntil = 0;
  var clickLockedLink = null;

  links.forEach(function (link) {
    link.addEventListener('click', function (e) {
      var anchorId = this.getAttribute('data-anchor');
      var target = resolveTarget(anchorId);
      if (!target) return; // 无目标则走默认行为
      e.preventDefault();

      var offset  = getStickyChromeOffset();
      var targetY = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: targetY, behavior: 'smooth' });

      /* 点击后 1.2s 内锁定该 link 为 active，期间忽略 scroll handler 的覆盖 */
      clickLockedLink = link;
      clickLockUntil  = Date.now() + 1200;
      setActive(link);
    });
  });

  /* 同步两组链接（PC 顶行 + MOB 底行）的高亮：以 data-anchor 为准 */
  function setActive(link) {
    var anchor = link && link.getAttribute('data-anchor');
    for (var i = 0; i < links.length; i++) {
      if (anchor && links[i].getAttribute('data-anchor') === anchor) {
        links[i].classList.add('is-active');
      } else {
        links[i].classList.remove('is-active');
      }
    }
  }

  /* ── 滚动高亮 ──────────────────────────────────────────────── */
  function updateActiveLink() {
    if (Date.now() < clickLockUntil) return; // 点击锁定期间不覆盖

    /* 重新解析目标，应对懒加载等场景 */
    if (!sectionList.length) sectionList = buildSections();
    if (!sectionList.length) return;

    /* 触发线：subnav 下沿 +1px（固定时仅计 subnav，因 header 已互斥收起） */
    var triggerLine = getStickyChromeOffset() + 1;

    var scrollY  = window.pageYOffset || document.documentElement.scrollTop;
    var docHeight = document.documentElement.scrollHeight;
    var winHeight = window.innerHeight;
    var atBottom  = scrollY + winHeight >= docHeight - 2;

    var active = null;

    /* 滚到底部时，强制激活最后一项（防止最后一节太短无法越过触发线） */
    if (atBottom) {
      active = sectionList[sectionList.length - 1];
    } else {
      /* 从后往前找：最后一个 top 已越过触发线的 section */
      for (var i = sectionList.length - 1; i >= 0; i--) {
        var rectTop = sectionList[i].element.getBoundingClientRect().top;
        if (rectTop <= triggerLine) {
          active = sectionList[i];
          break;
        }
      }
      /* 在第一节之前：默认选第一项 */
      if (!active) active = sectionList[0];
    }

    if (active && active.link !== clickLockedLink) {
      setActive(active.link);
    } else if (active) {
      setActive(active.link);
    }
  }

  /* rAF 节流，保证每帧最多一次 */
  var rafId = 0;
  function onScrollHighlight() {
    if (rafId) return;
    rafId = window.requestAnimationFrame(function () {
      rafId = 0;
      updateActiveLink();
    });
  }

  /* 初始化（等布局稳定） */
  window.requestAnimationFrame(updateActiveLink);
  setTimeout(updateActiveLink, 300);
  setTimeout(function () { sectionList = buildSections(); updateActiveLink(); }, 1500);

  window.addEventListener('scroll', onScrollHighlight, { passive: true });
  window.addEventListener('resize', onScrollHighlight, { passive: true });
  window.addEventListener('load',   function () { sectionList = buildSections(); updateActiveLink(); });
})();
</script>

