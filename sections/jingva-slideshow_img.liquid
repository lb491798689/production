   <!-- Plyr JS -->
  {% if section_type == "slideshow" %}
  <!-- jQuery (if not already loaded) -->
 
  {% comment %} 
  用原生JS重写，去除jQuery依赖。slick依然用jQuery初始化，但所有操作和事件监听都用原生JS。
  {% endcomment %}
  <script>



    function initJingvaSlideshow() {
      const carouselId = 'jingvaCarousel{{ sid }}';
      const carousel = document.getElementById(carouselId);
      if (!carousel) {
        return;
      }
      let players = [];
      let currentSlideIndex = 0;
      let autoplayTimer = null;
      let isTransitioning = false;
      let isMobile = window.innerWidth <= 767;
      const autoplay = {{ autoplay | json }};
      const showDots = {{ show_dots | json }};
      const fadeEffect = true;
      const showArrows = {{ show_arrows | json }};
      const defaultDuration = {{ default_duration | times: 1000 }};
      const dotStyle = {{ dot_style | json }};
      // 检查并显示所有视频元素
      function debugVideoElements() {
        const allVideos = carousel.querySelectorAll('[data-slide-video]');
        allVideos.forEach((video, index) => {
          const provider = video.getAttribute('data-plyr-provider');
          const embedId = video.getAttribute('data-plyr-embed-id');
          const isHidden = video.closest('.jingva-small--hidden, .jingva-medium--hidden, .jingva-large--hidden') !== null;
          const container = video.closest('div') ? video.closest('div').className : '';
        });
      }
      // 简化的播放器初始化 - 添加slide索引标记
      function initializePlayers() {
        // 清理旧播放器
        players.forEach(player => {
          if (player && player.destroy) {
            player.destroy();
          }
        });
        players = [];
        debugVideoElements();
        // 获取所有slide
        const slides = carousel.querySelectorAll('.jingva-slide');
        slides.forEach((slide, slideIndex) => {
          slide.setAttribute('data-slide-index', slideIndex);
          let videoElement = null;
          if (isMobile) {
            videoElement = slide.querySelector('.jingva-medium--hidden .plyr-video[data-slide-video]')
              || slide.querySelector('.jingva-large--hidden .plyr-video[data-slide-video]')
              || slide.querySelector('.plyr-video[data-slide-video]');
          } else {
            videoElement = slide.querySelector('.jingva-small--hidden .plyr-video[data-slide-video]')
              || slide.querySelector('.plyr-video[data-slide-video]');
          }
          if (videoElement) {
            const provider = videoElement.getAttribute('data-plyr-provider');
            const embedId = videoElement.getAttribute('data-plyr-embed-id');
            try {
              const player = new Plyr(videoElement, {
                controls: [],
                muted: true,
                loop: { active: true },
                autoplay: false,
                hideControls: true,
                clickToPlay: false,
                keyboard: { focused: false, global: false }
              });
              players[slideIndex] = player;
              player.on('ready', () => {
                console.log(`播放器 ${slideIndex} 准备就绪`);
              });
              player.on('error', (error) => {
                console.error(`播放器 ${slideIndex} 错误:`, error);
              });
            } catch (error) {
              console.error(`创建播放器 ${slideIndex} 失败:`, error);
              players[slideIndex] = null;
            }
          } else {
            console.log(`Slide ${slideIndex} 没有找到视频元素`);
            players[slideIndex] = null;
          }
        });
      }
      // 获取视频时长
      function getVideoDuration(slideIndex) {
        const slides = carousel.querySelectorAll('.jingva-slide');
        const slide = slides[slideIndex];
        const player = players[slideIndex];
        if (player && player.duration) {
          console.log(`Slide ${slideIndex} 视频时长:`, player.duration);
          return Promise.resolve(player.duration * 1000);
        }
        let customDuration = null;
        if (slide) {
          customDuration = slide.getAttribute('data-duration');
        }
        if (customDuration) {
          return Promise.resolve(Number(customDuration) * 1000);
        }
        return Promise.resolve(defaultDuration);
      }
      // 开始自动播放
      function startAutoplay() {
        if (!autoplay || isTransitioning) return;
        clearTimeout(autoplayTimer);
        getVideoDuration(currentSlideIndex).then(duration => {
          console.log(`设置自动播放定时器: ${duration}ms`);
          autoplayTimer = setTimeout(() => {
            if (!isTransitioning) {
              // slickNext 只能用jQuery
              window.jQuery(carousel).slick('slickNext');
            }
          }, duration);
        });
      }
      function stopAutoplay() {
        if (autoplayTimer) {
          clearTimeout(autoplayTimer);
          autoplayTimer = null;
          console.log('停止自动播放');
        }
      }
      // 控制视频播放
      function manageVideoPlayback(slickIndex) {
        // 通过slick-active类找到当前活动的slide
        const activeSlides = carousel.querySelectorAll('.slick-slide.slick-active:not(.slick-cloned)');
        let realSlideIndex = -1;
        if (activeSlides.length) {
          const activeSlide = activeSlides[0];
          realSlideIndex = parseInt(activeSlide.getAttribute('data-slide-index'))
            || parseInt(activeSlide.getAttribute('data-slick-index'))
            || Array.prototype.indexOf.call(carousel.querySelectorAll('.jingva-slide'), activeSlide);
        }
        // 如果方法1失败，使用模运算
        if (realSlideIndex === -1 || isNaN(realSlideIndex)) {
          const totalSlides = carousel.querySelectorAll('.jingva-slide').length;
          realSlideIndex = slickIndex % totalSlides;
        }
        players.forEach((player, index) => {
          if (player) {
            if (index === realSlideIndex) {
              player.muted = true;
              // 清除之前的事件监听
              player.off('timeupdate ended');
              if (autoplay) {
                let hasMoved = false;
                player.on('timeupdate', () => {
                  if (hasMoved) return;
                  const duration = player.duration || 0;
                  const currentTime = player.currentTime || 0;
                  if (duration > 0 && currentTime >= duration - 0.5) {
                    hasMoved = true;
                    window.jQuery(carousel).slick('slickNext');
                  }
                });
                player.on('ended', () => {
                  if (!hasMoved) {
                    hasMoved = true;
                    window.jQuery(carousel).slick('slickNext');
                  }
                });
              }
              player.play().catch(error => {
                console.warn(`播放视频 ${index} 失败:`, error);
              });
            } else {
              player.pause();
              player.off('timeupdate ended');
            }
          } else {
            console.log(`播放器 ${index} 为空`);
          }
        });
      }

      // 响应式处理
      window.addEventListener('resize', function () {
        const wasMobile = isMobile;
        isMobile = window.innerWidth <= 767;
        if (wasMobile !== isMobile) {
          stopAutoplay();
          setTimeout(() => {
            initializePlayers();
            setTimeout(() => {
              manageVideoPlayback(currentSlideIndex);
              startAutoplay();
            }, 300);
            fixDotsWrapper();
          }, 100);
        }
      });

      // 修复dots包装器
      function fixDotsWrapper() {
        {% if section.blocks.size <= 1 %}return {% endif %}
        // 只用jQuery查找dots，包装用原生
        const dots = document.querySelector('{{ default_sid }} .slick-dots');
        if (dots && !dots.parentElement.classList.contains('dots-wrapper')) {
          const dotsBox = document.createElement('div');
          dotsBox.className = `dots-box style-${dotStyle}`;
          const dotsWrapper = document.createElement('div');
          dotsWrapper.className = 'dots-wrapper {{ page_width }}';
          dots.parentElement.insertBefore(dotsBox, dots);
          dotsBox.appendChild(dotsWrapper);
          dotsWrapper.appendChild(dots);
        }
      }

      // slick初始化和事件绑定
      window.jQuery(carousel).on('init', function () {
        fixDotsWrapper();
      });

      window.jQuery(carousel).on('beforeChange', function (event, slick, currentSlide, nextSlide) {
        isTransitioning = true;
        stopAutoplay();
        currentSlideIndex = nextSlide;
      });

      window.jQuery(carousel).on('afterChange', function (event, slick, currentSlide) {
        isTransitioning = false;
        currentSlideIndex = currentSlide;
        manageVideoPlayback(currentSlide);
        startAutoplay();
      });

      // 鼠标悬停控制
      carousel.addEventListener('mouseenter', stopAutoplay);
      carousel.addEventListener('mouseleave', startAutoplay);

      // slick初始化
      let jingvaCarousel = window.jQuery(carousel).slick({
        {% if width_type == "page" %}
        centerMode: true,
        centerPadding: '10%',
        slidesToShow: 1,
        spaceBetween: 30,
        {% else %}
        fade: fadeEffect,
        cssEase: 'ease-in-out',
        {% endif %}
        dots: showDots,
        infinite: true,
        speed: 500,
        autoplay: false, // 手动控制
        arrows: showArrows,
        prevArrow: '<button type="button" class="slick-prev"><svg t="1754530798703" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="9596" width="200" height="200"><path d="M689.621 512l-328.832-328.832-60.331 60.331 268.501 268.501-268.501 268.501 60.331 60.331z" p-id="9597" fill="CurrentColor"></path></svg></button>',
        nextArrow: '<button type="button" class="slick-next"><svg t="1754530798703" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="9596" width="200" height="200"><path d="M689.621 512l-328.832-328.832-60.331 60.331 268.501 268.501-268.501 268.501 60.331 60.331z" p-id="9597" fill="CurrentColor"></path></svg></button>',
        customPaging: function (slider, i) {
          return `<button class="custom-dot">
                    <svg width="100%" height="100%" style="--percent: 0">
                      <circle cx="50%" cy="50%" r="15"></circle>
                      <circle cx="50%" class="fr" cy="50%" r="15" style="stroke-dasharray:0px 0px;"></circle>
                    </svg>
                    <span>${i + 1}</span>
                  </button>`;
        },
        pauseOnHover: false,
        pauseOnFocus: false,
        responsive: [
          {
            breakpoint: 767,
            settings: {
              {% if width_type == "page" %}
              centerMode: true,
              centerPadding: '4%',
              spaceBetween: 10,
              {% endif %}
            }
          }
        ],
      });
      

      // 更新移动端箭头按钮状态（默认/禁用/悬停）
      function updateMobileArrows(){
        var $box = $('{{ default_sid }} .slick-arrow-box');
        var $prev = $box.find('.j-btn-prev');
        var $next = $box.find('.j-btn-next');
        var current = jingvaCarousel.slick('slickCurrentSlide');
        var total = jingvaCarousel.slick('getSlick').slideCount;
        $prev.toggleClass('is-disabled', current === 0);
        $next.toggleClass('is-disabled', current === total - 1);
      }
      updateMobileArrows();
      // 点击切换（禁用时不执行）
      $(document).on('click', '{{ default_sid }} .slick-arrow-box .j-btn', function (e) {
        if($(this).hasClass('is-disabled')){ e.preventDefault(); return; }
        if($(this).hasClass('j-btn-next')) { jingvaCarousel.slick('slickNext'); }
        else { jingvaCarousel.slick('slickPrev'); }
      });
      // 同步状态
      window.jQuery(carousel).on('afterChange', function(){ updateMobileArrows(); });

      // 初始化播放器
      setTimeout(() => {
        initializePlayers();
        setTimeout(() => {
          manageVideoPlayback(0);
          startAutoplay();
        }, 1000);
      }, 500);
    }

    document.addEventListener('DOMContentLoaded', initJingvaSlideshow);
    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:unload', initJingvaSlideshow);
      document.addEventListener('shopify:section:load', initJingvaSlideshow);
    }
  </script>
 
  {% endif %}
</section>

