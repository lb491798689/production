t span{display:none;}{{ default_sid }} .dots-box.style-3 .slick-dots li{width:5px;height:2px;}{{ default_sid }} .dots-box.style-3 .custom-dot{position:relative;width:5px;height:2px;padding:0;color:#fff;background-color:rgba(255,255,255,.3);overflow:hidden;}{{ default_sid }} .dots-box.style-3 .slick-dots li .custom-dot::before{content:""!important;display:block;font-size:11px;width:100%;height:3px;color:#fff;background-color:#fff;}{{ default_sid }} .dots-box.style-3 .slick-dots li.slick-active .custom-dot::before{% if autoplay %}{width:0%;animation:width var(--default-duration) ease-out forwards;}{% else %}{width:100%;}{% endif %}{{ default_sid }} .dots-box.style-3 .slick-dots li .custom-dot svg,{{ default_sid }} .dots-box.style-3 .slick-dots li .custom-dot span{display:none;}{{ default_sid }} .dots-box.style-1 .custom-dot circle{fill:none;stroke:currentColor;stroke-linecap:butt;stroke-opacity:.3;stroke-width:2px;transform-origin:50% 50%;}{{ default_sid }} .dots-box.style-1 li.slick-active .custom-dot .fr{stroke-opacity:1;{% if autoplay %}animation:draw var(--default-duration) ease-out forwards;{% else %}stroke-dasharray:100px 100px;{% endif %}}{{ default_sid }} .slick-arrow{width:48px;height:48px;border-radius:50px;display:flex;justify-content:center;align-items:center;transition:transform .3s;border:1px solid #fff;color:#fff;position:absolute;top:50%;transform: translateY(-50%);}{{ default_sid }} .slick-arrow.slick-disabled{border:1px solid #D3D3D3;color:#D3D3D3;}{{ default_sid }} .slick-arrow:hover{background:#fff;color:#000;}{{ default_sid }} .slick-arrow.slick-disabled:hover{background:transparent;color:#D3D3D3;} {{ default_sid }} .slick-arrow::before{display:none;}{{ default_sid }} .slick-arrow.slick-next{right:46px;}{{ default_sid }} .slick-arrow.slick-prev{left:46px;z-index:2;}{{ default_sid }} .slick-arrow.slick-prev svg{transform:rotate(180deg);}{{ default_sid }} .slick-arrow svg{width:22px;height:22px;}@keyframes draw{from{stroke-dasharray:0px 100px;}to{stroke-dasharray:100px 100px;}}@keyframes width{from{width:0px;}to{width:100%;}}.jingva-small--hidden{}.jingva-large--hidden{display:none;}.jingva-carousel-{{sid}}[data-type="slideshow"] .jingva-slide:not(.jingva-slide-1){display:none;}.jingva-carousel-{{sid}}[data-type="slideshow"] .slick-list .jingva-slide{display:block;}.jingva-carousel-{{sid}}[data-widthType="page"] .jingva-slide{margin-right:30px;border-radius:20px;overflow:hidden;}.jingva-carousel-{{sid}}[data-widthType="page"] .slick-arrow.slick-next{right:clamp(30px,calc(10vw + 30px),240px);}.jingva-carousel-{{sid}}[data-widthType="page"] .slick-arrow.slick-prev{left:clamp(30px,10vw,240px);}@media screen and (min-width:768px) and (max-width:1400px){.jingva-slide-content-wrapper{padding:40px 0;}}@media screen and (max-width:1400px){ {{ default_sid }} .slick-arrow.slick-next{right:10px;}{{ default_sid }} .slick-arrow.slick-prev{left:10px;} }@media screen and (min-width:768px) and (max-width:999px){.jingva-medium--hidden{display:none;}.jingva-medium--hidden{display:block;}}@media screen and (max-width:767px){ {{ default_sid }} .dots-box.style-3 .slick-dots li{width:18px;} {{ default_sid }} .dots-box.style-3 .custom-dot{width:15px;} .jingva-small--hidden{display:none;}.jingva-medium--hidden{display:block;}.jingva-carousel-{{sid}}[data-widthType="page"] .jingva-slide{margin-right:10px;}{{ default_sid }} .dots-box{bottom:10px;}{{ default_sid }} .slick-dots{justify-content:center;}{{ default_sid }} .dots-box.style-2 .slick-dots li .custom-dot::before{font-size:8px;width:11px;height:11px;}{{ default_sid }} .dots-box.style-2 .custom-dot{width:11px;height:11px;}{{ default_sid }} .dots-box.style-2 .slick-dots li{width:11px;height:11px;}{{ default_sid }} .jingva-slide-content-wrapper{padding:20px 0;}{{ default_sid }} .jingva-slide-btn{font-size:12px;padding:10px 20px;}.jingva-slide-topsubtitle,.jingva-slide-title,.jingva-slide-subtitle{margin-top: 7px;margin-bottom:0px;line-height:1.2}.jingva-slide-title{margin-top:0;}}{% if use_custom_css %}{{ css|replace:".sectionID",default_sid}}{% endif %}
