<style>
.kik_about_player{
  background:{{ section.settings.background }};
  color:{{ section.settings.heading_color }}; 

}
.kik_about_player > .kik_header{
 padding-top:96px;
 padding-bottom:96px;
}
.kik_about_player .kik_heading{
font-size:40px;
line-height:1.2;
letter-spacing: 0;
color:{{ section.settings.heading_color }};
margin:0;
margin-bottom:32px;
text-align:center;
text-transform:uppercase;
font-style:italic;
}
.kik_about_player .kik_heading strong{
  color:{{ section.settings.sec_color }};
}
.kik_header_tabs{
  display:flex;
  justify-content:center;
  column-gap:32px;
}
.kik_header_tabs > div{
  padding:12px 48px;
  border: 1px solid;
  color: {{ section.settings.heading_color }};
  border-radius:8px;
  font-size:18px;
  line-height:1.5;
  cursor:pointer;
  font-style:italic;
}
.kik_header_tabs > div h4{
  font-size:18px;
  line-height:1.5;
  text-transform: uppercase;
}
.kik_header_tabs > div.active{
  color:{{ section.settings.sec_color }};
}
.kik-content{
  padding-top:0;
  padding-bottom:56px;
  text-align:center;
}
.kik_content{

  display:none;
}
.kik_content.active{
  display:block;
}
.kik_stats{
  display:flex;
  justify-content: center;
  flex-wrap:wrap;
  max-width:1010px;
  margin:auto;
  column-gap:85px;
  row-gap:64px;
}
.kik_stat{
  flex: 0 0 calc(33% - 55px);
  text-align: center;
}
.kik_stat h2,.kik_text_and_image .kik_text h2{
  font-size:40px;
  line-height:1.5;
  letter-spacing: 0;
  color:{{ section.settings.sec_color }};
  margin:0;
  margin-bottom:10px;
  text-transform:uppercase;
  font-style:italic;
}
.kik_text_and_image .kik_text p,.kik_stat h4{
  font-size:18px;
  line-height:1.5;
  letter-spacing: 0;
  color:{{ section.settings.heading_color }};
  margin:0;
}
.kik_stat h4{
  font-style:italic;
}
.kik_text_and_image img {
  width:100%;
  
  margin:0 auto;
  margin-top:32px;
  max-width:var(--width);
}
@media (max-width:699px){
.kik_about_player  > .kik_header{
 padding-top:64px;
 padding-bottom:40px;
}
.kik_about_player .kik_heading{
font-size:32px;

}
.kik_header_tabs{
  display:flex;
  flex-wrap:wrap;
  row-gap:16px;
}
.kik_header_tabs > div{
  padding:12px 40px;
  width:100%;
  font-size:16px;
  text-align:center;
}
.kik_header_tabs > div h4{
  font-size:16px;
}
.kik_text_and_image .kik_text p, .kik_stat h4{
  font-size:16px;
}
.kik-content{
  padding-bottom:64px;
}
.kik_stats{
  flex-wrap:wrap;
  column-gap:20px;
  row-gap:32px;
}
.kik_stat{
  flex:0 0 calc(50% - 10px);
}
.kik_stat h2,.kik_text_and_image .kik_text h2{
  font-size:32px;
}
.kik_text_and_image .kik_text p,.kik_stat p{
  font-size:16px;
}
.kik_text_and_image img {
  max-width:var(--mobile_width);
}
}
</style>
<div class="kik_about_player">
    <div class="section kik_header">
        <h1 class="kik_heading">{{ section.settings.title }}</h1>
        <div class="kik_header_tabs">
        {% for block in section.blocks %}
            <div class="kik_header {% if forloop.first %} active{% endif %}" data-open="{{ forloop.index0 }}">
                <h4>{{block.settings.title}}</h4>
            </div>
        {% endfor %}   
        </div>
    </div>
    <div class="section kik-content">
        {% for block in section.blocks %}
            <div class="kik_content {% if forloop.first %} active{% endif %}"  data-open="{{ forloop.index0 }}"> 
                {% case block.type %}
                        {% when 'stats' %}
                        <div class="kik_stats">
                          {% for i in (1..6) %}
                             {% assign stat = 'stat_' | append: i %}
                             {% assign desc = 'desc_' | append: i %}
                            <div class="kik_stat">
                                {% if block.settings[stat] != blank %}
                                <h2>{{ block.settings[stat] }}</h2>
                                <h4>{{ block.settings[desc] }}</h4>
                                {% endif %}
                            </div>
                          {% endfor %}
                        </div>
                        {% when 'text_and_image' %}
                        <div class="kik_text_and_image">
                            <div class="kik_text">
                                <h2>{{ block.settings.heading }}</h2>
                                <p>{{ block.settings.description | newline_to_br }}</p>
                            </div>
                            <div class="kik_image">
                                <img src="{{ block.settings.image | img_url: '400x400' }}" loading="lazy" alt="{{ block.settings.title }}" style="--width:{{ block.settings.image_width }}px;--mobile_width:{{ block.settings.mobile_image_width }}px" />
                            </div>
                        </div>
                {% endcase %}
            </div>
        {% endfor %}
    </div>


</div>
<script>
  document.querySelectorAll(".kik_header_tabs .kik_header").forEach((item)=>{
    item.addEventListener("click",function(){
      document.querySelectorAll(".kik_header_tabs .kik_header").forEach((elem)=>{
        elem.classList.remove("active");
      })
      document.querySelectorAll(".kik_content").forEach((elem)=>{
        elem.classList.remove("active");
      })
      this.classList.add("active");
      document.querySelector(".kik_content[data-open='"+ this.getAttribute("data-open") +"']").classList.add("active");
    })
  })
</script>
{% schema %}
{
  "name": "Kiks about player",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "blocks": [
    {
      "name": "Stats",
      "type": "stats",
      "settings": [
        {
      "type": "richtext",
      "id": "title",
      "label": "Title"
        },
        {
      "type": "text",
      "id": "stat_1",
      "label": "stat 1 Title ",
      "default": "1st"
        },
        {
      "type": "text",
      "id": "desc_1",
      "label": "Stat 1 Description"
        },
        {
      "type": "text",
      "id": "stat_2",
      "label": "stat 2 Title ",
      "default": "1st"
        },
        {
      "type": "text",
      "id": "desc_2",
      "label": "Stat 2 Description"
        },
        {
      "type": "text",
      "id": "stat_3",
      "label": "stat 3 Title ",
      "default": "1st"
        },
        {
      "type": "text",
      "id": "desc_3",
      "label": "Stat 3 Description"
        },
        {
      "type": "text",
      "id": "stat_4",
      "label": "stat 4 Title ",
      "default": "1st"
        },
        {
      "type": "text",
      "id": "desc_4",
      "label": "Stat 4 Description"
        },
        {
      "type": "text",
      "id": "stat_5",
      "label": "stat 5 Title ",
      "default": "1st"
        },
        {
      "type": "text",
      "id": "desc_5",
      "label": "Stat 5 Description"
        },
        {
      "type": "text",
      "id": "stat_6",
      "label": "stat 6 Title ",
      "default": "1st"
        },
        {
      "type": "text",
      "id": "desc_6",
      "label": "Stat 6 Description"
        }
      ]
    },
    {
      "name": "Text and image",
      "type": "text_and_image",
      "settings": [
        {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Title"
        },
        {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
        },
        {
      "type": "richtext",
      "id": "description",
      "label": "Description"
        },
        {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
        },
        {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
        "min": 50,
        "max": 500,
        "step": 5,
        "default": 400
        },
        {
      "type": "range",
      "id": "mobile_image_width",
      "label": "Image width mobile",
        "min": 50,
        "max": 500,
        "step": 5,
        "default": 250
        }
      ]
    },
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
      "default": "<p>Heading</p>"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Gradient replaces solid colors when set."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "color",
      "id": "sec_color",
      "label": "Secondary color"
    }
  ],
  "presets": [
    {
      "name": "Kiks about player",
      "blocks": [
     
      ]
    }
  ]
}
{% endschema %}
