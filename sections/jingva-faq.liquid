{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --section-stack-intro: 100% !important;
    --section-stack-main: 100% !important;
    --context-section-spacing-inline: 0px !important;
    --container-gutter: 0px !important;
    padding-inline: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  #shopify-section-{{ section.id }}.section,
  .shopify-section--jingva-faq.section {
    --context-section-spacing-inline: 0px !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  .shopify-section--jingva-faq {
    display: flex !important;
    justify-content: center !important;
    background-color: #232323 !important;
    padding: 140px 0 45px 0 !important;
  }

  .shopify-section--jingva-faq .section-stack {
    width: 100% !important;
    max-width: 1200px !important;
    padding: 0 !important;
    gap: 0 !important;
  }

  .shopify-section--jingva-faq .section-stack__main {
    width: 100% !important;
  }

  /* 标题区域 - 居中对齐，底部间距 48px */
  .shopify-section--jingva-faq .section-stack__intro {
    text-align: center !important;
    margin-bottom: 48px !important;
  }

  /* 主标题 (Popular Questions) - PC: Orbitron Black 48px 白色 (Figma fw=900) */
  .shopify-section--jingva-faq .section-stack__intro .h2 {
    color: #FFFFFF !important;
    text-align: center !important;
    font-family: 'Orbitron', sans-serif !important;
    font-size: 48px !important;
    font-style: normal !important;
    font-weight: 900 !important;
    line-height: 1.254 !important;
    text-transform: none !important;
    margin: 0 !important;
  }

  /* FAQ 容器 - 垂直排列，间距 48px */
  .shopify-section--jingva-faq .faq-container {
    display: flex !important;
    flex-direction: column !important;
    gap: 48px !important;
    width: 100% !important;
  }

  /* FAQ 项 */
  .shopify-section--jingva-faq .faq-item {
    width: 100% !important;
  }

  /* FAQ 问题标题 - PC: Gabarito Bold 32px 白色 (Figma fw=700) */
  .shopify-section--jingva-faq .faq-question {
    color: #FFFFFF !important;
    font-family: 'Gabarito', sans-serif !important;
    font-size: 32px !important;
    font-style: normal !important;
    font-weight: 700 !important;
    line-height: 1.2em !important;
    margin-bottom: 16px !important;
  }

  /* FAQ 答案文本 - PC: Gabarito Medium 18px 白色 60% (Figma fw=500) */
  .shopify-section--jingva-faq .faq-answer {
    color: rgba(255, 255, 255, 0.60) !important;
    font-family: 'Gabarito', sans-serif !important;
    font-size: 18px !important;
    font-style: normal !important;
    font-weight: 500 !important;
    line-height: 1.2em !important;
  }

  /* 移动端适配 */
  @media screen and (max-width: 1279px) {
    .shopify-section--jingva-faq {
      padding: 68px 16px !important;
    }

    .shopify-section--jingva-faq .section-stack {
      max-width: 358px !important;
      padding: 0 0 !important;
      gap: 0 !important;
    }

    .shopify-section--jingva-faq .section-stack__intro {
      margin-bottom: 48px !important;
    }

    /* 主标题 - 手机: Orbitron Black 32px 白色 (Figma fw=900) */
    .shopify-section--jingva-faq .section-stack__intro .h2 {
      color: #FFFFFF !important;
      text-align: center !important;
      font-family: 'Orbitron', sans-serif !important;
      font-size: 32px !important;
      font-style: normal !important;
      font-weight: 900 !important;
      line-height: 1.254 !important;
      text-transform: none !important;
    }

    /* FAQ 容器 - 间距 24px */
    .shopify-section--jingva-faq .faq-container {
      gap: 24px !important;
      margin-top: 5px !important;
    }

    /* FAQ 问题标题 - 手机: Gabarito Bold 24px 白色 (Figma fw=700) */
    .shopify-section--jingva-faq .faq-question {
      color: #FFFFFF !important;
      font-family: 'Gabarito', sans-serif !important;
      font-size: 24px !important;
      font-style: normal !important;
      font-weight: 700 !important;
      line-height: 1.2em !important;
      margin-bottom: 12px !important;
    }

    /* FAQ 答案文本 - 手机: Gabarito Medium 16px 白色 60% (Figma fw=500) */
    .shopify-section--jingva-faq .faq-answer {
      color: rgba(255, 255, 255, 0.60) !important;
      font-family: 'Gabarito', sans-serif !important;
      font-size: 16px !important;
      font-style: normal !important;
      font-weight: 500 !important;
      line-height: 1.2em !important;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="section-stack section-stack--center">
    {%- if section.settings.title != blank -%}
      <div class="section-stack__intro">
        <h2 class="h2">{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="section-stack__main">
      <div class="faq-container">
        {%- for block in section.blocks -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <h3 class="faq-question">{{ block.settings.question }}</h3>
            <div class="faq-answer">{{ block.settings.answer }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Jingva FAQ",
  "tag": "section",
  "class": "shopify-section--jingva-faq",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "POPULAR QUESTIONS"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jingva FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "WHAT DOES YOUR WARRANTY COVER?",
            "answer": "<p>Every AutoFull product is designed and tested for industry-leading safety and durability. That's why we stand behind all our chairs and desks with up to a 3 year extended warranty. Aesthetic defects and damage due to misuse of product are not covered. To make a warranty claim, submit your claim via our Contact page, along with image or video evidence of the affected area. AutoFull reserves the final right to determine if a benefit under the warranty can be claimed.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "CAN I CANCEL MY ORDER?",
            "answer": "<p>Due to the relatively short turnaround time between processing and courier pick-up, your order may already be on its way to you. We will try our best to cancel your order but in the event we are unable to cancel it in time and your order gets delivered, reach out to our Support team via our Contact page to initiate a return. For a smooth return process, do not open the packaging.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "WHERE DOES AUTOFULL SHIP TO?",
            "answer": "<p>We ship to residential or commercial addresses in the United States, but are unable to deliver to PO boxes.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "HOW LONG WILL IT TAKE TO GET MY ORDERS?",
            "answer": "<p>It depends on where you are. Orders processed here will take 1 business day to arrive. Deliveries can take anywhere from 3-7 days. Delivery details will be provided in your confirmation email.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "HOW DO I TRACK MY ORDER?",
            "answer": "<p>Once your order ships, you'll receive a shipping confirmation email and tracking number, so you can follow your package as it makes its way to you. However tracking information can take up to 24 hours to update, so don't worry if it doesn't show up immediately. We recommend tracking your order and ensuring that you're home on the day of delivery to receive your order.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
