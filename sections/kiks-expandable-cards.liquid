{%- if section.blocks.size > 0 -%}
    {%- render 'section-spacing-collapsing' -%}
    {%- assign section_identifier = '#shopify-section-' | append: section.id -%}
    {%- assign  enable_column_size = section.settings.enable_column_size | append:'%' -%}
    
    {%- assign  padding_top = section.settings.padding_top | append:'px' -%}
    {%- assign  padding_bottom = section.settings.padding_bottom | append:'px' -%}

    {%- assign padding_mobile_top = section.settings.padding_top_mob | append: 'px' -%}
    {%- assign padding_mobile_bottom = section.settings.padding_bottom_mob | append: 'px' -%}

    {% style %}
    {{ section_identifier }} .section{
        padding-top: {{padding_top}};
        padding-bottom: {{padding_bottom}};
      }

    @media only screen and (max-width: 430px) {
        {{ section_identifier }} .section {
          padding-top: {{ padding_mobile_top }};
          padding-bottom: {{ padding_mobile_bottom }};
        }
      }
    {% endstyle %}
    <style>
      #shopify-section-{{ section.id }} {
        {% if section.settings.stack_on_desktop %}
        --multi-column-grid: auto / auto-flow 73vw;
        {% elsif section.settings.stack_on_mobile %}
        --multi-column-grid: none;
        {% else %}
        --multi-column-grid: auto / auto-flow 73vw;
        {% endif %}

        --multi-column-list-gap: {% if section.settings.gap == 'small' %}var(--grid-gutter){% elsif section.settings.gap == 'medium' %}var(--spacing-12){% elsif section.settings.gap == 'large' %}var(--spacing-20){% else %}var(--spacing-28){% endif %};
      }
      {{ section_identifier }}.kiks-expandable-cards .section.section-full section-header.section-header {
          max-width: 100%;
          width: 100%;
          grid-template-columns: 80%;
      }
      {{ section_identifier }}.kiks-expandable-cards .multi-column {
            gap: 20px;
        }
        {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item {
            background-color: {{ section.settings.card_background }};
            border-radius: var(--rounded);
        }
        {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item .card-info {
            gap: 8px;
            padding: 0 24px 24px;
        }
        {% if section.settings.enable_hover_effect %}
          {% else %}
          {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item img {
              height: 300px;
              object-fit: cover;
          }
          @media only screen and (max-width: 430px) {
            {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item img {
              height: 100%;
              object-fit: cover;
          }
         }
       {% endif %}
          {% if section.settings.stack_on_desktop and section.settings.enable_column_width %}
          {{ section_identifier }} .multi-column {
              display: flex;
              flex-wrap: nowrap;
              overflow-x: auto;
              -webkit-overflow-scrolling: touch; 
              align-items: flex-start;
          }

          {{ section_identifier }} .multi-column .multi-column__item {
              display: flex;
              flex-direction: column;
              flex: 0 0 {{ enable_column_size }};
              gap: 24px;
              /* transition: flex 0.4s ease-in-out;  */
          }
          {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item.is-expanded .card-info {
              text-align: left;
          }
          {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item:hover {
              flex: 1; /* Distribute space evenly by default */
              transition: flex 0.4s ease-in-out;
          }
          {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item {
              flex: 1; /* Distribute space evenly by default */
              /* transition: flex 0.4s ease-in-out; */
          }
          
          /* Ensure the hovered/selected item expands while others shrink */
          {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item.is-expanded {
              flex: 1.5; /* Expand the hovered item */
          }

          {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item:not(.is-expanded) {
              flex: 1; /* Ensure non-expanded items shrink smoothly */
          }
          @media only screen and (max-width: 769px) {
              {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item {
                  flex: 0 0 80%; /* Distribute space evenly by default */
                  transition: flex 0.4s ease-in-out;
              }
              
              /* Ensure the hovered/selected item expands while others shrink */
              {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item.is-expanded {
                  flex: 0 0 95%; /* Expand the hovered item */
              }

              {{ section_identifier }}.kiks-expandable-cards .multi-column .multi-column__item:not(.is-expanded) {
                  flex: 0 0 80%; /* Ensure non-expanded items shrink smoothly */
              }
              {{ section_identifier }}.kiks-expandable-cards .section.section-full section-header.section-header {
                  grid-template-columns: 100%;
              }
          }
      {% endif %}
    </style>
  
    <div {% render 'section-properties' %}>
      <div class="section-stack">
        {%- render 'kiks-section-header', subheading: section.settings.subheading, heading: section.settings.title, content: section.settings.content, text_alignment: section.settings.text_alignment, style: section.settings.heading_tag -%}
  
        <div class="multi-column scroll-area bleed md:unbleed">
          {%- for block in section.blocks -%}
            {%- liquid
              assign loading_strategy = nil
    
              if section.index > 3 or forloop.index > 3
                assign loading_strategy = 'lazy'
              endif
            -%}
          
                {% comment %} {% assign delay = 1000 %}
                  {% if forloop.index == 2 %}
                    {% assign delay = 1000 %}
                  {% elsif forloop.index == 3 %}
                    {% assign delay = 1000 %}
                  {% endif %}
                  data-aos="fade-up" data-aos-delay="{{ delay }}"  data-aos-easing="ease-in-out"  {% endcomment %}
                <div class="multi-column__item justify-{{ section.settings.column_alignment }} snap-start" style="--multi-column-item-column-count: span {{ 12.0 | divided_by: block.settings.column_size | round }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.video != blank -%}
                    <video-media autoplay style="--aspect-ratio: {{ block.settings.video.aspect_ratio }}">
                      {{ block.settings.video | video_tag: playsinline: true, muted: true, loop: true, preload: 'metadata', class: 'rounded' }}
                    </video-media>
                  {%- elsif block.settings.image != blank -%}
                    {%- capture sizes -%}(max-width: 699px) calc(73vw - 40px), (max-width: 999px) calc(38vw - 64px), calc(min({{ settings.page_width }}px, 100vw) / {{ block.settings.column_size }}){%- endcapture -%}
                    {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: loading_strategy, sizes: sizes, widths: '300,400,500,600,800,1000,1200,1400,1600,1800', class: 'rounded' -}}
                  {%- endif -%}
  
                  {%- if block.settings.title != blank or block.settings.content != blank or block.settings.link_text != blank -%}
                    <div class="card-info v-stack gap-4 text-{{ section.settings.column_alignment }}">
                      {%- if block.settings.title != blank -%}
                        <p class="{{ block.settings.heading_tag }}">{{ block.settings.title | escape }}</p>
                      {%- endif -%}
  
                      {%- if block.settings.content != blank or block.settings.link_text != blank -%}
                        <div class="prose">
                          {{- block.settings.content -}}
  
                          {%- if block.settings.link_text != blank -%}
                            <div>
                              {%- if block.settings.link_style == 'link' -%}
                                <a href="{{ block.settings.link_url }}" class="link">{{ block.settings.link_text | escape }}</a>
                              {%- else -%}
                                {%- render 'button', href: block.settings.link_url, content: block.settings.link_text, size: 'lg' -%}
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {% if section.settings.enable_hover_effect %}
    <script>
      document.addEventListener("DOMContentLoaded", function () {
       const items = document.querySelectorAll(".kiks-expandable-cards .multi-column .multi-column__item");
   
       if (items.length > 0) {
           // Set the first item as expanded by default
           items[0].classList.add("is-expanded");
       }
   
       items.forEach(item => {
           item.addEventListener("mouseenter", function () {
               // Reset all items
               items.forEach(el => el.classList.remove("is-expanded"));
   
               // Add expanded class to the hovered item
               item.classList.add("is-expanded");
           });
       });
   });
     </script>
  {% endif %}
