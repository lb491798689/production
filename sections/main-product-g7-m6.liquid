{%- capture product_form_id -%}product-form-{{ product.id }}-{{ section.id }}{%- endcapture -%}

<div {% render 'section-properties', tight: true %}>
  <product-rerender id="product-info-{{ product.id }}-{{ section.id }}" observe-form="{{ product_form_id }}" allow-partial-rerender>
    <div class="product">
      {%- if product.media.size > 0 -%}
        {%- render 'product-gallery-g7-m6', product: product, product_form_id: product_form_id,  custom_metafield: product.metafields.custom.3d_product.value -%}
      {%- endif -%}

      {%- render 'product-info-g7-m6',
        product: product,
        update_url: true,
        product_form_id: product_form_id,
        context: 'main_product'
      -%}
    </div>
  </product-rerender>
</div>
<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    function syncQuantityInput(input) {
      if (!input || !input.classList || !input.classList.contains('quantity-selector__input')) return;
      var qs = input.closest('quantity-selector');
      if (!qs || !root.contains(qs)) return;
      var dec = qs.querySelector('.quantity-selector__button--minus');
      var inc = qs.querySelector('.quantity-selector__button--plus');
      if (!dec || !inc) return;

      var min = parseInt(input.getAttribute('min'), 10);
      if (isNaN(min)) min = 1;
      var v = parseInt(input.value, 10);
      if (isNaN(v)) v = min;

      var maxAttr = input.getAttribute('max');
      var max = maxAttr !== null && maxAttr !== '' ? parseInt(maxAttr, 10) : NaN;

      var aboveMin = v > min;
      var belowMax = isNaN(max) || v < max;

      qs.classList.toggle('is-above-min', aboveMin);
      qs.classList.toggle('is-below-max', belowMax);

      dec.disabled = !aboveMin;
      dec.setAttribute('aria-disabled', aboveMin ? 'false' : 'true');
      inc.disabled = !belowMax;
      inc.setAttribute('aria-disabled', belowMax ? 'false' : 'true');
    }

    function scanAll() {
      root.querySelectorAll('.quantity-selector__input').forEach(function (inp) {
        syncQuantityInput(inp);
      });
    }

    root.addEventListener(
      'input',
      function (e) {
        if (e.target && e.target.matches && e.target.matches('.quantity-selector__input')) syncQuantityInput(e.target);
      },
      true
    );
    root.addEventListener(
      'change',
      function (e) {
        if (e.target && e.target.matches && e.target.matches('.quantity-selector__input')) syncQuantityInput(e.target);
      },
      true
    );
    root.addEventListener(
      'click',
      function (e) {
        var qs = e.target.closest && e.target.closest('quantity-selector');
        if (!qs || !root.contains(qs)) return;
        var inp = qs.querySelector('.quantity-selector__input');
        if (inp) setTimeout(function () { syncQuantityInput(inp); }, 0);
      },
      true
    );

    var form = document.getElementById('{{ product_form_id }}');
    if (form) {
      form.addEventListener('product:rerender', function () {
        setTimeout(scanAll, 0);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scanAll);
    } else {
      scanAll();
    }
  })();
</script>
