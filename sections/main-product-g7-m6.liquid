{%- assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons' | first -%}

{%- if section.settings.show_fixed_add_to_cart and product.available and buy_buttons_block != blank -%}
  <product-rerender id="{{ product_form_id }}-sticky-bar" observe-form="{{ product_form_id }}">
    {%- if product.selected_or_first_available_variant.available -%}
      <div class="g7-custom-sticky-cart">
        <div class="g7-sticky-cart-container">
          {%- assign sticky_variant = product.selected_or_first_available_variant -%}
          {%- comment -%} Mobile：Grid + display:contents 对齐 Figma 934:43045（价格行｜配送文案｜双按钮） {%- endcomment -%}
          <div class="g7-sticky-delivery">
            <div class="g7-delivery-to">
              <span class="g7-delivery-label">Deliver to:</span>
              <span class="g7-delivery-location" id="g7-user-country">
                {%- if localization.country.name -%}
                  {{ localization.country.name }}
                {%- else -%}
                  <span class="g7-loading-country">Loading...</span>
                {%- endif -%}
              </span>
            </div>
            <div class="g7-delivery-date">
              {%- liquid
                assign g7_lead_days = section.settings.sticky_cart_ships_by_days | default: 15
                assign g7_spread_days = section.settings.sticky_cart_delivery_plus_days | default: 2
                assign g7_now_sec = 'now' | date: '%s' | times: 1
                assign g7_lead_sec = g7_lead_days | times: 86400
                assign g7_ship_sec = g7_now_sec | plus: g7_lead_sec
                assign g7_spread_sec = g7_spread_days | times: 86400
                assign g7_end_sec = g7_ship_sec | plus: g7_spread_sec
                assign g7_sb_month = g7_ship_sec | date: '%b'
                assign g7_sb_day = g7_ship_sec | date: '%-d'
                assign g7_end_month = g7_end_sec | date: '%b'
                assign g7_end_day = g7_end_sec | date: '%-d'
                assign g7_ym_ship = g7_ship_sec | date: '%Y-%m'
                assign g7_ym_end = g7_end_sec | date: '%Y-%m'
                if g7_ym_ship == g7_ym_end
                  assign g7_est_range = g7_sb_month | append: ' ' | append: g7_sb_day | append: '–' | append: g7_end_day
                else
                  assign g7_est_range = g7_sb_month | append: ' ' | append: g7_sb_day | append: '–' | append: g7_end_month | append: ' ' | append: g7_end_day
                endif
              -%}
              {%- liquid
                assign g7_ships_msg = section.settings.sticky_cart_ships_text
                if g7_ships_msg == blank
                  assign g7_ships_msg = 'Normally ships within [days] days.'
                endif
                assign g7_ships_msg = g7_ships_msg | replace: '[days]', g7_lead_days
              -%}
              <span class="g7-ships-text">{{ g7_ships_msg }}</span>
            </div>
          </div>

          <div class="g7-sticky-right">
            <div class="g7-sticky-price">
              <span class="g7-price-current">{{ sticky_variant.price | money }}</span>
              {%- if sticky_variant.compare_at_price > sticky_variant.price -%}
                <span class="g7-price-compare">{{ sticky_variant.compare_at_price | money }}</span>
              {%- endif -%}
            </div>

            <div class="g7-sticky-buttons-wrapper">
              <div class="g7-sticky-buttons">
                <buy-buttons template="{{ product.template_suffix }}" form="{{ product_form_id }}">
                  <button type="submit" form="{{ product_form_id }}" class="g7-btn-add-to-cart">
                    <span class="g7-sticky-atc-label g7-sticky-atc-label--desktop">Add to Cart</span>
                    <span class="g7-sticky-atc-label g7-sticky-atc-label--mobile">Add to Cart</span>
                  </button>
                  {%- comment -%} Buy Now Button - 直接跳转到结账 {%- endcomment -%}
                  <a
                    href="{{ routes.cart_url }}/{{ sticky_variant.id }}:1?checkout"
                    class="g7-btn-buy-now"
                    data-sticky-buy-now
                    data-cart-url="{{ routes.cart_url }}"
                  >
                    Buy Now
                  </a>
                </buy-buttons>
              </div>
              
              {%- comment -%} Klarna Payment Info {%- endcomment -%}
              <div class="g7-klarna-info">
                {%- assign monthly_payment = product.selected_or_first_available_variant.price | divided_by: 4.0 | money -%}
                <span class="g7-klarna-text">From {{ monthly_payment }}/month or 4 payments at 0% interest with</span>
                <img src="{{ 'pay-klarna.svg' | asset_url }}" alt="Klarna" class="g7-klarna-logo" loading="lazy">
                <span class="g7-klarna-link" style="display:none">Check purchase power</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} JavaScript to detect user country {%- endcomment -%}
      <script>
        (function() {
          // Try to get country from Shopify's localization
          const countryElement = document.getElementById('g7-user-country');
          if (!countryElement) return;
          
          // If no country from Shopify, try to detect via IP
          if (countryElement.querySelector('.g7-loading-country')) {
            fetch('https://ipapi.co/json/')
              .then(response => response.json())
              .then(data => {
                if (data.country_name) {
                  countryElement.textContent = data.country_name;
                } else {
                  countryElement.textContent = 'United States';
                }
              })
              .catch(() => {
                countryElement.textContent = 'United States';
              });
          }
        })();
      </script>

      <script>
        (function () {
          var buyNow = document.querySelector('[data-sticky-buy-now]');
          var form = document.getElementById('{{ product_form_id }}');
          if (!buyNow || !form) return;

          var cartUrl = buyNow.getAttribute('data-cart-url') || '/cart';
          var pageQuery = window.location.search.replace(/^\?/, '');
          var checkoutSuffix = pageQuery ? '?checkout&' + pageQuery : '?checkout';
          var updateHref = function () {
            var variantInput = form.querySelector('input[name="id"]');
            if (!variantInput || !variantInput.value) return;

            var qtyInput = form.querySelector('input[name="quantity"]');
            var qty = qtyInput && qtyInput.value ? parseInt(qtyInput.value, 10) : 1;
            if (!qty || qty < 1) qty = 1;

            buyNow.setAttribute('href', cartUrl + '/' + variantInput.value + ':' + qty + checkoutSuffix);
          };

          updateHref();
          form.addEventListener('change', updateHref);
          form.addEventListener('input', function (event) {
            if (event.target && event.target.name === 'quantity') {
              updateHref();
            }
          }, true);
        })();
      </script>

    {%- endif -%}
