        if (targetElement.dataset.stickyGalleryObserverBound === '1') return true;
        targetElement.dataset.stickyGalleryObserverBound = '1';

        function setOutOfView(isOut) {
          document.body.classList.toggle('is-gallery-out-of-view', !!isOut);
