    font-style: normal;
    font-weight: 500;
    cursor:pointer;
  }

  #shopify-section-{{ section.id }} .product-gallery__choose .product__choose-btn.active {
    background: #000;
    color: #fff;
  }

  
  #shopify-section-{{ section.id }} .product-gallery__ar-wrapper > button{
    display:none!important;
  }

  @media only screen and (max-width: 430px) {
    #shopify-section-{{ section.id }} .custom-group .product-info__quantity-selector {
      max-width: 130px;
    }
    #shopify-section-{{ section.id }} .custom-group {
      gap: 5px;
    }
    #shopify-section-{{ section.id }} .product-info__buy-buttons .custom-group.buttons--multiple form {
      max-width:unset;
    }
    #shopify-section-{{ section.id }} .discount-container .discount-content .discount-left-content {
      flex: 0 0 65%;
    }
    #shopify-section-{{ section.id }} .discount-container .discount-content {
      padding: 18px 5px;
    }
  }

  @media only screen and (max-width: 369px) {
    #shopify-section-{{ section.id }} .discount-container .discount-content .discount-left-content {
      flex-wrap: wrap;
      justify-content: center;
      gap: 4px;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .discount-container .discount-content {
      flex-direction: column;
      gap: 4px;
    }
  }

  @media only screen and (max-width: 329px) {
    #shopify-section-{{ section.id }} .custom-group .product-info__quantity-selector {
        max-width: 120px;
    }
  }
{% endif %}
#shopify-section-{{ section.id }} .size_guide{
  display: flex;
    align-items: center;
    color: black;
    gap: 4px;
    background: #F6F6F6;
    padding: 4px 14px;
    font-size: 13px;
    cursor: pointer;
    clip-path: polygon(
      0% 5px,            /* top-left corner cut */
      5px 0%, 
      calc(100% - 5px) 0%, /* top-right corner cut */
      100% 5px,
      100% calc(100% - 5px), /* bottom-right corner cut */
      calc(100% - 5px) 100%,
      5px 100%,          /* bottom-left corner cut */
      0% calc(100% - 5px)
    );
}

#shopify-section-{{ section.id }} .kik_product_size_guide{
  position: fixed;
    top: 0;
    left: 0;
    background: rgb(0 0 0 / 0%);
    z-index: 99;
    width: 100%;
    display: flex;
    justify-content: flex-end;
    transition: visibility 0s;
    visibility: hidden;
}
#shopify-section-{{ section.id }} .kik_size_guide_overlay{
  position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgb(0 0 0 / 0%);
    transition: .3s;
}
#shopify-section-{{ section.id }} .kik_product_size_guide_content{
    background: white;
    z-index: 99;
    max-width: 600px;
    width: 100%;
    height: 100vh;
    overflow: scroll;
    border-end-start-radius: 20px;
    border-start-start-radius: 20px;
    transition: .3s;
    transform: translateX(100%);
}
#shopify-section-{{ section.id }} .kik_product_size_guide.active{
  visibility: visible;
}
#shopify-section-{{ section.id }} .kik_product_size_guide.active .kik_size_guide_overlay{
  background: rgb(0 0 0 / 38%);
}
#shopify-section-{{ section.id }} .kik_product_size_guide.active .kik_product_size_guide_content{
  transform: translateX(0%);
}
#shopify-section-{{ section.id }} .kik_size_guide_heading{
    display: flex;
    justify-content: space-between;
    padding: 20px;
    align-items: center;
    border-bottom:1px solid #eaeaea;
}
#shopify-section-{{ section.id }} .kik_close_icon{
  padding: 5px;
    border: 1px solid;
    border-radius: 50%;
    cursor: pointer;
}
#shopify-section-{{ section.id }} .kik_close_icon svg{
  width: 24px;
    height: 24px;
}
#shopify-section-{{ section.id }} .kik_size_image img{
    width:100%;
}
#shopify-section-{{ section.id }} .selling_points{
  padding: 24px;
  gap: 16px;
  border-radius: 16px;
  background-color: #fafafa;
  margin-top: 24px;
  width:100%;
}
/* 商品标题行：Figma PC 5276:2539 / 移动 5726:3778 — 标题 + NEW 标签，gap 24px */
#shopify-section-{{ section.id }} .product-info__title-row {
  display: flex;
  align-items: flex-start;
  gap: 24px;
  width: 100%;
}

/* NEW 标签 — 移动 Figma 5726:3780（外框 22px 高：3px + 14px 字 + 3px + 上下边框 2px） */
#shopify-section-{{ section.id }} .product-info__new-badge {
  box-sizing: border-box;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  height: 22px;
  padding: 3px 4px;
  border: 1px solid #e90202;
  border-radius: 4px;
  background: transparent;
  color: #e90202;
  font-family: 'Orbitron', sans-serif;
  font-size: 14px;
  font-weight: 700;
  font-style: normal;
  line-height: 1;
}

#shopify-section-{{ section.id }} .product-info__new-badge__text {
  display: block;
  text-transform: uppercase;
  white-space: nowrap;
}

/* NEW 标签 — PC Figma 5276:2541～5276:2542 */
@media screen and (min-width: 1280px) {
  #shopify-section-{{ section.id }} .product-info__new-badge {
    height: auto;
    padding: 4px 8px;
    border-color: #e90206;
