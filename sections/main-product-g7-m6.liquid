}

/* Klarna 组件占满宽度 */
#shopify-section-{{ section.id }} .product-info__block-item[data-block-type="@app"] > *,
#shopify-section-{{ section.id }} .product-info__block-item[data-block-type="@app"] .klarna-custom-messaging {
