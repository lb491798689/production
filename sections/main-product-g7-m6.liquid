  <script>
    (function () {
      var formId = '{{ product_form_id }}';
      var readyDelayMs = 120;
      var maxWaitMs = 5000;
      var checkIntervalMs = 80;
      var delayTimer = null;
      var waitedMs = 0;
      var revealed = false;

      function isProductFormReady() {
        var form = document.getElementById(formId);
        if (!form) return false;

        var variantInput = form.querySelector('input[name="id"]');
        if (!variantInput) return false;

        return !variantInput.disabled && !!variantInput.value;
      }

      function revealSticky() {
        if (revealed || document.body.classList.contains('g7-sticky-ready')) return;
        revealed = true;
        delayTimer = window.setTimeout(function () {
          document.body.classList.add('g7-sticky-ready');
        }, readyDelayMs);
      }

      function waitUntilReady() {
        if (isProductFormReady()) {
          if (document.readyState === 'complete') {
            readyDelayMs = 0;
          }
          revealSticky();
          return;
        }

        var pollTimer = window.setInterval(function () {
          waitedMs += checkIntervalMs;

          if (isProductFormReady() || waitedMs >= maxWaitMs) {
            window.clearInterval(pollTimer);
            if (document.readyState === 'complete') {
              readyDelayMs = 0;
            }
            revealSticky();
          }
        }, checkIntervalMs);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', waitUntilReady, { once: true });
      } else {
        waitUntilReady();
      }

      window.addEventListener('pageshow', function () {
        if (delayTimer) window.clearTimeout(delayTimer);
        waitUntilReady();
      });
    })();
  </script>

  <script>
    (function () {
      function bindFooterObserver() {
        var footer = document.querySelector('.footer-v2, .footer');
        if (!footer) return false;
        if (footer.dataset.stickyObserverBound === '1') return true;
        footer.dataset.stickyObserverBound = '1';

        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              document.body.classList.toggle('is-footer-visible', entry.isIntersecting);
            });
          }, { root: null, threshold: 0, rootMargin: '0px 0px 0px 0px' });
          io.observe(footer);
        } else {
          var onScroll = function () {
            var rect = footer.getBoundingClientRect();
            var inView = rect.top < (window.innerHeight || document.documentElement.clientHeight) && rect.bottom > 0;
            document.body.classList.toggle('is-footer-visible', inView);
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }
        return true;
      }

      // 绑定 Footer 监听器
      if (!bindFooterObserver()) {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', bindFooterObserver);
        } else {
          var tries = 0;
          var retry = setInterval(function () {
            if (bindFooterObserver() || ++tries > 20) clearInterval(retry);
          }, 100);
        }
        window.addEventListener('load', bindFooterObserver);
      }
    })();
  </script>

  <script>
    /* G7/M6 PDP：画廊与右列 sticky top 跟随公告 + store-header 实际可见高度（含 hide-on-scroll 动画） */
    (function () {
      var mq = window.matchMedia('(min-width: 1280px)');
      var sectionId = 'shopify-section-{{ section.id }}';
      var gapPx = 20;
      var rafId = 0;

      function isVisibleSection(el) {
        if (!el) return false;
        var cs = window.getComputedStyle(el);
        return cs.visibility !== 'hidden' && cs.display !== 'none';
      }

      function syncPdpStickyTop() {
        if (!mq.matches) return;
        var sec = document.getElementById(sectionId);
        if (!sec) return;

        var offset = gapPx;
        var ann = document.querySelector('.shopify-section--announcement-bar');
        if (isVisibleSection(ann)) {
          var ar = ann.getBoundingClientRect();
          if (ar.bottom > 0) offset = Math.max(offset, ar.bottom + gapPx);
        }

        var storeHeader = document.querySelector('store-header.header');
        if (storeHeader) {
          var hr = storeHeader.getBoundingClientRect();
          if (hr.bottom > 0) offset = Math.max(offset, hr.bottom + gapPx);
        }

        sec.style.setProperty('--pdp-sticky-top', Math.round(offset) + 'px');

        var stickyInfo = sec.querySelector('safe-sticky.product-info');
        if (stickyInfo) {
          stickyInfo.style.removeProperty('top');
        }
      }

      function scheduleSync() {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(syncPdpStickyTop);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleSync, { once: true });
      } else {
        scheduleSync();
      }

      window.addEventListener('scroll', scheduleSync, { passive: true });
      window.addEventListener('resize', scheduleSync, { passive: true });
      window.addEventListener('pageshow', scheduleSync);

      if (typeof mq.addEventListener === 'function') {
        mq.addEventListener('change', scheduleSync);
      } else if (mq.addListener) {
        mq.addListener(scheduleSync);
      }

      var storeHeader = document.querySelector('store-header.header');
      if (storeHeader && typeof MutationObserver !== 'undefined') {
        var mo = new MutationObserver(scheduleSync);
        mo.observe(storeHeader, { attributes: true, attributeFilter: ['style', 'class'] });
        var hdrSec = document.querySelector('.shopify-section--header');
        if (hdrSec) mo.observe(hdrSec, { attributes: true, attributeFilter: ['style'] });
      }
    })();
  </script>


