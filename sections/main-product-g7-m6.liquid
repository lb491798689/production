/* Klarna logo 尺寸（保持原始比例，禁止横向拉伸） */
#shopify-section-{{ section.id }} .product-info__block-item[data-block-type="@app"] .klarna-logo,
#shopify-section-{{ section.id }} .product-info__block-item[data-block-type="@app"] klarna-placement img,
#shopify-section-{{ section.id }} .product-info__block-item[data-block-type="@app"] img[alt*="Klarna"],
