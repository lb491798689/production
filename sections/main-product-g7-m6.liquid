{% comment %} {{- 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true -}} {% endcomment %}
{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --product-grid: auto / minmax(0, 1fr);
    --product-gallery-media-list-grid: auto / auto-flow {% if section.settings.mobile_carousel_control == 'free_scroll' %}{% if section.settings.mobile_media_size == 'expanded' %}84vw{% else %}73vw{% endif %}{% else %}100%{% endif %};
    --product-gallery-media-list-gap: {% if section.settings.mobile_media_size == 'expanded' %}var(--spacing-0-5){% else %}var(--grid-gutter){% endif %};
  }

  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} {
      --section-spacing-block-start: 0px !important;
      --section-spacing-block-end: 0px !important;
      --calculated-section-spacing-block-start: 0px !important;
      --calculated-section-spacing-block-end: 0px !important;
      padding: 0 !important;
      margin: 0 !important;
      width: 100vw !important;
      max-width: 100vw !important;
      margin-left: calc(-50vw + 50%) !important;
      margin-right: calc(-50vw + 50%) !important;
    }

    /* 移动端产品容器全宽 */
    #shopify-section-{{ section.id }} .section,
    #shopify-section-{{ section.id }} .section--tight {
      padding: 0 !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    /* 移动端产品网格全宽 */
    #shopify-section-{{ section.id }} .product {
      padding: 0 !important;
      margin: 0 !important;
      gap: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      display: block !important;
    }

    /* 移动端画廊全宽 */
    #shopify-section-{{ section.id }} .product-gallery {
      width: 100% !important;
      max-width: 100% !important;
    }

    /* 移动端产品信息区域恢复正常布局 - 在block-item上添加padding */
    #shopify-section-{{ section.id }} .product-info {
      padding: 0 !important;
    }

    #shopify-section-{{ section.id }} .product-info__block-item {
      padding: 0 16px !important;
      margin: 0 !important;
    }

    #shopify-section-{{ section.id }} .product-info__block-item:first-child {
      padding-top: 16px !important;
    }

    #shopify-section-{{ section.id }} .product-info__block-item:last-child {
      padding-bottom: 16px !important;
    }

    /* 确保标题在移动端显示 */
    #shopify-section-{{ section.id }} .product-info__block-item[data-block-type="title"] {
      display: block !important;
      padding: 16px 16px 0 !important;
    }

    #shopify-section-{{ section.id }} .product-info__title {
      display: block !important;
    }

    /* 移动端覆盖容器类 */
    #shopify-section-{{ section.id }} .container {
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    #shopify-section-{{ section.id }} .container--narrow,
    #shopify-section-{{ section.id }} .container--wide {
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    /*
      数量药丸「下半截没了」排查结论（DOM 自上而下）：
      - theme.css 里 product-rerender { display: contents } → 不占盒，真正的父链是 div.section > div.product > safe-sticky.product-info > .product-info__block-item
      - safe-sticky 未设 display → 部分浏览器里自定义标签默认 inline，配合子块级可能影响叠层；此处强制 block + overflow 可见
      - 前一兄弟 variant 区块内：variant-picker.liquid 包了 .scroll-area，theme.css .scroll-area 为 overflow: auto hidden → 只应裁切选项内部；若仍怀疑纵向裁切，对 variant 区单独放开 overflow-y
      - 后一兄弟常为 product-tabs / Klarna：浅灰底 block 若叠层在上会盖住药丸底部 → quantity 的 block-item 设 position:relative; z-index:2
      - 勿对 quantity 用负 margin 抵消 padding：会把绘制区挤进相邻区块的叠层，易被盖住
    */
    #shopify-section-{{ section.id }} .section,
    #shopify-section-{{ section.id }} .product {
      overflow: visible !important;
    }

    #shopify-section-{{ section.id }} safe-sticky.product-info {
      display: block !important;
      width: 100% !important;
      overflow: visible !important;
    }

    #shopify-section-{{ section.id }} .product-info__variant-picker,
    #shopify-section-{{ section.id }} .product-info__variant-picker variant-picker {
      overflow: visible !important;
    }

    /* variant 选项条：主题 .scroll-area 默认 overflow-y:hidden，仅作用于选项容器本身，改为 visible 避免极端情况下影响下方区块视觉叠层 */
    #shopify-section-{{ section.id }} .product-info__variant-picker .scroll-area {
      overflow-y: visible !important;
    }

    /* PDP variant 选项标题（如 "Select:"）字体颜色对齐 Figma：theme 默认 .text-subdued 为 #AEAEAE，
       Jingva G7/M6 PDP 要求实色 #1A1A1A，覆盖范围严格限定到当前 section 的 variant-picker 标题区。 */
    #shopify-section-{{ section.id }} .product-info__variant-picker .variant-picker__option-heading,
    #shopify-section-{{ section.id }} .product-info__variant-picker .variant-picker__option-heading.text-subdued {
      color: #1A1A1A !important;
    }

    #shopify-section-{{ section.id }} .product-info__block-item[data-block-type="quantity-selector"] {
      position: relative !important;
      z-index: 2 !important;
      overflow: visible !important;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .product-info__quantity-selector {
      overflow: visible !important;
      clip-path: none !important;
      contain: none !important;
      padding-block: 6px !important;
    }

    #shopify-section-{{ section.id }} .product-info__quantity-selector .form-control {
      overflow: visible !important;
      clip-path: none !important;
    }

    #shopify-section-{{ section.id }} .product-info__quantity-selector quantity-selector.quantity-selector {
      clip-path: none !important;
      border-style: none !important;
      border-width: 0 !important;
      box-shadow: none !important;
      flex-shrink: 0 !important;
    }
  }

  /* G7-M6: mob (≤1279) 严格 normal flow，禁止任何 sticky / absolute / fixed —
     PAD/PC 仍保留主题默认 sticky 行为（大屏右列粘顶）。
     主题在 >=1000 给 .product-info 加了 position:sticky，仅在 mob 区间覆盖掉即可。 */
  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} safe-sticky,
    #shopify-section-{{ section.id }} safe-sticky.product-info,
    #shopify-section-{{ section.id }} .product-info,
    #shopify-section-{{ section.id }} product-rerender,
    #shopify-section-{{ section.id }} product-gallery,
    #shopify-section-{{ section.id }} .product-gallery,
    #shopify-section-{{ section.id }} .jingva-product-gallery-box,
    #shopify-section-{{ section.id }} .product-gallery__ar-wrapper,
    #shopify-section-{{ section.id }} .product-gallery__media-list-wrapper,
    #shopify-section-{{ section.id }} .product {
      position: static !important;
      top: auto !important;
      bottom: auto !important;
      left: auto !important;
      right: auto !important;
      transform: none !important;
      z-index: auto !important;
      float: none !important;
    }
  }

  /* PAD + PC（1280+）：按 develop.md 竬规范「版心：PC/PAD 均为 1200px」处理：
     - .product 内容区严格限制 max-width: 1200px 居中
     - section 本身跨视口全宽（背景可以铺满），仅用 padding 拉开顶底
     - PAD/PC 双列布局：1fr | 560px，gap 使用该档 Grid token */
  @media screen and (min-width: 1280px) {
    #shopify-section-{{ section.id }} {
      --product-grid: auto / 1fr 560px;
      --product-gallery-media-list-grid: auto / auto-flow 100%;
      --product-gallery-media-list-gap: calc(var(--grid-gutter) / 2);
      --pdp-sticky-gap: 20px;
      --pdp-sticky-top: calc(var(--sticky-area-height, var(--header-height, 60px)) + var(--pdp-sticky-gap));
    }

    /* 清除 section 默认上下间距，保留跨视口全宽以让背景铺满 */
    #shopify-section-{{ section.id }} .section,
    #shopify-section-{{ section.id }} .section--tight {
      --section-spacing-block-start: 0px !important;
      --section-spacing-block-end: 0px !important;
      --calculated-section-spacing-block-start: 0px !important;
      --calculated-section-spacing-block-end: 0px !important;
      padding-inline-start: 0 !important;
      padding-inline-end: 0 !important;
      padding-block-start: 0 !important;
      padding-block-end: 0 !important;
    }

    /* 版心 1200px 居中：PAD/PC 一致，按 develop.md 要求 */
    #shopify-section-{{ section.id }} .product {
      display: flex !important;
      grid: var(--product-grid) !important;
      width: 100% !important;
      max-width: 100% !important;
      margin-inline: auto !important;
      padding-top: 36px !important;
      padding-left: 48px !important;
      padding-right: 48px !important;
      padding-bottom: 0 !important;
      gap: 40px !important;
      column-gap: 40px !important;
      align-items: start !important;
    }

    /* gallery 在 1200 版心下填满左列 */
    #shopify-section-{{ section.id }} .product-gallery {
      {% comment %} width: 65% !important;
      max-width: 65% !important; {% endcomment %}
    }

    /* PC：左列画廊 sticky；top 由下方脚本按公告/导航实际可见底边写入 --pdp-sticky-top，
       与 store-header translateY 隐藏动画同步，避免顶栏消失后图片上方留白。 */
    #shopify-section-{{ section.id }} product-gallery.product-gallery,
    #shopify-section-{{ section.id }} .product-gallery {
      position: sticky !important;
      top: var(--pdp-sticky-top) !important;
      transition: top 0.2s ease !important;
      align-self: start !important;
      z-index: 1;
    }

    #shopify-section-{{ section.id }} safe-sticky.product-info {
      top: var(--pdp-sticky-top) !important;
      transition: top 0.2s ease !important;
    }
  }

  /* PAD（1280–1439）：缩 gap/padding + 弹性列宽；保留双列 sticky / safe-sticky 滚动逻辑，禁止横向撑出视口 */
  @media screen and (min-width: 1280px) and (max-width: 1439px) {
    #shopify-section-{{ section.id }} .product {
      gap: 16px !important;
      column-gap: 16px !important;
      padding-left: 40px !important;
      padding-right: 40px !important;
      padding-top: 24px !important;
      min-width: 0 !important;
      max-width: 100% !important;
      width: 100% !important;
      overflow-x: clip !important;
      box-sizing: border-box !important;
    }

    #shopify-section-{{ section.id }} product-gallery.product-gallery,
    #shopify-section-{{ section.id }} .product-gallery {
      flex: 1 1 0 !important;
      min-width: 0 !important;
      max-width: none !important;
      width: auto !important;
      position: sticky !important;
      top: var(--pdp-sticky-top) !important;
      transition: top 0.2s ease !important;
      align-self: start !important;
      z-index: 1;
    }

    #shopify-section-{{ section.id }} safe-sticky.product-info,
    #shopify-section-{{ section.id }} .product-info {
      flex: 0 0 480px !important;
      width: 480px !important;
      min-width: 0 !important;
      max-width: 480px !important;
      overflow-x: clip !important;
      overflow-y: visible !important;
    }

    #shopify-section-{{ section.id }} .product-info__block-item {
      min-width: 0 !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }

    #shopify-section-{{ section.id }} .product-info__block-item[data-block-type="product-tabs"],
    #shopify-section-{{ section.id }} .product-info__block-item[data-block-type="product-tabs"] .product-tabs-container {
      overflow-x: clip !important;
      max-width: 100% !important;
    }
  }

  /* PC（≥ 1440）：按 Figma 1920 稿（节点 1156:254024）原生尺寸展开画廊列。
     Figma 媒体橱窗 1264 × 852.69，信息列 560，列间 24 → PDP 版心 = 1264 + 24 + 560 = 1848px。
     在 1440~1919 视口下按 1fr 比例自动缩小画廊列；至 1920+ 视口达到 Figma 原生 1264。 */
  @media screen and (min-width: 1440px) {
    #shopify-section-{{ section.id }} {
      --product-gallery-media-list-gap: var(--grid-gutter);
    }

    /* 1848 = 1264 (gallery) + 24 (gap) + 560 (info)；box-sizing 取主题默认 border-box
       因此不加 L/R padding，避免把 1fr 列挤小。视口 < 1848 时自动 margin: 0 auto 居中缩放。 */
    #shopify-section-{{ section.id }} .product {
      max-width: 100% !important;
      padding-left: 48px !important;
      padding-right: 48px !important;
    }
  }
  @media screen and (min-width: 1440px) {
    #shopify-section-{{ section.id }} safe-sticky.product-info,
    #shopify-section-{{ section.id }} .product-info {
      flex: 0 0 536px;
      width: 536px;
      min-width: 0;
    }
  }

  /* 覆盖按钮文本的 text-transform: capitalize */
  #shopify-section-{{ section.id }} .g7-sticky-atc-label {
    text-transform: none !important;
  }
</style>
<style>
  {% if section.settings.type_switch %}
  #shopify-section-{{ section.id }}  .product-gallery__choose{
    display: flex;
    justify-content: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .product-gallery__choose .product__choose-btn {
