          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "delivery",
            "title": "<p>FAST, FREE DELIVERY</p>",
            "description": "Free shipping in 3-7 days on all orders"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "star",
            "title": "<p>PAY WITH EASE</p>",
            "description": "Free shipping in 3-7 days on all orders"
          }
        },
        {
          "type": "benefit",
