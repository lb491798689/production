<style>
  html{
    scroll-behavior: smooth;
  }
  .kik_navigation_sticky{
   position: sticky!important;
    top: 94.5px;
    z-index: 9;
  }
.kik_navigation_c{
  background:{{section.settings.background}};
  color:{{section.settings.text_color}};
  position:relative;
  text-transform:uppercase;
  font-style:italic;
}
.kik_navigation_tabs{
  background:{{section.settings.background}};
}
.kik_navigation_c .kik_header{
  display:flex;
  justify-content:space-between;
  padding-top:24px;
  align-items:center;
  padding-bottom:24px;
}
.kik_navigation_c .kik_header h1{
  margin:0;
  font-size:18px;
  line-height:1.5;
  letter-spacing: 0;
  color:{{section.settings.text_color}};
}
.kik_navigation_content{
  display:flex;
  justify-content:space-between;
  align-items:center;
  column-gap:64px;
}
.kik_navigation_tabs{
  display:flex;
  justify-content:space-between;
  align-items:center;
  column-gap:64px;
}
.kik_navigation a{
  text-decoration:none;
}
.kik_navigation h3{
  font-size:18px;
  line-height:1.5;
  color: {{section.settings.text_color}};
  cursor:pointer;
  padding:10px 0;
  }
  .kik_navigation.active h3{
  color:#ED1C24;
  border-bottom:2px solid;
  }
  .navigation_btn a{
    padding:10px 32px;
    background:#ED1C24;
    color:{{section.settings.text_color}};
    text-decoration:none;
    border-radius:100px;
    
  }
  .navigation_btn a h4{
    font-size:18px;
    line-height:1.5;
  }
  .navigation_btn{
    display:flex;
    align-items:center;
    column-gap:8px;
  }
  .navigation_btn svg{
    display:none;
  }
  @media (max-width:999px){
.kik_navigation_c .kik_header{
  padding-top:16px;
  padding-bottom:16px;
  padding-left:16px;
  padding-right: 16px;
}
.kik_navigation_c .kik_header h1{
  font-size:16px;
}
.kik_navigation_content{
  display:flex;
  justify-content:space-between;
  align-items:center;
  column-gap:8px;
}
.kik_navigation_tabs{
  display: block;
    position: absolute;
    z-index: 9;
    left: 0;
    width: 100%;
    top: 72px;
    max-height: 0px;
    transition: max-height .2s ease-in;
    overflow:hidden;
}
.kik_navigation_tabs.active{
  max-height:300px;
}
.kik_navigation h3{
  padding:10px 16px;
  font-size:16px;
}
.kik_navigation.active h3 {
    border-bottom: unset;
}
.kik_navigation{
  font-size:16px;
  }
  .navigation_btn a{
    padding:8px 24px;
    border-radius:100px;
    font-size:16px;
  }
  .navigation_btn a h4{
    font-size:16px;
  }
  .navigation_btn svg{
    display:flex;
    cursor:pointer;
  }
  }
  @media (max-width:699px){
    .kik_navigation_sticky{
    top: 54px;
  }
}

