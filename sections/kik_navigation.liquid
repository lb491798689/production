<div class="kik_navigation_c">
    <div class="section kik_header">
        <h1>{{ section.settings.title }}</h1>
        <div class="kik_navigation_content">
        <div class="kik_navigation_tabs">
        {% for block in section.blocks %}
            <div class="kik_navigation {% if forloop.first%} active {% endif %} " link-to="{{ block.settings.link_to }}">
              <a href="{{ block.settings.link_to }}">
                <h3>{{block.settings.title}}</h3>
                </a>
            </div>
        {% endfor %}
        </div>
        <div class="navigation_btn">
          <svg role="presentation" focusable="false" width="10" height="7" class="icon icon-chevron-bottom" viewBox="0 0 10 7">
        <path d="m1 1 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2"></path>
      </svg>
      <a href="{{ section.settings.link }}" class="kik_navigation_link"><h4>{{ section.settings.link_text }}</h4></a>
        </div>
        
        </div>
        </div>
</div>
<script>
  document.querySelector(".navigation_btn svg").addEventListener("click",function(){
    document.querySelector(".kik_navigation_tabs").classList.toggle("active");
  });

  function isElementBottom(el){
        var recte = el.getBoundingClientRect();
          return  recte.top <= 150 ;
        
        }
      function richText(){
          document.querySelectorAll("[data_link='true']").forEach(function(item){
            if(isElementBottom(item)){
              if(item.getAttribute("id") != ""){
              document.querySelectorAll(".kik_navigation").forEach(function(elem){
                    elem.classList.remove('active');
              })
              document.querySelector(".kik_navigation a[href='#"+ item.getAttribute("id") +"']").closest(".kik_navigation").classList.add("active");
              }
        }
          })

        }
 window.addEventListener("scroll", richText);  
</script>
{% schema %}
{
  "name": "Kiks Navigation",
  "tag": "section",
  "class": "kik_navigation_sticky",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "url",
      "id": "link",
      "label": "link"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Gradient replaces solid colors when set."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    }
  ],
  "blocks": [
    {
      "name": "Navigation",
      "type": "navigation",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Title"
        },
        {
          "type": "text",
          "id": "link_to",
          "label": "Link to"
        }
      ]
    }
    ],
  "presets": [
    {
      "name": "Kiks Navigation",
      "blocks": [
     
      ]
    }
  ]
}
{% endschema %}
