{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign title = se_stts.title
  assign title_mob = se_stts.title_mob | default: title
  assign description = se_stts.description
  assign theme = se_stts.theme | default: 'dark'
  if theme == 'light'
    assign theme_bg = '#FFFFFF'
    assign title_color = '#0A0A0A'
    assign desc_color = 'rgba(26, 26, 26, 0.60)'
    assign desc_color_mob = 'rgba(26, 26, 26, 0.60)'
    assign media_wrapper_bg = '#F1F1F1'
    assign collapsed_img_placeholder_bg = '#E8E8E8'
  else
    assign theme_bg = '#000000'
    assign title_color = '#FFFFFF'
    assign desc_color = 'rgba(255, 255, 255, 0.7)'
    assign desc_color_mob = 'rgba(255, 255, 255, 0.6)'
    assign media_wrapper_bg = '#000000'
    assign collapsed_img_placeholder_bg = '#434343'
  endif
  assign bg_color = se_stts.bg_color | default: theme_bg
  assign bg_color_mob = se_stts.bg_color_mob | default: bg_color

  assign collapsed_pc_img = se_stts.collapsed_pc_img
  assign collapsed_mob_img = se_stts.collapsed_mob_img
  assign expanded_pc_img = se_stts.expanded_pc_img
  assign expanded_mob_img = se_stts.expanded_mob_img
  assign collapsed_fallback_img = collapsed_pc_img | default: collapsed_mob_img
  assign expanded_fallback_img = expanded_pc_img | default: expanded_mob_img

  assign button_label = se_stts.button_label
  assign button_label_mob = se_stts.button_label_mob | default: button_label

  assign feature1_title = se_stts.feature1_title
  assign feature1_description = se_stts.feature1_description

  assign feature2_title = se_stts.feature2_title
  assign feature2_description = se_stts.feature2_description

  assign feature3_title = se_stts.feature3_title
  assign feature3_description = se_stts.feature3_description

  assign title_mob_raw = title_mob | default: title | default: '3D ErgoCloud Neck Pillow'
-%}
{% capture default_sid %}.jingva-m6-3d-ergo-neck-pillow-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-m6-3d-ergo-neck-pillow-{{ sid }}" data-section-id="{{ sid }}">
  {% style %}
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color | default: theme_bg }} !important;
      padding: 0 !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-wrapper {
      position: relative !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      padding-top: 160px !important;
      gap: 48px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-content {
      position: relative !important;
      width: 100% !important;
      max-width: 1296px !important;
      margin: 0 auto !important;
      padding: 0 48px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 12px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-title-mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn-label-mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-title {
      font-family: 'Orbitron', sans-serif !important;
      font-weight: 900 !important;
      font-size: 64px !important;
      line-height: 1.1em !important;
      color: {{ title_color }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 1200px !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-description {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 1.2000000476837158em !important;
      color: {{ desc_color }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 1080px !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-media-wrapper {
      position: relative !important;
      width: 100% !important;
      height: auto !important;
      background-color: {{ media_wrapper_bg }} !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-collapsed-state {
      position: relative !important;
      width: 100% !important;
      box-sizing: border-box !important;
      z-index: 10 !important;
      opacity: 1 !important;
      transition: opacity 0.45s ease !important;
      will-change: opacity !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-collapsed-state.hidden {
      display: block !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-collapsed-img {
      position: relative !important;
      display: block !important;
      width: 100%;
      height: auto;
      object-position: center !important;
      background-color: {{ collapsed_img_placeholder_bg }} !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn {
      position: absolute !important;
      left: 50% !important;
      bottom: 76px !important;
      margin-left: 0 !important;
      transform: translateX(-50%) !important;
      z-index: 20 !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 12px !important;
      padding: 14px 24px !important;
      height: 68px !important;
      background-color: transparent !important;
      border: none !important;
      border-radius: 200px !important;
      cursor: pointer !important;
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 600 !important;
      font-size: 18px !important;
      line-height: 1.2 !important;
      color: #000000 !important;
      text-align: center !important;
      text-transform: none !important;
      box-sizing: border-box !important;
      isolation: isolate !important;
      overflow: visible !important;
      transition: color 0.2s ease !important;
    }

    /* Pill background layer (visible by default; hidden only when JS adds .btn-init) */
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn-bg {
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      background-color: #FFFFFF !important;
      border-radius: 200px !important;
      backdrop-filter: blur(50px) !important;
      -webkit-backdrop-filter: blur(50px) !important;
      z-index: 1 !important;
      transform-origin: 50% 50% !important;
      transform: scaleX(1);
      transition: background-color 0.2s ease !important;
      pointer-events: none !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn-label,
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn-icon {
      position: relative !important;
      z-index: 2 !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      line-height: 1.2 !important;
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn:hover .jingva-m6-3d-ergo-neck-pillow-toggle-btn-bg {
      background-color: #F2F2F2 !important;
    }

    /* === Initial hidden state (only when JS adds .btn-init) === */
    /* --btn-icon-shift = 图标从默认右侧位置移动到按钮水平中央需要的 X 偏移（JS 测量后设置，负值） */
    /* --btn-half = 按钮一半宽度（JS 设置），用于 clip-path 中央圆计算 */
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-init .jingva-m6-3d-ergo-neck-pillow-toggle-btn-bg {
      /* 初始裁剪为中心 68px 圆形 */
      clip-path: inset(0 calc(var(--btn-half, 50%) - 34px) 0 calc(var(--btn-half, 50%) - 34px) round 999px);
      -webkit-clip-path: inset(0 calc(var(--btn-half, 50%) - 34px) 0 calc(var(--btn-half, 50%) - 34px) round 999px);
      /* 起初位于按钮下方遥远处 */
      transform: translate3d(0, 220%, 0);
      opacity: 0;
      will-change: transform, opacity, clip-path;
    }
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-init .jingva-m6-3d-ergo-neck-pillow-toggle-btn-icon {
      /* 图标被推到水平中央 + 下方遥远处 */
      transform: translate3d(var(--btn-icon-shift, 0px), 220%, 0);
      opacity: 0;
      will-change: transform, opacity;
    }
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-init .jingva-m6-3d-ergo-neck-pillow-toggle-btn-label > span {
      opacity: 0;
      transform: translate3d(0, 20%, 0);
      will-change: transform, opacity;
    }

    /* === Animation when JS adds .btn-animate (总时长 0.9s一气呵成) === */
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-animate .jingva-m6-3d-ergo-neck-pillow-toggle-btn-bg {
      animation: jingvaM6BtnBgRiseExpand 0.9s cubic-bezier(0.32, 0.72, 0.24, 1) 0s forwards;
    }
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-animate .jingva-m6-3d-ergo-neck-pillow-toggle-btn-icon {
      animation: jingvaM6BtnIconRiseSlide 0.9s cubic-bezier(0.32, 0.72, 0.24, 1) 0s forwards;
    }
    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-animate .jingva-m6-3d-ergo-neck-pillow-toggle-btn-label > span {
      animation: jingvaM6BtnLabelIn 0.4s cubic-bezier(0.32, 0.72, 0.24, 1) 0.5s forwards;
    }

    /* 背景层：升起(0→35%) → 重叠到 双向展开(25%→100%)，无停顿 */
    @keyframes jingvaM6BtnBgRiseExpand {
      0% {
        transform: translate3d(0, 180%, 0);
        opacity: 0;
        clip-path: inset(0 calc(var(--btn-half, 50%) - 34px) 0 calc(var(--btn-half, 50%) - 34px) round 999px);
        -webkit-clip-path: inset(0 calc(var(--btn-half, 50%) - 34px) 0 calc(var(--btn-half, 50%) - 34px) round 999px);
      }
      35% {
        transform: translate3d(0, 0, 0);
        opacity: 1;
        clip-path: inset(0 calc(var(--btn-half, 50%) - 34px) 0 calc(var(--btn-half, 50%) - 34px) round 999px);
        -webkit-clip-path: inset(0 calc(var(--btn-half, 50%) - 34px) 0 calc(var(--btn-half, 50%) - 34px) round 999px);
      }
      100% {
        transform: translate3d(0, 0, 0);
        opacity: 1;
        clip-path: inset(0 0 0 0 round 999px);
        -webkit-clip-path: inset(0 0 0 0 round 999px);
      }
    }

    /* 图标层：中央下方升起(0→35%) → 滑到右侧(35%→100%)，上升与滑动无缝衔接 */
    @keyframes jingvaM6BtnIconRiseSlide {
      0% {
        transform: translate3d(var(--btn-icon-shift, 0px), 180%, 0);
        opacity: 0;
      }
      35% {
        transform: translate3d(var(--btn-icon-shift, 0px), 0, 0);
        opacity: 1;
      }
      100% {
        transform: translate3d(0, 0, 0);
        opacity: 1;
      }
    }

    @keyframes jingvaM6BtnLabelIn {
      0%   { transform: translate3d(0, 15%, 0); opacity: 0; }
      100% { transform: translate3d(0, 0, 0); opacity: 1; }
    }

    {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-icon-bg {
