  <script>
    (function() {
      function init() {
        var sid = '{{ sid }}';
        var collapsed = document.getElementById('collapsed-' + sid);
        var expanded = document.getElementById('expanded-' + sid);
        var toggleBtn = document.getElementById('toggle-btn-' + sid);
        if (!collapsed || !expanded || !toggleBtn) return;

        var isExpanded = false;
        function toggleState() {
          isExpanded = !isExpanded;
          if (isExpanded) {
            collapsed.classList.add('hidden');
            expanded.classList.add('active');
          } else {
            collapsed.classList.remove('hidden');
            expanded.classList.remove('active');
          }
        }
        toggleBtn.addEventListener('click', toggleState);
        expanded.addEventListener('click', toggleState);

        // 测量按钮宽度，计算图标从右侧默认位置到按钮水平中央的偏移量
        function setBtnVars() {
          var w = toggleBtn.offsetWidth;
          if (!w) return;
          var iconEl = toggleBtn.querySelector('.jingva-m6-3d-ergo-neck-pillow-toggle-btn-icon');
          if (!iconEl) return;
          // 图标在默认 flex 布局中的中心 X (相对于按钮)
          var iconRect = iconEl.getBoundingClientRect();
          var btnRect = toggleBtn.getBoundingClientRect();
          var iconCenterX = iconRect.left + iconRect.width / 2 - btnRect.left;
          var btnCenterX = w / 2;
          // 需要的偏移 = 按钮中心 - 图标默认中心（负值 = 向左推）
          var shift = btnCenterX - iconCenterX;
          toggleBtn.style.setProperty('--btn-icon-shift', shift + 'px');
          toggleBtn.style.setProperty('--btn-half', (w / 2) + 'px');
        }
        // 在设置 .btn-init 之前先测量（此时元素处于默认可见状态，能拿到真实布局尺寸）
        setBtnVars();
        window.addEventListener('resize', setBtnVars);

        // 进入隐藏初始状态
        toggleBtn.classList.add('btn-init');

        // 进入视窗时播放一次动画
        if (typeof IntersectionObserver === 'undefined') {
          requestAnimationFrame(function() { toggleBtn.classList.add('btn-animate'); });
          return;
        }
        var btnObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              toggleBtn.classList.add('btn-animate');
              btnObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });
        btnObserver.observe(toggleBtn);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</section>

<script>
(function() {
  var section = document.querySelector('.jingva-m6-3d-ergo-neck-pillow-{{ sid }}');
  if (!section) return;

  var titles = section.querySelectorAll('.jingva-m6-3d-ergo-neck-pillow-title');
  if (!titles.length) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        titles.forEach(function(t) { t.classList.add('aos-animate'); });
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  observer.observe(titles[0]);
})();
</script>

