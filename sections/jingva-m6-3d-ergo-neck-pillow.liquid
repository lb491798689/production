      {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-init .jingva-m6-3d-ergo-neck-pillow-toggle-btn-bg {
        clip-path: inset(0 calc(var(--btn-half, 50%) - 20px) 0 calc(var(--btn-half, 50%) - 20px) round 999px);
        -webkit-clip-path: inset(0 calc(var(--btn-half, 50%) - 20px) 0 calc(var(--btn-half, 50%) - 20px) round 999px);
      }
      {{ default_sid }} .jingva-m6-3d-ergo-neck-pillow-toggle-btn.btn-animate .jingva-m6-3d-ergo-neck-pillow-toggle-btn-bg {
        animation: jingvaM6BtnBgRiseExpandMob 0.9s cubic-bezier(0.32, 0.72, 0.24, 1) 0s forwards;
      }
      @keyframes jingvaM6BtnBgRiseExpandMob {
        0% {
          transform: translate3d(0, 180%, 0);
          opacity: 0;
          clip-path: inset(0 calc(var(--btn-half, 50%) - 20px) 0 calc(var(--btn-half, 50%) - 20px) round 999px);
          -webkit-clip-path: inset(0 calc(var(--btn-half, 50%) - 20px) 0 calc(var(--btn-half, 50%) - 20px) round 999px);
        }
        35% {
          transform: translate3d(0, 0, 0);
          opacity: 1;
          clip-path: inset(0 calc(var(--btn-half, 50%) - 20px) 0 calc(var(--btn-half, 50%) - 20px) round 999px);
          -webkit-clip-path: inset(0 calc(var(--btn-half, 50%) - 20px) 0 calc(var(--btn-half, 50%) - 20px) round 999px);
        }
        100% {
          transform: translate3d(0, 0, 0);
          opacity: 1;
          clip-path: inset(0 0 0 0 round 999px);
          -webkit-clip-path: inset(0 0 0 0 round 999px);
        }
      }

