{%- render 'section-spacing-collapsing' -%}
{%- assign section_identifier = '#shopify-section-' | append: section.id -%}
{%- assign  padding_top = section.settings.padding_top | append:'px' -%}
{%- assign  padding_bottom = section.settings.padding_bottom | append:'px' -%}

{%- assign padding_mobile_top = section.settings.padding_top_mob | append: 'px' -%}
{%- assign padding_mobile_bottom = section.settings.padding_bottom_mob | append: 'px' -%}
{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>

  #shopify-section-{{ section.id }} {
    --media-grid-row-height: {{ section.settings.mobile_row_height }}px;
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --media-grid-row-height: {{ section.settings.desktop_row_height }}px;
    }
  }

  {%- for block in section.blocks -%}
    #media-grid-{{ block.id }} {
      --content-over-media-overlay: {{ block.settings.overlay_color.rgb }} /{{ block.settings.overlay_opacity | divided_by: 100.0 }};

      {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
        --content-over-media-gap: 1rem;
      {%- endif -%}
    }

    {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
      @media screen and (min-width: 740px) {
        #media-grid-{{ block.id }} {
          --content-over-media-gap: 1.5rem;
        }
      }
    {%- endif -%}
  {%- endfor -%}
  /* Custom Css Added  */
  {{ section_identifier }}.shopify-section--media-grid section-header.section-header {
      margin-bottom: 48px;
  }
  {{ section_identifier }} media-grid.media-grid {
    gap: {{ section.settings.column_gap }}px;
  }
  {{ section_identifier }} .section {
    padding-top: {{padding_top}};
    padding-bottom: {{padding_bottom}};
  }
  {{ section_identifier }}.shopify-section--media-grid .kiks-description{
      margin-top: 24px;
    }




  /* jiangva */
 {{ section_identifier }} .jiangva-content-over-media{
  width: 100%;
  position: relative;
 }
 {{ section_identifier }} .jiangva-content-over-media .prose button{
  position: absolute;
  bottom: 0;
  right: 0;
  margin-top: 0 !important;
  border-radius:8px ;
  padding: 14px 27px;
  font-size: 14px;
  background-color: transparent;
  border: 1px solid #fff;
 }
 {{ section_identifier }} .jiangva-content-over-media .prose button:hover{
  background-color: #E1040F;
  box-shadow: inset 0 0 0 0px !important;
  border: 1px solid #E1040F;
  
 }
 {{ section_identifier }} .jiangva-content-over-media .prose p:nth-child(2){
  margin-top: 10px;
  font-size: 16px;
 }

{{ section_identifier }} .jingva-image-mobile{
  display: none;
}
{{ section_identifier }} .jiangva-content-over-media .prose .jiangva-desktop-btn{
  margin-top: 0;
  position: absolute;
  bottom: 0;
  right: 0;
  font-size: 16px;
  display: flex;
  align-items: center;
  gap: 14px;
}
{{ section_identifier }} .jiangva-content-over-media .prose .jiangva-desktop-btn .button__icon {
  width: 29px;
  height: 29px;
  background: #fff;
  color: #000;
  clip-path: polygon(
    25% 0%,    
    75% 0%,     
    100% 25%,   
    100% 75%,   
    75% 100%,   
    25% 100%,   
    0% 75%,    
    0% 25%     
  );
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease-in-out;
}
{{ section_identifier }} .jiangva-content-over-media .prose .jiangva-desktop-btn .button__icon{
background-image:linear-gradient(to top,#E1040F 0%,#E1040F 100%);
background-size:106% 0%;
background-position:0 100%;
background-repeat:no-repeat;
transition:background-size .3s ease,border-color .3s ease,color .3s ease,opacity .3s !important;}

{{ section_identifier }} .jiangva-content-over-media .prose .jiangva-desktop-btn:hover .button__icon{
  background-size:106% 106%;
  color: #fff;
}
@media screen and (max-width: 768px) {
  {{ section_identifier }} .jiangva-content-over-media .prose button{
    position: relative;
    padding: 5px 5px !important;
    border-radius: 50%;
  }
  {{ section_identifier }}.shopify-section--media-grid section-header.section-header {
      margin-bottom: 24px;
  }

  {{ section_identifier }} .jiangva-content-over-media .prose .jiangva-desktop-btn{
    display: none;
  }
   {{ section_identifier }}.shopify-section--media-grid .h2{
  
 font-style: italic;
  }
  {{ section_identifier }} .jiangva-content-over-media .prose p:nth-child(1){
    font-size: 22px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 7px;
    line-height: 1.2;
    font-style: italic;
  }
 
  {{ section_identifier }} .jiangva-content-over-media .prose p:nth-child(2){
    margin-top: 8px;
    font-size: 11px;
  }

  {{ section_identifier }} .jingva-image-desktop{
    display: none;
  }
  {{ section_identifier }} .jingva-image-mobile{
    display: block;
  }

  {{ section_identifier }} media-grid.media-grid {
    gap: 12px;
  }
}


 @media only screen and (max-width: 430px) {
  {{ section_identifier }} .section {
    padding-top: {{ padding_mobile_top }};
    padding-bottom: {{ padding_mobile_bottom }};
  }
  {{ section_identifier }}.shopify-section--media-grid section-header.section-header {
    margin: 0 auto;
    max-width: 265px;
    margin-bottom: 24px;
  }
  {{ section_identifier }}.shopify-section--media-grid .h2{
    line-height: 1.2;
    font-family: 'RBNo3.1-BlackItalic', sans-serif;

  }
  {{ section_identifier }}.shopify-section--media-grid .kiks-description{
    margin-top: 10px;
  }
}




 
</style>

