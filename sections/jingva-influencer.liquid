  "class": "shopify-section--jingva-influencer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "红人模块设置"
    },
    {
      "type": "text",
      "id": "title",
      "label": "模块标题",
      "default": "The Strategic Gaming Partner of Choice"
    }
  ],
  "blocks": [
    {
      "type": "influencer",
      "name": "红人",
      "settings": [
        {
          "type": "image_picker",
          "id": "influencer_image",
          "label": "红人图片 (PC)"
        },
        {
          "type": "image_picker",
          "id": "influencer_image_mob",
          "label": "红人图片 (Mobile)",
          "info": "可选；在 ≤1023px 屏幕使用。未上传时使用 PC 图片。"
        },
        {
          "type": "text",
          "id": "influencer_name",
          "label": "红人姓名",
          "default": "Niko"
        },
        {
          "type": "text",
          "id": "influencer_role",
          "label": "红人身份",
          "default": "CS2 Legendary Player"
        },
        {
          "type": "textarea",
          "id": "influencer_description",
          "label": "红人描述",
          "default": "With its innovative features, the AutoFull M6 has convinced me. You should give it a try."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "按钮文字",
          "default": "LEARN MORE"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "按钮链接"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jingva Influencer",
      "settings": {
        "title": "The Strategic Gaming Partner of Choice"
      },
      "blocks": [
        {
          "type": "influencer",
          "settings": {
            "influencer_name": "Niko",
            "influencer_role": "CS2 Legendary Player",
            "influencer_description": "With its innovative features, the AutoFull M6 has convinced me. You should give it a try.",
            "button_text": "LEARN MORE"
          }
        }
      ]
    }
  ]
}
{% endschema %}
