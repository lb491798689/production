  {% endstyle %}

  <div class="jingva-m6-air-conditioned-seat-wrapper">
    <div class="jingva-m6-air-conditioned-seat-content">
      {% if title != blank %}
        <h2 class="jingva-m6-air-conditioned-seat-title">{{ title }}</h2>
      {% endif %}

      {% if description != blank %}
        <div class="jingva-m6-air-conditioned-seat-description">{{ description }}</div>
      {% endif %}
    </div>

    <div class="jingva-m6-air-conditioned-seat-media-wrapper">
      <div class="jingva-m6-air-conditioned-seat-media-container swiper" id="jingva-m6-air-seat-swiper-{{ sid }}">
        <div class="swiper-wrapper">
          <div class="swiper-slide">
            <div class="jingva-m6-air-conditioned-seat-media-slide">
              <picture class="jingva-m6-air-conditioned-seat-media">
                {% if tab1_pc_img != blank %}
                  <source media="(min-width: 1280px)" srcset="{{ tab1_pc_img | image_url: width: 1920 }}">
                {% endif %}
                {% if tab1_mob_img != blank %}
                  <source media="(max-width: 1279px)" srcset="{{ tab1_mob_img | image_url: width: 692 }}">
                {% endif %}
                <img
                  src="{{ tab1_pc_img | default: tab1_mob_img | image_url: width: 1920 }}"
                  alt="{{ tab1_label | escape }}"
                  loading="lazy"
                >
              </picture>
              {% if tab1_pc_video != blank %}
                <span class="jingva-m6-air-conditioned-seat-video jingva-m6-air-conditioned-seat-video--pc">
                  {{
                    tab1_pc_video
                    | video_tag:
                      class: 'jingva-m6-air-conditioned-seat-video-el',
                      image_size: '1920x',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true,
                      playsinline: true
                  }}
                </span>
              {% endif %}
              {% if tab1_mob_video != blank %}
                <span class="jingva-m6-air-conditioned-seat-video jingva-m6-air-conditioned-seat-video--mob">
                  {{
                    tab1_mob_video
                    | video_tag:
                      class: 'jingva-m6-air-conditioned-seat-video-el',
                      image_size: '780x',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true,
                      playsinline: true
                  }}
                </span>
              {% endif %}
            </div>
          </div>

          <div class="swiper-slide">
            <div class="jingva-m6-air-conditioned-seat-media-slide">
              <picture class="jingva-m6-air-conditioned-seat-media">
                {% if tab2_pc_img != blank %}
                  <source media="(min-width: 1280px)" srcset="{{ tab2_pc_img | image_url: width: 1920 }}">
                {% endif %}
                {% if tab2_mob_img != blank %}
                  <source media="(max-width: 1279px)" srcset="{{ tab2_mob_img | image_url: width: 692 }}">
                {% endif %}
                <img
                  src="{{ tab2_pc_img | default: tab2_mob_img | image_url: width: 1920 }}"
                  alt="{{ tab2_label | escape }}"
                  loading="lazy"
                >
              </picture>
              {% if tab2_pc_video != blank %}
                <span class="jingva-m6-air-conditioned-seat-video jingva-m6-air-conditioned-seat-video--pc">
                  {{
                    tab2_pc_video
                    | video_tag:
                      class: 'jingva-m6-air-conditioned-seat-video-el',
                      image_size: '1920x',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true,
                      playsinline: true
                  }}
                </span>
              {% endif %}
              {% if tab2_mob_video != blank %}
                <span class="jingva-m6-air-conditioned-seat-video jingva-m6-air-conditioned-seat-video--mob">
                  {{
                    tab2_mob_video
                    | video_tag:
                      class: 'jingva-m6-air-conditioned-seat-video-el',
                      image_size: '780x',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true,
                      playsinline: true
                  }}
                </span>
              {% endif %}
            </div>
          </div>

          <div class="swiper-slide">
            <div class="jingva-m6-air-conditioned-seat-media-slide">
              <picture class="jingva-m6-air-conditioned-seat-media">
                {% if tab3_pc_img != blank %}
                  <source media="(min-width: 1280px)" srcset="{{ tab3_pc_img | image_url: width: 1920 }}">
                {% endif %}
                {% if tab3_mob_img != blank %}
                  <source media="(max-width: 1279px)" srcset="{{ tab3_mob_img | image_url: width: 692 }}">
                {% endif %}
                <img
                  src="{{ tab3_pc_img | default: tab3_mob_img | image_url: width: 1920 }}"
                  alt="{{ tab3_label | escape }}"
                  loading="lazy"
                >
              </picture>
              {% if tab3_pc_video != blank %}
                <span class="jingva-m6-air-conditioned-seat-video jingva-m6-air-conditioned-seat-video--pc">
                  {{
                    tab3_pc_video
                    | video_tag:
