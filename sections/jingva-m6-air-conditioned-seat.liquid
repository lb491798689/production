{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign title = se_stts.title
  assign description = se_stts.description
  assign theme = se_stts.theme | default: 'dark'
  if theme == 'light'
    assign theme_bg = '#FFFFFF'
    assign title_color = '#0A0A0A'
    assign desc_color = 'rgba(26, 26, 26, 0.60)'
    assign desc_color_mob = 'rgba(26, 26, 26, 0.60)'
    assign tabs_bg = '#F1F1F1'
    assign bottom_text_color = '#0A0A0A'
    assign nav_btn_pad_bg = '#F1F1F1'
    assign mob_nav_icon_fill = '#0A0A0A'
  else
    assign theme_bg = '#1E0909'
    assign title_color = '#FFFFFF'
    assign desc_color = 'rgba(255, 255, 255, 0.7)'
    assign desc_color_mob = 'rgba(255, 255, 255, 0.6)'
    assign tabs_bg = '#f8f8f8'
    assign bottom_text_color = '#FFFFFF'
    assign nav_btn_pad_bg = '#FFFFFF'
    assign mob_nav_icon_fill = '#FFFFFF'
  endif
  assign bg_color = se_stts.bg_color | default: theme_bg
  assign bg_color_mob = se_stts.bg_color_mob | default: bg_color

  assign tab1_label = se_stts.tab1_label
  assign tab1_pc_img = se_stts.tab1_pc_img
  assign tab1_mob_img = se_stts.tab1_mob_img
  assign tab1_pc_video = se_stts.tab1_pc_video
  assign tab1_mob_video = se_stts.tab1_mob_video
  if tab1_pc_video == blank and tab1_mob_video != blank
    assign tab1_pc_video = tab1_mob_video
  endif
  if tab1_mob_video == blank and tab1_pc_video != blank
    assign tab1_mob_video = tab1_pc_video
  endif
  assign tab1_text = se_stts.tab1_text

  assign tab2_label = se_stts.tab2_label
  assign tab2_pc_img = se_stts.tab2_pc_img
  assign tab2_mob_img = se_stts.tab2_mob_img
  assign tab2_pc_video = se_stts.tab2_pc_video
  assign tab2_mob_video = se_stts.tab2_mob_video
  if tab2_pc_video == blank and tab2_mob_video != blank
    assign tab2_pc_video = tab2_mob_video
  endif
  if tab2_mob_video == blank and tab2_pc_video != blank
    assign tab2_mob_video = tab2_pc_video
  endif
  assign tab2_text = se_stts.tab2_text

  assign tab3_label = se_stts.tab3_label
  assign tab3_pc_img = se_stts.tab3_pc_img
  assign tab3_mob_img = se_stts.tab3_mob_img
  assign tab3_pc_video = se_stts.tab3_pc_video
  assign tab3_mob_video = se_stts.tab3_mob_video
  if tab3_pc_video == blank and tab3_mob_video != blank
    assign tab3_pc_video = tab3_mob_video
  endif
  if tab3_mob_video == blank and tab3_pc_video != blank
    assign tab3_mob_video = tab3_pc_video
  endif
  assign tab3_text = se_stts.tab3_text

  assign show_bottom_text = false
  if tab1_text != blank or tab2_text != blank or tab3_text != blank
    assign show_bottom_text = true
  endif
-%}
{% capture default_sid %}.jingva-m6-air-conditioned-seat-{{ sid }}{% endcapture %}

<link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}">

<section class="jingva-section-container jingva-m6-air-conditioned-seat-{{ sid }}" data-section-id="{{ sid }}">
  {% style %}
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color | default: theme_bg }} !important;
      padding: 0 !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-wrapper {
      position: relative !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      padding-top: 160px !important;
      gap: 24px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-content {
      position: relative !important;
      width: 100% !important;
      max-width: 1296px !important;
      margin: 0 auto !important;
      padding: 0 48px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 12px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-title {
      font-family: 'Orbitron', sans-serif !important;
      font-weight: 900 !important;
      font-size: 64px !important;
      line-height: 1.253999948501587em !important;
      color: {{ title_color }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 1000px !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-description,
    {{ default_sid }} .jingva-m6-air-conditioned-seat-description p {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 1.2em !important;
      color: {{ desc_color }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 1080px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-description {
      margin-bottom: 24px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-media-wrapper {
      position: relative !important;
      width: 100% !important;
      max-width: 1200px !important;
      margin: 0 auto !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-media-container {
      position: relative !important;
      width: 100% !important;
      height: 640px !important;
      overflow: hidden !important;
      border-radius: 12px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-media {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      transition: opacity 0.45s ease !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-media-slide {
      position: relative !important;
      width: 100% !important;
      height: 100% !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-media-slide.is-video-ready .jingva-m6-air-conditioned-seat-media {
      opacity: 0 !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-video {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      z-index: 1 !important;
      pointer-events: none !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-video video,
    {{ default_sid }} .jingva-m6-air-conditioned-seat-video-el {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center center !important;
      display: block !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-video--pc {
      display: block !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-video--mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn {
      position: absolute !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      width: 48px !important;
      height: 48px !important;
      border-radius: 12px !important;
      background: #FAFAFA !important;
      border: none !important;
      cursor: pointer !important;
      /* 全尺寸隐藏：Figma 设计未含左右切换按钮，DOM 与 Swiper navigation 配置保留以便后续如需重新开启。
         PC 媒体查询未声明 display，不会覆盖此处；MOB 媒体查询亦已显式 display:none。 */
      display: none !important;
      justify-content: center !important;
      align-items: center !important;
      z-index: 10 !important;
      transition: background 0.2s ease !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn:hover {
      background: #DBDBDB !important;
    }

    {{ default_sid }} .nav-icon--pc {
      display: block !important;
    }

    {{ default_sid }} .nav-icon--mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn--prev {
      left: 24px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn--next {
      right: 24px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-features-container {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      align-self: stretch !important;
      gap: 24px !important;
      box-sizing: border-box !important;
      width: 100% !important;
      max-width: 1200px !important;
      margin: 0 auto !important;
      padding: 0 48px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tabs-scroll {
      display: flex !important;
      justify-content: center !important;
      width: 100% !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tabs {
      display: flex !important;
      flex-direction: row !important;
      justify-content: center !important;
      gap: 12px !important;
      box-sizing: border-box !important;
      background: {{ tabs_bg }} !important;
      border-radius: 200px !important;
      padding: 4px !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tab {
      display: flex !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 10px !important;
      padding: 12px 24px !important;
      box-sizing: border-box !important;
      height: 40px !important;
      border-radius: 200px !important;
      border: none !important;
      background-color: transparent !important;
      cursor: pointer !important;
      white-space: nowrap !important;
      transition: background-color 0.2s ease, color 0.2s ease !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tab--active {
      background-color: #E8000B !important;
      backdrop-filter: blur(50px) !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tab-text {
      font-family: 'Gabarito', sans-serif !important;
      font-size: 16px !important;
      line-height: 1.2em !important;
      text-align: center !important;
      margin: 0 !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tab--active .jingva-m6-air-conditioned-seat-tab-text {
      font-weight: 500 !important;
      color: #FFFFFF !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-tab--inactive .jingva-m6-air-conditioned-seat-tab-text {
      font-weight: 500 !important;
      color: #1A1A1A !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 18px !important;
      line-height: 1.2000000211927626em !important;
      color: {{ bottom_text_color }} !important;
      text-align: center !important;
      margin: 0 !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text-item {
      display: none !important;
      padding: 4px 0 !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text-item--empty {
      display: none !important;
      padding: 0 !important;
      margin: 0 !important;
      min-height: 0 !important;
    }

    {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text-item--active:not(.jingva-m6-air-conditioned-seat-bottom-text-item--empty) {
      display: block !important;
    }

    /* === PAD: 1280~1439 === */
    @media screen and (min-width: 1280px) and (max-width: 1439px) {
      {{ default_sid }} .jingva-m6-air-conditioned-seat-wrapper {
        gap: 40px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-content {
        max-width: 1280px !important;
        padding: 0 40px !important;
        gap: 10px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-title {
        font-size: 48px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-description,
      {{ default_sid }} .jingva-m6-air-conditioned-seat-description p {
        font-size: 20px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-media-container {
        height: 500px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-features-container {
        padding: 0 40px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text {
        font-size: 16px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn {
        width: 36px !important;
        height: 36px !important;
        background: {{ nav_btn_pad_bg }} !important;
        border-radius: 8px !important;
      }
      
      {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn:hover {
        background: {{ nav_btn_pad_bg }} !important;
      }

      {{ default_sid }} .nav-icon--pc {
        display: none !important;
      }

      {{ default_sid }} .nav-icon--mob {
        display: block !important;
      }
    }

    /* === MOB: 375~1279 === */
    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        background-color: {{ bg_color_mob | default: theme_bg }} !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-wrapper {
        padding-top: 96px !important;
        gap: 20px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-content {
        padding: 0 16px !important;
        gap: 12px !important;
        max-width: 100% !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-title {
        font-size: 32px !important;
        line-height: normal !important;
        text-align: left !important;
        max-width: 100% !important;
        transform: translateY(-50px);
        transition: transform 0.5s ease-out;
        will-change: transform;
        display: block !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-title::before {
        content: '' !important;
        display: block !important;
        height: 0 !important;
        margin-top: -0.22em !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-title::after {
        content: '' !important;
        display: block !important;
        height: 0 !important;
        margin-bottom: -0.18em !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-description,
      {{ default_sid }} .jingva-m6-air-conditioned-seat-description p {
        font-size: 16px !important;
        line-height: 1.2em !important;
        color: {{ desc_color_mob }} !important;
        text-align: left !important;
        max-width: 100% !important;
        margin-bottom: 0 !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-description {
        margin-bottom: 4px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-media-wrapper {
        padding: 0 16px !important;
        max-width: 100% !important;
        box-sizing: border-box !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-media-container {
        width: 100% !important;
        height: 400px !important;
        border-radius: 8px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-features-container {
        gap: 12px !important;
        padding: 0 0 0 16px !important;
        max-width: 100% !important;
        align-items: stretch !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text {
        padding-right: 16px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-tabs-scroll {
        justify-content: flex-start !important;
        width: 100% !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
        scrollbar-width: none !important;
        -ms-overflow-style: none !important;
        scroll-behavior: smooth !important;
        padding-right: 16px !important;
        box-sizing: border-box !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-tabs-scroll::-webkit-scrollbar {
        display: none !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-tabs {
        gap: 8px !important;
        padding: 2px !important;
        width: max-content !important;
        max-width: none !important;
        flex-wrap: nowrap !important;
        justify-content: flex-start !important;
        flex-shrink: 0 !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-tab {
        height: 36px !important;
        padding: 0 12px !important;
        gap: 10px !important;
        border-radius: 200px !important;
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        flex-wrap: nowrap !important;
        flex-shrink: 0 !important;
        white-space: nowrap !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-tab-text {
        font-size: 14px !important;
        line-height: 1.2em !important;
        font-weight: 500 !important;
        text-align: center !important;
        white-space: nowrap !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-bottom-text {
        font-size: 16px !important;
        font-weight: 400 !important;
        max-width: 100% !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn {
        display: none !important;
      }

      {{ default_sid }} .nav-icon--pc {
        display: none !important;
      }

      {{ default_sid }} .nav-icon--mob {
        display: block !important;
      }

      {{ default_sid }} .nav-icon--mob path {
        fill: {{ mob_nav_icon_fill }} !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn--prev {
        left: 13px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-nav-btn--next {
        right: 13px !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-video--pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-m6-air-conditioned-seat-video--mob {
        display: block !important;
      }
