  <script src="{{ 'swiper-bundle.min.js' | asset_url }}"></script>
  <script>
    (function() {
      var sectionId = '{{ sid }}';
      var container = document.querySelector('.jingva-m6-air-conditioned-seat-' + sectionId);
      if (!container) return;

      var tabs = container.querySelectorAll('.jingva-m6-air-conditioned-seat-tab');
      var textItems = container.querySelectorAll('.jingva-m6-air-conditioned-seat-bottom-text-item');
      var tabsScroll = container.querySelector('.jingva-m6-air-conditioned-seat-tabs-scroll');

      function scrollActiveTabIntoView(index) {
        if (!tabsScroll) return;
        var tab = tabs[index];
        if (!tab) return;
        var scrollRect = tabsScroll.getBoundingClientRect();
        var tabRect = tab.getBoundingClientRect();
        var current = tabsScroll.scrollLeft;
        var delta = 0;
        if (tabRect.right > scrollRect.right) {
          delta = tabRect.right - scrollRect.right + 16;
        } else if (tabRect.left < scrollRect.left) {
          delta = tabRect.left - scrollRect.left - 16;
        }
        if (delta !== 0) {
          tabsScroll.scrollTo({ left: current + delta, behavior: 'smooth' });
        }
      }

      var swiper = new Swiper('#jingva-m6-air-seat-swiper-' + sectionId, {
        loop: true,
        slidesPerView: 1,
        navigation: {
          nextEl: '.swiper-button-next-' + sectionId,
          prevEl: '.swiper-button-prev-' + sectionId
        },
        on: {
          init: function() {
            updateActiveState(this.realIndex);
          },
          slideChange: function() {
            updateActiveState(this.realIndex);
          }
        }
      });

      function updateActiveState(index) {
        tabs.forEach(function(tab, i) {
          if (i === index) {
            tab.classList.remove('jingva-m6-air-conditioned-seat-tab--inactive');
            tab.classList.add('jingva-m6-air-conditioned-seat-tab--active');
          } else {
            tab.classList.remove('jingva-m6-air-conditioned-seat-tab--active');
            tab.classList.add('jingva-m6-air-conditioned-seat-tab--inactive');
          }
        });

        textItems.forEach(function(text, i) {
          if (i === index) {
            text.classList.add('jingva-m6-air-conditioned-seat-bottom-text-item--active');
          } else {
            text.classList.remove('jingva-m6-air-conditioned-seat-bottom-text-item--active');
          }
        });

        scrollActiveTabIntoView(index);
      }

      tabs.forEach(function(tab, index) {
        tab.addEventListener('click', function() {
          swiper.slideToLoop(index);
        });
      });

      // 视频加载完成后淡出封面图
      container.querySelectorAll('.jingva-m6-air-conditioned-seat-media-slide').forEach(function (slide) {
        slide.querySelectorAll('video').forEach(function (video) {
          function reveal() {
            slide.classList.add('is-video-ready');
          }
          if (video.readyState >= 2) {
            reveal();
          } else {
            video.addEventListener('loadeddata', reveal, { once: true });
            video.addEventListener('canplay', reveal, { once: true });
            video.addEventListener('playing', reveal, { once: true });
            video.addEventListener('error', function () {
              slide.classList.remove('is-video-ready');
            });
          }
          var p = video.play && video.play();
          if (p && typeof p.catch === 'function') p.catch(function () {});
        });
      });
    })();
  </script>
</section>

<script>
(function() {
  var section = document.querySelector('.jingva-m6-air-conditioned-seat-{{ sid }}');
  if (!section) return;

  var title = section.querySelector('.jingva-m6-air-conditioned-seat-title');
  if (!title) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        title.classList.add('aos-animate');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  observer.observe(title);
})();
</script>

