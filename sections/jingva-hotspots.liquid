      }
      
      {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-description * {
        font-size: 18px !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.blue {
        width: 139px !important;
        padding: 12px !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-title {
        font-size: 14px !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-description {
        font-size: 12px !important;
      }

        {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-content {
     
      gap: 4px;
     
    }
      /*
       * 注意：以下 dark 弹窗的 left/top 硬编码百分比已移除。
       * 原因：CSS 用 !important 钉死 left/top 后，会覆盖 JS 在 revealPopup() 里
       * 通过行内样式按"被点击圆点的真实坐标 + data-mob-popup-position"算出的位置，
       * 导致点哪个圆点弹窗都飘到固定的几个百分比位置上，看起来像位置错位/内容错位。
       * 现交由 JS 统一定位（与 blue 弹窗一致），如需微调请改 mob_popup_position 设置。
       */
       .jingva-hotspots-image-container > div:nth-child(2) .jingva-hotspots-popup.blue{
            left: 1%!important;
    /* top: 15%!important; */
      width: 139px !important
      }
       .jingva-hotspots-image-container > div:nth-child(3) .jingva-hotspots-popup.blue{
            width: 139px !important;
            /* top: 41% !important; */
            /* left: 28% !important; ← 移除：会让弹窗脱离圆点。改由 JS 按 data-mob-popup-position 计算位置 */
      }
      .jingva-hotspots-image-container > div:nth-child(4) .jingva-hotspots-popup.blue{
            /* left: 16% !important; ← 移除：让 JS 按 bottom-right 计算位置，圆点落在弹窗左上角 */
    /* top: 39%!important; */
            width: 139px !important
      }
       .jingva-hotspots-image-container > div:nth-child(5) .jingva-hotspots-popup.blue{
                   width: 208px !important;
                       /* left: 24% !important; ← 移除：让 JS 按 top-right 计算位置，圆点落在弹窗左下角 */
      }
      .jingva-hotspots-image-container > div:nth-child(6) .jingva-hotspots-popup.blue{
                width: 102px !important;
                    left: 57%!important;
    /* top: 50%!important; */
      }
    }
  {% endstyle %}

  {% if se_stts.show_title or se_stts.pc_background_image != blank or se_stts.mob_background_image != blank %}
    <div class="jingva-hotspots-wrapper">
      {% if se_stts.show_title %}
        <div class="jingva-hotspots-content">
          {% if se_stts.title != blank %}
            <h2 class="jingva-hotspots-title jingva-hotspots-title-pc">{{ se_stts.title | escape }}</h2>
          {% endif %}
          {% if se_stts.mobile_title != blank %}
            <h2 class="jingva-hotspots-title jingva-hotspots-title-mobile">{{ se_stts.mobile_title | escape }}</h2>
          {% elsif se_stts.title != blank %}
            <h2 class="jingva-hotspots-title jingva-hotspots-title-mobile">{{ se_stts.title | escape }}</h2>
          {% endif %}
          {% if se_stts.subtitle != blank %}
            <p class="jingva-hotspots-subtitle">{{ se_stts.subtitle | escape }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% assign bg_image = se_stts.pc_background_image | default: se_stts.mob_background_image %}
      {% if bg_image != blank %}
        <div class="jingva-hotspots-image-container{% if has_hotspots %} jingva-hotspots-image-container--await-bg{% endif %}">
          <picture class="jingva-hotspots-image">
            {% if se_stts.pc_background_image != blank %}
              <source media="(min-width: 1280px)" srcset="{{ se_stts.pc_background_image | image_url: width: 2400 }}">
            {% endif %}
            {% if se_stts.mob_background_image != blank %}
              <source media="(max-width: 1279px)" srcset="{{ se_stts.mob_background_image | image_url: width: 800 }}">
            {% endif %}
            <img
              src="{{ bg_image | image_url: width: 2400 }}"
              alt="{{ se_stts.title | default: 'Background image' | escape }}"
              loading="lazy"
            />
          </picture>

          {% for block in hotspot_blocks %}
            {% if block.type == 'hotspot' %}
              {% assign block_index = forloop.index0 %}
              {% assign pc_x = block.settings.pc_x | default: '50%' %}
              {% assign pc_y = block.settings.pc_y | default: '50%' %}
              {% assign mob_x = block.settings.mob_x | default: '50%' %}
              {% assign mob_y = block.settings.mob_y | default: '50%' %}
              {% assign pc_popup_position = block.settings.pc_popup_position | default: 'bottom-right' %}
              {% assign mob_popup_position = block.settings.mob_popup_position | default: 'bottom-right' %}
              {% assign popup_style = se_stts.popup_style | default: 'dark' %}

              <div class="jingva-hotspots-hotspot" style="--pc-x: {{ pc_x }}; --pc-y: {{ pc_y }}; --mob-x: {{ mob_x }}; --mob-y: {{ mob_y }};">
                <button
                  class="jingva-hotspots-dot"
                  type="button"
                  aria-expanded="false"
                  aria-controls="jingva-hotspots-popup-{{ sid }}-{{ block_index }}"
                  data-hotspot-index="{{ block_index }}"
                >
                  {%- comment -%}
                    Figma MOB node 2804:3427 (Union): 11.25×11.281, arm=2.2px (≈19.5% 占比，比 PC 路径粗)。
                    PC node 2534:473 用 15×15 viewBox（arm=2.2/15=14.67%）；MOB 必须用专属 11.25 viewBox 路径，
                    否则 PC 路径缩到 11.25 后 arm 变成 1.65px，视觉显细 25%。
                  {%- endcomment -%}
                  <svg class="jingva-hotspots-dot-icon-plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 11.25 11.281" fill="none" aria-hidden="true">
                    <path d="M6.72461 4.54004L11.25 4.54004L11.25 6.73926L6.72461 6.73926L6.72461 11.2812L4.52539 11.2812L4.52539 6.73926L0 6.73926L0 4.54004L4.52539 4.54004L4.52539 0L6.72461 0L6.72461 4.54004Z" fill="#FFFFFF"/>
                  </svg>
                  <svg class="jingva-hotspots-dot-icon-cross" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                    <path d="M5.73965 4.57127L9.13363 7.96524L7.96662 9.13224L4.57265 5.73827L1.16694 9.14398L-6.60414e-05 7.97698L3.40565 4.57127L0.011673 1.17729L1.17868 0.0102894L4.57265 3.40426L7.97698 -6.85839e-05L9.14398 1.16693L5.73965 4.57127Z" fill="#FFF"/>
                  </svg>
                </button>

                <div
                  id="jingva-hotspots-popup-{{ sid }}-{{ block_index }}"
                  class="jingva-hotspots-popup {{ popup_style }}{% if popup_style == 'blue' %} jingva-hotspots-popup--blue-above-icon{% endif %}"
                  data-pc-popup-position="{{ pc_popup_position }}"
                  data-mob-popup-position="{{ mob_popup_position }}"
                >
                  <div class="jingva-hotspots-popup-content">
                    {% if popup_style == 'dark' and block.settings.popup_image != blank %}
                      <img
                        class="jingva-hotspots-popup-icon"
                        src="{{ block.settings.popup_image | image_url: width: 256 }}"
                        alt="{{ block.settings.popup_title | default: 'Icon' | escape }}"
                        loading="lazy"
                      />
                    {% endif %}
                    {% if block.settings.popup_title != blank %}
                      <h3 class="jingva-hotspots-popup-title">{{ block.settings.popup_title | escape }}</h3>
                    {% endif %}
                    {% if block.settings.popup_description != blank %}
                      <p class="jingva-hotspots-popup-description">{{ block.settings.popup_description | escape }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endif %}

  <script>
    (function() {
      var sectionId = '{{ sid }}';
      var section = document.querySelector('.jingva-hotspots-' + sectionId);
      if (!section) return;

      var imgContainer = section.querySelector('.jingva-hotspots-image-container');
      var bgImg = section.querySelector('.jingva-hotspots-image img');
      if (imgContainer && bgImg && imgContainer.classList.contains('jingva-hotspots-image-container--await-bg')) {
        function revealHotspotsAfterBg() {
          imgContainer.classList.remove('jingva-hotspots-image-container--await-bg');
        }
        if (bgImg.complete && bgImg.naturalWidth > 0) {
          revealHotspotsAfterBg();
        } else {
          bgImg.addEventListener('load', revealHotspotsAfterBg, { once: true });
          bgImg.addEventListener('error', revealHotspotsAfterBg, { once: true });
        }
      }

      var dots = section.querySelectorAll('.jingva-hotspots-dot');
      var popups = section.querySelectorAll('.jingva-hotspots-popup');
      var currentIndex = -1;

      function showPopup(index) {
        if (index < 0 || index >= popups.length) return;

        var popup = popups[index];
        var pcPosition = popup.dataset.pcPopupPosition;
        var mobPosition = popup.dataset.mobPopupPosition;
        var isMobile = window.innerWidth < 1280;
        var position = isMobile ? mobPosition : pcPosition;

        // 切换时：直接关闭旧弹窗并立即显示新弹窗，无中间的平移过渡
        if (currentIndex >= 0 && currentIndex !== index) {
          var curPopup = popups[currentIndex];
          var curHotspot = dots[currentIndex].closest('.jingva-hotspots-hotspot');
          curPopup.classList.remove('active', 'jingva-hotspots-popup--anim-in', 'jingva-hotspots-popup--anim-out', 'jingva-hotspots-popup--migrate');
          curPopup.style.removeProperty('transition');
          curPopup.style.removeProperty('opacity');
          curHotspot.classList.remove('active');
          dots[currentIndex].setAttribute('aria-expanded', 'false');
        }

        revealPopup(index, position);
      }

      function finalizeHideAll() {
        popups.forEach(function(p) {
          p.classList.remove('active', 'jingva-hotspots-popup--anim-in', 'jingva-hotspots-popup--anim-out', 'jingva-hotspots-popup--migrate');
          p.style.removeProperty('opacity');
          p.style.removeProperty('transition');
        });
        document.querySelectorAll('.jingva-hotspots-hotspot').forEach(function(h) {
          h.classList.remove('active');
        });
        dots.forEach(function(d) {
          d.setAttribute('aria-expanded', 'false');
        });
        currentIndex = -1;
      }

      function hideAllPopups() {
        if (currentIndex >= 0 && currentIndex < popups.length) {
          var closing = popups[currentIndex];
          closing.classList.add('jingva-hotspots-popup--anim-out');
          setTimeout(function() {
            finalizeHideAll();
          }, POPUP_ANIM_MS);
          return;
        }
        finalizeHideAll();
      }

      function effectiveBluePopupPosition(position) {
        var p = position && String(position).trim();
        if (!p) p = 'bottom-right';
        switch (p) {
          case 'bottom-right':
            return 'top-right';
          case 'bottom-left':
            return 'top-left';
          case 'bottom':
            return 'top';
          case 'left':
            return 'top-left';
          case 'right':
            return 'top-right';
          case 'top':
          case 'top-left':
          case 'top-right':
            return p;
          default:
            return 'top';
        }
      }

      function computePopupPosition(dot, popup, position) {
        if (popup.classList.contains('blue')) {
          position = effectiveBluePopupPosition(position);
          /* 第 4 个热点（block index 3）：固定为相对圆点右上方向（弹窗在 icon 上方偏右，圆点贴弹窗左下角） */
          var hi = parseInt(dot.getAttribute('data-hotspot-index'), 10);
          if (hi === 3) {
            position = 'top-right';
          }
        }

        var containerRect = section.querySelector('.jingva-hotspots-image-container').getBoundingClientRect();
        var isMobile = window.innerWidth < 1280;
        var isBlue = popup.classList.contains('blue');

        // 先把弹窗显示出来（不可见）以便测量真实尺寸，避免 CSS 宽度被 JS 硬编码值"覆盖"导致定位漂移
        popup.style.opacity = '0';
        popup.style.visibility = 'visible';
        var popupRect = popup.getBoundingClientRect();
        // 读取 CSS 实际渲染宽度，CSS 调整后无需同步改 JS
        var popupWidth = popupRect.width || (isMobile ? (isBlue ? 220 : 280) : (isBlue ? 254 : 316));
        var popupHeight = popupRect.height || (isBlue ? 180 : 246);

        var dotRect = dot.getBoundingClientRect();
        var dotCenterX = dotRect.left + dotRect.width / 2 - containerRect.left;
        var dotCenterY = dotRect.top + dotRect.height / 2 - containerRect.top;
        var left = 0;
        var top = 0;
        var gap = 20;

        switch(position) {
          case 'top-left':
            left = dotCenterX - popupWidth + gap;
            top = dotCenterY - popupHeight + gap;
            break;
          case 'top-right':
            left = dotCenterX - gap;
            top = dotCenterY - popupHeight + gap;
            break;
          case 'bottom-left':
            left = dotCenterX - popupWidth + gap;
            top = dotCenterY - gap;
            break;
          case 'bottom-right':
            left = dotCenterX - gap;
            top = dotCenterY - gap;
            break;
          case 'top':
            left = dotCenterX - popupWidth / 2;
            top = dotCenterY - popupHeight + gap;
            break;
          case 'bottom':
            left = dotCenterX - popupWidth / 2;
            top = dotCenterY - gap;
            break;
          case 'left':
            left = dotCenterX - popupWidth + gap;
            top = dotCenterY - popupHeight / 2;
            break;
          case 'right':
            left = dotCenterX - gap;
            top = dotCenterY - popupHeight / 2;
            break;
          default:
            left = dotCenterX - gap;
            top = dotCenterY - gap;
        }

        if (left < 0) left = gap;
        if (top < 0) top = gap;
        if (left + popupWidth > containerRect.width) left = containerRect.width - popupWidth - gap;
        if (top + popupHeight > containerRect.height) top = containerRect.height - popupHeight - gap;

        return { left: left, top: top };
      }

      function positionPopup(dot, popup, position) {
        var p = computePopupPosition(dot, popup, position);
        popup.style.left = p.left + 'px';
        popup.style.top = p.top + 'px';
        popup.style.removeProperty('opacity');
      }

      var POPUP_ANIM_MS = 320;
      var MIGRATE_MS = 460;

      function revealPopup(index, position, migrateFrom) {
        var popup = popups[index];
        var dot = dots[index];
        var hotspot = dot.closest('.jingva-hotspots-hotspot');
        var placement = computePopupPosition(dot, popup, position);

        popup.classList.remove('jingva-hotspots-popup--anim-in', 'jingva-hotspots-popup--anim-out', 'jingva-hotspots-popup--migrate');

        if (migrateFrom && typeof migrateFrom.prevLeft === 'number' && typeof migrateFrom.prevTop === 'number') {
          hotspot.classList.add('active');
          popup.style.transition = 'none';
          popup.style.left = migrateFrom.prevLeft + 'px';
          popup.style.top = migrateFrom.prevTop + 'px';
          popup.style.visibility = 'visible';
          popup.style.opacity = '0';
          popup.classList.add('active');
          dots.forEach(function(d) {
            d.setAttribute('aria-expanded', 'false');
          });
          dot.setAttribute('aria-expanded', 'true');
          currentIndex = index;

          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              popup.style.removeProperty('transition');
              popup.classList.add('jingva-hotspots-popup--migrate');
              popup.style.left = placement.left + 'px';
              popup.style.top = placement.top + 'px';
              popup.style.removeProperty('opacity');
              setTimeout(function() {
                popup.classList.remove('jingva-hotspots-popup--migrate');
              }, MIGRATE_MS);
            });
          });
          return;
        }

        popup.style.left = placement.left + 'px';
        popup.style.top = placement.top + 'px';
        popup.style.removeProperty('opacity');
        popup.classList.add('active', 'jingva-hotspots-popup--anim-in');
        hotspot.classList.add('active');
        dots.forEach(function(d) {
          d.setAttribute('aria-expanded', 'false');
        });
        dot.setAttribute('aria-expanded', 'true');
        currentIndex = index;
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            popup.classList.remove('jingva-hotspots-popup--anim-in');
          });
        });
      }

      function advancePopupCycle() {
        // 已废弃：改用 togglePopup
      }

      function togglePopup(index) {
        if (index < 0 || index >= popups.length) return;
        
        // 如果点击的是当前已打开的弹窗，则关闭
        if (currentIndex === index) {
          hideAllPopups();
          return;
        }
        
        // 否则显示点击的弹窗
        showPopup(index);
      }

      dots.forEach(function(dot, index) {
        dot.addEventListener('click', function(e) {
          e.stopPropagation();
          togglePopup(index);
        });
      });

      /* 点击弹窗关闭 */
      popups.forEach(function(popup, index) {
        popup.addEventListener('click', function(e) {
          e.stopPropagation();
          hideAllPopups();
        });
      });

      section.addEventListener('click', function(e) {
        var isInsidePopup = false;
        popups.forEach(function(popup) {
          if (popup.contains(e.target)) {
            isInsidePopup = true;
          }
        });
        var isInsideDot = false;
        dots.forEach(function(dot) {
          if (dot.contains(e.target)) {
            isInsideDot = true;
          }
        });

        if (!isInsidePopup && !isInsideDot) {
          hideAllPopups();
        }
      });

      window.addEventListener('resize', function() {
        if (currentIndex >= 0 && currentIndex < popups.length) {
          var popup = popups[currentIndex];
          var dot = dots[currentIndex];
          var pcPosition = popup.dataset.pcPopupPosition;
          var mobPosition = popup.dataset.mobPopupPosition;
          var isMobile = window.innerWidth < 1280;
          var position = isMobile ? mobPosition : pcPosition;
          positionPopup(dot, popup, position);
        }
      });
    })();
  </script>
</section>

<script>
(function() {
  var section = document.querySelector('.jingva-hotspots-{{ sid }}');
  if (!section) return;

  var titles = section.querySelectorAll('.jingva-hotspots-title');
  if (!titles.length) return;

  var trigger = section.querySelector('.jingva-hotspots-content') || titles[0];

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        titles.forEach(function(el) {
          el.classList.add('aos-animate');
        });
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  observer.observe(trigger);
})();
</script>

