{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign hotspot_blocks = section.blocks
  assign bg_color = se_stts.bg_color
  assign title_color = se_stts.title_color
  assign description_color = se_stts.description_color
  assign padding_top = se_stts.padding_top
  assign padding_bottom = se_stts.padding_bottom
  assign padding_top_mob = se_stts.padding_top_mob
  assign padding_bottom_mob = se_stts.padding_bottom_mob
  assign has_hotspots = false
  for block in hotspot_blocks
    if block.type == 'hotspot'
      assign has_hotspots = true
      break
    endif
  endfor
-%}
{% capture default_sid %}.jingva-hotspots-{{ sid }}{% endcapture %}

<section{% if se_stts.anchor_id != blank %} id="{{ se_stts.anchor_id | escape }}"{% endif %} class="jingva-section-container jingva-hotspots-{{ sid }}" data-section-id="{{ sid }}">
  {% style %}
    /*
     * ======width: 11.25px;
height: 11.281px;==================================
     * Figma PC (1920px, node 2534-473) 详细参数:
     * ========================================
     *   section: w:1920, flex column, gap:48px
     *   title: Orbitron 900 64px line-height:1.254 #FFFFFF uppercase center
     *   subtitle: Gabarito 500 24px line-height:1.2 rgba(255,255,255,0.6) center
     *   image: w:1920, h:960
     *   hotspot dot: w:32, h:32, bg:#005EFF, backdropFilter: blur(40px)
     *   popup dark: bg:rgba(0,0,0,0.6), blur:40px, br:12px
     *   popup blue: bg:rgba(0,94,255,0.5), blur:50px, br:12px
     *
     * ========================================
     * Figma MOB (390px, node 4188-2593) 详细参数:
     * ========================================
     *   section: w:390, flex column, gap:24px, p:68px 0
     *   title: Orbitron 900 28px line-height:1.254 #FFFFFF uppercase center
     *   subtitle: Gabarito 500 16px line-height:1.2 rgba(255,255,255,0.6) center
     *   image: w:390, h:540
     *   hotspot dot: w:24, h:24, bg:#005EFF, backdropFilter: blur(40px)
     *
     * ========================================
     * develop.md 规范 (必须遵守):
     * ========================================
     *   基准尺寸: PC=1920, MOB=390
     *   版心: PC/PAD 均为 1200px
     *   Grid.Padding: PC=48px, PAD=40px, MOB=16px
     *   断点: MOB≤1279, PAD 1280~1439, PC≥1440
     *   字体: Orbitron(展示标题), Gabarito(正文/说明)
     *   所有样式使用 !important 确保优先级
     */

    /* === PC: 1440~2560 === */
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color | default: '#121B2C' }} !important;
      padding-top: {{ padding_top | default: 48 }}px !important;
      padding-bottom: {{ padding_bottom | default: 0 }}px !important;
      overflow: visible !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-hotspots-wrapper {
      position: relative !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 48px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-hotspots-content {
      position: relative !important;
      width: 100% !important;
      max-width: 1296px !important;
      margin: 0 auto !important;
      padding: 0 48px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 24px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-hotspots-title {
      font-family: 'Orbitron', sans-serif !important;
      font-weight: 900 !important;
      font-size: 64px !important;
      line-height: 1.254 !important;
      color: {{ title_color | default: '#ffffff' }} !important;
      text-align: center !important;
      text-transform: none !important;
      margin: 0 !important;
      max-width: {{ se_stts.title_max_width | default: '1200px' }} !important;
      /* 首次进入视口下沉载入动效 */
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-hotspots-title-pc {
      display: block !important;
    }

    {{ default_sid }} .jingva-hotspots-title-mobile {
      display: none !important;
    }

    {{ default_sid }} .jingva-hotspots-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-hotspots-subtitle {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 24px !important;
      line-height: 1.2 !important;
      color: {{ description_color | default: 'rgba(255, 255, 255, 0.6)' }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: {{ se_stts.title_max_width | default: '1200px' }} !important;
    }

    {{ default_sid }} .jingva-hotspots-image-container {
      position: relative !important;
      width: 100% !important;
      max-width: none !important;
      height: auto !important;
      overflow: visible !important;
      box-sizing: border-box !important;
      z-index: 1 !important;
    }

    /* 背景图未就绪时不显示标记点，避免白屏阶段圆点漂在空白处 */
    {{ default_sid }} .jingva-hotspots-image-container--await-bg .jingva-hotspots-hotspot {
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }

    {{ default_sid }} .jingva-hotspots-image {
      position: relative !important;
      display: block !important;
      width: 100% !important;
      height: auto !important;
      z-index: 1 !important;
    }

    {{ default_sid }} .jingva-hotspots-image img {
      width: 100% !important;
      height: auto !important;
      display: block !important;
    }

    {{ default_sid }} .jingva-hotspots-hotspot {
      position: absolute !important;
      inset: 0 !important;
      box-sizing: border-box !important;
      pointer-events: none !important;
    }

    /* 未展开的热点整层压低，展开中的热点整层抬高，避免其它标记点的 z-index 压过当前弹窗 */
    {{ default_sid }} .jingva-hotspots-hotspot:not(.active) {
      z-index: 2 !important;
    }

    {{ default_sid }} .jingva-hotspots-hotspot.active {
      z-index: 5000 !important;
      isolation: isolate !important;
    }

    {{ default_sid }} .jingva-hotspots-hotspot .jingva-hotspots-dot {
      pointer-events: auto !important;
    }

    {{ default_sid }} .jingva-hotspots-hotspot.active .jingva-hotspots-popup {
      pointer-events: auto !important;
    }

    {{ default_sid }} .jingva-hotspots-dot {
      position: absolute !important;
      width: 32px !important;
      height: 32px !important;
      border-radius: 999px !important;
      background-color: #005EFF !important;
      backdrop-filter: blur(40px) !important;
      -webkit-backdrop-filter: blur(40px) !important;
      border: none !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      box-sizing: border-box !important;
      z-index: 100 !important;
      padding: 0 !important;
      opacity: 1 !important;
      transition: transform 0.38s cubic-bezier(0.34, 1.15, 0.64, 1), opacity 0.2s ease !important;
      left: var(--pc-x, 50%) !important;
      top: var(--pc-y, 50%) !important;
      transform: translate(-50%, -50%) !important;
    }

    {{ default_sid }} .jingva-hotspots-dot:hover {
      transform: translate(-50%, -50%) scale(1.1) !important;
    }

    /* 展开时：切换为 x 图标 */
    {{ default_sid }} .jingva-hotspots-dot[aria-expanded="true"] {
      z-index: 200 !important;
      opacity: 1 !important;
      pointer-events: auto !important;
    }

    /* + / x 切换：叠在一起做淡入+旋转过渡 */
    {{ default_sid }} .jingva-hotspots-dot-icon-plus,
    {{ default_sid }} .jingva-hotspots-dot-icon-cross {
      position: absolute !important;
      top: 50% !important;
      left: 50% !important;
      width: 15px !important;
      height: 15px !important;
      display: block !important;
      transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.34, 1.15, 0.64, 1) !important;
      pointer-events: none !important;
    }
    {{ default_sid }} .jingva-hotspots-dot-icon-plus {
      opacity: 1 !important;
      transform: translate(-50%, -50%) rotate(0deg) !important;
    }
    {{ default_sid }} .jingva-hotspots-dot-icon-cross {
      opacity: 0 !important;
      transform: translate(-50%, -50%) rotate(-90deg) !important;
    }
    {{ default_sid }} .jingva-hotspots-dot[aria-expanded="true"] .jingva-hotspots-dot-icon-plus {
      opacity: 0 !important;
      transform: translate(-50%, -50%) rotate(90deg) !important;
    }
    {{ default_sid }} .jingva-hotspots-dot[aria-expanded="true"] .jingva-hotspots-dot-icon-cross {
      opacity: 1 !important;
      transform: translate(-50%, -50%) rotate(0deg) !important;
    }

    /* Figma node 2534:351 精确参数: w:316px bg:rgba(0,0,0,0.6) blur:20px br:12px */
    {{ default_sid }} .jingva-hotspots-popup {
      position: absolute !important;
      width: 316px !important;
      border-radius: 12px !important;
      backdrop-filter: blur(20px) !important;
      -webkit-backdrop-filter: blur(20px) !important;
      padding: 12px;
      box-sizing: border-box !important;
      z-index: 1 !important;
      opacity: 0 !important;
      visibility: hidden !important;
      transform: translateY(10px) !important;
      transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease !important;
      pointer-events: none !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: flex-start !important;
    }

    {{ default_sid }} .jingva-hotspots-popup.active {
      opacity: 1 !important;
      visibility: visible !important;
      transform: translateY(0) scale(1) !important;
      pointer-events: auto !important;
      z-index: 10 !important;
    }

    /* 从一个标记点切换到另一个：弹窗 left/top 位移动画 */
    {{ default_sid }} .jingva-hotspots-popup.active.jingva-hotspots-popup--migrate {
      transition: left 0.44s cubic-bezier(0.34, 1, 0.64, 1), top 0.44s cubic-bezier(0.34, 1, 0.64, 1), opacity 0.32s ease, transform 0.4s cubic-bezier(0.34, 1.1, 0.64, 1), visibility 0s !important;
    }

    /* 标记点切换：旧弹窗收起 */
    {{ default_sid }} .jingva-hotspots-popup.active.jingva-hotspots-popup--anim-out {
      opacity: 0 !important;
      transform: translateY(14px) scale(0.96) !important;
      pointer-events: none !important;
      transition: opacity 0.32s cubic-bezier(0.4, 0, 0.2, 1), transform 0.32s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    /* 新弹窗进入（首帧由 JS 挂上，下一帧移除以触发过渡） */
    {{ default_sid }} .jingva-hotspots-popup.active.jingva-hotspots-popup--anim-in {
      opacity: 0 !important;
      transform: translateY(20px) scale(0.92) !important;
      transition: opacity 0.38s cubic-bezier(0.34, 1.15, 0.64, 1), transform 0.38s cubic-bezier(0.34, 1.15, 0.64, 1) !important;
    }

    /* === 深色弹窗 (node 2534:351): 316px === */
    {{ default_sid }} .jingva-hotspots-popup.dark {
      background-color: rgba(0, 0, 0, 0.6) !important;
      width: 316px !important;
      padding: 24px !important;
      gap: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
    }

    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-content > *:first-child {
      margin-top: 0 !important;
    }

    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-content > *:not(:first-child) {
      margin-top: 4px !important;
    }

    /* === 蓝色弹窗 (node 4012:2592): 254px === */
    {{ default_sid }} .jingva-hotspots-popup.blue {
      background-color: rgba(0, 94, 255, 0.5) !important;
      backdrop-filter: blur(25px) !important;
      -webkit-backdrop-filter: blur(25px) !important;
      width: 254px !important;
      padding: 24px !important;
      gap: 12px !important;
      align-items: flex-start !important;
    }

    /*
     * 防止标记点遮挡弹窗文字：弹窗相对标记点的方位决定了"标记点在弹窗的哪一侧"，
     * 反向在对应侧增加内边距。PC 标记点 32px + 20px 回吸 = 插入 36px，留 44px 安全距；
     * MOB 标记点 24px + 20px 回吸 = 插入 32px，留 40px 安全距。
     */
    @media screen and (min-width: 1280px) {
      {{ default_sid }} .jingva-hotspots-popup.blue,
      {{ default_sid }} .jingva-hotspots-image-container .jingva-hotspots-popup.blue {
        width: 254px !important;
        padding: 24px !important;
      }
      /*
       * 圆点（直径 32，半径 16）侵入 popup = gap(20) + 16 = 36px。
       * 这里给"圆点所在那一侧"加 40px 单边 padding，让文字让出 4px 视觉空白。
       * 其余边保持 24px 不变。data-pc-popup-position 表示 popup 相对圆点的方位，
       * 例如 popup 在圆点的 top-right → 圆点位于 popup 的 bottom-left 角。
       */
      /* 仅允许调整 padding-bottom：padding-top/left/right 始终保持 24px。
         只在圆点位于 popup 底部（top* / top 三种方位）时加大下 padding。 */
      {{ default_sid }} .jingva-hotspots-popup.blue[data-pc-popup-position="top-right"] { padding-bottom: 40px !important; }
      {{ default_sid }} .jingva-hotspots-popup.blue[data-pc-popup-position="top-left"]  { padding-bottom: 40px !important; }
      {{ default_sid }} .jingva-hotspots-popup.blue[data-pc-popup-position="top"]       { padding-bottom: 40px !important; }
      /* blue 主题：JS 将弹窗统一置于圆点上方，圆点恒落在弹窗下侧，与 data 原始值无关 */
      {{ default_sid }} .jingva-hotspots-popup.blue.jingva-hotspots-popup--blue-above-icon { padding-bottom: 40px !important; }
    }

    @media screen and (max-width: 1279px) {
      {{ default_sid }} .jingva-hotspots-popup.dark,
      {{ default_sid }} .jingva-hotspots-popup.blue {
        padding: 12px !important;
      }

      /*
       * MOB 圆点（直径 24，半径 12）侵入 = gap(20) + 12 = 32px。
       * 单边 padding 用 32px 让出圆点位置（基础 padding 仍是 12px）。
       */
      /* 仅允许调整 padding-bottom：padding-top/left/right 始终保持 12px。 */
      {{ default_sid }} .jingva-hotspots-popup.blue[data-mob-popup-position="top-right"] { padding-bottom: 32px !important; }
      {{ default_sid }} .jingva-hotspots-popup.blue[data-mob-popup-position="top-left"]  { padding-bottom: 32px !important; }
      {{ default_sid }} .jingva-hotspots-popup.blue[data-mob-popup-position="top"]       { padding-bottom: 32px !important; }
      {{ default_sid }} .jingva-hotspots-popup.blue.jingva-hotspots-popup--blue-above-icon { padding-bottom: 32px !important; }
    }

    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-content {
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 0 !important;
      box-sizing: border-box !important;
      padding: 0 !important;
    }

    {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-content {
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 12px;
      box-sizing: border-box !important;
      padding: 0 !important;
    }

    /* === 深色弹窗图片 (node 2534:339): 128×128px === */
    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-icon {
      width: 128px !important;
      height: 128px !important;
      object-fit: cover !important;
      display: block !important;
      flex-shrink: 0 !important;
      margin-bottom: 4px !important;
    }

    /* === 蓝色弹窗无图片 === */
    {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-icon {
      display: none !important;
    }

    /* === 深色弹窗文字 (node 2534:340): 24px, 紧贴图片 === */
    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-description {
      font-family: 'Gabarito', -apple-system, BlinkMacSystemFont, sans-serif !important;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 1.2 !important;
      color: #ffffff !important;
      text-align: center !important;
      padding: 12px 0 0 0 !important;
      margin-top: 12px !important;
      flex-shrink: 0 !important;
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      text-transform: none !important;
      letter-spacing: normal !important;
      word-spacing: normal !important;
      white-space: normal !important;
      text-shadow: none !important;
    }
    
    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-description * {
      color: #ffffff !important;
      font-size: 24px !important;
      font-family: 'Gabarito', -apple-system, BlinkMacSystemFont, sans-serif !important;
      font-weight: 400 !important;
    }

    /* === 蓝色弹窗标题 (node 4012:2594): 16px === */
    {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-title {
      display: block !important;
      font-family: 'Gabarito', -apple-system, BlinkMacSystemFont, sans-serif !important;
      font-weight: 400 !important;
      font-size: 16px !important;
      line-height: normal !important;
      color: #ffffff !important;
      text-align: left !important;
      margin: 0 !important;
      width: 100% !important;
      padding: 0 !important;
    }

    /* === 蓝色弹窗描述 (node 4012:2595): 12px === */
    {{ default_sid }} .jingva-hotspots-popup.blue .jingva-hotspots-popup-description {
      font-family: 'Gabarito', -apple-system, BlinkMacSystemFont, sans-serif !important;
      font-weight: 400 !important;
      font-size: 12px !important;
      line-height: normal !important;
      color: #ffffff !important;
      text-align: left !important;
      margin: 0 !important;
      width: 100% !important;
      padding: 0 !important;
      flex-shrink: 0 !important;
    }

    /* === 深色弹窗隐藏标题 === */
    {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-title {
      display: none !important;
    }

    /* === PAD: 1280~1439 === */
    @media screen and (min-width: 1280px) and (max-width: 1439px) {
      {{ default_sid }} {
        /* 不要用 padding 简写覆盖 padding-top/bottom，否则会清空后台设置 */
        padding-top: {{ padding_top | default: 48 }}px !important;
        padding-bottom: {{ padding_bottom | default: 0 }}px !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
      }

      {{ default_sid }} .jingva-hotspots-wrapper {
        gap: 40px !important;
      }

      {{ default_sid }} .jingva-hotspots-content {
        max-width: {{ se_stts.title_max_width | default: '1200px' }} !important;
        gap: 20px !important;
        padding: 0 40px !important;
      }

      {{ default_sid }} .jingva-hotspots-title {
        font-size: 56px !important;
        transform: translateY(-50px);
        transition: transform 0.5s ease-out;
        will-change: transform;
      }

      {{ default_sid }} .jingva-hotspots-subtitle {
        font-size: 20px !important;
      }
    }

    /* === MOB: 375~1279 (基准 390, 内容随视口自适应; Grid.Padding=16) === */
    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        padding-top: {{ padding_top_mob | default: 96 }}px !important;
        padding-bottom: {{ padding_bottom_mob | default: 0 }}px !important;
      }

      {{ default_sid }} .jingva-hotspots-wrapper {
        gap: 24px !important;
      }

      {{ default_sid }} .jingva-hotspots-dot-icon-plus,
      {{ default_sid }} .jingva-hotspots-dot-icon-cross {
        width: 11.25px !important;
        height: 11.25px !important;
      }

      {{ default_sid }} .jingva-hotspots-content {
        width: 100% !important;
        max-width: 100% !important;
        padding: 0 16px !important;
        gap: 12px !important;
        align-items: center !important;
      }

      {{ default_sid }} .jingva-hotspots-title {
        font-size: 32px !important;
        line-height: 1.254em !important;
        text-align: center !important;
        max-width: 100% !important;
      }

      {{ default_sid }} .jingva-hotspots-title-pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-hotspots-title-mobile {
        display: block !important;
      }

      {{ default_sid }} .jingva-hotspots-subtitle {
        font-size: 16px !important;
        line-height: 1.2em !important;
        text-align: center !important;
        max-width: 100% !important;
      }

      {{ default_sid }} .jingva-hotspots-image-container {
        /* 高度跟随图片自然比例，max-width 防止平板段过宽 */
        max-width: 768px !important;
        margin-left: auto !important;
        margin-right: auto !important;
      }

      {{ default_sid }} .jingva-hotspots-dot {
        width: 24px !important;
        height: 24px !important;
        left: var(--mob-x, 50%) !important;
        top: var(--mob-y, 50%) !important;
      }

      {{ default_sid }} .jingva-hotspots-dot svg {
        width: 11.25px !important;
        height: 11.25px !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.dark {
        width: 154px !important;
        height: auto !important;
        padding: 12px !important;
        gap: 0 !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-content > *:first-child {
        margin-top: 0 !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-content > *:not(:first-child) {
        margin-top: 4px !important;
      }

      {{ default_sid }} .jingva-hotspots-popup.dark .jingva-hotspots-popup-icon {
        width: 64px !important;
        height: 64px !important;
        margin-bottom: 0 !important;
      }

