{% liquid
  assign page_width = "page-width row t4s-container container section section--page-width"
  assign sid = section.id
  assign se_stts = section.settings
  assign margin_top      = se_stts.margin_top      | split: ";" 
  assign margin_bottom   = se_stts.margin_bottom   | split: ";" 
  assign padding_top     = se_stts.padding_top     | split: ";" 
  assign padding_bottom  = se_stts.padding_bottom  | split: ";" 
  assign color           = se_stts.color
  assign color_mb        = se_stts.color_mb
  assign css             = se_stts.css
  assign use_custom_css  = se_stts.use_custom_css
  assign width_type      = se_stts.width_type
  assign section_type    = se_stts.section_type
  assign slide_height    = se_stts.slide_height
  assign slide_height_mb = se_stts.slide_height_mb
  assign autoplay        = se_stts.autoplay
  assign default_duration= se_stts.default_duration
  assign show_arrows     = se_stts.show_arrows
  assign show_dots       = se_stts.show_dots
  if section.blocks.size <= 1
    assign show_dots = false
  endif
  assign dot_style   = se_stts.dot_style
  assign dot_align   = se_stts.dot_align
  assign aspect_ratio    = "100vh"
  assign aspect_ratio_mb = "100vh"
  if slide_height == "adapt_image"
    assign aspect_ratio    = 1 | divided_by: section.blocks[0].settings.image.aspect_ratio    | times: 100 | append: "%"
    assign aspect_ratio_mb = 1 | divided_by: section.blocks[0].settings.image_mb.aspect_ratio | times: 100 | append: "%"
  elsif slide_height == "full_screen"
    assign aspect_ratio    = 100 | append: "vh"
    assign aspect_ratio_mb = 100 | append: "vh"
  else
    assign aspect_ratio    = slide_height    | append: "px"
    assign aspect_ratio_mb = slide_height_mb | append: "px"
  endif
%}
{% capture default_sid %}.jingva-section-container-{{ sid }}{% endcapture %}
 

<section class="jingva-section-container  jingva-section-container-{{sid}} {{section.settings.section_css}} jingva-carousel-section">
  {% style %}
  {{ default_sid }}{--margin-top:{{margin_top[0]}};--margin-bottom:{{margin_bottom[0]}};--padding-top:{{padding_top[0]}};--padding-bottom:{{padding_bottom[0]}};--background-color:{{color}};--slide-height:{{aspect_ratio}};--default-duration:{{default_duration}}s;}@media screen and (max-width:992px){ {{ default_sid }}{--margin-top:{{margin_top[1]}};--margin-bottom:{{margin_bottom[1]}};--padding-top:{{padding_top[1]}};--padding-bottom:{{padding_bottom[1]}};} }@media screen and (max-width:767px){ {{ default_sid }}{--margin-top:{{margin_top[2]}};--margin-bottom:{{margin_bottom[2]}};--padding-top:{{padding_top[2]}};--padding-bottom:{{padding_bottom[2]}};--background-color:{{color_mb}};--slide-height:{{aspect_ratio_mb}};} }{{ default_sid }}{margin-top:var(--margin-top);margin-bottom:var(--margin-bottom);padding-top:var(--padding-top);padding-bottom:var(--padding-bottom);background-color:var(--background-color);position:relative;overflow:hidden;}{{ default_sid }} .page-width{max-width:1560px;}.jingva-wrapper.page-width .page-width{padding-left:60px;padding-right:60px;}.jingva-wrapper.page-width .jingva-box{border-radius:20px;overflow:hidden;}.jingva-slide-content{text-decoration:unset;}{{ default_sid }} .media-box{position:relative;padding-top:var(--slide-height);}{{ default_sid }} .media-box .media-box-wrapper{position:absolute;inset:0;width:100%;height:100%;}{{ default_sid }} .media-box .media-box-wrapper .image-box,{{ default_sid }} .media-box .media-box-wrapper .image-box img,{{ default_sid }} .media-box .media-box-wrapper video,{{ default_sid }} .media-box .media-box-wrapper iframe{width:100%;height:100%;object-fit:cover;}.jingva-slide-wrapper{position:relative;}.jingva-slide-content{position:absolute;inset:0;width:100%;height:100%;} {{ default_sid }} .jingva-slide-content .page-width,{{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper{width:100%;height:100%;padding:0;padding-bottom:56px;}.jingva-slide-content .plyr__video-wrapper{aspect-ratio:unset;}{{ default_sid }} .jingva-slide-content-wrapper{display:flex;padding:0 0;}.jingva-slide-content-wrapper-inner{flex:1;line-height:1.4;}.jingva-slide-topsubtitle{font-weight:700;margin:0 0 15px 0;}.jingva-slide-title{font-style: italic;font-weight:700;margin:0;}.jingva-slide-subtitle{margin-top:24px;font-weight:400;} #jingvaCarousel{{sid}} .jingva-slide-btn{border: 1px solid #fff;padding:13px 30px;line-height:1;display:inline-table;border-radius:4px;margin-top:64px;text-decoration:unset;font-weight:normal;transition:opacity .3s;}{{ default_sid }} .slick-dotted.slick-slider{margin-bottom:0;}{{ default_sid }} .dots-box{width:100%;position:absolute;left:0;bottom:25px;} {% if dot_align == "left" %}{% assign dotAlign = "flex-start" %}{% elsif dot_align == "center" %}{% assign dotAlign = "center" %}{% elsif dot_align == "right" %}{% assign dotAlign = "flex-end" %}{% endif %}{{ default_sid }} .slick-dots{position:static;display:flex;justify-content:{{dotAlign}};bottom:33px;}{% unless show_dots %}{{ default_sid }} .slick-dots{display:none!important;} {% endunless %}{{ default_sid }} .dots-box.style-1 .slick-dots li{width:33px;height:33px;}{{ default_sid }} .dots-box.style-1 .slick-dots li span{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:15px;font-weight:600;}{{ default_sid }} .dots-box.style-1 .custom-dot{position:relative;width:33px;height:33px;padding:0;color:#fff;}{{ default_sid }} .dots-box .custom-dot::before{transition:all .3s;}{{ default_sid }} .dots-box.style-1 .slick-dots li .custom-dot::before{display:none;}{{ default_sid }} .dots-box.style-2 .slick-dots li{width:18px;height:18px;}{{ default_sid }} .dots-box.style-2 .custom-dot{position:relative;width:18px;height:18px;padding:0;color:#fff;}{{ default_sid }} .dots-box.style-2 .slick-dots li .custom-dot::before{display:block;font-size:11px;width:18px;height:18px;color:#fff;}{{ default_sid }} .dots-box.style-2 .slick-dots li .custom-dot svg,{{ default_sid }} .dots-box.style-2 .slick-dots li .custom-dot span{display:none;}{{ default_sid }} .dots-box.style-3 .slick-dots li{width:54px;height:2px;}{{ default_sid }} .dots-box.style-3 .custom-dot{position:relative;width:50px;height:2px;padding:0;color:#fff;background-color:rgba(255,255,255,.3);border-radius:50px;overflow:hidden;}{{ default_sid }} .dots-box.style-3 .slick-dots li .custom-dot::before{content:""!important;display:block;font-size:11px;width:100%;height:3px;color:#fff;background-color:#fff;border-radius:50px;}{{ default_sid }} .dots-box.style-3 .slick-dots li.slick-active .custom-dot::before{% if autoplay %}{width:0%;animation:width var(--default-duration) ease-out forwards;}{% else %}{width:100%;}{% endif %}{{ default_sid }} .dots-box.style-3 .slick-dots li .custom-dot svg,{{ default_sid }} .dots-box.style-3 .slick-dots li .custom-dot span{display:none;}{{ default_sid }} .dots-box.style-1 .custom-dot circle{fill:none;stroke:currentColor;stroke-linecap:butt;stroke-opacity:.3;stroke-width:2px;transform-origin:50% 50%;}{{ default_sid }} .dots-box.style-1 li.slick-active .custom-dot .fr{stroke-opacity:1;{% if autoplay %}animation:draw var(--default-duration) ease-out forwards;{% else %}stroke-dasharray:100px 100px;{% endif %}}{{ default_sid }} .slick-arrow{width:40px;height:40px;border-radius:50px;display:flex;justify-content:center;align-items:center;transition:transform .3s;position:absolute;top:50%;transform: translateY(-50%);}{{ default_sid }} .slick-arrow:hover{transform:translate(0,-50%) scale(1.1);}{{ default_sid }} .slick-arrow::before{display:none;}{{ default_sid }} .slick-arrow.slick-next{right:30px;}{{ default_sid }} .slick-arrow.slick-prev{left:30px;z-index:2;}{{ default_sid }} .slick-arrow.slick-prev svg{transform:rotate(180deg);}{{ default_sid }} .slick-arrow svg{width:41px;height:41px;}@keyframes draw{from{stroke-dasharray:0px 100px;}to{stroke-dasharray:100px 100px;}}@keyframes width{from{width:0px;}to{width:100%;}}.jingva-small--hidden{}.jingva-large--hidden{display:none;}.jingva-carousel-{{sid}}[data-type="slideshow"] .jingva-slide:not(.jingva-slide-1){display:none;}.jingva-carousel-{{sid}}[data-type="slideshow"] .slick-list .jingva-slide{display:block;}.jingva-carousel-{{sid}}[data-widthType="page"] .jingva-slide{margin-right:30px;border-radius:20px;overflow:hidden;}.jingva-carousel-{{sid}}[data-widthType="page"] .slick-arrow.slick-next{right:clamp(30px,calc(10vw + 30px),240px);}.jingva-carousel-{{sid}}[data-widthType="page"] .slick-arrow.slick-prev{left:clamp(30px,10vw,240px);}@media screen and (min-width:768px) and (max-width:1400px){.jingva-slide-content-wrapper{padding:40px 0;}}@media screen and (max-width:1400px){ {{ default_sid }} .slick-arrow.slick-next{right:10px;}{{ default_sid }} .slick-arrow.slick-prev{left:10px;} }@media screen and (min-width:768px) and (max-width:999px){.jingva-medium--hidden{display:none;}.jingva-medium--hidden{display:block;}}@media screen and (max-width:767px){.jingva-small--hidden{display:none;}.jingva-medium--hidden{display:block;}.jingva-carousel-{{sid}}[data-widthType="page"] .jingva-slide{margin-right:10px;}{{ default_sid }} .dots-box{bottom:10px;}{{ default_sid }} .slick-dots{justify-content:center;}{{ default_sid }} .dots-box.style-2 .slick-dots li .custom-dot::before{font-size:8px;width:11px;height:11px;}{{ default_sid }} .dots-box.style-2 .custom-dot{width:11px;height:11px;}{{ default_sid }} .dots-box.style-2 .slick-dots li{width:11px;height:11px;}{{ default_sid }} .slick-arrow{display:none!important;}{{ default_sid }} .jingva-slide-content-wrapper{padding:20px 0;}{{ default_sid }} .jingva-slide-btn{font-size:12px;padding:10px 20px;}.jingva-slide-topsubtitle,.jingva-slide-title,.jingva-slide-subtitle{margin-top: 21px;margin-bottom:0px;}.jingva-slide-title{margin-top:0;}}{% if use_custom_css %}{{ css|replace:".sectionID",default_sid}}{% endif %}
    
    {{ default_sid }} .jingva-slide-btn{background-image:linear-gradient(to top,#E1040F 0%,#E1040F 100%);background-size:100% 0%;background-position:0 100%;background-repeat:no-repeat;transition:background-size .3s ease,border-color .3s ease,color .3s ease,opacity .3s !important;}
    {{ default_sid }} .jingva-slide-btn:hover{background-size:100% 100%;border:1px solid #E1040F !important;}
 
    {{ default_sid }} .video-switch-box{
      position: absolute;
      bottom: 50px;
      right: 255px;
      z-index: 2;
      display: flex;
      gap:20px;
    }
    {{ default_sid }} .video-switch-box .v-icon-item{
      width: 50px;
      height: 50px;
      border: 2px solid #E1040F;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
    {{ default_sid }} .video-switch-box .v-icon-item .icon{
      display: none;
    }
    {{ default_sid }} .video-switch-box .v-icon-item .v-off{
      display: flex;
    }
    {{ default_sid }} .video-switch-box .v-icon-item.active .v-on{
      display: flex;
    }
    {{ default_sid }} .video-switch-box .v-icon-item.active .v-off{
      display: none;
    }
    {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper .md-hr {
      display: none;
    }
    @media screen and (max-width: 767px) {
      {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper .md-hr {
        display: inline-block;
      }
      {{ default_sid }} .jingva-slide-content .page-width{
        padding-top:0;
        max-width:75%;
      }
      {{ default_sid }} .video-switch-box{
        right: 20px;
      }
      {{ default_sid }} .video-switch-box .v-icon-item{
        width: 30px;
        height: 30px;
      }
      {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper{
        padding: 0px;
        padding-top: 40px;
      }

      {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper .jingva-slide-title{
        line-height:1.2;
      }
      {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper .jingva-slide-subtitle{
        line-height: 1.5;
      }
      {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper .jingva-slide-subtitle{
        font-size: 15px;
        line-height:18px;
      }

      {{ default_sid }} .jingva-slide-content .jingva-slide-content-wrapper .jingva-slide-btn{
        padding:9px 20px !important; 
        margin-top: 14px !important;
      }

      {{ default_sid }} .media-box .video-switch-box {
        display: none;
      }

    }
  
    
  {% endstyle %}

  <div class="jingva-section-container-inner">
    <div class="jingva-wrapper {{ section.blocks.size }} {% if width_type == "container" %}{{page_width}}{% endif %}">
      <div class="jingva-box">
        <div class="jingva-carousel-{{sid}}" id="jingvaCarousel{{sid}}" data-widthType="{{ width_type }}" data-type="{{ section_type }}" data-duration="{{ block.settings.slide_duration | default: default_duration }}">
          {% for block in section.blocks %}
            {% liquid
              assign bid                  = block.id
              assign bk_stts              = block.settings
              assign type                 = bk_stts.type
              assign image                = bk_stts.image
              assign image_mb             = bk_stts.image_mb
              assign video_mp4            = bk_stts.video_mp4
              assign video_mp4_mb         = bk_stts.video_mp4_mb
              assign video_link           = bk_stts.video_link
              assign video_link_mb        = bk_stts.video_link_mb
              assign content_layout       = bk_stts.content_layout
              assign content_position     = bk_stts.content_position
              assign top_range            = bk_stts.top_range
              assign left_range           = bk_stts.left_range
              assign content_position_mb  = bk_stts.content_position_mb
              assign top_range_mb         = bk_stts.top_range_mb
              assign left_range_mb        = bk_stts.left_range_mb
              assign max_width            = bk_stts.max_width
              assign topsubtitle          = bk_stts.topsubtitle
              assign topsubtitle_size     = bk_stts.topsubtitle_size | split: ";" 
              assign topsubtitle_color    = bk_stts.topsubtitle_color | split: ";" 
              assign title                = bk_stts.title
              assign title_size           = bk_stts.title_size | split: ";" 
              assign title_color          = bk_stts.title_color | split: ";" 
              assign subtitle             = bk_stts.subtitle
              assign subtitle_size        = bk_stts.subtitle_size | split: ";" 
              assign subtitle_color       = bk_stts.subtitle_color | split: ";" 
              assign btn_text             = bk_stts.btn_text
              assign link_type            = bk_stts.link_type
              assign btn_link             = bk_stts.btn_link
              assign btn_bg_color         = bk_stts.btn_bg_color
              assign btn_text_color       = bk_stts.btn_text_color
              assign btn_border_radius    = bk_stts.btn_border_radius
              assign show_overlay         = bk_stts.show_overlay
              assign overlay_color        = bk_stts.overlay_color
              assign overlay_opacity      = bk_stts.overlay_opacity
            %}
            {% capture _bid %}.jingva-slide-{{bid}}{% endcapture %}
            <div class="jingva-slide jingva-slide-{{ link_type }} jingva-slide-{{ forloop.index }} jingva-slide-{{bid}}" data-block-id="{{ block.id }}" >
              {% style %}
                {{ _bid }}{--max-width:{{ max_width | times: 10 | append: "px" }};--topsubtitle-size:{{ topsubtitle_size[0] }};--topsubtitle-color:{{ topsubtitle_color[0] }};--title-size:{{ title_size[0] }};--title-color:{{ title_color[0] }};--subtitle-size:{{ subtitle_size[0] }};--subtitle-color:{{ subtitle_color[0] }};--btn-bg-color:{{ btn_bg_color }};--btn-text-color:{{ btn_text_color }};--btn-font-size:{{ btn_font_size }};--btn-border-radius:{{ btn_border_radius }}px;--position:{{ content_position | split: " " | first }};--alignment:{{ content_position | split: " " | last }};}@media screen and (min-width:768px) and (max-width:992px){ {{ _bid }}{--topsubtitle-size:{{ topsubtitle_size[2] | default: topsubtitle_size[0] }};--title-size:{{ title_size[2] | default: title_size[0] }};--subtitle-size:{{ subtitle_size[2] | default: subtitle_size[0] }};} }@media screen and (max-width:767px){ {{ _bid }}{--topsubtitle-color:{{ topsubtitle_color[1] | default: topsubtitle_color[0] }};--title-color:{{ title_color[1] | default: title_color[0] }};--subtitle-color:{{ subtitle_color[1] | default: subtitle_color[0] }};--topsubtitle-size:{{ topsubtitle_size[2] | default: topsubtitle_size[0] }};--title-size:{{ title_size[2] | default: title_size[0] }};--subtitle-size:{{ subtitle_size[2] | default: subtitle_size[0] }};--position:{{ content_position_mb | split: " " | first }};--alignment:{{ content_position_mb | split: " " | last }};} }{{ _bid }} .jingva-slide-content-wrapper{align-items:var(--position);text-align:var(--alignment);justify-content:var(--alignment);}{{ _bid }} .jingva-slide-content-wrapper-inner{max-width:var(--max-width);}{{ _bid }} .jingva-slide-topsubtitle{font-size:var(--topsubtitle-size);color:var(--topsubtitle-color);}{{ _bid }} .jingva-slide-title{font-size:var(--title-size);color:var(--title-color);}{{ _bid }} .jingva-slide-subtitle{font-size:var(--subtitle-size);color:var(--subtitle-color);}{{ _bid }} .jingva-slide-btn{color:var(--btn-text-color);background-color:var(--btn-bg-color);}{% if show_overlay %}{{ _bid }} .jingva-slide-content{background-color:rgba({{ overlay_color.red }},{{ overlay_color.green }},{{ overlay_color.blue }},{{ overlay_opacity }});}{% endif %}
              {% endstyle %}
              <div class="jingva-slide-wrapper">
              <!-- Background -->
              <div class="media-box">
              <div class="media-box-wrapper">
                {% case type %}
                {% when 'image' %}
                  {% if image %}
                    <div class="image-box">
                      <picture>
                        {% if image_mb != blank %}
                        <source srcset="{{ image_mb | img_url: '750x' }}"  media="(max-width: 767px)">
                        <source srcset="{{ image_mb | img_url: '1160x' }}" media="(max-width: 1000px)" >
                       {% endif %}
                        <img fetchpriority="high"  src="{{ image | img_url: '2400x' }}"  alt="{{ image.alt }}" {%unless forloop.first%}loading="lazy"{% endunless %} width="auto" height="100%">
                      </picture>
                    </div>   
                  {% else %}
                      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                {% when 'mp4' %}
                  {% if  video_mp4 %}
                    <div class="jingva-video-box {% if video_mp4_mb %}jingva-small--hidden{% endif %}">
                      {{ video_mp4  | video_tag: image_size: '1920x', autoplay: true, loop:true, muted: true  }}

                      <div class="video-switch-box ">
                        <div class="v-icon-item video-on-off-icon active">
                          {% comment %} 暂停 {% endcomment %}
                          <svg  class="icon v-off" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="2186" width="28" height="28"><path d="M852.5 533.9L279 864.7c-11.9 6.9-27.2 2.8-34.1-9.1-2.2-3.8-3.3-8.1-3.3-12.5V181.5c0-13.8 11.2-24.9 24.9-24.9 4.4 0 8.7 1.2 12.5 3.3l573.4 330.8c11.9 6.9 16 22.1 9.1 34.1-2.1 3.8-5.2 6.9-9 9.1z" p-id="2187" fill="#E1040F"></path></svg>
                          {% comment %} 开始 {% endcomment %}
                          <svg  class="icon v-on"  viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="4377" width="28" height="28"><path d="M377.567 153.513H243.134c-24.69 0-44.812 20.121-44.812 44.812v627.354c0 24.691 20.119 44.812 44.812 44.812h134.433c24.691 0 44.812-20.121 44.812-44.812V198.325c0-24.691-20.121-44.812-44.812-44.812z m403.299 0H646.433c-24.691 0-44.812 20.121-44.812 44.812v627.354c0 24.691 20.121 44.812 44.812 44.812h134.433c24.69 0 44.812-20.121 44.812-44.812V198.325c0-24.691-20.119-44.812-44.812-44.812z" p-id="4378" fill="#E1040F"></path></svg>
                        </div>
                        <div class="v-icon-item video-ovolume-icon">
                          {% comment %} 关闭 {% endcomment %}
