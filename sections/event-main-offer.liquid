{% assign enable_mock_variants = false %}

<section
  id="{{ section.id }}"
  class="
    event-main-offer event-main-offer--{{ section.settings.color_mode }}
    tw:font-gabarito
  "
  style="
    --event-main-offer-padding-top: {{ section.settings.padding_top }}px;
    --event-main-offer-padding-bottom: {{ section.settings.padding_bottom }}px;
    --event-main-offer-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --event-main-offer-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="tw:mx-auto tw:flex tw:w-full tw:max-w-[1200px] tw:flex-col tw:gap-12 tw:max-md:gap-8">
    {%- if section.settings.title != blank -%}
      <h2
        class="
          event-main-offer__title tw:m-0 tw:text-center tw:font-orbitron tw:text-[48px] tw:font-black
          tw:leading-[normal] tw:uppercase tw:tracking-normal
          tw:max-md:text-[32px] tw:max-md:px-4
        "
      >
        {{ section.settings.title | escape | newline_to_br }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="event-main-offer__list tw:flex tw:flex-col tw:gap-6 tw:max-md:flex-row tw:max-md:gap-3 tw:max-md:overflow-x-auto tw:max-md:[scrollbar-width:none] tw:max-md:px-4">
        {%- for block in section.blocks -%}
          {%- liquid
            assign product = block.settings.product
            assign current_variant = null
            assign default_product_title = 'AutoFull M6 Ultra+ 2.0 Shiatsu Massage Gaming Chair'
            assign default_features_text = 'New Feature: Shiatsu Lumbar Massage||Active Cooling & Heating||3D Ergocloud Headrest||New Feature: Built-in Battery'
            assign default_features = default_features_text | split: '||'

            if product != blank
              assign current_variant = product.selected_or_first_available_variant
              if current_variant == blank
                assign current_variant = product.variants.first
              endif
            endif

            assign product_title = block.settings.product_title
            if product_title == blank and product != blank
              assign product_title = product.title
            endif
            if product_title == blank
              assign product_title = default_product_title
            endif

            assign product_image = block.settings.product_image
            if product_image == blank and current_variant != blank
              assign product_image = current_variant.featured_image | default: current_variant.featured_media.preview_image
            endif
            if product_image == blank and product != blank
              assign product_image = product.featured_image
            endif

            assign compare_price = current_variant.compare_at_price
            assign price = current_variant.price
            assign display_price = price | money
            assign display_compare_price = compare_price | money
            assign show_discount = false
            assign discount_amount_text = blank
            assign price_off_text = blank
            if compare_price != blank and price != blank and compare_price > price
              assign show_discount = true
              assign discount_amount = compare_price | minus: price
              assign discount_amount_text = discount_amount | money_without_trailing_zeros
              assign price_off_text = discount_amount_text | append: ' OFF'
            elsif current_variant == blank
              assign show_discount = true
              assign display_price = '$390.00'
              assign display_compare_price = '$490.00'
              assign discount_amount_text = '$200'
              assign price_off_text = '$100 OFF'
            endif

            assign block_features = block.settings.product_features
            assign learn_more_link = block.settings.learn_more_btn_link
            if learn_more_link == blank and product != blank
              assign learn_more_link = product.url
            endif
            if learn_more_link == blank
              assign learn_more_link = '#'
            endif

            assign mock_variant_id = ''
            assign mock_variant_available = 'true'
            assign mock_variant_image = ''
            if current_variant != blank
              assign mock_variant_id = current_variant.id
              if current_variant.available == false
                assign mock_variant_available = 'false'
              endif
            endif
            if product_image != blank
              assign mock_variant_image = product_image | image_url: width: 900
            endif

            assign current_variant_color = current_variant.metafields.custom.color_code | default: current_variant.option1
            assign current_variant_swatch_image = ''
            if current_variant != blank
              assign current_swatch_label = current_variant.option1 | default: current_variant.title | downcase | strip
              assign current_swatch_full_name = current_swatch_label | replace: ' ', '-'
              assign current_swatch_candidates_str = current_swatch_full_name
              assign current_swatch_words = current_swatch_label | split: ' ' | reverse
              for current_swatch_word in current_swatch_words
                assign current_swatch_candidates_str = current_swatch_candidates_str | append: '|' | append: current_swatch_word
              endfor
              assign current_swatch_candidates = current_swatch_candidates_str | split: '|'
              assign current_swatch_extensions = 'png,svg,webp,jpg,jpeg' | split: ','
              for current_swatch_candidate in current_swatch_candidates
                if current_variant_swatch_image != blank
                  break
                endif
                assign current_swatch_candidate = current_swatch_candidate | strip
                if current_swatch_candidate == blank
                  continue
                endif
                for current_swatch_extension in current_swatch_extensions
                  assign current_swatch_asset_name = 'swatch-' | append: current_swatch_candidate | append: '.' | append: current_swatch_extension
                  assign current_swatch_asset = current_swatch_asset_name | asset_url
                  if current_swatch_asset != blank and current_swatch_asset contains current_swatch_asset_name
                    assign current_variant_swatch_image = current_swatch_asset
                    break
                  endif
                endfor
              endfor
            endif

            assign current_variant_quantity_max = ''
            if current_variant != blank and current_variant.inventory_management != blank and current_variant.inventory_policy == 'deny'
              assign current_variant_quantity_max = current_variant.inventory_quantity
            endif
          -%}

          <article
            class="
              event-main-offer__card tw:relative tw:flex tw:min-h-[480px]
              tw:overflow-visible tw:rounded-[12px]
              tw:max-md:min-h-0 tw:max-md:w-[340px] tw:max-md:shrink-0 tw:max-md:flex-col
            "
            data-event-offer-card
            {{ block.shopify_attributes }}
          >
            <div
              class="
                event-main-offer__media tw:relative tw:flex tw:min-h-[480px] tw:w-[588px] tw:shrink-0 tw:items-center
                tw:justify-center tw:overflow-hidden tw:rounded-l-[12px]
                tw:max-md:h-[280px] tw:max-md:min-h-0 tw:max-md:w-full tw:max-md:rounded-t-[12px]
              "
            >
              {%- if product_image != blank -%}
                {{
                  product_image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '340,480,588,720,900,1176,1200',
                    sizes: '(min-width: 1150px) 588px, 340px',
                    class: 'event-main-offer__image tw:absolute tw:inset-0 tw:h-full tw:w-full tw:object-contain',
                    alt: product_image.alt
                }}
              {%- else -%}
                <div class="event-main-offer__image tw:absolute tw:inset-0 tw:h-full tw:w-full tw:bg-black/5"></div>
              {%- endif -%}

              {%- if section.settings.label_bg_image != blank -%}
                <div
                  class="
                    event-main-offer__label
                    {% unless show_discount %}tw:hidden{% endunless %}
                  "
                  style="color: {{ section.settings.label_text_color | default: '#ffffff' }}; background-image: url('{{ section.settings.label_bg_image | image_url: width: 160 }}');"
                  data-off-label
                >
                  <span class="event-main-offer__label-text">
                    <span class="event-main-offer__label-amount" data-off-amount>
                      {{- discount_amount_text | strip_html -}}
                    </span>
                    <span class="event-main-offer__label-suffix">OFF</span>
                  </span>
                </div>
              {%- endif -%}
            </div>

            <div
              class="
                event-main-offer__content tw:flex tw:min-w-0 tw:flex-col tw:justify-between tw:rounded-r-[12px] tw:px-8 tw:py-8
                tw:max-md:gap-6 tw:max-md:flex-1 tw:max-md:rounded-r-none tw:max-md:rounded-b-[12px] tw:max-md:px-4 tw:max-md:py-6
                tw:md:flex-1
              "
            >
              <div class="tw:flex tw:flex-col tw:gap-6">
                <div class="tw:flex tw:flex-col tw:gap-3">
                  {%- if product_title != blank -%}
                    <h3
                      class="
                        event-main-offer__product-title tw:m-0 tw:text-[28px] tw:font-semibold tw:leading-[normal]
                        tw:max-md:text-[20px] tw:font-gabarito
                      "
                    >
                      {{ product_title | escape | newline_to_br }}
                    </h3>
                  {%- endif -%}

                  <div
                    class="event-main-offer__features tw:text-[16px] tw:font-normal tw:leading-[normal] tw:max-md:text-[14px]"
                    data-features
                  >
                    {%- if block_features != blank -%}
                      {{ block_features }}
                    {%- elsif product != blank -%}
                      {%- assign product_features = product.metafields.custom.selling_points_titles.value -%}
                      {%- if product_features != blank -%}
                        <ul>
                          {%- for feature in product_features -%}
                            <li>{{ feature }}</li>
                          {%- endfor -%}
                        </ul>
                      {%- else -%}
                        <ul>
                          {%- for feature in default_features -%}
                            <li>{{ feature }}</li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    {%- else -%}
                      <ul>
                        {%- for feature in default_features -%}
                          <li>{{ feature }}</li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                </div>
              </div>

              <div class="tw:flex tw:flex-col tw:gap-3">
                <div class="event-main-offer__controls tw:flex tw:items-center tw:justify-between tw:gap-6 tw:border-b tw:pb-3 tw:max-md:gap-4">
                  {%- if product != blank and product.variants.size > 1 -%}
                    <div class="tw:flex tw:w-[328px] tw:items-center tw:gap-2 tw:text-[16px] tw:font-normal tw:leading-[normal] tw:max-md:min-w-0 tw:max-md:flex-1">
                      <span class="event-main-offer__color-label">color</span>

                      <div class="event-main-offer__variant-select tw:relative" data-variant-select>
                        <button
                          type="button"
                          class="
                            event-main-offer__variant-toggle tw:flex tw:h-8 tw:max-md:w-[168px] tw:w-[180px]
                            tw:items-center tw:justify-between tw:gap-3 tw:rounded-[999px] tw:px-1.5
                            tw:text-[14px] tw:max-md:gap-1 tw:mad-md:text-[13px]
                          "
                          aria-haspopup="listbox"
                          aria-expanded="false"
                          data-variant-toggle
                        >
                          <span class="tw:flex tw:items-center tw:gap-2">
                            <span
                              class="event-main-offer__swatch"
                              style="background-color: {{ current_variant_color | escape }};{% if current_variant_swatch_image != blank %} background-image: url('{{ current_variant_swatch_image }}');{% endif %}"
                              data-selected-swatch
                            ></span>
                            <span data-selected-title>{{ current_variant.title | escape }}</span>
                          </span>
                          <span aria-hidden="true" class="tw:flex tw:items-center">
                            <svg
                              width="20"
                              height="20"
                              viewBox="0 0 20 20"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M9.99902 14.5115L3.57715 8.0896L4.75488 6.91089L9.99902 12.155L15.2432 6.91089L16.4219 8.0896L9.99902 14.5115Z" fill="currentColor"/>
                            </svg>
                          </span>
                        </button>

                        <div
                          class="event-main-offer__variant-list tw:rounded tw:p-1 tw:shadow-[0_8px_24px_rgba(0,0,0,0.16)]"
                          role="listbox"
                          aria-hidden="true"
                          data-variant-list
                        >
                          {%- for variant in product.variants -%}
                            {%- liquid
                              assign variant_image = variant.featured_image | default: variant.featured_media.preview_image | default: product_image
                              assign variant_color = variant.metafields.custom.color_code | default: variant.option1
                              assign variant_swatch_image = ''
                              assign variant_swatch_label = variant.option1 | default: variant.title | downcase | strip
                              assign variant_swatch_full_name = variant_swatch_label | replace: ' ', '-'
                              assign variant_swatch_candidates_str = variant_swatch_full_name
                              assign variant_swatch_words = variant_swatch_label | split: ' ' | reverse
                              for variant_swatch_word in variant_swatch_words
                                assign variant_swatch_candidates_str = variant_swatch_candidates_str | append: '|' | append: variant_swatch_word
                              endfor
                              assign variant_swatch_candidates = variant_swatch_candidates_str | split: '|'
                              assign variant_swatch_extensions = 'png,svg,webp,jpg,jpeg' | split: ','
                              for variant_swatch_candidate in variant_swatch_candidates
                                if variant_swatch_image != blank
                                  break
                                endif
                                assign variant_swatch_candidate = variant_swatch_candidate | strip
                                if variant_swatch_candidate == blank
                                  continue
                                endif
                                for variant_swatch_extension in variant_swatch_extensions
                                  assign variant_swatch_asset_name = 'swatch-' | append: variant_swatch_candidate | append: '.' | append: variant_swatch_extension
                                  assign variant_swatch_asset = variant_swatch_asset_name | asset_url
                                  if variant_swatch_asset != blank and variant_swatch_asset contains variant_swatch_asset_name
                                    assign variant_swatch_image = variant_swatch_asset
                                    break
                                  endif
                                endfor
                              endfor
                              assign variant_compare = variant.compare_at_price
                              assign variant_price = variant.price
                              assign variant_show_discount = false
                              assign variant_discount_amount = blank
                              assign variant_quantity_max = ''
                              if variant_compare != blank and variant_price != blank and variant_compare > variant_price
                                assign variant_show_discount = true
                                assign variant_discount_amount = variant_compare | minus: variant_price
                              endif
                              if variant.inventory_management != blank and variant.inventory_policy == 'deny'
                                assign variant_quantity_max = variant.inventory_quantity
                              endif
                            -%}
                            <button
                              type="button"
                              class="event-main-offer__variant-option tw:flex tw:w-full tw:items-center tw:gap-2 tw:rounded tw:px-2 tw:py-1.5 tw:text-left tw:text-[14px]"
                              role="option"
                              aria-selected="{% if variant.id == current_variant.id %}true{% else %}false{% endif %}"
                              data-variant-option
                              data-variant-id="{{ variant.id }}"
                              data-variant-title="{{ variant.title | escape }}"
                              data-variant-color="{{ variant_color | escape }}"
                              data-variant-swatch-image="{{ variant_swatch_image | escape }}"
                              data-variant-available="{% if variant.available %}true{% else %}false{% endif %}"
                              data-variant-quantity-max="{{ variant_quantity_max }}"
                              data-variant-price="{{ variant.price | money | strip_html | escape }}"
                              data-variant-compare="{{ variant.compare_at_price | money | strip_html | escape }}"
                              data-variant-has-discount="{% if variant_show_discount %}true{% else %}false{% endif %}"
                              data-variant-off="{{ variant_discount_amount | money_without_trailing_zeros }}"
                              data-variant-price-off="{{ variant_discount_amount | money_without_trailing_zeros }} OFF"
                              data-variant-coupon-off="{{ variant_discount_amount | money_without_trailing_zeros }}"
                              data-variant-image="{% if variant_image != blank %}{{ variant_image | image_url: width: 900 }}{% endif %}"
                            >
                              <span
                                class="event-main-offer__swatch"
                                style="background-color: {{ variant_color | escape }};{% if variant_swatch_image != blank %} background-image: url('{{ variant_swatch_image }}');{% endif %}"
                              ></span>
                              <span>{{ variant.title | escape }}</span>
                            </button>
                          {%- endfor -%}
                        </div>
                      </div>
                    </div>
                  {%- elsif enable_mock_variants -%}
                    <div class="tw:flex tw:w-[328px] tw:items-center tw:gap-2 tw:text-[16px] tw:font-normal tw:leading-[normal] tw:max-md:min-w-0 tw:max-md:flex-1">
                      <span class="event-main-offer__color-label">color</span>

                      <div class="event-main-offer__variant-select tw:relative" data-variant-select>
                        <button
                          type="button"
                          class="event-main-offer__variant-toggle tw:flex tw:h-8 tw:max-md:w-[168px] tw:w-[180px]
                            tw:items-center tw:justify-between tw:gap-3 tw:rounded-[999px] tw:px-1.5
                            tw:text-[14px] tw:max-md:gap-1 tw:mad-md:text-[13px]"
                          aria-haspopup="listbox"
                          aria-expanded="false"
                          data-variant-toggle
                        >
                          <span class="tw:flex tw:items-center tw:gap-2">
                            <span
                              class="event-main-offer__swatch"
                              style="background: #111111;"
                              data-selected-swatch
                            ></span>
                            <span data-selected-title>Black</span>
                          </span>
                          <span aria-hidden="true" class="tw:flex tw:items-center">
                            <svg
                              width="20"
                              height="20"
                              viewBox="0 0 20 20"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M9.99902 14.5115L3.57715 8.0896L4.75488 6.91089L9.99902 12.155L15.2432 6.91089L16.4219 8.0896L9.99902 14.5115Z" fill="currentColor"/>
                            </svg>
                          </span>
                        </button>

                        <div
                          class="event-main-offer__variant-list tw:rounded tw:p-1 tw:shadow-[0_8px_24px_rgba(0,0,0,0.16)]"
                          role="listbox"
                          aria-hidden="true"
                          data-variant-list
                        >
                          <button
                            type="button"
                            class="event-main-offer__variant-option tw:flex tw:w-full tw:items-center tw:gap-2 tw:rounded tw:px-2 tw:py-1.5 tw:text-left tw:text-[14px]"
                            role="option"
                            aria-selected="true"
                            data-variant-option
                            data-variant-id="{{ mock_variant_id }}"
                            data-variant-title="Black"
                            data-variant-color="#111111"
                            data-variant-available="{{ mock_variant_available }}"
                            data-variant-price="{{ display_price | strip_html | escape }}"
                            data-variant-compare="{{ display_compare_price | strip_html | escape }}"
                            data-variant-has-discount="{% if show_discount %}true{% else %}false{% endif %}"
                            data-variant-off="{{ discount_amount_text }}"
                            data-variant-price-off="{{ price_off_text }}"
                            data-variant-coupon-off="{{ discount_amount_text }}"
                            data-variant-image="{{ mock_variant_image }}"
                          >
                            <span class="event-main-offer__swatch" style="background: #111111;"></span>
                            <span>Black</span>
                          </button>
                          <button
                            type="button"
                            class="event-main-offer__variant-option tw:flex tw:w-full tw:items-center tw:gap-2 tw:rounded tw:px-2 tw:py-1.5 tw:text-left tw:text-[14px]"
                            role="option"
                            aria-selected="false"
                            data-variant-option
                            data-variant-id="{{ mock_variant_id }}"
                            data-variant-title="Blue"
                            data-variant-color="#005bee"
                            data-variant-available="{{ mock_variant_available }}"
                            data-variant-price="{{ display_price | strip_html | escape }}"
                            data-variant-compare="{{ display_compare_price | strip_html | escape }}"
                            data-variant-has-discount="{% if show_discount %}true{% else %}false{% endif %}"
                            data-variant-off="{{ discount_amount_text }}"
                            data-variant-price-off="{{ price_off_text }}"
                            data-variant-coupon-off="{{ discount_amount_text }}"
                            data-variant-image="{{ mock_variant_image }}"
                          >
                            <span class="event-main-offer__swatch" style="background: #005bee;"></span>
                            <span>Blue</span>
                          </button>
                          <button
                            type="button"
                            class="event-main-offer__variant-option tw:flex tw:w-full tw:items-center tw:gap-2 tw:rounded tw:px-2 tw:py-1.5 tw:text-left tw:text-[14px]"
                            role="option"
                            aria-selected="false"
                            data-variant-option
                            data-variant-id="{{ mock_variant_id }}"
                            data-variant-title="Pink"
                            data-variant-color="#ee00d2"
                            data-variant-available="{{ mock_variant_available }}"
                            data-variant-price="{{ display_price | strip_html | escape }}"
                            data-variant-compare="{{ display_compare_price | strip_html | escape }}"
                            data-variant-has-discount="{% if show_discount %}true{% else %}false{% endif %}"
                            data-variant-off="{{ discount_amount_text }}"
                            data-variant-price-off="{{ price_off_text }}"
                            data-variant-coupon-off="{{ discount_amount_text }}"
                            data-variant-image="{{ mock_variant_image }}"
                          >
                            <span class="event-main-offer__swatch" style="background: #ee00d2;"></span>
                            <span>Pink</span>
                          </button>
                        </div>
                      </div>
                    </div>
                  {%- elsif current_variant != blank -%}
                    <input type="hidden" data-single-variant-id value="{{ current_variant.id }}">
                    <div class="tw:min-w-0 tw:flex-1" aria-hidden="true"></div>
                  {%- else -%}
                    <div class="tw:flex tw:w-[328px] tw:items-center tw:gap-2 tw:text-[16px] tw:font-normal tw:leading-[normal] tw:max-md:min-w-0 tw:max-md:flex-1">
                      <span class="event-main-offer__color-label">color</span>
                      <div class="event-main-offer__variant-toggle tw:flex tw:h-8 tw:w-[160px] tw:items-center tw:justify-between tw:gap-3 tw:rounded-[999px] tw:px-1.5">
                        <span class="tw:flex tw:items-center tw:gap-2">
                          <span
                            class="event-main-offer__swatch"
                            style="background: linear-gradient(135deg, #ffffff 0%, #0a0a0a 100%);"
                          ></span>
                          <span>Black</span>
                        </span>
                        <span aria-hidden="true" class="tw:flex tw:items-center">
                          <svg
                            width="20"
                            height="20"
                            viewBox="0 0 20 20"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M9.99902 14.5115L3.57715 8.0896L4.75488 6.91089L9.99902 12.155L15.2432 6.91089L16.4219 8.0896L9.99902 14.5115Z" fill="currentColor"/>
                          </svg>
                        </span>
                      </div>
                    </div>
                  {%- endif -%}

                  <div class="event-main-offer__quantity tw:flex tw:h-8 tw:w-[84px] tw:shrink-0 tw:items-center tw:justify-between tw:rounded-[999px] tw:px-1">
                    <button
                      type="button"
                      class="tw:flex tw:size-8 tw:items-center tw:justify-center"
                      aria-label="Decrease quantity"
                      data-qty-minus
                    >
                      −
                    </button>
                    <input
                      class="tw:h-8 tw:w-8 tw:border-0 tw:bg-transparent tw:p-0 tw:text-center tw:text-[16px]"
                      type="number"
                      value="1"
                      min="1"
                      {% if current_variant_quantity_max != blank %}
                        max="{{ current_variant_quantity_max }}"
                      {% endif %}
                      inputmode="numeric"
                      data-quantity-max="{{ current_variant_quantity_max }}"
                      data-quantity
                    >
                    <button
                      type="button"
                      class="tw:flex tw:size-8 tw:items-center tw:justify-center"
                      aria-label="Increase quantity"
                      data-qty-plus
                    >
                      +
                    </button>
                  </div>
                </div>

                <div class="tw:flex tw:items-center tw:gap-2">
                  <span class="event-main-offer__price tw:text-[24px] tw:font-semibold tw:leading-[normal] tw:max-md:text-[20px]" data-price>
                    {{ display_price }}
                  </span>
                  <span
                    class="
                      event-main-offer__compare-price tw:text-[20px] tw:font-normal tw:leading-[normal] tw:line-through tw:max-md:text-[16px]
                      {% unless show_discount %}tw:hidden{% endunless %}
                    "
                    data-compare-price
                  >
                    {%- if show_discount -%}{{ display_compare_price }}{%- endif -%}
                  </span>
                  <span
                    class="
                      event-main-offer__price-off tw:rounded-[999px] tw:px-3 tw:py-1 tw:text-[14px] tw:font-medium tw:leading-[normal] tw:max-md:text-[12px]
                      {% unless show_discount %}tw:hidden{% endunless %}
                    "
                    data-price-off
                  >
                    {%- if show_discount -%}{{ price_off_text }}{%- endif -%}
                  </span>
                </div>

                <div class="tw:flex tw:h-12 tw:max-md:h-10 tw:gap-3">
                  {%- if block.settings.learn_more_btn_text != blank -%}
                    <a
                      href="{{ learn_more_link }}"
                      class="
                        event-main-offer__learn-more tw:flex tw:h-12 tw:max-md:h-10 tw:flex-1 tw:items-center tw:justify-center tw:rounded-xl tw:px-5 tw:text-center
                        tw:text-[20px] tw:font-semibold tw:leading-[1.2] tw:no-underline tw:max-md:text-[16px] tw:max-md:rounded-[8px]
                      "
                    >
                      {{ block.settings.learn_more_btn_text | escape }}
                    </a>
                  {%- endif -%}

                  <button
                    type="button"
                    class="
                      event-main-offer__add tw:flex tw:h-12 tw:max-md:h-10 tw:flex-1 tw:items-center tw:justify-center tw:rounded-xl tw:px-5 tw:text-center
                      tw:text-[20px] tw:font-semibold tw:leading-[1.2] tw:max-md:text-[16px] tw:max-md:rounded-[8px]
                    "
                    data-add-to-cart
                    {% if product != blank and current_variant.available == false %}
                      disabled
                    {% endif %}
                  >
                    <span data-add-label>{{ block.settings.add_to_cart_text | default: 'add to cart' | escape }}</span>
                  </button>
                </div>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

