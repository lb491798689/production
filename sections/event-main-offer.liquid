<script>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.getElementById({{ section.id | json }});
    if (!root) return;

    const cartUrl = {{ routes.cart_url | json }};
    const cartAddUrl = `${window.Shopify?.routes?.root || '/'}cart/add.js`;

    const setLoading = (button, isLoading) => {
      button.classList.toggle('is-loading', isLoading);
      button.toggleAttribute('aria-busy', isLoading);
    };

    const refreshCartDrawer = async (baseEvent, item) => {
      if (!document.getElementById('cart-drawer')) {
        window.location.href = cartUrl;
        return;
      }

      const sections = ['variant-added'];
      document.documentElement.dispatchEvent(new CustomEvent('cart:prepare-bundled-sections', {
        bubbles: true,
        detail: { sections }
      }));

      const cart = await fetch(`${window.Shopify?.routes?.root || '/'}cart.js`).then((response) => response.json());
      const sectionQuery = encodeURIComponent(sections.join(','));
      const sectionResponse = await fetch(`${window.Shopify?.routes?.root || '/'}?sections=${sectionQuery}`);
      cart.sections = await sectionResponse.json();

      root.dispatchEvent(new CustomEvent('variant:add', {
        bubbles: true,
        detail: { items: item ? [item] : [], cart }
      }));

      document.documentElement.dispatchEvent(new CustomEvent('cart:change', {
        bubbles: true,
        detail: { baseEvent, cart }
      }));
    };

    root.querySelectorAll('[data-event-offer-card]').forEach((card) => {
      const image = card.querySelector('.event-main-offer__image');
      const price = card.querySelector('[data-price]');
      const comparePrice = card.querySelector('[data-compare-price]');
      const priceOff = card.querySelector('[data-price-off]');
      const offLabel = card.querySelector('[data-off-label]');
      const offAmount = card.querySelector('[data-off-amount]');
      const addButton = card.querySelector('[data-add-to-cart]');
      const quantityInput = card.querySelector('[data-quantity]');
      const qtyMinusButton = card.querySelector('[data-qty-minus]');
      const qtyPlusButton = card.querySelector('[data-qty-plus]');
      const toggle = card.querySelector('[data-variant-toggle]');
      const list = card.querySelector('[data-variant-list]');
      const selectedSwatch = card.querySelector('[data-selected-swatch]');
      const selectedTitle = card.querySelector('[data-selected-title]');
      let selectedVariantId = card.querySelector('[data-single-variant-id]')?.value || card.querySelector('[data-variant-option]')?.dataset.variantId || '';
      const mobileVariantQuery = window.matchMedia('(max-width: 1149px)');

      const positionMobileList = () => {
        if (!toggle || !list || !mobileVariantQuery.matches) return;

        const gap = 6;
        const viewportPadding = 12;
        const toggleRect = toggle.getBoundingClientRect();
        const width = Math.min(toggleRect.width, window.innerWidth - viewportPadding * 2);
        const left = Math.min(
          Math.max(toggleRect.left, viewportPadding),
          window.innerWidth - width - viewportPadding
        );
        const availableAbove = Math.max(96, toggleRect.top - viewportPadding - gap);
        const maxHeight = Math.min(280, availableAbove);

        list.style.setProperty('--event-main-offer-variant-left', `${left}px`);
        list.style.setProperty('--event-main-offer-variant-width', `${width}px`);
        list.style.setProperty('--event-main-offer-variant-max-height', `${maxHeight}px`);

        const listHeight = Math.min(list.scrollHeight || maxHeight, maxHeight);
        const top = Math.max(viewportPadding, toggleRect.top - listHeight - gap);

        list.style.setProperty('--event-main-offer-variant-top', `${top}px`);
      };

      const closeList = () => {
        if (!toggle || !list) return;
        toggle.setAttribute('aria-expanded', 'false');
        list.setAttribute('aria-hidden', 'true');
        list.classList.remove('is-open');
      };

      const getQuantityMax = () => {
        if (!quantityInput) return null;
        const rawMax = quantityInput.dataset.quantityMax || quantityInput.getAttribute('max') || '';
        if (rawMax === '') return null;

        const max = Number(rawMax);
        return Number.isFinite(max) && max >= 0 ? max : null;
      };

      const getQuantityValue = () => {
        const value = Number(quantityInput?.value || 1);
        return Number.isFinite(value) ? Math.max(1, value) : 1;
      };

      const updateQuantityButtons = () => {
        if (!quantityInput) return;

        const value = getQuantityValue();
        const max = getQuantityMax();
        const isUnavailable = addButton?.disabled || max === 0;

        if (qtyMinusButton) qtyMinusButton.disabled = isUnavailable || value <= 1;
        if (qtyPlusButton) qtyPlusButton.disabled = isUnavailable || (max !== null && value >= max);
      };

      const normalizeQuantity = () => {
        if (!quantityInput) return 1;

        const max = getQuantityMax();
        let value = getQuantityValue();
        if (max !== null && max > 0) value = Math.min(value, max);
        quantityInput.value = value;
        updateQuantityButtons();

        return value;
      };

      const setQuantityMax = (max) => {
        if (!quantityInput) return;

        quantityInput.dataset.quantityMax = max || '';
        if (max) {
          quantityInput.setAttribute('max', max);
        } else {
          quantityInput.removeAttribute('max');
        }
      };

      const applyVariant = (option) => {
        selectedVariantId = option.dataset.variantId;
        const color = option.dataset.variantColor || '';
        const swatchImage = option.dataset.variantSwatchImage || '';

        if (selectedSwatch) {
          selectedSwatch.style.backgroundColor = color;
          selectedSwatch.style.backgroundImage = swatchImage ? `url("${swatchImage}")` : '';
        }
        if (selectedTitle) selectedTitle.textContent = option.dataset.variantTitle || '';
        if (price) price.textContent = option.dataset.variantPrice || '';

        const hasDiscount = option.dataset.variantHasDiscount === 'true';
        comparePrice?.classList.toggle('tw:hidden', !hasDiscount);
        priceOff?.classList.toggle('tw:hidden', !hasDiscount);
        offLabel?.classList.toggle('tw:hidden', !hasDiscount);

        if (hasDiscount) {
          if (comparePrice) comparePrice.textContent = option.dataset.variantCompare || '';
          if (priceOff) priceOff.innerHTML = option.dataset.variantPriceOff || `${option.dataset.variantOff || ''} OFF`.trim();
          if (offAmount) offAmount.innerHTML = option.dataset.variantCouponOff || option.dataset.variantOff || '';
        }

        if (image && option.dataset.variantImage) {
          image.setAttribute('src', option.dataset.variantImage);
          image.removeAttribute('srcset');
        }

        if (addButton) {
          addButton.disabled = option.dataset.variantAvailable !== 'true';
        }
        setQuantityMax(option.dataset.variantQuantityMax || '');
        normalizeQuantity();

        card.querySelectorAll('[data-variant-option]').forEach((item) => {
          item.setAttribute('aria-selected', item === option ? 'true' : 'false');
        });
      };

      toggle?.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        if (!isOpen) positionMobileList();
        toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        list?.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
        list?.classList.toggle('is-open', !isOpen);
      });

      const repositionOpenList = () => {
        if (toggle?.getAttribute('aria-expanded') === 'true') positionMobileList();
      };

      window.addEventListener('resize', repositionOpenList);
      window.addEventListener('scroll', repositionOpenList, true);

      card.querySelectorAll('[data-variant-option]').forEach((option) => {
        option.addEventListener('click', () => {
          applyVariant(option);
          closeList();
        });
      });

      document.addEventListener('click', (event) => {
        if (!card.contains(event.target)) closeList();
      });

      qtyMinusButton?.addEventListener('click', () => {
        if (!quantityInput || qtyMinusButton.disabled) return;
        quantityInput.value = Math.max(1, getQuantityValue() - 1);
        updateQuantityButtons();
      });

      qtyPlusButton?.addEventListener('click', () => {
        if (!quantityInput || qtyPlusButton.disabled) return;

        const max = getQuantityMax();
        const nextValue = getQuantityValue() + 1;
        quantityInput.value = max !== null ? Math.min(max, nextValue) : nextValue;
        updateQuantityButtons();
      });

      quantityInput?.addEventListener('input', updateQuantityButtons);
      quantityInput?.addEventListener('change', normalizeQuantity);
      updateQuantityButtons();

      addButton?.addEventListener('click', async () => {
        if (!selectedVariantId || addButton.disabled || addButton.classList.contains('is-loading')) return;

        setLoading(addButton, true);

        try {
          const response = await fetch(cartAddUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
              id: Number(selectedVariantId),
              quantity: normalizeQuantity()
            })
          });

          const item = await response.json();
          if (!response.ok) throw new Error(item.description || 'Unable to add item to cart.');

          await refreshCartDrawer('variant:add', item);
        } catch (error) {
          console.error(error);
          window.location.href = cartUrl;
        } finally {
          setLoading(addButton, false);
        }
      });
    });
  });
</script>

