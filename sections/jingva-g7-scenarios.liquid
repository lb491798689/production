{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign title = se_stts.title
  assign scenario_blocks = section.blocks
  assign bg_color = se_stts.bg_color
  assign title_color = se_stts.title_color
  assign padding_top = se_stts.padding_top
  assign padding_bottom = se_stts.padding_bottom
  assign padding_top_mob = se_stts.padding_top_mob
  assign padding_bottom_mob = se_stts.padding_bottom_mob
-%}
{% capture default_sid %}.jingva-g7-scenarios-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-g7-scenarios jingva-g7-scenarios-{{sid}}" data-section-id="{{ sid }}">
  {% style %}
    /*
     * ========================================
     * Figma PC (1920px, node 3675:3535) 详细参数:
     * ========================================
     *   section: w:1920, flex column, gap:48px, bg:#000000
     *   title: Gabarito 600 48px line-height:1.2 #FFFFFF title center, w:1000
     *   tabs: flex row, gap:24px, center
     *   tab: capsule button, p:14 24, br:200px, active:#003CFF, inactive:#333336
     *   tab text: Gabarito, active:500 18px, inactive:400 18px, title
     *   image: w:1200, h:640, br:12px
     *   gap: title→tabs 48px, tabs→image 24px
     *
     * ========================================
     * Figma MOB (390px, node 2812:3906) 详细参数:
     * ========================================
     *   section: w:358, flex column, gap:32px, pt:68px, bg:#000000
     *   title: Orbitron 900 28px line-height:1.254 #FFFFFF uppercase center, w:358
     *   tabs: flex row, gap:12px, center
     *   tab: capsule button, p:12, br:200px, active:#005EFF, inactive:#333336
     *   tab text: Gabarito, active:500 12px, inactive:400 12px, title
     *   image: w:358, h:480, br:12px
     *   gap: title→tabs 32px, tabs→image 12px
     *
     * ========================================
     * develop.md 规范 (必须遵守):
     * ========================================
     *   基准尺寸: PC=1920, MOB=390
     *   版心: PC/PAD 均为 1200px
     *   Grid.Padding: PC=48px, PAD=40px, MOB=16px
     *   断点: MOB≤1279, PAD 1280~1439, PC≥1440
     *   字体: Orbitron(展示标题), Gabarito(正文/说明)
     *   所有样式使用 !important 确保优先级
     */

    /* === PC: 1440~2560 === */
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color | default: '#121B2C' }} !important;
      padding: 0 !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-wrapper {
      position: relative !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 25px !important;
      box-sizing: border-box !important;
      padding-top: {{ padding_top | default: 162 }}px !important;
      padding-bottom: {{ padding_bottom | default: 0 }}px !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-title {
      width: 100% !important;
      max-width: 1000px !important;
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 600 !important;
      font-size: 48px !important;
      line-height: 1.2 !important;
      color: {{ title_color | default: '#ffffff' }} !important;
      text-align: center !important;
      text-transform: none !important;
      margin: 0 !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-g7-scenarios-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-g7-scenarios-title {
      padding: 0 !important;
      padding-bottom: 20px !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-tabs {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      gap: 24px !important;
      flex-wrap: wrap !important;
      justify-content: center !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-tab {
      display: flex !important;
      flex-direction: row !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 10px !important;
      padding: 14px 24px !important;
      border-radius: 200px !important;
      background-color: #333336 !important;
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 400 !important;
      font-size: 18px !important;
      line-height: 1.2 !important;
      color: #ffffff !important;
      text-transform: none !important;
      border: none !important;
      cursor: pointer !important;
      transition: all 0.3s ease !important;
      outline: none !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-tab:not(.active):hover {
      background-color: rgba(0, 60, 255, 0.60) !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-tab.active {
      background-color: #003CFF !important;
      font-weight: 500 !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-images {
      width: 100% !important;
      max-width: 1200px !important;
      height: 640px !important;
      position: relative !important;
      overflow: hidden !important;
      border-radius: 12px !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-nav {
      position: absolute !important;
      top: 50% !important;
      left: 24px !important;
      right: 24px !important;
      transform: translateY(-50%) !important;
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      pointer-events: none !important;
      z-index: 10 !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-nav-btn {
      width: 48px !important;
      height: 48px !important;
      padding: 0 !important;
      border-radius: 12px !important;
      background-color: #ffffff !important;
      border: none !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      box-sizing: border-box !important;
      transition: background-color 0.3s ease !important;
      pointer-events: auto !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-nav-btn:hover {
      background-color: #DBDBDB !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-nav-btn:disabled {
      background-color: rgba(255, 255, 255, 0.2) !important;
      cursor: not-allowed !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-icon-pc {
      display: block !important;
      width: 10px !important;
      height: 16px !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-icon-mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-image-wrapper {
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      opacity: 0 !important;
      transition: opacity 0.5s ease !important;
      z-index: 1 !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-image-wrapper.active {
      opacity: 1 !important;
      z-index: 2 !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      display: block !important;
    }

    {{ default_sid }} .jingva-g7-scenarios-image.mob {
      display: none !important;
    }

    /* === PAD: 1280~1439 ===
       PAD 与 PC 共用基础规则（padding-top / padding-bottom 来自 shopify 后台 padding_top / padding_bottom 设置） */

    /* === MOB: 375~1279 === */
    @media screen and (max-width: 1279px) {
      {{ default_sid }} .jingva-g7-scenarios-wrapper {
        max-width: 100% !important;
        padding-top: {{ padding_top_mob | default: 96 }}px !important;
        padding-bottom: {{ padding_bottom_mob | default: 0 }}px !important;
        padding-left:16px;
        padding-right:16px;
        gap: 12px !important;
        margin: 0 auto !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-title {
        font-family: 'Orbitron', sans-serif !important;
        font-weight: 900 !important;
        font-size: 32px !important;
        line-height: 1.25 !important;
        text-transform: none !important;
        transform: translateY(-50px);
        transition: transform 0.5s ease-out;
        will-change: transform;
      }

      {{ default_sid }} .jingva-g7-scenarios-tabs {
        width: 100% !important;
        gap: 12px !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-tab {
        padding: 16px !important;
        font-size: 16px !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-tab.active {
        background-color: #005EFF !important;
        font-weight: 500 !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-images {
        max-width: 100% !important;
        height: 480px !important;
        margin: 0 auto !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-nav {
        display: none !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-nav-btn {
        width: 36px !important;
        height: 36px !important;
        border-radius: 8px !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-nav-btn:disabled svg path {
        stroke: white !important;
        stroke-opacity: 0.3 !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-nav-btn:not(:disabled) svg path {
        stroke: black !important;
        stroke-opacity: 1 !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-icon-pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-icon-mob {
        display: block !important;
        width: 18px !important;
        height: 18px !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-image.pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-g7-scenarios-image.mob {
        display: block !important;
        object-fit: fill !important;
      }
    }
  {% endstyle %}

  {% if scenario_blocks.size > 0 %}
    <div class="jingva-g7-scenarios-wrapper">
      {% if title != blank %}
        <h2 class="jingva-g7-scenarios-title">{{ title }}</h2>
      {% endif %}

      <div class="jingva-g7-scenarios-tabs">
        {% for block in scenario_blocks %}
          <button class="jingva-g7-scenarios-tab {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            {{ block.settings.label }}
          </button>
        {% endfor %}
      </div>

      <div class="jingva-g7-scenarios-images">
        {% for block in scenario_blocks %}
          {% assign pc_image = block.settings.image %}
          {% assign mob_image = block.settings.mobile_image %}
          {% if mob_image == blank %}
            {% assign mob_image = pc_image %}
          {% endif %}

          <div class="jingva-g7-scenarios-image-wrapper {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            {% if pc_image != blank or mob_image != blank %}
              <picture class="jingva-g7-scenarios-image">
                {% if pc_image != blank %}
                  <source media="(min-width: 1280px)" srcset="{{ pc_image | image_url: width: 1920 }}">
                {% endif %}
                {% if mob_image != blank %}
                  <img
                    src="{{ mob_image | image_url: width: 780 }}"
                    alt="{{ block.settings.label | escape }}"
                    loading="lazy"
                    class="mob"
                  />
                {% elsif pc_image != blank %}
                  <img
                    src="{{ pc_image | image_url: width: 1920 }}"
                    alt="{{ block.settings.label | escape }}"
                    loading="lazy"
                    class="pc"
                  />
                {% endif %}
              </picture>
            {% endif %}
          </div>
        {% endfor %}

        {% if scenario_blocks.size > 1 %}
          <div class="jingva-g7-scenarios-nav">
            <button class="jingva-g7-scenarios-nav-btn jingva-g7-scenarios-nav-prev" aria-label="Previous">
              <svg class="jingva-g7-scenarios-icon-pc" xmlns="http://www.w3.org/2000/svg" width="10" height="16" viewBox="0 0 10 16" fill="none">
                <path d="M0 7.70703L7.70703 15.4141L9.12109 14L2.82812 7.70703L9.12109 1.41406L7.70703 0L0 7.70703Z" fill="#0A0A0A"/>
              </svg>
              <svg class="jingva-g7-scenarios-icon-mob" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M10.875 13.125L6.75 9L10.875 4.875" stroke="white" stroke-opacity="0.3" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="jingva-g7-scenarios-nav-btn jingva-g7-scenarios-nav-next" aria-label="Next">
              <svg class="jingva-g7-scenarios-icon-pc" xmlns="http://www.w3.org/2000/svg" width="10" height="16" viewBox="0 0 10 16" fill="none">
                <path d="M9.12109 7.70703L1.41406 15.4141L0 14L6.29297 7.70703L0 1.41406L1.41406 0L9.12109 7.70703Z" fill="#0A0A0A"/>
              </svg>
              <svg class="jingva-g7-scenarios-icon-mob" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M7.125 13.125L11.25 9L7.125 4.875" stroke="black" stroke-opacity="1" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if scenario_blocks.size > 1 %}
    <script>
      (function() {
        var container = document.querySelector('{{ default_sid }}');
        if (!container) return;

        var tabs = container.querySelectorAll('.jingva-g7-scenarios-tab');
        var images = container.querySelectorAll('.jingva-g7-scenarios-image-wrapper');
        var prevBtn = container.querySelector('.jingva-g7-scenarios-nav-prev');
        var nextBtn = container.querySelector('.jingva-g7-scenarios-nav-next');
        var total = tabs.length;
        var current = 0;
        var autoPlayTimer = null;

        function goTo(index) {
          // 循环轮播：超出范围时回到开头或结尾
          current = (index + total) % total;
          tabs.forEach(function(tab, i) {
            tab.classList.toggle('active', i === current);
          });
          images.forEach(function(img, i) {
            img.classList.toggle('active', i === current);
          });
          
          // 重置自动播放计时器
          resetAutoPlay();
        }

        function startAutoPlay() {
          stopAutoPlay();
          autoPlayTimer = setInterval(function() {
            goTo(current + 1);
          }, 4000);
        }

        function stopAutoPlay() {
          if (autoPlayTimer) {
            clearInterval(autoPlayTimer);
            autoPlayTimer = null;
          }
        }

        function resetAutoPlay() {
          startAutoPlay();
        }

        tabs.forEach(function(tab, index) {
          tab.addEventListener('click', function() {
            goTo(index);
          });
        });

        if (prevBtn) {
          prevBtn.addEventListener('click', function() {
            // 循环：当前是第一个时，跳到最后一个
            goTo(current - 1);
          });
        }

        if (nextBtn) {
          nextBtn.addEventListener('click', function() {
            // 循环：当前是最后一个时，跳到第一个
            goTo(current + 1);
          });
        }

        // 鼠标悬停时暂停自动播放
        container.addEventListener('mouseenter', function() {
          stopAutoPlay();
        });

        // 鼠标离开时恢复自动播放
        container.addEventListener('mouseleave', function() {
          startAutoPlay();
        });

        // 启动自动播放
        startAutoPlay();
      })();
    </script>
  {% endif %}
</section>

<script>
(function() {
  var section = document.querySelector('.jingva-g7-scenarios-{{ sid }}');
  if (!section) return;

  var title = section.querySelector('.jingva-g7-scenarios-title');
  if (!title) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        title.classList.add('aos-animate');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  observer.observe(title);
})();
</script>

{% schema %}
{
  "name": "Jingva G7 Scenarios",
  "class": "shopify-section--jingva-g7-scenarios",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Built for Multiple Scenarios"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "text",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#121B2C",
      "info": "Supports hex (#121B2C) or rgba (rgba(18, 27, 44, 1))"
    },
    {
      "type": "text",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff",
      "info": "Supports hex (#ffffff) or rgba (rgba(255, 255, 255, 1))"
    },
    {
      "type": "header",
      "content": "PC Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 162
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "label": "Mobile Padding Top (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "label": "Mobile Padding Bottom (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "scenario",
      "name": "Scenario",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Gaming Room"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jingva G7 Scenarios",
      "settings": {
        "title": "Built for Multiple Scenarios"
      },
      "blocks": [
        {
          "type": "scenario",
          "settings": {
            "label": "Gaming Room"
          }
        },
        {
          "type": "scenario",
          "settings": {
            "label": "Home Studio"
          }
        }
      ]
    }
  ]
}
{% endschema %}