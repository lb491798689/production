  <style>
    .safe-guard-{{ section.id }} .s-g-content{
        display: grid;
        grid-template-columns: calc(25% - 18px) 50% calc(25% - 18px);
        grid-template-rows: repeat(1, 1fr);
        gap: 18px;
    }
    .safe-guard-{{ section.id }} .s-g-content .left-c-box{
        display: flex;
        flex-direction: column;
        gap: 18px;
        justify-content: space-between;
    }
    .safe-guard-{{ section.id }} .s-g-content .left-c-box .l-c-b-content{
      display: flex;
      justify-content: space-between;
      gap: 18px;
    }
    
    .safe-guard-{{ section.id }} .s-g-content .right-c-box{
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        grid-template-rows: repeat(1, 1fr);
        gap: 18px;
    }
    .safe-guard-{{ section.id }} .s-g-content .right-c-box .r-c-b-content{
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 18px;
    }
    
    .safe-guard-{{ section.id }} .l-item,
    .safe-guard-{{ section.id }} .r-item{
        position: relative;
        transition: all 0.3s ease-in-out;
        flex-grow: 1;
    }
    .safe-guard-{{ section.id }} .l-item:hover,
    .safe-guard-{{ section.id }} .r-item:hover{
        transform: scale(1.02);
    }
    .safe-guard-{{ section.id }} .l-item .l-primary-content{
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: #fff;
        width: 90%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    .safe-guard-{{ section.id }} .s-g-content .primary-img{
      height: 380px;
      max-width: 340px;
      width: 100%;
      object-fit: cover;
    }


    .safe-guard-{{ section.id }} .l-item .l-primary-content h3{

      font-size: 46px;

    }
    .safe-guard-{{ section.id }} .l-item .l-primary-content p{

      font-size: 20px;
      margin-top: 61px;
    
    }

    .safe-guard-{{ section.id }} .link-item{
      display: flex;
      justify-content: flex-end;
      align-items: flex-end;
      height: 240px;
      background-color: #fff;
      border-radius: 8px;
      padding: 20px;
    }
    .safe-guard-{{ section.id }} .img-asp{
      max-height: 240px;
    }
    

    .safe-guard-{{ section.id }} .item-content{
        position: absolute;
        top: 20px;
        left: 18px;
        display: inline-block;
        width: calc(100% - 36px);
    }
    .safe-guard-{{ section.id }} .item-content h3{ 
      font-style: normal;
      font-family: 'HarmonyOS-Sans-SC';
      font-size: 20px;
      line-height: 1.2;
    }
    .safe-guard-{{ section.id }} .item-content p{
      font-size: 15px;
      margin-top: 12px;
      line-height: 1.2;
      font-family: 'HarmonyOS-Sans-SC';
    }
    .safe-guard-{{ section.id }} .s-g-content img{
      border-radius: 8px;
    }
    .safe-guard-{{ section.id }} .l-item .l-primary-content img{
        width: 327px;
      }

    .jingva-lg{
      display: block;
    }
    .jingva-md{
      display: none;
    }


    @media screen and (max-width: 990px) {
      .jingva-lg{
        display: none;
      }
      .jingva-md{
        display: block;
      }

      .safe-guard-{{ section.id }} .s-g-content{
        grid-template-columns: repeat(1, 1fr);
        grid-template-rows: repeat(2, 1fr);
  
      }
      .safe-guard-{{ section.id }} .l-item .l-primary-content{
        width: 100%;
      }
      .safe-guard-{{ section.id }} .l-item .l-primary-content img{
        width: 199px;
        margin: 0 auto;
      }
      .safe-guard-{{ section.id }} .l-item .l-primary-content p{
        font-size: 20px;
        font-family: 'HarmonyOS-Sans-SC';
        margin-top: 26px;
        
      }
      .safe-guard-{{ section.id }} .item-content{
        left: 8px;
        top: 8px;
        width: 90%;
      }
      .safe-guard-{{ section.id }} .item-content h3{
        font-size: 16px;
      }
      .safe-guard-{{ section.id }} .item-content p{
        font-size: 12px;
      }
        
    }

    .safe-guard-{{ section.id }} .des-br-hid{
      display: none;
    }
     @media screen and (max-width: 768px) {
        .safe-guard-{{ section.id }} .img-asp{
          /* aspect-ratio: 3 / 3; */
        }
      .safe-guard-{{ section.id }} .r-item .primary-img{
        aspect-ratio: auto !important; 
      }
      .safe-guard-{{ section.id }} .s-g-content{
        grid-template-rows: 1fr;
        gap: 10px;
      }
      .safe-guard-{{ section.id }} .s-g-content .right-c-box .r-c-b-content,
      .safe-guard-{{ section.id }} .s-g-content .right-c-box,
      .safe-guard-{{ section.id }} .s-g-content .left-c-box .l-c-b-content,
      .safe-guard-{{ section.id }} .s-g-content .left-c-box{
        gap: 10px;
      }
      
      .safe-guard-{{ section.id }} .l-item,
      .safe-guard-{{ section.id }} .r-item{
        min-height: 170px;
        background-color: #fff;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        justify-content:flex-end;
      }

      .safe-guard-{{ section.id }} .r-item.r-item-long{
        min-height: 287px;
        background-color: #f2f2f2;
      }

      .safe-guard-{{ section.id }} .mb-br-hid{
        display: none;
      }
    .safe-guard-{{ section.id }} .des-br-hid{
      display: block;
    }
      
      
     }
   
    </style>

  <!-- 移动端轮播样式 -->
  <style>
    .jingva-lg{
      display: block;
    }
    .jingva-md{
      display: none;
    }

    /* 移动端轮播样式 */
    .safe-guard-{{ section.id }} .mobile-carousel {
      position: relative;
      width: 100%;
      
      margin: 0 auto;
      overflow: hidden;
      border-radius: 12px;
    }

    .safe-guard-{{ section.id }} .carousel-container {
      position: relative;
      width: 100%;
      height: 300px;
    }

    .safe-guard-{{ section.id }} .carousel-track {
      display: flex;
      transition: transform 0.3s ease-in-out;
      height: 100%;
    }

    .safe-guard-{{ section.id }} .carousel-slide {
      min-width: 100%;
      height: 100%;
      position: relative;
      background: #ffffff;
      border-radius: 12px;
      overflow: hidden;

      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .safe-guard-{{ section.id }} .carousel-slide a {
      display: block;
      height: 100%;
      text-decoration: none;
      color: inherit;
      width: 100%;
    }

    .safe-guard-{{ section.id }} .slide-icon {
      width: 75px;
      height: 75px;
      margin: 0 auto 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 24px;
    }

    .safe-guard-{{ section.id }} .slide-content h3 {
      font-size: 15px;
      font-weight: 700;
      color: #000000;
      line-height: 1.3;
      font-family: 'HarmonyOS-Sans-SC';
     
    }

    .safe-guard-{{ section.id }} .slide-content h3 .red-text {
      color: #e1040f;
    }

    .safe-guard-{{ section.id }} .slide-content p {
      font-size: 13px;
      color: #545454;
      line-height: 1.4;
    }

    .safe-guard-{{ section.id }} .play-button {
      width: 16px;
      height: 13px;
      border: 1.5px solid #e1040f;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto;
      margin-bottom: 16px;
      margin-top: 8px;
    }

    /* 导航箭头 */
    .safe-guard-{{ section.id }} .carousel-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 10;
      transition: all 0.3s ease;
      color: #929292;
    }

    .safe-guard-{{ section.id }} .carousel-nav:hover {
      background: #ffffff;
      color: #000000;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .safe-guard-{{ section.id }} .carousel-prev {
      left: 10px;
    }

    .safe-guard-{{ section.id }} .carousel-next {
      right: 10px;
    }

    .safe-guard-{{ section.id }} .carousel-nav:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    /* 分页指示器 */
    .safe-guard-{{ section.id }} .carousel-dots {
      /* display: flex; */
      display: none;
      justify-content: center;
      gap: 8px;
      margin-top: 20px;
    }

    .safe-guard-{{ section.id }} .carousel-dots .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: none;
      background: #d0d0d0;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .safe-guard-{{ section.id }} .carousel-dots .dot.active {
      background: #e1040f;
      transform: scale(1.2);
    }

    .safe-guard-{{ section.id }} .carousel-dots .dot:hover {
      background: #ff6666;
    }

    @media screen and (max-width: 990px) {
      .jingva-lg{
        display: none;
      }
      .jingva-md{
        display: block;
      }

      .safe-guard-{{ section.id }} .carousel-container {
        height: 260px;
      }
    }
  </style>

