{% liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign autoplay = se_stts.autoplay
  assign default_duration = se_stts.default_duration
  assign show_arrows = se_stts.show_arrows
  assign show_dots = se_stts.show_dots
  if section.blocks.size <= 1
    assign show_dots = false
  endif
%}
{% capture default_sid %}.jingva-section-container-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-section-container-{{ sid }} {{ section.settings.section_css }}">
  {% style %}
    {{ default_sid }} {
      position: relative;
      width: 100%;
      overflow: hidden;
    }

    {{ default_sid }} .jingva-hero-slider.swiper {
      position: relative;
      width: 100%;
      height: 90vh;
    }

    {{ default_sid }} .jingva-hero-slider.swiper-fade .swiper-slide {
      pointer-events: none;
      z-index: 1 !important;
    }

    {{ default_sid }} .jingva-hero-slider.swiper-fade .swiper-slide-active {
      pointer-events: auto;
      z-index: 2 !important;
    }

    {{ default_sid }} .jingva-hero-slide-inner {
      position: relative;
      width: 100%;
      height: 100%;
    }

    {{ default_sid }} .jingva-hero-media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* 背景图/视频：hover 轻微放大 + 遮罩（精细指针设备启用，避免移动端误触） */
    {{ default_sid }} .jingva-hero-media::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.12);
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      z-index: 1;
    }

    {{ default_sid }} .jingva-hero-media__inner {
      width: 100%;
      height: 100%;
      transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    }

    {{ default_sid }} .jingva-hero-media img,
    {{ default_sid }} .jingva-hero-media video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* 图片+视频 同时存在：图片作为封面，视频加载成功后淡入覆盖在上层 */
    {{ default_sid }} .jingva-hero-poster {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    {{ default_sid }} .jingva-hero-video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
    }

    {{ default_sid }} .jingva-hero-video.is-ready {
      opacity: 1;
    }

    @media (hover: hover) and (pointer: fine) {
      {{ default_sid }} .jingva-hero-slide-active .jingva-hero-slide-inner:hover .jingva-hero-media::after {
        opacity: 1;
      }
      {{ default_sid }} .jingva-hero-slide-active .jingva-hero-slide-inner:hover .jingva-hero-media__inner {
        transform: scale(1.045);
      }
    }

    {{ default_sid }} .jingva-hero-content {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
      padding: 144px 0 120px;
      box-sizing: border-box;
      z-index: 2;
    }

    @media screen and (max-width: 1279px) {
      {{ default_sid }} .jingva-hero-content {
        padding: 100px 16px 24px;
      }
    }

    {{ default_sid }} .jingva-hero-title-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      width: 1200px;
      max-width: 100%;
    }

    {{ default_sid }} .jingva-hero-title {
      font-family: 'Orbitron', sans-serif !important;
      font-weight: 900 !important;
      font-size: 48px !important;
      line-height: 1.254 !important;
      text-transform: none !important;
      text-align: center !important;
      color: #FFFFFF !important;
      margin: 0 !important;
      width: 100%;
      opacity: 0;
    }

    {{ default_sid }} .swiper-slide-active .jingva-hero-title,
    {{ default_sid }} .jingva-hero-title.aos-animate {
      opacity: 1;
      transition: opacity 0.4s ease 0.1s;
      will-change: opacity;
    }

    {{ default_sid }} .jingva-hero-buttons {
      display: flex !important;
      justify-content: center !important;
      gap: 10px !important;
      margin-top: 0 !important;
      opacity: 0;
    }

    {{ default_sid }} .swiper-slide-active .jingva-hero-buttons,
    {{ default_sid }} .jingva-hero-buttons.aos-animate {
      opacity: 1;
      transition: opacity 0.4s ease 0.15s;
      will-change: opacity;
    }

    /* Figma：小圆角矩形（非胶囊）；主 Learn More 白底实色无边框，次 Buy Now 透明 + 白边白字 */
    {{ default_sid }} .jingva-hero-btn {
      font-family: 'Orbitron', sans-serif !important;
      font-weight: 700 !important;
      font-size: 16px !important;
      line-height: 1.2 !important;
      text-transform: none !important;
      text-align: center !important;
      border-radius: 6px !important;
      padding: 12px 20px !important;
      min-height: 48px !important;
      display: inline-flex !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 8px !important;
      text-decoration: none !important;
      box-sizing: border-box !important;
      cursor: pointer !important;
      transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.15s ease !important;
      -webkit-tap-highlight-color: transparent;
    }

    {{ default_sid }} .jingva-hero-btn-primary {
      background-color: #ffffff !important;
      color: #0a0a0a !important;
      border: 1px solid transparent !important;
    }

    {{ default_sid }} .jingva-hero-btn-primary:hover {
      background-color: #f0f0f0 !important;
      color: #0a0a0a !important;
    }

    {{ default_sid }} .jingva-hero-btn-primary:active {
      transform: scale(0.97);
    }

    {{ default_sid }} .jingva-hero-btn-secondary {
      background-color: transparent !important;
      color: #ffffff !important;
      border: 1px solid #ffffff !important;
    }

    /* KV / Buy Now：透明白边 → Hover 品牌红实底白字 */
    {{ default_sid }} .jingva-hero-btn-secondary:hover {
      background-color: #d6000d !important;
      color: #ffffff !important;
      border-color: #d6000d !important;
    }

    {{ default_sid }} .jingva-hero-btn-secondary:active {
      transform: scale(0.97);
    }

    {{ default_sid }} .jingva-hero-nav-layer {
      position: absolute !important;
      inset: 0 !important;
      z-index: 5 !important;
      pointer-events: none !important;
    }

    {{ default_sid }} .jingva-hero-arrows {
      position: absolute !important;
      top: 60% !important;
      transform: translateY(-50%) !important;
      left: 0 !important;
      right: 0 !important;
      display: flex !important;
      justify-content: space-between !important;
      align-items: center !important;
      padding: 0 48px !important;
      box-sizing: border-box !important;
      pointer-events: none !important;
    }

    {{ default_sid }} .jingva-hero-arrow {
      width: 48px !important;
      height: 48px !important;
      border-radius: 12px !important;
      background-color: #ffffff !important;
      display: flex !important;
      justify-content: center !important;
      align-items: center !important;
      cursor: pointer !important;
      pointer-events: auto !important;
      transition: background-color 0.3s ease, transform 0.15s ease, border-color 0.3s ease !important;
    }

    /* 线框 Tab 悬浮：浅灰底 #e8e8e8、去边框、图标保持黑色 */
    {{ default_sid }} .jingva-hero-arrow:hover {
      background-color: #e8e8e8 !important;
      border-color: transparent !important;
    }

    {{ default_sid }} .jingva-hero-arrow:active {
      transform: scale(0.94);
    }

    {{ default_sid }} .jingva-hero-arrow svg {
      width: auto !important;
      height: auto !important;
      transition: fill 0.3s ease !important;
    }

    {{ default_sid }} .jingva-hero-arrow .icon-pc {
      display: block !important;
    }

    {{ default_sid }} .jingva-hero-arrow .icon-mobile {
      display: none !important;
    }

    /* 底部仅保留居中圆点指示器（无侧栏文案） */
    {{ default_sid }} .jingva-hero-bottom-ui {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 24px;
      z-index: 6;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }

    {{ default_sid }} .jingva-hero-dots {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      pointer-events: auto;
    }

    /* 底部分段指示：PC 48×2，Figma 规范 */
    {{ default_sid }} .jingva-hero-dot {
      width: 48px;
      height: 2px;
      border-radius: 999px;
      padding: 0;
      border: none;
      cursor: pointer;
      background: rgba(255, 255, 255, 0.6);
      transition: background-color 0.3s ease;
    }

    {{ default_sid }} .jingva-hero-dot.is-active {
      background: #d6000d;
    }

    @media screen and (max-width: 1279px) {
      {{ default_sid }} .jingva-hero-slider.swiper {
        height: 640px;
      }

      {{ default_sid }} .jingva-hero-content {
        padding: 100px 16px 24px;
      }

      {{ default_sid }} .jingva-hero-title-group {
        width: 358px;
        max-width: 100%;
        gap: 12px;
      }

      {{ default_sid }} .jingva-hero-title {
        font-size: 28px !important;
      }

      {{ default_sid }} .jingva-hero-btn {
        font-size: 14px !important;
        border-radius: 6px !important;
        padding: 12px !important;
        min-height: 40px !important;
        gap: 6px !important;
      }

      {{ default_sid }} .jingva-hero-arrows {
        padding: 0 16px !important;
        top: 68% !important;
      }

      {{ default_sid }} .jingva-hero-arrow {
        width: 36px !important;
        height: 36px !important;
        border-radius: 6px !important;
      }

      {{ default_sid }} .jingva-hero-arrow .icon-pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-hero-arrow .icon-mobile {
        display: block !important;
      }

      {{ default_sid }} .jingva-hero-dot {
        width: 32px !important;
        height: 2px !important;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      {{ default_sid }} .jingva-hero-title,
      {{ default_sid }} .jingva-hero-buttons {
        transition: none !important;
      }
      {{ default_sid }} .jingva-hero-media__inner {
        transition: none !important;
      }
      {{ default_sid }} .jingva-hero-media::after {
        transition: none !important;
      }
      {{ default_sid }} .jingva-hero-btn,
      {{ default_sid }} .jingva-hero-arrow {
        transition: none !important;
      }
    }
  {% endstyle %}

  <div
    class="jingva-hero-slider swiper jingva-hero-swiper-{{ sid }}"
    id="jingvaHeroSlider{{ sid }}"
    data-total-slides="{{ section.blocks.size }}"
  >
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide jingva-hero-slide" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="jingva-hero-slide-inner">
            <div class="jingva-hero-media">
              <div class="jingva-hero-media__inner">
                {%- liquid
                  assign has_video = false
                  if block.settings.video_mp4 != blank
                    assign has_video = true
                  endif
                  assign has_image = false
                  if block.settings.image != blank
                    assign has_image = true
                  endif
                -%}

                {%- comment -%} 图片封面：当同时存在图片和视频时作为 poster；仅图片时作为唯一展示 {%- endcomment -%}
                {% if has_image and has_video %}
                  <picture class="jingva-hero-poster">
                    {% if block.settings.image_mb != blank %}
                      <source srcset="{{ block.settings.image_mb | image_url: width: 750 }}" media="(max-width: 1279px)">
                    {% endif %}
                    <img
                      src="{{ block.settings.image | image_url: width: 2400 }}"
                      alt="{{ block.settings.image.alt }}"
                      width="{{ block.settings.image.width | default: 2400 }}"
                      height="{{ block.settings.image.height | default: 1350 }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    >
                  </picture>
                {% elsif block.settings.type == 'image' and has_image %}
                  <picture>
                    {% if block.settings.image_mb != blank %}
                      <source srcset="{{ block.settings.image_mb | image_url: width: 750 }}" media="(max-width: 1279px)">
                    {% endif %}
                    <img
                      src="{{ block.settings.image | image_url: width: 2400 }}"
                      alt="{{ block.settings.image.alt }}"
                      width="{{ block.settings.image.width | default: 2400 }}"
                      height="{{ block.settings.image.height | default: 1350 }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    >
                  </picture>
                {% elsif block.settings.type == 'creditcard' %}
                  <picture>
                    {% if block.settings.image_mb != blank %}
                      <source srcset="{{ block.settings.image_mb | image_url: width: 750 }}" media="(max-width: 1279px)">
                    {% endif %}
                    <img
                      src="{{ 'autofull/creditcard.svg' | asset_url }}"
                      alt="Credit Card"
                      width="2400"
                      height="1350"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    >
                  </picture>
                {% endif %}

                {%- comment -%} 视频层：加载成功后淡入；与图片共存时叠加在图片上方 {%- endcomment -%}
                {% if has_video %}
                  <div class="jingva-hero-video{% unless has_image %} is-ready{% endunless %}" data-jingva-video>
                    {{
                      block.settings.video_mp4
                      | video_tag:
                        autoplay: true,
                        loop: true,
                        muted: true,
                        playsinline: true,
                        preload: 'auto'
                    }}
                  </div>
                {% endif %}
              </div>
            </div>

            <div class="jingva-hero-content">
              <div class="jingva-hero-title-group">
                {% if block.settings.title != blank %}
                  <h2 class="jingva-hero-title">{{ block.settings.title }}</h2>
                {% endif %}

                {% if block.settings.btn1_text != blank or block.settings.btn2_text != blank %}
                  <div class="jingva-hero-buttons">
                    {% if block.settings.btn1_text != blank %}
                      <a href="{{ block.settings.btn1_link | default: '#' }}" class="jingva-hero-btn jingva-hero-btn-primary">
                        {{ block.settings.btn1_text }}
                      </a>
                    {% endif %}
                    {% if block.settings.btn2_text != blank %}
                      <a href="{{ block.settings.btn2_link | default: '#' }}" class="jingva-hero-btn jingva-hero-btn-secondary">
                        {{ block.settings.btn2_text }}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if show_arrows and section.blocks.size > 1 %}
      <div class="jingva-hero-nav-layer">
        <div class="jingva-hero-arrows">
          <button type="button" class="jingva-hero-arrow jingva-hero-prev" aria-label="Previous slide">
            <svg class="icon-pc" xmlns="http://www.w3.org/2000/svg" width="10" height="16" viewBox="0 0 10 16" fill="none">
              <path d="M0 7.70703L7.70703 15.4141L9.12109 14L2.82812 7.70703L9.12109 1.41406L7.70703 0L0 7.70703Z" fill="#0A0A0A"/>
            </svg>
            <svg class="icon-mobile" xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none">
              <path d="M0 5.1377L5.1377 10.2754L6.08105 9.33301L1.88574 5.1377L6.08105 0.942383L5.1377 0L0 5.1377Z" fill="#0A0A0A"/>
            </svg>
          </button>
          <button type="button" class="jingva-hero-arrow jingva-hero-next" aria-label="Next slide">
            <svg class="icon-pc" xmlns="http://www.w3.org/2000/svg" width="10" height="16" viewBox="0 0 10 16" fill="none">
              <path d="M9.12109 7.70703L1.41406 15.4141L0 14L6.29297 7.70703L0 1.41406L1.41406 0L9.12109 7.70703Z" fill="#0A0A0A"/>
            </svg>
            <svg class="icon-mobile" xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none">
              <path d="M6.08105 5.1377L0.943359 10.2754L0 9.33301L4.19531 5.1377L0 0.942383L0.943359 0L6.08105 5.1377Z" fill="#0A0A0A"/>
            </svg>
          </button>
        </div>
      </div>
    {% endif %}

    {% if show_dots and section.blocks.size > 1 %}
      <div class="jingva-hero-bottom-ui">
        <div class="jingva-hero-dots">
          {% for block in section.blocks %}
            <button
              type="button"
              class="jingva-hero-dot{% if forloop.first %} is-active{% endif %}"
              data-jingva-dot
              data-index="{{ forloop.index0 }}"
              aria-label="Go to slide {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var slider = document.getElementById('jingvaHeroSlider{{ sid }}');
      if (!slider || typeof Swiper === 'undefined') return;

      var total = parseInt(slider.getAttribute('data-total-slides') || '0', 10);
      if (total < 1) return;

      var autoplayEnabled = {{ autoplay | json }};
      var duration = {{ default_duration | times: 1000 }};
      var fadeMs = {{ se_stts.transition_ms | default: 600 }};
      var enableLoop = total > 1;

      var prevBtn = slider.querySelector('.jingva-hero-prev');
      var nextBtn = slider.querySelector('.jingva-hero-next');
      var dots = slider.querySelectorAll('[data-jingva-dot]');

      // 尝试播放并在成功后给 wrap 标记 is-ready，让视频层淡入覆盖封面图
      function tryPlay(v) {
        if (!v) return;
        var wrap = v.closest('[data-jingva-video]');
        // 强制确保自动播放所需属性（部分浏览器只认 property，不认 attribute）
        v.muted = true;
        v.defaultMuted = true;
        v.playsInline = true;
        v.setAttribute('muted', '');
        v.setAttribute('playsinline', '');
        var p;
        try { p = v.play(); } catch (e) { p = null; }
        if (p && typeof p.then === 'function') {
          p.then(function () {
            if (wrap) wrap.classList.add('is-ready');
          }).catch(function () {
            // 自动播放被浏览器拦截：保留图片作为封面
            if (wrap) wrap.classList.remove('is-ready');
          });
        } else if (wrap) {
          // 旧浏览器无 Promise 返回：直接乐观标记
          wrap.classList.add('is-ready');
        }
      }

      // 为每个视频绑定 ready 监听：canplay / loadeddata / playing 任一触发即视为加载成功
      slider.querySelectorAll('[data-jingva-video]').forEach(function (wrap) {
        var v = wrap.querySelector('video');
        if (!v) return;

        var onReady = function () {
          tryPlay(v);
        };

        // 若视频已具备播放数据（命中缓存等），事件可能已经错过 → 直接尝试
        // readyState: 0 NOTHING / 1 METADATA / 2 CURRENT / 3 FUTURE / 4 ENOUGH
        if (v.readyState >= 3) {
          tryPlay(v);
        }

        v.addEventListener('canplay', onReady);
        v.addEventListener('loadeddata', onReady);
        v.addEventListener('playing', function () {
          wrap.classList.add('is-ready');
        });
        v.addEventListener('error', function () {
          wrap.classList.remove('is-ready');
        });

        // 主动触发加载（preload=auto 下也保险一手）
        try { v.load(); } catch (e) {}
      });

      function syncVideos(swiper) {
        slider.querySelectorAll('.jingva-hero-media video').forEach(function (v) {
          v.pause();
        });
        var active = swiper.slides[swiper.activeIndex];
        if (!active) return;
        var vid = active.querySelector('.jingva-hero-media video');
        if (vid) tryPlay(vid);
      }

      function updateDots(realIndex) {
        dots.forEach(function (btn, i) {
          btn.classList.toggle('is-active', i === realIndex);
        });
      }

      var autoplayConfig = false;
      if (autoplayEnabled && enableLoop) {
        autoplayConfig = {
          delay: duration,
          disableOnInteraction: false  // 点击后继续自动播放
        };
      }

      var swiperOptions = {
        observer: true,
        observeParents: true,
        slidesPerView: 1,
        spaceBetween: 0,
        loop: enableLoop,
        speed: fadeMs,
        effect: 'fade',
        fadeEffect: {
          crossFade: true
        },
        autoplay: autoplayConfig,
        on: {
          afterInit: function (sw) {
            syncVideos(sw);
            updateDots(sw.realIndex);
            
            // 首屏直接显示
            var firstSlide = sw.slides[sw.activeIndex];
            if (firstSlide) {
              var title = firstSlide.querySelector('.jingva-hero-title');
              var buttons = firstSlide.querySelector('.jingva-hero-buttons');
              if (title) title.classList.add('aos-animate');
              if (buttons) buttons.classList.add('aos-animate');
            }
          },
          slideChange: function (sw) {
            // 切换开始的瞬间立即更新底部圆点指示器，避免动画结束后才高亮
            updateDots(sw.realIndex);
          },
          slideChangeTransitionStart: function (sw) {
            // 切换开始时，隐藏所有幻灯片的文字内容
            sw.slides.forEach(function(slide) {
              var title = slide.querySelector('.jingva-hero-title');
              var btns = slide.querySelector('.jingva-hero-buttons');
              if (title) title.classList.remove('aos-animate');
              if (btns) btns.classList.remove('aos-animate');
            });
          },
          slideChangeTransitionEnd: function (sw) {
            syncVideos(sw);
            
            // 切换结束后，重新触发当前幻灯片的动画
            var activeSlide = sw.slides[sw.activeIndex];
            if (!activeSlide) return;
            
            var title = activeSlide.querySelector('.jingva-hero-title');
            var btns = activeSlide.querySelector('.jingva-hero-buttons');
            
            // 使用 setTimeout 确保动画重新触发
            setTimeout(function() {
              if (title) title.classList.add('aos-animate');
              if (btns) {
                setTimeout(function() {
                  btns.classList.add('aos-animate');
                }, 100);
              }
            }, 50);
          }
        }
      };

      if (prevBtn && nextBtn) {
        swiperOptions.navigation = {
          nextEl: nextBtn,
          prevEl: prevBtn
        };
      }

      var swiper = new Swiper(slider, swiperOptions);

      function goToIndex(index) {
        if (enableLoop) {
          swiper.slideToLoop(index);
        } else {
          swiper.slideTo(index);
        }
      }

      dots.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var idx = parseInt(btn.getAttribute('data-index') || '0', 10);
          goToIndex(idx);
          if (swiper.autoplay && swiper.autoplay.running) {
            swiper.autoplay.stop();
            swiper.autoplay.start();
          }
        });
      });

      // 只在鼠标悬停在箭头按钮上时暂停
      var arrows = slider.querySelectorAll('.jingva-hero-arrow');
      arrows.forEach(function(arrow) {
        arrow.addEventListener('mouseenter', function () {
          if (swiper.autoplay && swiper.autoplay.running) swiper.autoplay.stop();
        });
        arrow.addEventListener('mouseleave', function () {
          if (autoplayEnabled && enableLoop && swiper.autoplay) swiper.autoplay.start();
        });
      });
    });
  </script>
</section>

