{% schema %}
{
  "name": "Kiks Buy More",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "coupons_title",
      "label": "Coupons heading",
      "default": "Heading"
    },
    {
      "type": "richtext",
      "id": "coupons_content",
      "label": "Coupons content"
    },
    {
      "type": "text",
      "id": "wheel_title",
      "label": "Wheel heading",
      "default": "Heading"
    },
    {
      "type": "textarea",
      "id": "wheel_content",
      "label": "Wheel content"
    },
    {
      "type": "image_picker",
      "id": "wheel_image",
      "label": "Wheel image"
    },
    {
      "type": "url",
      "id": "wheel_link_1",
      "label": "Wheel link 1"
    },
    {
      "type": "text",
      "id": "wheel_link_1_text",
      "label": "Wheel link 1 text"
    },
    {
      "type": "url",
      "id": "wheel_link_2",
      "label": "Wheel link 2"
    },
    {
      "type": "text",
      "id": "wheel_link_2_text",
      "label": "Wheel link 2 text"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Gradient replaces solid colors when set."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "text",
      "id": "wheel_rules_heading",
      "label": "Wheel rules heading",
      "default": "Heading"
    },
    {
      "type": "richtext",
      "id": "wheel_rules_content",
      "label": "Wheel rules content",
      "default": "<p>Content</p>"
    }
  ],
  "blocks": [
    {
      "name": "Coupon",
      "type": "coupon",
      "limit": 9,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Title"
        },
        {
          "type": "text",
          "id": "discount-type",
          "label": "Discount Type",
          "default": "OFF"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
    ],
  "presets": [
    {
      "name": "Kiks Buy More",
      "blocks": [

      ]
    }
  ]
}
{% endschema %}
