<div {% if section.settings.section_id != blank %}id="{{ section.settings.section_id | downcase | replace: ' ', '_' }}" {% endif %}{% render 'kiks-section-properties', narrow: section.settings.reduce_width, enable_column_layout: section.settings.enable_column_layout %}>
    {%- render 'kiks-section-header', subheading: section.settings.subheading, heading: section.settings.title, content: section.settings.content, text_alignment: section.settings.text_alignment, style: section.settings.heading_tag-%}
  <kiks-media-grid class="{% if section.settings.enable_collage %}media-flex{% else %}media-grid{% endif %}">
    {%- for block in section.blocks -%}
      <a {% if block.settings.link_url != blank %}href="{{ block.settings.link_url }}"{% endif %} class="media-grid__item shadow group" reveal-js style="--media-grid-column-span: {{ block.settings.desktop_column_span }}; --media-grid-row-span: {{ block.settings.desktop_row_span }}" {{ block.shopify_attributes }}>
        <div id="media-grid-{{ block.id }}" {% render 'surface', class: 'content-over-media rounded', background: block.settings.background, background_gradient: block.settings.background_gradient %}>
          {%- liquid
            assign loading_strategy = nil
  
            if section.index > 3 or forloop.index > 3
              assign loading_strategy = 'lazy'
            endif
          -%}
          
          {%- case block.type -%}
            {%- when 'image' -%}
              {%- if block.settings.image -%}
                {%- capture sizes -%}(max-width: 699px) 100vw, min({{ 390 | times: block.settings.desktop_column_span }}px, {{ 25 | times: block.settings.desktop_column_span }}vw){%- endcapture -%}
                {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: loading_strategy, sizes: sizes, widths: '200,300,400,500,600,700,800,1000,1200,1400,1600,1800,2000,2200,2400', class: 'content-over-media__media zoom-image' -}}
              {%- endif -%}

            {%- when 'video' -%}
              {%- if block.settings.video -%}
                <video-media autoplay style="--aspect-ratio: auto">
                  {%- if block.settings.show_video_controls -%}
                    {%- assign loop_video = false -%}
                  {%- else -%}
                    {%- assign loop_video = true -%}
                  {%- endif -%}

                  {{- block.settings.video | video_tag: playsinline: true, muted: true, loop: loop_video, controls: block.settings.show_video_controls, preload: 'metadata', class: 'object-fill' -}}
                </video-media>
              {%- else -%}
                <video-media host="{{ block.settings.external_video_url.type }}" autoplay style="--aspect-ratio: auto">
                  <template>
                    {%- if block.settings.external_video_url.type == 'youtube' -%}
                      <iframe src="https://www.youtube.com/embed/{{ block.settings.external_video_url.id }}?playsinline=1&autoplay=1&controls=0&mute=1&loop=1&playlist={{ block.settings.external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}" allow="autoplay; encrypted-media" allowfullscreen="allowfullscreen"></iframe>
                    {%- elsif block.settings.external_video_url.type == 'vimeo' -%}
                      <iframe src="https://player.vimeo.com/video/{{ block.settings.external_video_url.id }}?autoplay=1&autopause=1&background=1&loop=1&muted=1&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}" allow="autoplay; encrypted-media;" allowfullscreen="allowfullscreen"></iframe>
                    {%- endif -%}
                  </template>
                </video-media>
              {%- endif -%}
          {%- endcase -%}

          {%- if block.settings.title != blank or block.settings.link_text != blank -%}
            <div class="kiks-overlay-content {{ block.settings.mobile_text_position }} {{ block.settings.desktop_text_position }}" style="justify-content: {{ block.settings.text_position }};text-align: {{ block.settings.align_position }};">
              <div class="prose">

              {%- if block.settings.subheading != blank -%}
                <p class="custom_font_family subheading" style="">
                  {% render 'styled-text', content: block.settings.subheading, gradient: block.settings.text_gradient, text_color: block.settings.sub_color %}
                </p>
              {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <p class="{{ block.settings.heading_tag }} heading">
                    {% render 'styled-text', content: block.settings.title, gradient: block.settings.text_gradient, text_color: block.settings.heading_color %}
                  </p>
                {%- endif -%}
                
                {%- if block.settings.content != blank -%}
                  <div  {{ block.shopify_attributes }} class="richtext-description rte kiks-custom-description" style="color: {{ block.settings.description_color }};">
                    {{- block.settings.content -}}
                  </div>
                {%- endif -%} 
                {%- if block.settings.link_text != blank -%}
                  {%- render 'button', size: 'lg', content: block.settings.link_text, background: block.settings.button_background, text_color: block.settings.button_text_color -%}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </kiks-media-grid>
</div>
{% if section.settings.enable_collage %}
  <script>
document.addEventListener("DOMContentLoaded", () => {
    const items = document.querySelectorAll(".media-grid__item");

    // Function to wrap or unwrap items based on screen size
    function handleGridLayout() {
        // Only run the logic if screen width is larger than 600px
        if (window.innerWidth > 600) {
            if (items.length >= 3) {
                // Create wrapper div only if it doesn't exist
                if (!document.querySelector(".media-grid__pair-wrapper")) {
                    const wrapper = document.createElement("div");
                    wrapper.classList.add("media-grid__pair-wrapper");

                    // Insert wrapper before the 2nd item
                    items[1].parentNode.insertBefore(wrapper, items[1]);

                    // Move 2nd and 3rd items into wrapper
                    wrapper.appendChild(items[1]);
                    wrapper.appendChild(items[2]);
                }
            }
        } else {
            // Remove the wrapper if screen width is less than 600px
            const wrapper = document.querySelector(".media-grid__pair-wrapper");
            if (wrapper) {
                // Move the 2nd and 3rd items out of the wrapper
                wrapper.parentNode.insertBefore(items[1], wrapper);
                wrapper.parentNode.insertBefore(items[2], wrapper);

                // Remove the wrapper
                wrapper.remove();
            }
        }
    }

    // Call the function when the page loads
    handleGridLayout();

    // Listen for window resize and adjust accordingly
    window.addEventListener("resize", handleGridLayout);
});

  </script>
{% endif %}
