{%- render 'section-spacing-collapsing' -%}
{%- assign section_identifier = '#shopify-section-' | append: section.id -%}
{%- assign  padding_top = section.settings.padding_top | append:'px' -%}
{%- assign  padding_bottom = section.settings.padding_bottom | append:'px' -%}

{%- assign padding_mobile_top = section.settings.padding_top_mob | append: 'px' -%}
{%- assign padding_mobile_bottom = section.settings.padding_bottom_mob | append: 'px' -%}
{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>

  #shopify-section-{{ section.id }} {
    --media-grid-row-height: {{ section.settings.mobile_row_height }}px;
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --media-grid-row-height: {{ section.settings.desktop_row_height }}px;
    }
  }

  {%- for block in section.blocks -%}
    #media-grid-{{ block.id }} {
      --content-over-media-overlay: {{ block.settings.overlay_color.rgb }} /{{ block.settings.overlay_opacity | divided_by: 100.0 }};

      {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
        --content-over-media-gap: 1rem;
      {%- endif -%}
    }

    {%- if block.settings.heading_tag == 'h5' or block.settings.heading_tag == 'h6' -%}
      @media screen and (min-width: 740px) {
        #media-grid-{{ block.id }} {
          --content-over-media-gap: 1.5rem;
        }
      }
    {%- endif -%}
  {%- endfor -%}
  
  /* {{ section_identifier }}.shopify-section--media-grid section-header.section-header {
      margin-bottom: 32px;
  } */

  {{ section_identifier }} .section {
    padding-top: {{padding_top}};
    padding-bottom: {{padding_bottom}};
  }
  {%- if section.settings.enable_column_layout -%}
    {{ section_identifier }}.shopify-section-kiks-media-grid .section.section-full section-header.section-header {
      margin-bottom: 32px;
  }
  {%- endif -%}


 @media only screen and (max-width: 430px) {
    {{ section_identifier }} .section {
      padding-top: {{ padding_mobile_top }};
      padding-bottom: {{ padding_mobile_bottom }};
    }
  }
/* Custom Css Added  */
{{ section_identifier }} kiks-media-grid.media-grid {
    margin-top: 50px;
}
{% if section.settings.enable_collage %}
  {{ section_identifier }} .kiks-media-grid {
    display: grid;
    align-items: center;
    max-width: 100%;
    grid-template-columns: 1fr 2fr;
    gap: 50px;
  }
{% endif %}

  {{ section_identifier }} .media-flex {
    gap: {{ section.settings.column_gap }}px;
    display: flex;
    align-items: center;
  }
  .media-flex .media-grid__pair-wrapper {
    display: flex;
    gap: {{ section.settings.column_gap }}px;
    flex-direction: column;
    width: 100%;
}
  {{ section_identifier }} .kiks-media-grid section-header.section-header{
    grid-template-columns: auto;
  }
  .kiks-media-grid .media-flex a.media-grid__item .content-over-media {
      --container-gutter: 20px;
  }
  .kiks-media-grid .media-flex a.media-grid__item .content-over-media .kiks-overlay-content {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .kiks-overlay-content .richtext-description.rte.kiks-custom-description, 
  .kiks-overlay-content p.heading {
      margin: 0;
  }
  .media-flex > a.media-grid__item {
      height: 535px;
      width: 100%;
  }
  .media-flex .media-grid__pair-wrapper a.media-grid__item:first-child {
      height: 320px;
  }
  .media-flex .media-grid__pair-wrapper a.media-grid__item:last-child {
      height: 230px;
  }
  @media only screen and (max-width: 820px) {
    {{ section_identifier }} .kiks-media-grid {
        grid-template-columns: unset;
        gap: 30px;
    }
  }
  @media only screen and (max-width: 600px) {
    {{ section_identifier }} .media-flex {
        gap: 15px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        overscroll-behavior-x: contain;
        scroll-behavior: smooth;
        padding-inline: 1.25rem;
        margin-inline: calc(1.25rem * -1);
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .media-flex > a.media-grid__item {
        height: 350px;
        flex: 0 0 90%;
    }
    {{ section_identifier }} .kiks-media-grid .media-flex a.media-grid__item .content-over-media .kiks-overlay-content {
      justify-content: flex-end !important;
      text-align: left !important;
    }
  }
  @media only screen and (max-width: 390px) {
    .media-flex > a.media-grid__item {
        flex: 0 0 95%;
    }
  }

</style>

{%- comment -%}
