<div class="section cold-cure-foam-section">
  <div class="cold-cure-foam-main" style="background-color: {{ section.settings.bg-color }};">
    <div class="cold-cure-foam-image">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: 'master' }}" alt="Cold-cure Foam">
      {% endif %}
    </div>
    <div class="cold-cure-foam-content">
      {% if section.settings.heading != blank %}
        <h4 class="cold-cure-heading h4">{{ section.settings.heading }}</h4>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <h3 class="cold-cure-subheading h3">{{ section.settings.subheading }}</h3>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="cold-cure-description">{{ section.settings.description }}</p>
      {% endif %}
      <div class="cold-cure-icons">
        {% assign block_count = section.blocks.size %}
        {% for block in section.blocks %}
          <div class="cold-cure-icon-item {% if block_count <= 3 %}cold-cure-item-three{% else %}cold-cure-item-multiple{% endif %}">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | img_url: 'master' }}" alt="Icon">
            {% endif %}
            {% if block.settings.icon_text != blank %}
              <p>{{ block.settings.icon_text }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<Style>
  .cold-cure-foam-section .cold-cure-foam-main { display: flex; gap: 30px; justify-content: space-between; }
  .cold-cure-foam-section .cold-cure-foam-image { width: calc(50% - 30px); } .cold-cure-foam-section
  .cold-cure-foam-content { width: calc(50% - 30px); padding-top: 79px; padding-right: 79px; padding: 50px 50px 50px 0;
  } .cold-cure-foam-section .cold-cure-icons { display: flex; align-items: center; flex-wrap: wrap; row-gap: 20px; }
  .cold-cure-foam-section .cold-cure-item-three { width: 50%; } .cold-cure-foam-section .cold-cure-item-multiple {
  width: 33.33%; } .cold-cure-foam-section h4.cold-cure-heading.h4{ color: #7a7a7a; margin-bottom: 25px; }
  .cold-cure-foam-section h3.cold-cure-subheading.h3 { margin-bottom: 30px; color: #fff; } .cold-cure-foam-section
  p.cold-cure-description { color: #c4c4c4; margin-bottom: 50px; } .cold-cure-foam-section .cold-cure-icon-item p {
  margin-top: 16px; color: #c4c4c4; } @media screen and (max-width: 768px) { .cold-cure-foam-section
  .cold-cure-foam-main{ flex-direction: column; } .cold-cure-foam-section .cold-cure-foam-image { width: 100%; }
  .cold-cure-foam-section .cold-cure-foam-content{ width: 100%; padding: 30px; }

  }
</Style>
{% schema %}
{
  "name": "kik Cold-cure Foam",
  "settings": [
    {
        "type": "color",
        "id": "bg-color",
        "label": "Background color"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cold-cure Foam"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "As Comfortable as Durable"
    },
    {
      "type": "html",
      "id": "description",
      "label": "Top Description"
    }
  ],
  "blocks": [
    {
      "type": "icon_block",
      "name": "Icon Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon Text",
          "default": "SGS Credited Durability"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "kik Cold-cure Foam"
    }
  ]
}
{% endschema %}
