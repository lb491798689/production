0.0891 6.37643 20.0536 0H27.8516Z" fill="#FFA8CD"/>
          </svg>
        {% endif %}
      </div>
      
      <p class="jingva-klarna-text">{{ se_stts.klarna_text | default: 'Flexible payments - Monthly options with rates as low as 0% APR' }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Jingva Klarna Payment",
  "class": "shopify-section--jingva-klarna-payment",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Klarna支付"
    },
    {
      "type": "image_picker",
      "id": "klarna_logo",
      "label": "Klarna Logo"
    },
    {
      "type": "text",
      "id": "klarna_text",
      "label": "支付说明文字",
      "default": "Flexible payments - Monthly options with rates as low as 0% APR"
    }
  ],
  "presets": [
    {
      "name": "Jingva Klarna Payment"
    }
  ]
}
{% endschema %}
