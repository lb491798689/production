{% liquid
  assign sid = section.id
  assign se_stts = section.settings
%}
{% capture default_sid %}.jingva-section-container-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-section-container-{{sid}}">
  {% style %}
    {{ default_sid }} {
      position: relative !important;
      width: 100% !important;
      overflow: hidden !important;
      background-color: #121212 !important;
      padding: 70px 0 0 !important;
    }
    
    {{ default_sid }} .jingva-klarna-wrapper {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 48px !important;
      width: 100% !important;
      max-width: 1200px !important;
      margin: 0 auto !important;
    }
    
    {{ default_sid }} .jingva-klarna-card {
      display: flex !important;
      flex-direction: row !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 102px !important;
      padding: 24px 48px !important;
      background-color: #383838 !important;
      border-radius: 12px !important;
      width: 100% !important;
      max-width: 1200px !important;
      height: 70px !important;
      box-sizing: border-box !important;
    }
    
    {{ default_sid }} .jingva-klarna-logo {
      width: 185.95px !important;
      height: 74.38px !important;
      flex-shrink: 0 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
    
    {{ default_sid }} .jingva-klarna-logo svg,
    {{ default_sid }} .jingva-klarna-logo img {
      width: 100% !important;
      height: 100% !important;
      fill: #FFFFFF !important;
      object-fit: contain !important;
    }
    
    {{ default_sid }} .jingva-klarna-text {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 24px !important;
      line-height: 1.2 !important;
      text-align: center !important;
      color: #FFFFFF !important;
      margin: 0 !important;
    }
    
    /* === MOB: 375~1279 === */
    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        padding: 0 !important;
      }
      
      {{ default_sid }} .jingva-klarna-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 12px !important;
        width: 100% !important;
        max-width: none !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding: 24px 16px !important;
        box-sizing: border-box !important;
      }
      
      {{ default_sid }} .jingva-klarna-card {
        display: flex !important;
        flex-direction: column !important;
        justify-content: center !important;
        align-items: center !important;
        gap: 12px !important;
        padding: 24px 16px !important;
        background-color: #282828 !important;
        border-radius: 8px !important;
        width: 100% !important;
        max-width: none !important;
        height: auto !important;
      }
      
      {{ default_sid }} .jingva-klarna-logo {
        width: 106.5px !important;
        height: 24px !important;
        border-radius: 24px !important;
      }
      
      {{ default_sid }} .jingva-klarna-logo svg,
      {{ default_sid }} .jingva-klarna-logo img {
        width: 100% !important;
        height: 100% !important;
      }
      
      {{ default_sid }} .jingva-klarna-text {
        font-size: 16px !important;
        width: 100% !important;
      }
    }

    /* === PAD: 1280~1439 === */
    @media screen and (min-width: 1280px) and (max-width: 1439px) {
      {{ default_sid }} {
        padding: 60px 40px 120px !important;
      }

      {{ default_sid }} .jingva-klarna-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        gap: 60px !important;
        width: 100% !important;
        max-width: 1200px !important;
        margin: 0 auto !important;
      }

      {{ default_sid }} .jingva-klarna-card {
        display: flex !important;
        flex-direction: row !important;
        justify-content: center !important;
        align-items: center !important;
        gap: 102px !important;
        padding: 24px 40px !important;
        background-color: #383838 !important;
        border-radius: 12px !important;
        width: 100% !important;
        max-width: 1200px !important;
        height: 70px !important;
        box-sizing: border-box !important;
      }

      {{ default_sid }} .jingva-klarna-logo {
        width: 185.95px !important;
        height: 74.38px !important;
        flex-shrink: 0 !important;
      }

      {{ default_sid }} .jingva-klarna-logo svg,
      {{ default_sid }} .jingva-klarna-logo img {
        width: 100% !important;
        height: 100% !important;
        fill: #FFFFFF !important;
        object-fit: contain !important;
      }

      {{ default_sid }} .jingva-klarna-text {
        font-family: 'Gabarito', sans-serif !important;
        font-weight: 500 !important;
        font-size: 24px !important;
        line-height: 1.2 !important;
        text-align: center !important;
        color: #FFFFFF !important;
        margin: 0 !important;
      }
    }

    /* === PC: 1440~2560 === */
    @media screen and (min-width: 1440px) {
      {{ default_sid }} {
        padding: 70px 48px 0 !important;
      }
      
      {{ default_sid }} .jingva-klarna-wrapper {
        gap: 48px !important;
      }
      
      {{ default_sid }} .jingva-klarna-card {
        padding: 24px 48px !important;
      }
    }
  {% endstyle %}

  <div class="jingva-klarna-wrapper">
    <div class="jingva-klarna-card">
      <div class="jingva-klarna-logo">
        {% if se_stts.klarna_logo %}
          <img src="{{ se_stts.klarna_logo | image_url: width: 400 }}" alt="Klarna" style="width: 100%; height: 100%; object-fit: contain;">
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" width="159" height="36" viewBox="0 0 159 36" fill="none">
