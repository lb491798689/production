{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign title = se_stts.title
  assign bg_color = se_stts.bg_color
  assign bg_color_mob = se_stts.bg_color_mob | default: bg_color
  assign theme = se_stts.theme | default: 'dark'
  if theme == 'light'
    assign title_color = '#0A0A0A'
  else
    assign title_color = '#FFFFFF'
  endif
-%}
{% capture default_sid %}.jingva-m6-armrest-support-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-m6-armrest-support-{{ sid }}" data-section-id="{{ sid }}">
  {% style %}
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color | default: '#000000' }} !important;
      padding: 0 !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-armrest-support-wrapper {
      position: relative !important;
      width: 100% !important;
      max-width: 1200px !important;
      margin: 0 auto !important;
      padding: 160px 0 0 0 !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-armrest-support-title {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 600 !important;
      font-size: 48px !important;
      line-height: 1.2 !important;
      color: {{ title_color }} !important;
      text-align: center !important;
      margin: 0 0 24px 0 !important;
      width: 100% !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-m6-armrest-support-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-m6-armrest-support-title.mob-title {
      display: none !important;
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 20px !important;
      line-height: normal !important;
      color: {{ title_color }} !important;
      text-align: center !important;
      margin: 0 0 24px 0 !important;
      width: 100% !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-m6-armrest-support-title.mob-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-m6-armrest-support-swiper {
      position: relative !important;
      width: 100% !important;
      overflow: hidden !important;
    }

    {{ default_sid }} .jingva-m6-armrest-support-swiper-wrapper {
      display: flex !important;
      width: 100% !important;
      transition-timing-function: ease-out !important;
      transition-duration: 0.3s !important;
    }

    {{ default_sid }} .jingva-m6-armrest-support-slide {
      width: 100% !important;
      flex-shrink: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
    }

    {{ default_sid }} .jingva-m6-armrest-support-image {
      width: 100% !important;
      max-width: 1200px !important;
      height: 640px !important;
      object-fit: cover !important;
      object-position: center !important;
      border-radius: 12px !important;
    }

    {{ default_sid }} .jingva-m6-armrest-support-image.mob-image {
      display: none !important;
    }

    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        background-color: {{ bg_color_mob | default: '#000000' }} !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-wrapper {
        padding: 96px 0 0 0 !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-title {
        display: none !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-title.mob-title {
        display: block !important;
        font-size: 24px !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-image.pc-image {
        display: none !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-image.mob-image {
        display: block !important;
        height: 480px !important;
        max-width: none !important;
        width: calc(100% - 32px) !important;
        margin: 0 16px !important;
      }
    }

    {{ default_sid }} .jingva-m6-armrest-support-pagination {
      display: flex !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 8px !important;
      position: relative !important;
      margin-top: 24px !important;
    }

    {{ default_sid }} .swiper-pagination-bullet {
      width: 12px !important;
      height: 12px !important;
      background: #D9D9D9 !important;
      opacity: 1 !important;
      margin: 0 4px !important;
    }

    {{ default_sid }} .swiper-pagination-bullet-active {
      background: #E90202 !important;
    }

    @media screen and (max-width: 1279px) {
      {{ default_sid }} .jingva-m6-armrest-support-wrapper {
        padding: 68px 0 0 0 !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-title {
        display: none !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-image {
        height: 408px !important;
        max-width: 390px !important;
      }

      {{ default_sid }} .jingva-m6-armrest-support-pagination {
        margin-top: 20px !important;
      }

      {{ default_sid }} .swiper-pagination-bullet {
        width: 8px !important;
        height: 8px !important;
        margin: 0 !important;
      }
    }
  {% endstyle %}

  <div class="jingva-m6-armrest-support-wrapper">
    <h2 class="jingva-m6-armrest-support-title">{{ title | default: 'Linked Adjustment, Full Support' }}</h2>
    <h2 class="jingva-m6-armrest-support-title mob-title">{{ title | default: 'Linked Adjustment, Full Support' }}</h2>

    <div class="jingva-m6-armrest-support-swiper swiper">
      <div class="jingva-m6-armrest-support-swiper-wrapper swiper-wrapper">
        {% for block in section.blocks %}
          <div class="jingva-m6-armrest-support-slide swiper-slide">
            {% if block.settings.pc_image %}
              <img class="jingva-m6-armrest-support-image pc-image" src="{{ block.settings.pc_image | image_url: width: 1920 }}" alt="{{ title | default: 'Linked Adjustment, Full Support' }}" width="1200" height="640">
            {% endif %}
            {% if block.settings.mob_image %}
              <img class="jingva-m6-armrest-support-image mob-image" src="{{ block.settings.mob_image | image_url: width: 780 }}" alt="{{ title | default: 'Linked Adjustment, Full Support' }}" width="390" height="408">
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="jingva-m6-armrest-support-pagination swiper-pagination"></div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiper = new Swiper('.jingva-m6-armrest-support-{{ sid }} .swiper', {
      slidesPerView: 1,
      spaceBetween: 0,
      pagination: {
        el: '.jingva-m6-armrest-support-{{ sid }} .jingva-m6-armrest-support-pagination',
        clickable: true,
      },
    });
  });
</script>

<script>
(function() {
  var section = document.querySelector('.jingva-m6-armrest-support-{{ sid }}');
  if (!section) return;

  var titles = section.querySelectorAll('.jingva-m6-armrest-support-title');
  if (!titles.length) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('aos-animate');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  titles.forEach(function(title) {
    observer.observe(title);
  });
})();
</script>

{% schema %}
{
  "name": "Jingva M6 Armrest Support",
  "tag": "section",
  "class": "jingva-m6-armrest-support-section",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Linked Adjustment, Full Support"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        { "value": "dark", "label": "Dark (white title)" },
        { "value": "light", "label": "Light (dark title)" }
      ],
      "default": "dark",
      "info": "Switches the title color. Background color is set separately below."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "PC Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color_mob",
      "label": "Mobile Background Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "mob_image",
          "label": "Mobile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jingva M6 Armrest Support",
      "category": "Jingva",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
