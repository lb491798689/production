  <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  // 丝滑无限匀速滚动 + 允许拖动（悬停/触摸时暂停，移开/松开恢复）
  let swiper{{ section.id | slice: -3, 3 }} = new Swiper('.swiper-container-carousel-{{section.id}}', {
    slidesPerView: 6,
    spaceBetween: 15,
    loop: true,
    speed: 5000,
    allowTouchMove: true,
    autoplay: {
      delay: 0,
      reverseDirection: {{ section.settings.reverse_autoplay }},
      stopOnLastSlide: false,
    },
    breakpoints: {
      0: {
        slidesPerView: 1.5,
      },
      768: {
        slidesPerView: 4,
      },
      1024: {
        slidesPerView: 6,
      },
    },
    on: {
      
    }
  });




  // 图片大图弹窗
  const overlayId = 'mc-image-overlay-{{ section.id }}';
  const sectionRoot = document.getElementById('shopify-section-{{ section.id }}');
  let overlay = sectionRoot ? sectionRoot.querySelector('#'+overlayId) : null;
  if(!overlay && sectionRoot){
    overlay = document.createElement('div');
    overlay.id = overlayId;
    overlay.className = 'mc-image-overlay';
    overlay.innerHTML = '<button class="close" type="button">×</button><img alt="" />';
    sectionRoot.appendChild(overlay);
    overlay.addEventListener('click', function(e){
      if(e.target === overlay || e.target.classList.contains('close')){
        overlay.classList.remove('is-open');
      }
    });
    document.addEventListener('keydown', function(e){ if(e.key === 'Escape'){ overlay.classList.remove('is-open'); } });
  }
  // 使用事件委托，确保动态 slide 内图片也能响应
  const swiperEl = document.getElementById('swiper-{{ section.id }}');
  if(swiperEl && overlay){
    swiperEl.addEventListener('click', function(e){
      const img = e.target.closest('.mc-zoomable');
      if(!img) return;
      e.preventDefault();
      const src = img.currentSrc || img.src;
      const big = overlay.querySelector('img');
      if(big){ big.src = src; }
      overlay.classList.add('is-open');
    });
  }


});



</script>
  {% schema %}
  {
    "name": "Media Carousel Videos",
    "class": "media-carousel-videos",
    "tag": "section",
    "disabled_on": {
      "groups": ["header", "custom.overlay"]
    },
    "settings": [
       {
        "type": "text",
        "id": "section_id",
        "label": "Section id",
        "info": "This is used to identify the section if the you added this on the (Kiks Section Navigation) section. Make sure to use the same (id or name) in the (Kiks Section Navigation) section."
      },
      {
        "type": "checkbox",
        "id": "reverse_autoplay",
        "label": "是否反向自动轮播",
        "default": false
      },
      {
        "type": "text",
        "id": "title",
        "label": "Heading"
      },
      {
        "type": "richtext",
        "id": "content",
        "label": "Content"
      },
      {
        "type": "paragraph",
        "content": "For best visual results and avoid platform branding, use a MP4 file."
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full width",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "allow_transparent_header",
        "label": "Allow transparent header",
        "info": "This setting only applies when this section is the first one.",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "autoplay",
        "label": "Autoplay",
        "info": "Video are muted to allow autoplay. For best results, do not add any content on top of the video when autoplay is enabled.",
        "default": false
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color",
        "id": "background",
        "label": "Background"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "sec_color",
        "label": "Secondary color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "overlay_color",
        "label": "Overlay",
        "default": "#000000"
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay opacity",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "default": 30
      },
      {
        "type": "text",
        "id": "padding_top",
        "label": "Padding top",
        "default": "0px;0px;0px",
        "info": "单位：可用px/rem/vw | 使用;分割电脑端/Pad端/移动端"
      },
      {
        "type": "text",
        "id": "padding_bottom",
        "label": "Padding bottom",
        "default": "0px;0px;0px",
        "info": "单位：可用px/rem/vw | 使用;分割电脑端/Pad端/移动端"
      }
    ],
    "blocks": [
      {
        "type": "video",
        "name": "Video Review",
        "settings": [
          {
              "type": "header",
              "content": "Review"
          },
          {
              "type": "image_picker",
              "id": "icon",
              "label": "Image"
          },
          {
              "type": "text",
              "id":"heading",
              "label": "Heading"
          },
          {
              "type": "text",
              "id":"description",
              "label": "Description"
          },
          {
              "type": "header",
              "content": "Video Settings"
          },
          {
            "type": "select",
            "id": "video_size",
            "label": "Video size",
            "info": "Choose \"Original video ratio\" to avoid video cropping.",
            "options": [
              {
                "value": "auto",
                "label": "Original aspect ratio"
              },
              {
                "value": "sm",
                "label": "Small"
              },
              {
                "value": "md",
                "label": "Medium"
              },
              {
                "value": "lg",
                "label": "Large"
              },
              {
                "value": "fill",
                "label": "Fill screen"
              }
            ],
            "default": "auto"
          },
          {
            "type": "video",
            "id": "video",
            "label": "Video",
            "info": "Replaces external video if both are set."
          },
          {
            "type": "video",
