                                        allow="autoplay; encrypted-media;"
                                        allowfullscreen="allowfullscreen"
                                    ></iframe>
                                    {%- endif -%}
                                </template>
                                </video-media>
                            {%- endif -%}
                            <button class="video-play-button" type="button" {{ block.shopify_attributes }}>
                                <span class="sr-only">{{ 'general.accessibility.play_video' | t }}</span>
                                {%- render 'icon' with 'play-button', width: 30, height: 30 -%}
                            </button>
                          </div>
                        {% endif %}
                        
                      <div class="content_area">
                        <div class="content_details">
                            {% if block.settings.heading %}
                                <p>{{ block.settings.heading }}</p>
                            {% endif %}

                            {% if block.settings.description %}
                              <p>{{ block.settings.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                  
                  </div>
              {% endfor %}
              {% for block in section.blocks %}
                  <div
                      class="flex align-start justify-start section-boxed h-full swiper-slide"
                  >
                      {% comment %} 图片 {% endcomment %}
                       {% if block.settings.icon %}
                          <div class="jingva-img-box flex align-center justify-center">
                             <img class="mc-zoomable" src="{{ block.settings.icon | img_url: 'original' }}" alt="">
