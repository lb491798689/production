{{- 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true -}}
{%- unless section.settings.full_width -%}
    {%- render 'section-spacing-collapsing' -%}
  {%- endunless -%}
  {%- assign section_identifier = '#shopify-section-' | append: section.id -%}
  {%- assign overlay_width = section.settings.overlay_width | append: 'px' -%}
  {%- assign enable_custom_width = section.settings.enable_custom_width -%}
  {%- assign padding_top = section.settings.padding_top | split: ';' -%}
  {%- assign padding_bottom = section.settings.padding_bottom | split: ';' -%}
  {% comment %} {{ 'kik-video-review.css' | asset_url | stylesheet_tag }} {% endcomment %}
  
  <style>
    {{ section_identifier }}.media-carousel-videos .section-full{
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .section{
      padding-top: {{ padding_top[0] }};
      padding-bottom: {{ padding_bottom[0] }};
    }
    #shopify-section-{{ section.id }} {
      {%- if section.settings.full_width -%}
        --section-outer-spacing-block: 0;
      {%- endif -%}
      background:{{section.settings.background}};
      --content-over-media-overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  
      {%- if section.settings.allow_transparent_header -%}
        margin-block-start: calc(-1 * var(--header-height) * var(--section-is-first));
      {%- endif -%}
    }
  
    {%- unless section.settings.full_width -%}
      #shopify-section-{{ section.id }}:first-child .section[allow-transparent-header] {
        padding-block-start: max(var(--section-inner-max-spacing-block), var(--header-height));
      }
    {%- endunless -%}
    {% if enable_custom_width %}
      {{ section_identifier }} .content-over-media>:not(img,video,iframe,svg,video-media,picture) {
        max-width: {{ overlay_width }};
      }
      @media only screen and (max-width: 820px){
        {{ section_identifier }} .content-over-media>:not(img,video,iframe,svg,video-media,picture) {
          max-width: 100%;
        }
      }
    {% endif %}
    {{ section_identifier }} .content_area{
      width: 100%;
      text-align: center;
      padding: 12px;
    }
    {{ section_identifier }} .content_area .content_details p{
      font-size: 13px;
    }
    {{ section_identifier }} .kik_video_heading{
      justify-content: center;
      align-items: center;
    }
    {{ section_identifier }} .kik_video_heading h2{
        color:{{ section.settings.text_color}};
        padding-bottom: 36px;
        text-align: center;
    }

    {{ section_identifier }} .flex{
        display:flex;
        flex-direction:column;
        border-radius: 0;
        padding: 0;
        margin-left: 0;
        background: #F9F9F9;
        box-shadow: none;
    }
    {{ section_identifier }} .kik_buttons{
      display:flex;
      justify-content: center;
      align-items: center;
    }
    .video-reviews .kik-arrow-button:hover {
      transition: all 0.3s ease-in-out;
      background: #ED1C22 !important;
      border: 1px solid #ED1C22 !important;
      color: #fff !important;
    }
    {{ section_identifier }} .kik_videos_slider{
      padding-top: 3px;
      padding-bottom: 3px;
    }
    {{ section_identifier }}.video-reviews{
      margin-top: 0;
    }
    {{ section_identifier }} .swiper-container-carousel .jingva-img-box img{
      width: 100%;
      height: 100%;
      /* aspect-ratio: 16 / 9; */
      object-fit: cover;
    }

    .logo-list .logo-list__item:last-child,
    .logo-list .logo-list__item:nth-last-child(2){
        width: 40%;
    }

    {{ section_identifier }} .swiper-wrapper{
      transition-timing-function: linear !important; /* 连续匀速关键 */
      will-change: transform; /* 提示 GPU 合成，拖动更顺滑 */
      cursor: pointer;
    }
    /* hover scale effect */
    {{ section_identifier }} .swiper-container-carousel .swiper-slide{
      transition: transform .2s ease, box-shadow .2s ease;
      will-change: transform;
    }
    {{ section_identifier }} .swiper-container-carousel .swiper-slide:hover{
      transform: scale(1.04);
      z-index: 3;
    }

    /* image overlay */
    {{ section_identifier }} .mc-image-overlay{position:fixed;inset:0;background:rgba(0,0,0,.9);display:none;align-items:center;justify-content:center;z-index:9999;}
    {{ section_identifier }} .mc-image-overlay.is-open{display:flex;}
    {{ section_identifier }} .mc-image-overlay img{max-width:90vw;max-height:90vh;border-radius:4px;box-shadow:0 8px 40px rgba(0,0,0,.4);}
    {{ section_identifier }} .mc-image-overlay .close{position:absolute;top:16px;right:16px;width:36px;height:36px;border:1px solid #fff;color:#fff;background:transparent;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;line-height:1;}
    
    @media screen and (max-width: 1024px) {
      #shopify-section-{{ section.id }} .section{
        padding-top: {{ padding_top[1] }};
        padding-bottom: {{ padding_bottom[1] }};
      }
    }
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .section{
        padding-top: {{ padding_top[2] }};
        padding-bottom: {{ padding_bottom[2] }};  
      }
      {{ section_identifier }} .kik_video_heading h2{
        text-align: left;
        padding-top: 0;
        margin-bottom: 0;
      }
    }
    
  </style>
  <div {% if section.settings.section_id != blank %}id="{{ section.settings.section_id | downcase | replace: ' ', '_' }}" {% endif %}{% render 'section-properties' %}>
    <div
        class="kik_videos_slider"
        {% if section.settings.allow_transparent_header %}
