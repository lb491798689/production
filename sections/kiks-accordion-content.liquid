{%- render 'section-spacing-collapsing' -%}

{%- assign text_position = section.settings.text_position -%}
{%- assign section_identifier = '#shopify-section-' | append: section.id -%}
<style>
  #shopify-section-{{ section.id }} {
    --section-stack-intro: {% if text_position == 'center' %}66.6667%{% else %}50%{% endif %};
    --section-stack-main: 50%;
  }
  {% if section.settings.remove_arrow %}
    {{ section_identifier }} .kiks-custom-accordion .accordion-item summary .accordion__toggle span.circle-chevron {
        display: none;
    }
  {% endif %}
      .custom-dots {
        position: relative;
        display: none;
    }
    div#kiks-custom-background {
        padding: 0;
        position: relative;
    }
   
    .shopify-section-kiks-accordion-content .section-stack {
        gap: 0;
    }
    .shopify-section-kiks-accordion-content .accordion-image-container .accordion-image-item picture {
        display: block;
        height: 100%;
    }
    .shopify-section-kiks-accordion-content .accordion-image-container .accordion-image-item picture img {
        height: 100%;
        object-fit: cover;
    }
    .kiks-custom-accordion {
          overflow: hidden;
          height: 700px !important;
          background: unset;
          padding-left: 32px;
      }
    {{ section_identifier }} .kiks-custom-accordion .accordion-item {
        background: {{ section.settings.accordion_background }};
        padding: 24px 16px;
        color: {{ section.settings.accordion_text_color }};
        border-radius: 12px;
        /* max-height: 77px; */
        height: auto;
        transition: all 0.5s ease;
    }
    @media only screen and (max-width: 1149px) {
      {{ section_identifier }} .kiks-custom-accordion .accordion-item {
        height: fit-content;
        border-radius: 0;
      }
    }
    .kiks-custom-accordion .accordion-item[aria-expanded="true"] .accordion__content {
        opacity: 1;
        transform: translateY(-4px);
        margin-top: 8px;
    }
    {{ section_identifier }}.shopify-section-kiks-accordion-content .section-stack__intro::after {
        content: "";
        background: {{ section.settings.custom_background_gradient }};
        position: absolute;
        width: 100%;
        height: 100%;
        z-index: 1;
    }
    {{ section_identifier }}.shopify-section-kiks-accordion-content .section-stack__intro::before {
      content: "";
        background: {{ section.settings.custom_background_gradient_top }};
        position: absolute;
        width: 100%;
        height: 100%;
        z-index: 1;
    }
    .kiks-custom-accordion .accordion-item summary {
        width: 100%;
    }
    .kiks-custom-accordion .accordion-item summary .accordion__toggle {
        justify-content: space-between;
        width: 100%;
        max-width: 100%;
    }

    .shopify-section-kiks-accordion-content a.button {
      margin: 40px var(--spacing-12);
    }

    .shopify-section-kiks-accordion-content .section-stack__intro {
        position: relative;
        display: flex;
        flex-direction: column;
    }
    .shopify-section-kiks-accordion-content .section-stack__intro .prose {
        z-index: 2;
    }
    .shopify-section-kiks-accordion-content .accordion-image-container .accordion-image-item {
        position: absolute;
        opacity: 0;
        height: 100%;
        width: 100%;
        transition: all 0.4s ease;
    }
    .shopify-section-kiks-accordion-content .accordion-image-container .accordion-image-item.is-active{
        opacity: 1;
    }
    @media only screen and (max-width: 1601px) {
        .shopify-section-kiks-accordion-content .section-stack__intro .prose {
            z-index: 2;
            padding: 3rem 3rem;
        }
        .shopify-section-kiks-accordion-content .section-stack__main {
            padding: 3rem 3rem 3rem 0;
        }
        .kiks-custom-accordion {
            padding-right: 0;
        }
    }
    @media only screen and (max-width: 1441px) {
        .shopify-section-kiks-accordion-content .section-stack__main {
            padding: 3rem 0rem 3rem 0;
        }
        
        .kiks-custom-accordion {
            padding: 0 var(--spacing-12);
        }
        .shopify-section-kiks-accordion-content a.button {
            margin: 40px var(--spacing-12);
        }
    }
    @media only screen and (max-width: 1149px) {
        .shopify-section-kiks-accordion-content .section-stack__intro {
            height: 90vw;
        }
        .shopify-section-kiks-accordion-content .section-stack__main {
            padding: 3rem 0rem 10rem 0;
        }
        .shopify-section-kiks-accordion-content .section-stack__intro .prose {
            padding: 3rem 2rem;
        }
        .kiks-custom-accordion {
          height: 100% !important;
      }
      
      .shopify-section-kiks-accordion-content a.button {
          margin: 0 var(--spacing-12);
      }
      .custom-dots {
          display: block;
          z-index: 1;
      }
      .custom-button-container {
          display: flex;
          justify-content: center;
          margin-top: 32px;
      }
    }
    @media only screen and (max-width: 820px) {
        .shopify-section-kiks-accordion-content .section-stack__main {
            padding: 2rem 0rem 2rem 0;
        }
        .kiks-custom-accordion {
            padding: 0 2rem;
        }
        .shopify-section-kiks-accordion-content .section-stack__intro {
            height: 90vw;
        }
        .shopify-section-kiks-accordion-content a.button {
            margin: 40px 2rem;
        }
        .kiks-custom-accordion {
            height: auto !important;
            margin-bottom: 3.5rem;
        }
        .custom-button-container {
          margin-top: 0;
         }
    }
    @media only screen and (max-width: 699px) {
        .shopify-section-kiks-accordion-content .section-stack__main {
            padding: 1rem 0rem 1rem 0;
        }
        .kiks-custom-accordion {
            padding: 0 1rem;
        }
        .shopify-section-kiks-accordion-content .section-stack__intro .prose {
            padding: 3rem 1rem;
        }
        .shopify-section-kiks-accordion-content a.button {
            margin: 40px 1rem 15px;
        }
        .shopify-section-kiks-accordion-content .section-stack__intro {
            height: 120vw;
        }
        .kiks-custom-accordion {
            height: auto !important;
        }
    }
    @media only screen and (min-width: 1600px) {
        .shopify-section-kiks-accordion-content .section-stack__intro .prose {
            z-index: 2;
            padding: 5rem 9rem;
        }
        .shopify-section-kiks-accordion-content .section-stack__main {
            padding: 5rem 8rem 5rem 0;
        }
        .kiks-custom-accordion {
            padding-right: 0;
        }
    }
</style>

<div id="kiks-custom-background" {% render 'section-properties' %}>
  <div class="section-stack {% if text_position != 'center' %}section-stack--horizontal{% else %}section-stack--center{% endif %} {% if text_position == 'end' %}section-stack--reverse{% endif %}">
    {%- capture content -%}
      {%- if section.settings.subheading != blank -%}
        <p class="custom_font_family subheading" data-aos="fade-up" data-aos-delay="100" data-aos-easing="ease-in-out">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="h2" data-aos="fade-up" data-aos-delay="600" data-aos-easing="ease-in-out">
          {%- render 'styled-text', content: section.settings.title, text_color: section.settings.heading_color, gradient: section.settings.heading_gradient -%}
        </h2>
      {%- endif -%}
      <div class="kiks-description" data-aos="fade-up" data-aos-delay="800" data-aos-easing="ease-in-out">
        {{- section.settings.content -}}
      </div>

      
    {%- endcapture -%}

    {%- if content != blank -%}
      <div class="section-stack__intro">
        <div class="accordion-image-container">
            {%- for block in section.blocks -%}
                {%- if block.settings.custom_image != blank -%}
                {% comment %} {% if forloop.first %} is-active{% endif %} {% endcomment %}
                <div class="accordion-image-item{% if forloop.first %} is-active{% endif %}" data-count="{{ forloop.index }}">
                        {%- capture sizes -%}{% if block.settings.full_width %}100vw{% else %}(max-width: 740px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px){% endif %}{%- endcapture -%}
                        {%- capture fetch_priority -%}{% if block.index == 1 %}high{% else %}low{% endif %}{%- endcapture -%}
                
                        <picture>
                        {%- if block.settings.custom_image_mobile != blank -%}
                            <source
                            media="(max-width: 699px)"
                            srcset="{{ block.settings.custom_image_mobile | image_url: width: 400 }} 400w, {{ block.settings.custom_image_mobile | image_url: width: 600 }} 600w, {{ block.settings.custom_image_mobile | image_url: width: 800 }} 800w, {{ block.settings.custom_image_mobile | image_url: width: 1000 }} 1000w, {{ block.settings.custom_image_mobile | image_url: width: 1200 }} 1200w"
                            width="{{ block.settings.custom_image_mobile.width }}"
                            height="{{ block.settings.custom_image_mobile.height }}"
                            >
                        {%- endif -%}
                
                        {{- block.settings.custom_image | image_url: width: block.settings.custom_image.width | image_tag: sizes: sizes, fetchpriority: fetch_priority, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
                        </picture>
                     </div>
                 {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="prose {% if text_position == 'center' %}text-center{% endif %}">
          {{- content -}}
        </div>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="section-stack__main">
        <kiks-slider-accordion {% if section.settings.enable_hover %}data-hover="true" data-scroll-mobile="true"{% else %}data-scroll="true"{% endif %} data-loop="{{ section.settings.enable_loop }}">
            <div {% render 'surface', class: 'kiks-custom-accordion accordion-box rounded', background: section.settings.accordion_background, text_color: section.settings.accordion_text_color, background_fallback: 'bg-secondary' %}  data-aos="slide-up" data-aos-delay="400" data-aos-easing="ease-in-out">
                  <div class="swiper-wrapper">
                      {%- for block in section.blocks -%}
                          {% if block.settings.custom_image %}
                              {%  assign  have_image =  true %} 
                              {%  else %}
                              {%  assign  have_image =  false %} 
                          {% endif %}
                          {%- if block.settings.title != blank and block.settings.content != blank -%}
                          {%- capture accordion_content -%}
                              <div class="prose">{{ block.settings.page.content | default: block.settings.content }}</div>
                          {%- endcapture -%}

                          {%- assign icon = block.settings.custom_icon | default: block.settings.icon -%}
                          {%- render 'kiks-accordion', title: block.settings.title, content: accordion_content, icon: icon, icon_width: block.settings.icon_width, block: block , have_imge: have_image data_count: forloop.index  first_loop: forloop.first -%}
                          {%- endif -%}
                      {%- endfor -%}
                  </div>
                </div>
 
            </kiks-slider-accordion>
            <div class="custom-dots">
              <div class="swiper-pagination"></div>
              </div>
            {%- if section.settings.button_text != blank -%}
              <div class="custom-button-container">
               {% render 'button', content: section.settings.button_text, href: section.settings.button_url, background: section.settings.button_background, text_color: section.settings.button_text_color, size: section.settings.size, style: section.settings.style %} 
             </div>
           {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

