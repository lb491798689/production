      "label": "PC Image (Poster for Video)"
    },
    {
      "type": "image_picker",
      "id": "mob_image",
      "label": "Mobile Image (Poster for Video)"
    },
    {
      "type": "video",
      "id": "pc_video",
      "label": "PC Video"
    },
    {
      "type": "video",
      "id": "mob_video",
      "label": "Mobile Video"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Front/Back Adjustment\n6 levels, 6cm travel"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Height Adjustment\n5cm adaptive"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Rotation Adjustment\n5° adaptive"
    },
    {
      "type": "text",
      "id": "feature_4",
      "label": "Feature 4",
      "default": "Built-in Vibration Massage"
    }
  ],
  "presets": [
    {
      "name": "Jingva M6 Lumbar Support",
      "settings": {
        "title": "World's First Dynamic Tracking Lumbar Support",
        "description": "<p>Third-generation 6-way adjustable dynamic lumbar support ensures no fatigue, whether leaning forward for competitive gaming or reclining to watch videos. Prevents long-sitting-related lumbar strain, letting you game longer with peak performance.</p>",
        "theme": "dark",
        "feature_1": "Front/Back Adjustment\n6 levels, 6cm travel",
        "feature_2": "Height Adjustment\n5cm adaptive",
        "feature_3": "Rotation Adjustment\n5° adaptive",
        "feature_4": "Built-in Vibration Massage"
      }
