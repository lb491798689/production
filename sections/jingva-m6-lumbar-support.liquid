{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign title = se_stts.title
  assign description = se_stts.description
  assign description_mob = se_stts.description_mob | default: description
  assign theme = se_stts.theme | default: 'dark'
  if theme == 'light'
    assign theme_bg = '#FFFFFF'
    assign title_color = '#0A0A0A'
    assign desc_color = 'rgba(26, 26, 26, 0.60)'
  else
    assign theme_bg = '#171717'
    assign title_color = '#FFFFFF'
    assign desc_color = 'rgba(255, 255, 255, 0.60)'
  endif
  assign bg_color = se_stts.bg_color | default: theme_bg
  assign bg_color_mob = se_stts.bg_color_mob | default: bg_color
  assign pc_image = se_stts.pc_image
  assign mob_image = se_stts.mob_image
  assign pc_video = se_stts.pc_video
  assign mob_video = se_stts.mob_video
  assign feature_1 = se_stts.feature_1
  assign feature_2 = se_stts.feature_2
  assign feature_3 = se_stts.feature_3
  assign feature_4 = se_stts.feature_4
-%}
{% capture default_sid %}.jingva-m6-lumbar-support-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-m6-lumbar-support-{{sid}}" data-section-id="{{ sid }}">
  {% style %}
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color }} !important;
      padding: 0 !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-wrapper {
      position: relative !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      padding-top: 160px !important;
      gap: 48px !important;
      flex: 1 !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-content {
      position: relative !important;
      width: 100% !important;
      max-width: 1296px !important;
      margin: 0 auto !important;
      padding: 0 48px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 12px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-title {
      font-family: 'Orbitron', sans-serif !important;
      font-weight: 900 !important;
      font-size: 64px !important;
      line-height: 1.253999948501587em !important;
      color: {{ title_color }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 1200px !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-m6-lumbar-support-description--mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-description {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 1.2000000476837158em !important;
      color: {{ desc_color }} !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      max-width: 1080px !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-description p {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 1.2000000476837158em !important;
      color: {{ desc_color }} !important;
      text-align: center !important;
      margin: 0 !important;
    }

    /* Firefox 修复：rich-text 输出可能是 <div> 包 <p>，
       浏览器对块级元素 margin collapse 处理不同会导致额外高度。
       强制所有子元素 margin 0、消除空段引起的额外行 */
    {{ default_sid }} .jingva-m6-lumbar-support-description > * {
      margin: 0 !important;
    }
    {{ default_sid }} .jingva-m6-lumbar-support-description br + br,
    {{ default_sid }} .jingva-m6-lumbar-support-description p:empty,
    {{ default_sid }} .jingva-m6-lumbar-support-description div:empty {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-media-container {
      position: relative !important;
      width: 100% !important;
      aspect-ratio: 2 / 1 !important;
      height: auto !important;
      overflow: hidden !important;
      background-color: #000000 !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-media {
      width: 100% !important;
      height: 100% !important;
      display: block !important;
      object-fit: cover !important;
      object-position: center center !important;
    }

    /* PC: 只显示 PC 媒体，隐藏移动媒体 */
    {{ default_sid }} .jingva-m6-lumbar-support-media--mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-features {
      position: absolute !important;
      left: 50% !important;
      bottom: 70px !important;
      top: auto !important;
      transform: translateX(-50%) !important;
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 12px !important;
      z-index: 2 !important;
      backdrop-filter: blur(60px) !important;
      -webkit-backdrop-filter: blur(60px) !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-feature {
      display: flex !important;
      flex-direction: row !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 10px !important;
      padding: 25px 14.5px !important;
      background-color: rgba(44, 44, 44, 0.40) !important;
      backdrop-filter: blur(50px) !important;
      -webkit-backdrop-filter: blur(50px) !important;
      border-radius: 12px !important;
      width: 231px !important;
      height: 95px !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(2),
    {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(3) {
      width: 232px !important;
    }

    {{ default_sid }} .jingva-m6-lumbar-support-feature-text {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 600 !important;
      font-size: 18px !important;
      line-height: 1.2000000211927626em !important;
      color: #FFFFFF !important;
      text-align: center !important;
      margin: 0 !important;
      width: 100% !important;
      white-space: pre-line !important;
    }

    @media screen and (min-width: 1280px) and (max-width: 1439px) {
      {{ default_sid }} .jingva-m6-lumbar-support-wrapper {
        gap: 40px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-content {
        max-width: 1280px !important;
        padding: 0 40px !important;
        gap: 10px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-title {
        font-size: 48px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-description,
      {{ default_sid }} .jingva-m6-lumbar-support-description p {
        font-size: 20px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature {
        width: 200px !important;
        height: 80px !important;
        padding: 28px 24px 27px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(2),
      {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(3) {
        width: 200px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature-text {
        font-size: 16px !important;
      }
    }

    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        background-color: {{ bg_color_mob }} !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-description--pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-description--mob {
        display: block !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-wrapper {
        padding-top: 96px !important;
        gap: 24px !important;
        padding: 96px 0 0 0 !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-content {
        width: 100% !important;
        max-width: none !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
        margin-inline: 0 !important;
        padding: 0 16px !important;
        gap: 12px !important;
        box-sizing: border-box !important;
        align-items: stretch !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-title {
        font-size: 32px !important;
        line-height: 1.253999982561384em !important;
        max-width: none !important;
        text-align: left !important;
        transform: translateY(-50px);
        transition: transform 0.5s ease-out;
        will-change: transform;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-description,
      {{ default_sid }} .jingva-m6-lumbar-support-description p {
        font-size: 16px !important;
        line-height: 1.2000000476837158em !important;
        max-width: none !important;
        text-align: left !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-media-container {
        width: 100% !important;
        aspect-ratio: 390 / 540 !important;
        height: auto !important;
        margin: 0 !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-media {
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
      }

      /* Mobile: 隐藏 PC 媒体，只显示移动媒体 */
      {{ default_sid }} .jingva-m6-lumbar-support-media--pc {
        display: none !important;
      }
      {{ default_sid }} .jingva-m6-lumbar-support-media--mob {
        display: block !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-features {
        position: absolute !important;
        left: 50% !important;
        bottom: 24px !important;
        top: auto !important;
        transform: translateX(-50%) !important;
        display: grid !important;
        grid-template-columns: 164px 164px !important;
        grid-template-rows: 60px 60px !important;
        gap: 12px !important;
        z-index: 2 !important;
        width: auto !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature {
        display: flex !important;
        width: 164px !important;
        height: 60px !important;
        padding: 16px 18px !important;
        justify-content: center !important;
        align-items: center !important;
        align-content: center !important;
        flex-wrap: wrap !important;
        border-radius: 8px !important;
        background: rgba(45, 45, 45, 0.20) !important;
        backdrop-filter: blur(50px) !important;
        -webkit-backdrop-filter: blur(50px) !important;
        box-sizing: border-box !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(1) {
        grid-column: 1 !important;
        grid-row: 1 !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(2) {
        grid-column: 2 !important;
        grid-row: 1 !important;
        width: 164px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(3) {
        grid-column: 1 !important;
        grid-row: 2 !important;
        width: 164px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature:nth-child(4) {
        grid-column: 2 !important;
        grid-row: 2 !important;
        width: 164px !important;
      }

      {{ default_sid }} .jingva-m6-lumbar-support-feature-text {
        font-size: 12px !important;
        font-weight: 500 !important;
        line-height: 1.2000000476837158em !important;
        text-align: center !important;
        display: flex !important;
        flex-direction: column !important;
        justify-content: center !important;
        align-items: center !important;
        height: 100% !important;
      }
    }
  {% endstyle %}

  <div class="jingva-m6-lumbar-support-wrapper">
    <div class="jingva-m6-lumbar-support-content">
      {% if title != blank %}
        <h2 class="jingva-m6-lumbar-support-title">{{ title }}</h2>
      {% endif %}

      {% if description != blank %}
        <div class="jingva-m6-lumbar-support-description jingva-m6-lumbar-support-description--pc">{{ description }}</div>
      {% endif %}

      {% if description_mob != blank %}
        <div class="jingva-m6-lumbar-support-description jingva-m6-lumbar-support-description--mob">{{ description_mob }}</div>
      {% endif %}
    </div>

    {% if pc_image != blank or mob_image != blank or pc_video != blank or mob_video != blank %}
      {%- liquid
        assign pc_media_video = pc_video | default: mob_video
        assign mob_media_video = mob_video | default: pc_video
        assign pc_media_image = pc_image | default: mob_image
        assign mob_media_image = mob_image | default: pc_image
      -%}
      <div class="jingva-m6-lumbar-support-media-container">
        {%- comment -%} PC media (>=1280px) {%- endcomment -%}
        {% if pc_media_video != blank %}
          <video
            class="jingva-m6-lumbar-support-media jingva-m6-lumbar-support-media--pc"
            autoplay
            muted
            loop
            playsinline
            {% if pc_media_image != blank %}poster="{{ pc_media_image | image_url: width: 1920 }}"{% endif %}
          >
            {%- for source in pc_media_video.sources -%}
              {%- if source.mime_type == 'video/mp4' -%}
                <source src="{{- source.url -}}" type="{{- source.mime_type -}}">
              {%- endif -%}
            {%- endfor -%}
          </video>
        {% elsif pc_media_image != blank %}
          <img
            class="jingva-m6-lumbar-support-media jingva-m6-lumbar-support-media--pc"
            src="{{ pc_media_image | image_url: width: 1920 }}"
            alt="{{ title | escape }}"
            loading="lazy"
          >
        {% endif %}

        {%- comment -%} Mobile media (<=1279px) {%- endcomment -%}
        {% if mob_media_video != blank %}
          <video
            class="jingva-m6-lumbar-support-media jingva-m6-lumbar-support-media--mob"
            autoplay
            muted
            loop
            playsinline
            {% if mob_media_image != blank %}poster="{{ mob_media_image | image_url: width: 1200 }}"{% endif %}
          >
            {%- for source in mob_media_video.sources -%}
              {%- if source.mime_type == 'video/mp4' -%}
                <source src="{{- source.url -}}" type="{{- source.mime_type -}}">
              {%- endif -%}
            {%- endfor -%}
          </video>
        {% elsif mob_media_image != blank %}
          <img
            class="jingva-m6-lumbar-support-media jingva-m6-lumbar-support-media--mob"
            src="{{ mob_media_image | image_url: width: 1200 }}"
            alt="{{ title | escape }}"
            loading="lazy"
          >
        {% endif %}

        <div class="jingva-m6-lumbar-support-features">
          {% if feature_1 != blank %}
            <div class="jingva-m6-lumbar-support-feature">
              <p class="jingva-m6-lumbar-support-feature-text">{{ feature_1 }}</p>
            </div>
          {% endif %}
          {% if feature_2 != blank %}
            <div class="jingva-m6-lumbar-support-feature">
              <p class="jingva-m6-lumbar-support-feature-text">{{ feature_2 }}</p>
            </div>
          {% endif %}
          {% if feature_3 != blank %}
            <div class="jingva-m6-lumbar-support-feature">
              <p class="jingva-m6-lumbar-support-feature-text">{{ feature_3 }}</p>
            </div>
          {% endif %}
          {% if feature_4 != blank %}
            <div class="jingva-m6-lumbar-support-feature">
              <p class="jingva-m6-lumbar-support-feature-text">{{ feature_4 }}</p>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
(function() {
  var section = document.querySelector('.jingva-m6-lumbar-support-{{ sid }}');
  if (!section) return;

  var title = section.querySelector('.jingva-m6-lumbar-support-title');
  if (!title) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        title.classList.add('aos-animate');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  observer.observe(title);
})();
</script>

{% schema %}
{
  "name": "Jingva M6 Lumbar Support",
  "class": "shopify-section--jingva-m6-lumbar-support",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark",
      "info": "Dark: bg #171717 / title #FFF / desc rgba(255,255,255,.6). Light: bg #FFF / title #0A0A0A / desc rgba(26,26,26,.6). Background color settings below override theme background."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "World's First Dynamic Tracking Lumbar Support"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description (PC)",
      "default": "<p>Third-generation 6-way adjustable dynamic lumbar support ensures no fatigue, whether leaning forward for competitive gaming or reclining to watch videos. Prevents long-sitting-related lumbar strain, letting you game longer with peak performance.</p>"
    },
    {
      "type": "richtext",
      "id": "description_mob",
      "label": "Description (Mobile)",
      "default": "<p>Third-generation 6-way adjustable dynamic lumbar support ensures no fatigue, whether leaning forward for competitive gaming or reclining to watch videos. Prevents long-sitting-related lumbar strain, letting you game longer with peak performance.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "PC Background Color (override theme)",
      "info": "Leave blank to use theme default."
    },
    {
      "type": "color",
      "id": "bg_color_mob",
      "label": "Mobile Background Color (override theme)",
      "info": "Leave blank to use theme default."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (PC)",
      "min": 0,
      "max": 300,
      "step": 5,
      "default": 160,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 68,
      "unit": "px"
