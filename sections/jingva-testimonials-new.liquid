    {% if slide_count > 1 %}
      <script>
        (function() {
          var sliderEl = document.getElementById('jingva-testimonials-new-slider-{{ sid }}');
          if (!sliderEl) return;

          var swiper = new Swiper(sliderEl, {
            slidesPerView: 1,
            spaceBetween: 12,
            centeredSlides: false,
            initialSlide: 0,
            loop: false,
            breakpoints: {
              0: {
                slidesPerView: 'auto',
                spaceBetween: 12,
                centeredSlides: false
              },
              768: {
                slidesPerView: 'auto',
                spaceBetween: 12,
                centeredSlides: false
              },
              1280: {
                slidesPerView: 1,
                spaceBetween: 12,
                centeredSlides: false
              },
              1440: {
                slidesPerView: 1,
                spaceBetween: 12,
                centeredSlides: false
              }
            },
            navigation: {
              nextEl: '{{ default_sid }} .jingva-testimonials-new-nav-next',
              prevEl: '{{ default_sid }} .jingva-testimonials-new-nav-prev'
            },
            speed: 500,
            grabCursor: true,
            simulateTouch: true,
            touchEventsTarget: 'wrapper',
            touchRatio: 1,
            touchAngle: 45,
            shortSwipes: true,
            longSwipes: true,
            longSwipesRatio: 0.5,
            longSwipesMs: 300,
            followFinger: true,
            resistance: true,
            resistanceRatio: 0.85
          });
        })();
      </script>
    {% endif %}
  {% endif %}
</section>

<script>
(function() {
  var section = document.querySelector('.jingva-testimonials-new-{{ sid }}');
  if (!section) return;

  var title = section.querySelector('.jingva-testimonials-new-title');
  if (!title) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        title.classList.add('aos-animate');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.01,
    rootMargin: '0px 0px 0px 0px'
  });

  observer.observe(title);
})();
</script>

