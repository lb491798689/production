{{- 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true -}}
{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign slide_blocks = section.blocks
  assign slide_count = slide_blocks | size
  assign padding_top = se_stts.padding_top | default: 160
  assign padding_bottom = se_stts.padding_bottom | default: 115
  assign padding_top_mob = se_stts.padding_top_mob | default: 96
  assign padding_bottom_mob = se_stts.padding_bottom_mob | default: 0
  assign description_font_size = se_stts.description_font_size | default: 18
  assign bg_color = se_stts.bg_color
  assign bg_color_mob = se_stts.bg_color_mob | default: bg_color
  assign title_color = se_stts.title_color
  assign theme_mode = se_stts.theme_mode | default: 'dark'
-%}
{%- comment -%}Spacing configuration{%- endcomment -%}
{%- liquid
  assign image_to_title_gap = se_stts.image_to_title_gap | default: 24
  assign title_to_description_gap = se_stts.title_to_description_gap | default: 12
  assign image_to_description_gap_no_title = se_stts.image_to_description_gap_no_title | default: 24
  assign description_to_buttons_gap = se_stts.description_to_buttons_gap | default: 24
  
  assign image_to_title_gap_mob = se_stts.image_to_title_gap_mob | default: 12
  assign title_to_description_gap_mob = se_stts.title_to_description_gap_mob | default: 12
  assign image_to_description_gap_no_title_mob = se_stts.image_to_description_gap_no_title_mob | default: 12
  assign description_to_buttons_gap_mob = se_stts.description_to_buttons_gap_mob | default: 24
  
  if theme_mode == 'dark'
    assign auto_title_color = title_color | default: '#ffffff'
    assign auto_subtitle_color = '#ffffff'
    assign auto_description_color = 'rgba(255, 255, 255, 0.6)'
    assign auto_description_color_mob = 'rgba(255, 255, 255, 0.4)'
    assign auto_button_bg = '#FAFAFA'
    assign auto_button_text = '#0A0A0A'
    assign auto_button_hover_bg = '#DBDBDB'
    assign auto_button_disabled_bg = 'rgba(255, 255, 255, 0.20)'
    assign auto_button_icon_color = '#0A0A0A'
  else
    assign auto_title_color = title_color | default: '#0A0A0A'
    assign auto_subtitle_color = '#0A0A0A'
    assign auto_description_color = 'rgba(26, 26, 26, 0.60)'
    assign auto_description_color_mob = 'rgba(26, 26, 26, 0.60)'
    assign auto_button_bg = '#0A0A0A'
    assign auto_button_text = '#ffffff'
    assign auto_button_hover_bg = '#383838'
    assign auto_button_disabled_bg = 'rgba(26, 26, 26, 0.20)'
    assign auto_button_icon_color = '#ffffff'
  endif
-%}
{% capture default_sid %}.jingva-testimonials-new-{{ sid }}{% endcapture %}

<section class="jingva-section-container jingva-testimonials-new-{{sid}}" data-section-id="{{ sid }}">
  {% style %}
    /*
     * ========================================
     * Figma PC (1920px, node 3671:3453) 详细参数:
     * ========================================
     *   section: w:1920, flex column, gap:48px, p:0 360px
     *   title: Gabarito 600 48px line-height:1.2 #FFFFFF title case left
     *   slider wrapper: column, gap:24px
     *   slides container: row, gap:12px
     *   slide: w:1200, flex column, gap:24px
     *   image: w:1200, h:640, br:12px, object-fit:cover
     *   text container: flex column, gap:12px, p:0 120px 0 0
     *   subtitle: Gabarito 500 24px line-height:1.2 #FFFFFF title case left
     *   description: Gabarito 500 18px line-height:1.2 rgba(255,255,255,0.6) left
     *   buttons container: row, gap:12px, align-self:start
     *   buttons: w:48, h:48, p:12px, br:999px, bg:rgba(255,255,255,0.2)
     *
     * ========================================
     * Figma MOB (390px, node 2804:3455) 详细参数:
     * ========================================
     *   section: w:390, flex column, gap:24px, p:0 16px
     *   title: Gabarito 600 20px line-height:1.2 #FFFFFF title case left
     *   slider wrapper: column, gap:24px
     *   slides container: row, gap:12px
     *   slide: w:346, flex column, gap:24px
     *   image: w:346, h:480, br:12px, object-fit:cover
     *   text container: flex column, gap:12px
     *   subtitle: Gabarito 500 18px line-height:1.2 #FFFFFF title case left
     *   description: Gabarito 500 16px line-height:1.2 rgba(255,255,255,0.4) left
     *   buttons: w:36, h:36, p:9px, br:999px, bg:rgba(255,255,255,0.2)
     *
     * ========================================
     * develop.md 规范 (必须遵守):
     * ========================================
     *   基准尺寸: PC=1920, MOB=390
     *   版心: PC/PAD 均为 1200px
     *   Grid.Padding: PC=48px, PAD=40px, MOB=16px
     *   断点: MOB≤1279, PAD 1280~1439, PC≥1440
     *   字体: Orbitron(展示标题), Gabarito(正文/说明)
     *   所有样式使用 !important 确保优先级
     */

    /* === PC: 1440~2560 === */
    {{ default_sid }} {
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      background-color: {{ bg_color | default: '#121b2c' }} !important;
      padding: {{ padding_top }}px 0 {{ padding_bottom }}px 0 !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-testimonials-new-wrapper {
      position: relative !important;
      width: 100% !important;
      max-width: 1200px !important;
      margin: 0 auto !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: stretch !important;
      gap: 48px !important;
      padding: 0 !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-testimonials-new-title {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 600 !important;
      font-size: 48px !important;
      line-height: 1.2 !important;
      color: {{ auto_title_color }} !important;
      text-align: left !important;
      text-transform: none !important;
      margin: 0 !important;
      width: 100% !important;
      transform: translateY(-50px);
      transition: transform 0.5s ease-out;
      will-change: transform;
    }

    {{ default_sid }} .jingva-testimonials-new-title.aos-animate {
      transform: translateY(0);
    }

    {{ default_sid }} .jingva-testimonials-new-slider-wrapper {
      position: relative !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: stretch !important;
      gap: var(--description-to-buttons-gap, 24px) !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slider-container {
      position: relative !important;
      width: 100% !important;
      overflow: visible !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slider {
      width: 100% !important;
      overflow: visible !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slide {
      /* CSS 变量：从 Shopify 配置传入 */
      --image-to-title-gap: {{ image_to_title_gap }}px;
      --title-to-description-gap: {{ title_to_description_gap }}px;
      --image-to-description-gap-no-title: {{ image_to_description_gap_no_title }}px;
      --description-to-buttons-gap: {{ description_to_buttons_gap }}px;
      
      width: 100% !important;
      max-width: 1200px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: stretch !important;
      gap: var(--image-to-title-gap) !important;
      box-sizing: border-box !important;
      flex-shrink: 0 !important;
    }

    /* 当没有标题时，使用不同的间距 */
    {{ default_sid }} .jingva-testimonials-new-slide:has(.jingva-testimonials-new-slide-text:not(:has(.jingva-testimonials-new-slide-subtitle))) {
      gap: var(--image-to-description-gap-no-title) !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slide-image {
      width: 100% !important;
      height: 640px !important;
      border-radius: 12px !important;
      display: block !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slide-image img {
      width: 100% !important;
      height: 100% !important;
      border-radius: 12px !important;
      object-fit: cover !important;
      display: block !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slide-text {
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: stretch !important;
      gap: var(--title-to-description-gap) !important;
      padding: 0 120px 0 0 !important;
      box-sizing: border-box !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slide-subtitle {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: 24px !important;
      line-height: 1.2 !important;
      color: {{ auto_subtitle_color }} !important;
      text-align: left !important;
      margin: 0 !important;
      width: 100% !important;
    }

    {{ default_sid }} .jingva-testimonials-new-subtitle-pc {
      display: block !important;
    }

    {{ default_sid }} .jingva-testimonials-new-subtitle-mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-testimonials-new-slide-description {
      font-family: 'Gabarito', sans-serif !important;
      font-weight: 500 !important;
      font-size: {{ description_font_size }}px !important;
      line-height: 1.2 !important;
      color: {{ auto_description_color }} !important;
      text-align: left !important;
      margin: 0 !important;
      width: 100% !important;
    }

    {{ default_sid }} .jingva-testimonials-new-description-pc {
      display: block !important;
    }

    {{ default_sid }} .jingva-testimonials-new-description-mob {
      display: none !important;
    }

    {{ default_sid }} .jingva-testimonials-new-nav {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      gap: 12px !important;
      align-self: flex-start !important;
      box-sizing: border-box !important;
      /* margin-top: 24px !important; */
      margin-bottom: 2px !important;
    }

    {{ default_sid }} .jingva-testimonials-new-nav-btn {
      width: 48px !important;
      height: 48px !important;
      padding: 0 !important;
      border-radius: 12px !important;
      background-color: {{ auto_button_bg }} !important;
      border: none !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      box-sizing: border-box !important;
      transition: background-color 0.3s ease !important;
    }

    {{ default_sid }} .jingva-testimonials-new-nav-btn:hover {
      background-color: {{ auto_button_hover_bg }} !important;
    }

    {{ default_sid }} .jingva-testimonials-new-nav-btn:disabled,
    {{ default_sid }} .jingva-testimonials-new-nav-btn.swiper-button-disabled {
      background-color: {{ auto_button_disabled_bg }} !important;
      cursor: not-allowed !important;
    }

    {% if theme_mode == 'dark' %}
      /* Dark：实心箭头 fill #0A0A0A，与 stroke 型旧图标互斥 */
      {{ default_sid }} .jingva-testimonials-new-nav-btn svg path {
        fill: #0A0A0A !important;
        stroke: none !important;
      }
      {{ default_sid }} .jingva-testimonials-new-nav-btn:disabled svg path,
      {{ default_sid }} .jingva-testimonials-new-nav-btn.swiper-button-disabled svg path {
        fill: #0A0A0A !important;
        stroke: none !important;
      }
    {% endif %}

    {% if theme_mode == 'light' %}
      /* Light：背景 #0A0A0A / 禁用 rgba(26,26,26,.2)，箭头 fill #fff */
      {{ default_sid }} .jingva-testimonials-new-nav-btn svg path {
        fill: #fff !important;
        stroke: none !important;
      }
      {{ default_sid }} .jingva-testimonials-new-nav-btn:disabled svg path,
      {{ default_sid }} .jingva-testimonials-new-nav-btn.swiper-button-disabled svg path {
        fill: #fff !important;
        stroke: none !important;
      }
    {% endif %}

    /* 固定 slide 位置，防止轮播时位置变化 */
    {{ default_sid }} .swiper-slide {
      transform: scale(1) !important;
      transition: none !important;
    }

    {{ default_sid }} .swiper-slide-active,
    {{ default_sid }} .swiper-slide-duplicate-active {
      transform: scale(1) !important;
    }

    /* PC: show pc icon, hide mob icon */
    {{ default_sid }} .jingva-testimonials-new-icon-pc {
      display: block !important;
    }

    {{ default_sid }} .jingva-testimonials-new-icon-mob {
      display: none !important;
    }

    /* === PAD: 1280~1439 === */
    @media screen and (min-width: 1280px) and (max-width: 1439px) {
      {{ default_sid }} .jingva-testimonials-new-wrapper {
        padding: 0 48px !important;
        gap: 48px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-title {
        font-size: 40px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide {
        width: 100% !important;
        max-width: 800px !important;
        gap: 16px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-image {
        height: 533px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-text {
        padding: 0 100px 0 0 !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-subtitle {
        font-size: 20px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-description {
        font-size: 16px !important;
      }
    }

    /* === PC: 1440~1919 === */
    @media screen and (min-width: 1440px) and (max-width: 1919px) {
      {{ default_sid }} .jingva-testimonials-new-wrapper {
        padding: 0 !important;
        gap: 48px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide {
        width: 100% !important;
        max-width: 1200px !important;
        gap: 12px !important;
      }

      {{ default_sid }} .swiper-slide {
        transform: scale(1) !important;
        transition: none !important;
      }

      {{ default_sid }} .swiper-slide-active,
      {{ default_sid }} .swiper-slide-duplicate-active {
        transform: scale(1) !important;
      }
    }

    /* === PC Large: 1920~2559 === */
    @media screen and (min-width: 1920px) and (max-width: 2559px) {
      {{ default_sid }} .jingva-testimonials-new-wrapper {
        padding: 0 !important;
        gap: 48px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide {
        width: 100% !important;
        max-width: 1200px !important;
        gap: 12px !important;
      }

      {{ default_sid }} .swiper-slide {
        transform: scale(1) !important;
        transition: none !important;
      }

      {{ default_sid }} .swiper-slide-active,
      {{ default_sid }} .swiper-slide-duplicate-active {
        transform: scale(1) !important;
      }
    }

    /* === PC Ultra: 2560+ === */
    @media screen and (min-width: 2560px) {
      {{ default_sid }} .jingva-testimonials-new-wrapper {
        padding: 0 !important;
        gap: 48px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide {
        width: 100% !important;
        max-width: 1200px !important;
        gap: 24px !important;
      }

      {{ default_sid }} .swiper-slide {
        transform: scale(1) !important;
        transition: none !important;
      }

      {{ default_sid }} .swiper-slide-active,
      {{ default_sid }} .swiper-slide-duplicate-active {
        transform: scale(1) !important;
      }
    }

    /* === MOB: 375~1279 === */
    @media screen and (max-width: 1279px) {
      {{ default_sid }} {
        background-color: {{ bg_color_mob | default: '#121b2c' }} !important;
        padding: {{ padding_top_mob }}px 0 {{ padding_bottom_mob }}px 0 !important;
        /* CSS 变量：移动端间距 */
        --image-to-title-gap-mob: {{ image_to_title_gap_mob }}px;
        --title-to-description-gap-mob: {{ title_to_description_gap_mob }}px;
        --image-to-description-gap-no-title-mob: {{ image_to_description_gap_no_title_mob }}px;
        --description-to-buttons-gap-mob: {{ description_to_buttons_gap_mob }}px;
      }

      {{ default_sid }} .jingva-testimonials-new-slider-wrapper {
        gap: var(--description-to-buttons-gap-mob, 24px) !important;
      }

      {{ default_sid }} .jingva-testimonials-new-wrapper {
        padding: 0 16px !important;
        gap: 24px !important;
      }

      {{ default_sid }} .jingva-testimonials-new-title {
        font-size: 24px !important;
        /* Figma 5738-5082：title→slides itemSpacing=24，由 wrapper gap 提供。
           MOB 关掉 translateY(-50px) 入场动画，避免视觉上额外 50px 间隔 */
        transform: translateY(0) !important;
        transition: none !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide {
        /* Figma 5738-5082：slide 346，slide 之间 12px 间距 */
        width: 346px !important;
        max-width: 346px !important;
        gap: var(--image-to-title-gap-mob) !important;
      }

      /* 移动端：当没有标题时，使用不同的间距 */
      {{ default_sid }} .jingva-testimonials-new-slide:has(.jingva-testimonials-new-slide-text:not(:has(.jingva-testimonials-new-slide-subtitle))) {
        gap: var(--image-to-description-gap-no-title-mob) !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-image {
        width: 100% !important;
        height: 284px !important;
        margin: 0 !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-image img {
        height: 100% !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-text {
        padding: 0 20px 0 0 !important;
        gap: var(--title-to-description-gap-mob) !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-subtitle {
        font-size: 24px !important;
        font-weight: 500;
        line-height: 120%; /* 28.8px */
        letter-spacing: -0.48px;
      }

      {{ default_sid }} .jingva-testimonials-new-subtitle-pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-testimonials-new-subtitle-mob {
        display: block !important;
      }

      {{ default_sid }} .jingva-testimonials-new-slide-description {
        font-size: 16px !important;
        color: {{ auto_description_color_mob }} !important;
      }

      {{ default_sid }} .jingva-testimonials-new-description-pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-testimonials-new-description-mob {
        display: block !important;
      }

      {% if theme_mode == 'light' %}
        {{ default_sid }} .jingva-testimonials-new-nav-btn {
          width: 40px !important;
          height: 40px !important;
          padding: 0 !important;
          border-radius: 8px !important;
        }
      {% else %}
        {{ default_sid }} .jingva-testimonials-new-nav-btn {
          width: 36px !important;
          height: 36px !important;
          padding: 0 !important;
          border-radius: 8px !important;
        }
      {% endif %}

      {{ default_sid }} .jingva-testimonials-new-nav-btn:hover {
        background-color: {{ auto_button_hover_bg }} !important;
      }

      {{ default_sid }} .jingva-testimonials-new-nav-btn:disabled,
      {{ default_sid }} .jingva-testimonials-new-nav-btn.swiper-button-disabled {
        background-color: {{ auto_button_disabled_bg }} !important;
        cursor: not-allowed !important;
      }

      /* MOB: show mob icon, hide pc icon */
      {{ default_sid }} .jingva-testimonials-new-icon-pc {
        display: none !important;
      }

      {{ default_sid }} .jingva-testimonials-new-icon-mob {
        display: block !important;
      }
    }

    {% if theme_mode == 'light' %}
      {{ default_sid }} .jingva-testimonials-new-nav {
        margin-top: 0 !important;
      }
    {% endif %}
  {% endstyle %}

  {% if slide_count > 0 %}
    <div class="jingva-testimonials-new-wrapper">
      {% if se_stts.title != blank %}
        <h2 class="jingva-testimonials-new-title">{{ se_stts.title }}</h2>
      {% endif %}

      <div class="jingva-testimonials-new-slider-wrapper">
        <div class="jingva-testimonials-new-slider-container">
          <div class="jingva-testimonials-new-slider swiper" id="jingva-testimonials-new-slider-{{ sid }}">
            <div class="swiper-wrapper">
              {% for block in slide_blocks %}
                <div class="swiper-slide jingva-testimonials-new-slide" data-slide-index="{{ forloop.index0 }}">
                  {% if block.settings.pc_image != blank or block.settings.mob_image != blank %}
                    <picture class="jingva-testimonials-new-slide-image">
                      {% if block.settings.pc_image != blank %}
                        <source media="(min-width: 1280px)" srcset="{{ block.settings.pc_image | image_url: width: 2400 }}">
                      {% endif %}
                      {% if block.settings.mob_image != blank %}
                        <source media="(max-width: 1279px)" srcset="{{ block.settings.mob_image | image_url: width: 800 }}">
                      {% endif %}
                      {% assign default_image = block.settings.pc_image | default: block.settings.mob_image %}
                      {% if default_image != blank %}
                        <img
                          src="{{ default_image | image_url: width: 2400 }}"
                          alt="{{ block.settings.subtitle | default: se_stts.title | escape }}"
                          loading="lazy"
                        />
                      {% endif %}
                    </picture>
                  {% endif %}

                  <div class="jingva-testimonials-new-slide-text">
                    {% if se_stts.show_subtitle %}
                      {% if block.settings.subtitle_pc != blank %}
                        <h3 class="jingva-testimonials-new-slide-subtitle jingva-testimonials-new-subtitle-pc">{{ block.settings.subtitle_pc }}</h3>
                      {% endif %}
                      {% if block.settings.subtitle_mob != blank %}
                        <h3 class="jingva-testimonials-new-slide-subtitle jingva-testimonials-new-subtitle-mob">{{ block.settings.subtitle_mob }}</h3>
                      {% endif %}
                    {% endif %}

                    {% if block.settings.description_pc != blank %}
                      <p class="jingva-testimonials-new-slide-description jingva-testimonials-new-description-pc">{{ block.settings.description_pc }}</p>
                    {% endif %}
                    {% if block.settings.description_mob != blank %}
                      <p class="jingva-testimonials-new-slide-description jingva-testimonials-new-description-mob">{{ block.settings.description_mob }}</p>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>

        {% if slide_count > 1 %}
          <div class="jingva-testimonials-new-nav">
            <button class="jingva-testimonials-new-nav-btn jingva-testimonials-new-nav-prev" aria-label="Previous">
              {% if theme_mode == 'dark' %}
                {%- comment -%}深色主题 PC/MOB 左侧 icon（Figma 实心箭头）{%- endcomment -%}
                <svg class="jingva-testimonials-new-icon-pc" xmlns="http://www.w3.org/2000/svg" width="9.121" height="15.414" viewBox="0 0 10 16" fill="none" aria-hidden="true">
