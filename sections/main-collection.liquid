{%- render 'section-spacing-collapsing' -%}
{%- assign section_identifier = '#shopify-section-' | append: section.id -%}
{%- assign padding_top = section.settings.padding_top | append: 'px' -%}
{%- assign padding_bottom = section.settings.padding_bottom | append: 'px' -%}

{%- assign padding_mobile_top = section.settings.padding_top_mob | append: 'px' -%}
{%- assign padding_mobile_bottom = section.settings.padding_bottom_mob | append: 'px' -%}

{%- if section.settings.show_filters and collection.filters.size > 0 -%}
  {%- assign show_filters = true -%}
{%- else -%}
  {%- assign show_filters = false -%}
{%- endif -%}

<style>
    .product-card {
      display: flex;
      overflow: hidden;
      flex-direction: column;
  }
    {{ section_identifier }}.shopify-section--main-collection .collection{
      margin-block-start: {{padding_top}};
      margin-block-end: {{padding_bottom}};
    }

   @media only screen and (max-width: 430px) {
      {{ section_identifier }}.shopify-section--main-collection .collection{
        margin-block-start: {{ padding_mobile_top }};
        margin-block-end: {{ padding_mobile_bottom }};
      }
    }
    {%- assign card_blends = false -%}

    {%- unless settings.background != 'rgba(0,0,0,0)' and settings.product_card_background != 'rgba(0,0,0,0)' and settings.background != settings.product_card_background -%}
      {%- assign card_blends = true -%}
    {%- endunless -%}

    #shopify-section-{{ section.id }} {
      --product-list-gap: {% if section.settings.products_per_row_mobile == '2' %}{% if card_blends %}var(--product-list-row-gap){% endif %} var(--spacing-2){% else %}var(--product-list-row-gap) var(--product-list-column-gap){% endif %};
      --product-list-items-per-row: {{ section.settings.products_per_row_mobile | times: 1 }};
      --product-list-grid: auto-flow dense / repeat(var(--product-list-items-per-row), minmax(0, 1fr));
      --product-list-promo-grid-column: span {{ section.settings.products_per_row_mobile }};

      --content-over-media-gap: var(--spacing-8);
    }

    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} {
        --product-list-gap: var(--product-list-row-gap) var(--product-list-column-gap);
        --product-list-items-per-row: 2;
        --product-list-promo-grid-column: span 1;
      }
    }

    @media screen and (min-width: 1000px) {
      #shopify-section-{{ section.id }} {
        --product-list-items-per-row: {% if section.settings.filter_layout == 'sidebar' %}2{% else %}{{ section.settings.products_per_row_desktop | at_most: 3 }}{% endif %};
        --product-list-promo-grid-column: span 2;
      }
    }

    @media screen and (min-width: 1200px) {
      #shopify-section-{{ section.id }} {
        --product-list-items-per-row: {% if section.settings.filter_layout == 'sidebar' %}{{ section.settings.products_per_row_desktop | at_most: 3 }}{% else %}{{ section.settings.products_per_row_desktop }}{% endif %};
      }
    }

    @media screen and (min-width: 1400px) {
      #shopify-section-{{ section.id }} {
        --product-list-items-per-row: {{ section.settings.products_per_row_desktop }};
      }

      {%- for block in section.blocks -%}
        #block-{{ section.id }}-{{ block.id }} {
          --product-list-promo-grid-column: span {{ block.settings.column_span }};

          {%- if block.settings.column_span == '2' -%}
            --content-over-media-column-gap: var(--spacing-12);
          {%- endif -%}
        }
      {%- endfor -%}
    }
    {% if section.settings.enable_sticky %}
      {{ section_identifier }}.shopify-section--main-collection .scrolled-past-container .scrolled-past-filter {
          position: sticky;
          top: 95px;
          z-index: 9;
          width: 100.1%;
          background: rgb(var(--background));
          padding: 20px 0;
      }
      {{ section_identifier }}.shopify-section--main-collection .container facet-floating-filter.facets__floating-filter.scrolled-past-filter {
          position: sticky;
          width: 50%;
        }
        @media only screen and (max-width: 1149px) {
          {{ section_identifier }}.shopify-section--main-collection .scrolled-past-container .scrolled-past-filter {
            top: 58px;
          }
        }
        @media only screen and (max-width: 430px) {
          {{ section_identifier }}.shopify-section--main-collection .scrolled-past-container .scrolled-past-filter {
            top: 54px;
            display: flex;
            align-items: center;
          }
          .shopify-section--main-collection .scrolled-past-container .scrolled-past-filter.collection__top-bar.kiks-collection-top-bar {
              justify-content: end;
          }
        }
    {% endif %}

    {% if section.settings.enable_comparison %}
      .collection .collection__top-bar .facets-summary {
          justify-content: space-between;
      }
      .custom-group {
          display: flex;
          gap: 16px;
      }
      /* button.btn-custom.text-with-icon {
          font-size: 16px;
          font-weight: 700;
      } */
  {% endif %}
  @media only screen and (max-width: 820px) {
    {{ section_identifier }} .container[data-custom="true"] .place-self-center-start {
        place-self: end start;
    }
  }
  @media only screen and (max-width: 430px) {
    {{ section_identifier }} .container[data-custom="true"] .custom-content-overlay {
        width: 100% !important;
    }
  }
</style>

<div class="container" data-custom="{{ section.settings.enable_custom_layout }}">
  {%- if collection.all_products_count == 0 -%}
    <div class="empty-state">
      <div class="empty-state__icon-wrapper">
        {%- render 'icon' with 'picto-stop', width: 32, height: 32, stroke_width: 1 -%}
        <span class="count-bubble count-bubble--lg">0</span>
      </div>

      <div class="prose">
        <p class="h4">{{ 'collection.general.empty_collection' | t }}</p>

        {%- assign button_content = 'collection.general.continue_shopping' | t -%}
        {%- render 'button', href: routes.all_products_collection_url, size: 'xl', content: button_content -%}
      </div>
    </div>
  {%- else -%}
    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="collection {% if show_filters %}collection--filters-{{ section.settings.filter_layout | escape }}{% endif %}">
        {%- if show_filters or section.settings.show_sort_by -%}
          {%- comment -%}
            IMPLEMENTATION NOTE: we have to output the drawer no matter what, as it is used on mobile (all the time) or desktop (when in drawer mode)
          {%- endcomment -%}

          <facet-drawer header-bordered id="facets-drawer" class="facets-drawer drawer" open-from="left">
            <p class="h5" slot="header">{{ 'collection.faceting.filters' | t }}</p>
            {%- render 'facets-vertical',
              results: collection,
              show_filters: true,
              show_sort_by: section.settings.show_sort_by,
              update_on_change: false
            -%}
          </facet-drawer>
          {%- if section.settings.enable_custom_layout -%}
            {%- render 'kiks-collection-top-bar',
              results: collection,
              show_filters: show_filters,
              show_active_filters: show_filters,
              show_sort_by: section.settings.show_sort_by,
              comparison_product: section.settings.enable_comparison
            -%}
          {%- else -%}
            {%- if section.settings.filter_layout == 'horizontal' -%}
              {%- render 'collection-top-bar',
                results: collection,
                show_filters: show_filters,
                show_active_filters: show_filters,
                show_sort_by: section.settings.show_sort_by,
                comparison_product: section.settings.enable_comparison
              -%}
            {%- else -%}
              {%- render 'collection-top-bar',
                results: collection,
                show_filters: false,
                show_active_filters: show_filters,
                show_sort_by: section.settings.show_sort_by,
                comparison_product: section.settings.enable_comparison
              -%}
            {%- endif -%}
          {%- endif -%}
          {%- comment -%}We also need to render the button, that is floating on mobile{%- endcomment -%}
          {%- if show_filters -%}
            <facet-floating-filter class="kiks_filter_fam facets__floating-filter md:hidden">
              {%- assign filter_label = 'collection.faceting.filter_and_sort' | t -%}
              {%- assign custom_filter_label = 'Filters' -%}
              {%- render 'button',
                size: 'xl',
                content: custom_filter_label,
                icon: 'custom-filter',
                style: 'fill',
                background: settings.text_color,
                text_color: settings.background,
                aria_controls: 'facets-drawer'
              -%}
            </facet-floating-filter>
          {%- endif -%}
        {%- endif -%}

        {%- if show_filters and section.settings.filter_layout == 'sidebar' -%}
          <div class="collection__facets">
            <safe-sticky class="collection__facets-scroller">
              {%- render 'facets-vertical',
                results: collection,
                show_filters: true,
                show_sort_by: false,
                update_on_change: true
              -%}
            </safe-sticky>
          </div>
        {%- endif -%}
        <div class="collection__results">
          {%- if collection.products_count == 0 -%}
            <div class="empty-state">
              <div class="empty-state__icon-wrapper">
                {%- render 'icon' with 'picto-stop', width: 32, height: 32, stroke_width: 1 -%}
                <span class="count-bubble count-bubble--lg">0</span>
              </div>

              <div class="prose">
                <p class="h5">{{ 'collection.faceting.no_results' | t }}</p>

                {%- assign button_content = 'collection.faceting.clear_filters' | t -%}
                {%- render 'button', href: collection.url, is: 'facet-link', size: 'xl', content: button_content -%}
              </div>
            </div>
          {%- else -%}
            <div class="v-stack gap-6">
              <div class="v-stack gap-4 md:hidden product-custom-count">
                {%- comment -%}We have to duplicate some information on mobile and tablet here{%- endcomment -%}
                <p class="text-center">{{ 'collection.products_count' | t: count: collection.products_count }}</p>
                {%- render 'active-facets', results: collection -%}
              </div>

              <reveal-items selector=".product-list > *">
                <product-list class="product-list" role="region" aria-live="polite">
                  {%- for product in collection.products -%}
                    {%- for block in section.blocks -%}
                      {%- if forloop.parentloop.index != block.settings.position -%}
                        {%- continue -%}
                      {%- endif -%}

                      <div
                        id="block-{{ section.id }}-{{ block.id }}"
                        {% render 'surface',
                          class: 'product-list__promo group',
                          text_color: block.settings.text_color
                        %}
                        {{ block.shopify_attributes }}
                      >
                        <a
                          {% if block.settings.link_url %}
                            href="{{ block.settings.link_url }}"
                          {% endif %}
                          class="content-over-media h-full rounded-sm"
                          style="--content-over-media-overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }}"
                        >
                          {%- case block.type -%}
                            {%- when 'promotion_image' -%}
                              {%- liquid
                                assign loading_strategy = null

                                if section.index > 3 or forloop.index > 3
                                  assign loading_strategy = 'lazy'
                                endif
                              -%}

                              {%- if block.settings.image != blank -%}
                                <picture>
                                  {%- capture sizes -%}(max-width: 699px) 100vw, {{ 400 | times: block.settings.column_span }}px{%- endcapture -%}

                                  <source
                                    media="(max-width: 699px)"
                                    srcset="{{ block.settings.mobile_image | image_url: width: 400 }} 400w, {{ block.settings.mobile_image | image_url: width: 600 }} 600w, {{ block.settings.mobile_image | image_url: width: 800 }} 800w, {{ block.settings.mobile_image | image_url: width: 1000 }} 1000w, {{ block.settings.mobile_image | image_url: width: 1200 }} 1200w"
                                    width="{{ block.settings.mobile_image.width }}"
                                    height="{{ block.settings.mobile_image.height }}"
                                  >

                                  {{-
                                    block.settings.image
                                    | image_url: width: block.settings.image.width
                                    | image_tag:
                                      loading: loading_strategy,
                                      sizes: sizes,
                                      widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600',
                                      class: 'zoom-image'
                                  -}}
                                </picture>
                              {%- endif -%}

                            {%- when 'promotion_video' -%}
                              {%- if block.settings.video -%}
                                <video-media autoplay>
                                  {{-
                                    block.settings.video
                                    | video_tag: playsinline: true, muted: true, loop: true, preload: 'metadata'
                                  -}}
                                </video-media>
                              {%- else -%}
                                <video-media host="{{ block.settings.external_video_url.type }}" autoplay>
                                  <template>
                                    {%- if block.settings.external_video_url.type == 'youtube' -%}
                                      <iframe
                                        src="https://www.youtube.com/embed/{{ block.settings.external_video_url.id }}?playsinline=1&autoplay=1&controls=0&mute=1&loop=1&playlist={{ block.settings.external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}"
                                        allow="autoplay; encrypted-media"
                                        allowfullscreen="allowfullscreen"
                                      ></iframe>
                                    {%- elsif block.settings.external_video_url.type == 'vimeo' -%}
                                      <iframe
                                        src="https://player.vimeo.com/video/{{ block.settings.external_video_url.id }}?autoplay=1&autopause=1&background=1&loop=1&muted=1&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}"
                                        allow="autoplay; encrypted-media;"
                                        allowfullscreen="allowfullscreen"
                                      ></iframe>
                                    {%- endif -%}
                                  </template>
                                </video-media>
                              {%- endif -%}
                          {%- endcase -%}

                          {%- if block.settings.title != blank or block.settings.link_text != blank -%}
                            <div
                              class="{% if section.settings.enable_custom_layout %}custom-content-overlay {% endif %}{{ block.settings.text_position }}"
                              {% if block.settings.enable_custom_position %}
                                style="
                                  width: {{ block.settings.custom_width | append:'%' }};
                                  margin-{{ block.settings.content_position }}: auto;
                                "
                              {% endif %}
                            >
                              <div class="v-stack gap-4 sm:gap-6 {% if block.settings.text_position contains 'text-center' %}justify-items-center{% elsif block.settings.text_position contains 'text-end' %}justify-items-end{% endif %}">
                                {%- if block.settings.title != blank or block.settings.content != blank -%}
                                  <div class="prose">
                                    {%- if block.settings.title != blank -%}
                                      <p class="{{ block.settings.heading_tag }}">
                                        {{ block.settings.title | escape }}
                                      </p>
                                    {%- endif -%}

                                    {{- block.settings.content -}}
                                  </div>
                                {%- endif -%}
                                {%- if block.settings.show_compare_modal -%}
                                  <button
                                    type="button"
                                    class="kiks_filter_fam btn-custom text-with-icon"
                                    style="color: {{ block.settings.btn_color }};"
                                  >
                                    {{- block.settings.link_text | escape -}}
                                    {%- render 'icon' with 'plus' -%}
                                  </button>
                                {%- else -%}
                                  {%- if block.settings.link_text != blank -%}
                                    <div class="h-stack gap-4">
                                      <span class="kiks_btn_fam bold">{{- block.settings.link_text | escape -}}</span>

                                      <div class="circle-button circle-button--sm">
                                        <span class="sr-only">{{ 'general.accessibility.previous' | t }}</span>
                                        <span class="animated-arrow"></span>
                                      </div>
                                    </div>
                                  {%- endif -%}
                                {%- endif -%}
                              </div>
                            </div>
                          {%- endif -%}
                        </a>
                      </div>
                    {%- endfor -%}

                    {%- render 'product-card',
                      product: product,
                      stacked: true,
                      position: forloop.index,
                      show_badges: true
                    -%}
                  {%- endfor -%}
                </product-list>
              </reveal-items>
            </div>
          {%- endif -%}
        </div>

        {%- render 'pagination', paginate: paginate, facet: true, class: 'collection__pagination' -%}
      </div>
    {%- endpaginate -%}
  {%- endif -%}
</div>
{% if section.settings.enable_comparison %}
  <facet-drawer header-bordered id="comparison-modal" class="facets-drawer drawer" open-from="left">
    <kiks-product-comparison>
      <h2 class="h2 section-header-comparison" style="text-align: center; padding-top: 50px;">
        Choose Your Perfect Gaming Chair
      </h2>
      <div class="product-comparison section section-full">
        <div class="select-container">
          <div class="select-main-inner">
            <select id="modal-chair1" class="chair1">
              {%- for entry in collection.metafields.custom.products_comparison.value -%}
                <option
                  value="product-{{ entry.product.value.id }}"
                  data-style="{{ entry.style }}"
                  data-color="{{ entry.color }}"
                  data-massage="{{ entry.massage }}"
                  data-arm_style="{{ entry.arm_style }}"
                  data-ventilation_&_heated_function="{{ entry.ventilation_heated_function }}"
                  data-warranty="{{ entry.warranty }}"
                  data-material="{{ entry.material }}"
                  data-recommended_height="{{ entry.product_dimensions | escape }}"
                  data-maximum_weight="{{ entry.maximum_weight }}"
                >
                  {{ entry.product.value.title }}
                </option>
              {%- endfor -%}
            </select>
          </div>
          <div class="select-main-inner">
            <select id="modal-chair2" class="chair2">
              {%- for entry in collection.metafields.custom.products_comparison.value -%}
                <option
                  value="product-{{ entry.product.value.id }}"
                  data-style="{{ entry.style }}"
                  data-color="{{ entry.color }}"
                  data-massage="{{ entry.massage }}"
                  data-arm_style="{{ entry.arm_style }}"
                  data-ventilation_&_heated_function="{{ entry.ventilation_heated_function }}"
                  data-warranty="{{ entry.warranty }}"
                  data-material="{{ entry.material }}"
                  data-recommended_height="{{ entry.product_dimensions | escape }}"
                  data-maximum_weight="{{ entry.maximum_weight }}"
                >
                  {{ entry.product.value.title }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        </div>

        <div class="product-container">
          <div id="modal-product-left" class="product-left product-item"></div>
          <div id="modal-product-right" class="product-right product-item"></div>
        </div>

        {%- for entry in collection.metafields.custom.products_comparison.value -%}
          <div class="product" id="product-{{ entry.product.value.id }}">
            {%- if entry.product.value.featured_image != blank -%}
              {{-
                entry.product.value.featured_image
                | image_url: width: entry.product.value.featured_image.width
                | image_tag:
                  loading: 'lazy',
                  sizes: '(max-width: 740px) 100vw, 650px',
                  widths: '200,300,400,600,800,1000,1200,1400,1600',
                  class: 'rounded-sm'
              -}}
            {%- else -%}
              {%- capture image_placeholder -%}product-{%- cycle '1', '2', '3', '4' -%}{%- endcapture -%}
              {{- image_placeholder | placeholder_svg_tag: 'placeholder' -}}
            {%- endif -%}

            <div class="product-info">
              <div class="inner-product-info">
                <div class="rating-with-text">
                  <span class="product-card__title">
                    <a href="{{ entry.product.value.url }}" class="kiks_product_fam bold" data-instant>
                      {{- entry.product.value.title -}}
                    </a>
                  </span>
                  {%- capture rating_class -%}{% if mobile_reduced %}hidden sm:flex{% endif %}{%- endcapture -%}
                  {%- render 'product-rating',
                    product: entry.product.value,
                    class: rating_class,
                    display_mode: settings.product_rating_mode
                  -%}
                </div>
                <p class="comparison-price">
                  {%- render 'price-list', product: entry.product.value -%}
                </p>
              </div>
              <div class="action-container">
                <a href="{{ entry.product.value.url }}" is="custom-button" class="shop-now button button--xl"
                  >SHOP NOW</a
                >
              </div>
            </div>
          </div>
        {%- endfor -%}

        <table class="compare-table">
          {%- assign features = 'style,color,massage,arm_style,ventilation_&_heated_function,warranty,material,recommended_height,maximum_weight'
            | split: ','
          -%}
          {%- for feature in features -%}
            <tr>
              <td>{{ feature | replace: '_', ' ' | capitalize }}</td>
              <td class="{{ feature }}-chair1">-</td>
              <!-- Chair 1 -->
              <td class="{{ feature }}-chair2">-</td>
              <!-- Chair 2 -->
            </tr>
          {%- endfor -%}
        </table>
      </div>
    </kiks-product-comparison>
  </facet-drawer>
{% endif %}

{% if section.settings.enable_sticky %}
  <script>
    window.addEventListener('scroll', function () {
      const targetSection = document.querySelector('.shopify-section--main-collection');
      if (!targetSection) return;

      const collection = targetSection.querySelector('.collection');
      const topBar = targetSection.querySelector('.collection__top-bar');
      const flostingFilter = targetSection.querySelector(' facet-floating-filter.facets__floating-filter');
      if (!collection || !topBar) return;

      const scrollY = window.scrollY;
      const sectionTop = targetSection.offsetTop;

      // Add classes when we've scrolled past the top of the target section
      if (scrollY >= sectionTop) {
        targetSection.classList.add('scrolled-past-section');
        collection.classList.add('scrolled-past-container');
        topBar.classList.add('scrolled-past-filter');
        flostingFilter.classList.add('scrolled-past-filter');
      } else {
        collection.classList.remove('scrolled-past-container');
        topBar.classList.remove('scrolled-past-filter');
        targetSection.classList.remove('scrolled-past-section');
        flostingFilter.classList.remove('scrolled-past-filter');
      }
    });
  </script>
{% endif %}

<script>
  $(document).ready(function() {
    $('.jingva-color-item').click(function() {
      let currentColor = $(this).data('color-id')

      let productCard = $(this).closest('.product-card')
      let cardInfo = $(this).closest('.product-card__info')
      let priceBox = $(this).closest('.product-card__info').find('.jiangva-cart-buy-box')
      let salePriceEl = cardInfo.find('sale-price').eq(0)
      let comparePriceEl = cardInfo.find('compare-at-price').eq(0)
     
      // 得到变体中的价格和对比价格 然后除以100
      let priceCents = $(this).data('price-cents')
      let comparePriceCents = $(this).data('compare-price-cents')
      

      if(priceCents < comparePriceCents){
       // 根据国家格式化价格，这里以US为例
        const formatPrice = cents => (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        let price = formatPrice(priceCents);
        let comparePrice = formatPrice(comparePriceCents);

        // 只替换 salePriceEl 和 comparePriceEl 中的价格，不重复渲染标签
        salePriceEl.each(function() {
          let html = $(this).html();
          // 美国格式例如 1,234.56
          html = html.replace(/\d{1,3}(?:,\d{3})*\.\d{2}/, price);
          $(this).html(html);
        });
        comparePriceEl.each(function() {
          let html = $(this).html();
          html = html.replace(/\d{1,3}(?:,\d{3})*\.\d{2}/, comparePrice);
          $(this).html(html);
        });

        // 折扣计算公式：(comparePrice - price) / comparePrice * 100
        let discount = ((comparePriceCents - priceCents) / comparePriceCents * 100).toFixed(0)
        let saveEl = productCard.find('.product-card__badge-list .save')
        if(discount > 0){
          saveEl.html(discount + '%')
        }
      }
      

      priceBox.find('input[name="id"]').val(currentColor);
      priceBox.find('.jiangva-buy-now button').attr('onclick', `window.location.href=\`/cart/${currentColor}:1\``)
    })

  })
</script>

{% schema %}
{
  "name": "Collection page",
  "class": "shopify-section--main-collection",
  "tag": "section",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "promotion_image",
