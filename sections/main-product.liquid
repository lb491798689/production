  <script>
// Only enable variant-based gallery logic when default_slider is ON and product has per-variant images
{% assign has_variant_gallery = false %}
{% for v in product.variants %}
  {% if v.metafields.custom.images and v.metafields.custom.images.value and v.metafields.custom.images.value.size > 0 %}
    {% assign has_variant_gallery = true %}
    {% break %}
  {% endif %}
{% endfor %}
{% if section.settings.default_slider and has_variant_gallery %}
// Function to get the currently selected variant ID
function getCurrentVariantId() {
  const selectedInput = document.querySelector('.variant-picker__option-values input:checked');
  console.log(selectedInput.getAttribute("data-id"))
  return selectedInput ? selectedInput.getAttribute("data-id") : null;
}

function getVariantIdFromUrl() {
  const urlParams = new URLSearchParams(window.location.search);
  return urlParams.get('variant');
}

// Function to update visible images based on variant ID
function updateVisibleImages(variantId) {
  // Hide all media elements first

  document.querySelectorAll('.product-gallery__media').forEach(el => {
    el.style.display = 'none';
  });
  // Hide all thumbnail elements first
  document.querySelectorAll('.product-gallery__thumbnail').forEach(el => {
    el.style.display = 'none';
  });
   
const firstThumbnail = document.querySelector(`.product-gallery__thumbnail[data-id="${variantId}"]`);
  if (firstThumbnail) {
    firstThumbnail.click();
  }
  // Show only media elements with matching variant ID
  document.querySelectorAll(`.product-gallery__media[data-id="${variantId}"]`).forEach(el => {
    el.style.display = 'block';
  });
  
  // Show only thumbnail elements with matching variant ID
  document.querySelectorAll(`.product-gallery__thumbnail[data-id="${variantId}"]`).forEach(el => {
    el.style.display = 'block';
  });
 
}




const initialVariantId = getCurrentVariantId();
setTimeout(function(){
 updateVisibleImages(initialVariantId);
},250)
 


// Listen for variant selection changes
document.querySelectorAll('.variant-picker__option-values input').forEach(input => {
  input.addEventListener('change', () => {
    const variantId = getCurrentVariantId();
    if (variantId) {
      updateVisibleImages(variantId);
      // Update URL to maintain the variant
      const url = new URL(window.location.href);
     // url.searchParams.set('variant', variantId);
     // window.history.replaceState({}, '', url.toString());
    }
  });
});

// Watch for URL changes (back/forward buttons)
let lastUrl = window.location.href;
function checkUrlChange() {
  const currentUrl = window.location.href;
  if (currentUrl !== lastUrl) {
    lastUrl = currentUrl;
    const variantMatch = currentUrl.match(/variant=(\d+)/);
    if (variantMatch && variantMatch[1]) {
      updateVisibleImages(variantMatch[1]);
      // Also update the radio input to match
      const input = document.querySelector(`.variant-picker__option-values input[value="${variantMatch[1]}"]`);
      if (input) input.checked = true;
    }
  }
  requestAnimationFrame(checkUrlChange);
}
checkUrlChange();
{% endif %}
</script>
 
