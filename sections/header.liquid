}

.kiks_nav_fam,
.kiks_nav_fam span{
  display:flex;
  align-items:center;
  gap:4px;
  font-family: 'Orbitron', sans-serif;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0;
  line-height: 1;
  color: #ffffff;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.kiks_nav_fam img{
  width:24px;
  height:24px;
}

/* 隐藏导航菜单向下箭头 */
.kiks_nav_fam svg.icon,
.header__link-list summary svg.icon,
.header__link-list .icon-chevron-bottom,
.header__link-list svg[class*="chevron"] {
  display: none !important;
}

/* 导航菜单项间距 32px（规范），每项 padding 0 8px；栏高 PC/PAD 64px / Mobile 56px */
.header__link-list {
  gap: 32px !important;
}
/* DOM 为 nav > ul.contents > li（非 nav > li），必须用 ul.contents 否则选择器永远不命中 */
.header__link-list > ul.contents > li > a,
.header__link-list > ul.contents > li > details > summary {
  padding: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Mobile (375~1279px): 导航项高度 56px */
@media screen and (max-width: 1279px) {
  .header__link-list > ul.contents > li > a,
  .header__link-list > ul.contents > li > details > summary {
    height: 56px;
  }
}

/* PAD + PC (1280px+): 导航项高度 64px */
@media screen and (min-width: 1280px) {
  .header__link-list > ul.contents > li > a,
  .header__link-list > ul.contents > li > details > summary {
    height: 64px;
  }

  /*
    PC 主导航交互（Figma）：
    - 悬浮：不改背景、不改字色、不减透明度（覆盖 theme .link-faded-reverse:hover opacity:.7）
    - 纯链接一级菜单：底部红线（与 details 的 .red-line-pc 一致）
    - 仅指向 .header__main-nav / .header__secondary-nav 下顶层 li > a，避免命中下拉内链接
  */
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.link-faded-reverse:hover,
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.link-faded-reverse:focus-visible,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a.link-faded-reverse:hover,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a.link-faded-reverse:focus-visible {
    opacity: 1 !important;
  }
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list details > summary.link-faded-reverse:hover,
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list details > summary.link-faded-reverse:focus-visible,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list details > summary.link-faded-reverse:hover,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list details > summary.link-faded-reverse:focus-visible {
    opacity: 1 !important;
  }
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.kiks_nav_fam,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a {
    position: relative;
    z-index: 1;
    background-color: transparent !important;
    color: #ffffff !important;
  }
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.kiks_nav_fam:hover,
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.kiks_nav_fam:focus-visible,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a:hover,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a:focus-visible {
    background-color: transparent !important;
    color: #ffffff !important;
    opacity: 1 !important;
  }
  /* 纯文字一级链接：header 底边红线（主栏 .kiks_nav_fam + 次栏 .bold 等任意顶层 a） */
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.kiks_nav_fam::after,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: #D6000C;
    pointer-events: none;
    z-index: 3;
    opacity: 0;
    transform: scaleX(0.6);
    transform-origin: center;
    transition: none;
  }
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.kiks_nav_fam:hover::after,
  #shopify-section-{{ section.id }} .header__wrapper .header__main-nav .header__link-list > ul.contents > li > a.kiks_nav_fam:focus-visible::after,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a:hover::after,
  #shopify-section-{{ section.id }} .header__wrapper .header__secondary-nav .header__link-list > ul.contents > li > a:focus-visible::after {
    opacity: 1;
    transform: scaleX(1);
  }
}

/* 右侧功能区 gap 16px（规范） */
.header__secondary-nav {
  gap: 16px !important;
}

/* 右侧图标列表 gap 16px（规范：图标间距 16px，图标尺寸 24px）*/
.header__icon-list {
  gap: 16px !important;
}

  /* —— Figma 1391:123637 仅本 Header section，不影响页脚/抽屉内 localization —— */
