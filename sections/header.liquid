{%- comment -%} 全局导航遮罩：在 product mega-menu 或 search-drawer 打开时显示 {%- endcomment -%}
<div class="af-nav-overlay" id="af-nav-overlay" aria-hidden="true"></div>

<script>
(function () {
  var overlay = document.getElementById('af-nav-overlay');
  if (!overlay) return;

  // 把遮罩挂到 body 末尾，避免被父级 stacking context 限制
  if (overlay.parentElement !== document.body) {
    document.body.appendChild(overlay);
  }

  function show() { overlay.classList.add('is-active'); }
  function hide() { overlay.classList.remove('is-active'); }

  function isSearchOpen() {
    var sd = document.getElementById('search-drawer');
    return !!(sd && sd.open);
  }
  function isAnyMegaOpen() {
    return !!document.querySelector('.header__wrapper details[is="mega-menu-disclosure"][open]');
  }
  function syncState() {
    if (isAnyMegaOpen() || isSearchOpen()) show();
    else hide();
  }

  // 1) 给每个 mega-menu details 直接绑 toggle（toggle 事件不冒泡）
  function bindMegaMenus() {
    document.querySelectorAll('.header__wrapper details[is="mega-menu-disclosure"]').forEach(function (d) {
      if (d._afOverlayBound) return;
      d._afOverlayBound = true;
      d.addEventListener('toggle', syncState);
    });
  }

  // 2) search-drawer：CustomEvent('toggle', { bubbles: true }) 能冒泡到 document
  document.addEventListener('toggle', function (e) {
    var t = e.target;
    if (!t) return;
    if (t.id === 'search-drawer' ||
        (t.matches && t.matches && t.matches('details[is="mega-menu-disclosure"]'))) {
      // 异步一帧让 [open] 属性先更新
      requestAnimationFrame(syncState);
    }
  }, true);

  bindMegaMenus();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindMegaMenus);
  }
  window.addEventListener('load', bindMegaMenus);
  document.addEventListener('shopify:section:load', bindMegaMenus);

  // 3) 点击遮罩 → 关闭一切并隐藏
  overlay.addEventListener('click', function () {
    document.querySelectorAll('.header__wrapper details[is="mega-menu-disclosure"][open]').forEach(function (d) {
      d.removeAttribute('open');
    });
    var sd = document.getElementById('search-drawer');
    if (sd && sd.open && typeof sd.hide === 'function') sd.hide();
    syncState();
  });
})();
</script>

