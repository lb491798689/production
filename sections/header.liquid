{%- style -%}
  /* 移动端汉堡按钮 hamburger ↔ close 切换（跟随 aria-expanded）。放在 enbale_custom 条件外，始终生效 */
  .af-nav-mobile-toggle {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .af-nav-mobile-toggle__hamburger,
  .af-nav-mobile-toggle__close {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 20px !important;
    height: 20px !important;
    line-height: 0 !important;
  }
  /* 锁定 SVG 精确尺寸（Figma 节点数据），防止父级 flex/stroke 拉伸 */
  .af-nav-mobile-toggle__hamburger svg {
    width: 13.334px !important;
    height: 11.666px !important;
    flex-shrink: 0 !important;
    max-width: none !important;
    max-height: none !important;
  }
  .af-nav-mobile-toggle__close svg {
    width: 11.178px !important;
    height: 11.178px !important;
    flex-shrink: 0 !important;
    max-width: none !important;
    max-height: none !important;
  }
  .af-nav-mobile-toggle__close {
    display: none !important;
  }
  .af-nav-mobile-toggle[aria-expanded="true"] .af-nav-mobile-toggle__hamburger {
    display: none !important;
  }
  .af-nav-mobile-toggle[aria-expanded="true"] .af-nav-mobile-toggle__close {
    display: inline-flex !important;
  }

  /*
    手机顶栏图标（汉堡/关闭、搜索、购物车）：点击后浏览器会给 button/a 画焦点环（常见为浅色描边），并非随意加的 border。
    去掉默认 outline/box-shadow，避免在黑底上出现「白圈」。键盘导航可用系统默认别处补足。
  */
  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} .header__icon-list .af-nav-mobile-icon:focus,
    #shopify-section-{{ section.id }} .header__icon-list .af-nav-mobile-icon:focus-visible,
    #shopify-section-{{ section.id }} .header__icon-list .af-nav-mobile-toggle:focus,
    #shopify-section-{{ section.id }} .header__icon-list .af-nav-mobile-toggle:focus-visible {
      outline: none !important;
      box-shadow: none !important;
    }
  }

  /* 滚动重新出现的导航栏：背景 #000（与滚过 KV 后 .header.is-filled 一致） */
  #shopify-section-{{ section.id }}.is-revealed .header__wrapper,
  #shopify-section-{{ section.id }}.is-revealed .header__wrapper:hover {
    background: #000 !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    --header-background-opacity: 1 !important;
    border-bottom: none !important;
  }

  /* ========================================
     develop.md: MOB 375~1279 / PAD 1280~1439 / PC 1440~2560
     Tailwind 原生 sm=700、lg=1024 不匹配 develop.md 的 MOB 上界 1279。
     在 700~1279 区间强制：移动图标显示、PC 图标/工具隐藏、抽屉可展开
     ======================================== */
  @media screen and (min-width: 700px) and (max-width: 1279px) {
    /* Tailwind sm:hidden 默认在 >=700 时 display:none，这里针对 header 内移动图标恢复显示 */
    #shopify-section-{{ section.id }} .header__secondary-nav li.sm\:hidden {
      display: list-item !important;
    }
    /* 隐藏 PC 才用到的 locale 选择器和工具栏 */
    #shopify-section-{{ section.id }} .header__secondary-nav li.hidden.sm\:block,
    #shopify-section-{{ section.id }} .header__secondary-nav li.hidden.sm\:flex {
      display: none !important;
    }
    /* 汉堡按钮/抽屉容器使用 lg:hidden（默认 1024+ 隐藏），扩展到 1279 也可见 */
    #shopify-section-{{ section.id }} .header__secondary-nav li.lg\:hidden {
      display: list-item !important;
    }
    navigation-drawer.lg\:hidden {
      display: block !important;
    }
  }

  /* ─────────────── 全局导航遮罩：product 下拉 / 搜索下拉打开时显示 ─────────────── */
  /* 关闭 mega-menu 自带的全屏 box-shadow，避免与遮罩叠加变得过暗 */
  .header__wrapper .mega-menu {
    box-shadow: none !important;
  }

  .af-nav-overlay {
    position: fixed !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    top: 0 !important;
    background: rgba(0, 0, 0, 0.4) !important;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, visibility 0s linear 0.2s;
    z-index: 102;
  }

  .af-nav-overlay.is-active {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    transition: opacity 0.2s ease, visibility 0s linear 0s !important;
  }

  /*
    PAD（1280~1439）：Figma 仅缩小 logo↔菜单、菜单↔右侧工具区间距；菜单项间距 32px、字号 16px 不变。
    禁止 flex-wrap 避免 ABOUT US / 语言切换被挤到第二行。
  */
  @media screen and (min-width: 1280px) {
    #shopify-section-{{ section.id }} .header__main-nav .header__link-list.wrap {
      flex-wrap: nowrap !important;
    }
    #shopify-section-{{ section.id }} .header__secondary-nav {
      flex-wrap: nowrap !important;
    }
    #shopify-section-{{ section.id }} .header__secondary-nav .header__link-list,
    #shopify-section-{{ section.id }} .header__secondary-nav .header__icon-list {
      flex-wrap: nowrap !important;
    }
    #shopify-section-{{ section.id }} .header__main-nav .header__link-list > ul.contents > li > a,
    #shopify-section-{{ section.id }} .header__main-nav .header__link-list > ul.contents > li > details > summary,
    #shopify-section-{{ section.id }} .header__secondary-nav .header__link-list > ul.contents > li > a {
      white-space: nowrap;
    }
  }

  @media screen and (min-width: 1280px) and (max-width: 1439px) {
    {%- if section.settings.layout contains 'logo_left' -%}
    #shopify-section-{{ section.id }} {
      --header-grid-template: "logo main-nav secondary-nav" / auto minmax(0, 1fr) auto;
    }
    {%- endif -%}

    #shopify-section-{{ section.id }} .header {
      --header-part-gap: 16px;
    }

    #shopify-section-{{ section.id }} .header__wrapper {
      padding-left: 40px !important;
      padding-right: 40px !important;
      gap: 16px !important;
    }

    #shopify-section-{{ section.id }} .header__main-nav,
    #shopify-section-{{ section.id }} .header__main-nav .header__link-list {
      overflow: visible !important;
    }
  }
{%- endstyle -%}
<height-observer variable="header">
  <store-header class="header{% unless is_transparent_header %} is-filled{% endunless %}" {% if section.settings.enable_sticky %}sticky{% endif %}{% if is_transparent_header %} allow-transparency data-transparent-header{% endif %} hide-on-scroll="48">
    <div class="header__wrapper">
      {%- comment -%}
      --------------------------------------------------------------------------------------------------------------------
      MAIN NAV AREA
      --------------------------------------------------------------------------------------------------------------------
      {%- endcomment -%}

      <div class="header__main-nav">
        <div class="header__icon-list">
          {%- if section.settings.layout != 'drawer' and section.settings.menu.links.size > 0 -%}
            <nav class="header__link-list {% if section.settings.layout == 'logo_left_navigation_center' %}justify-center{% endif %} wrap" role="navigation">
              <ul class="contents" role="list">
                {%- for link in section.settings.menu.links -%}
                  {% liquid
                    assign link_title_downcase = link.title | strip | downcase
                    assign mega_menu_block = ''

                    comment
                      仅 mega_menu 区块参与匹配。常见坑：后台填「Products」主导航为「Product」→ 永不命中 mega。
                      额外accept：product ↔ products。
                    endcomment
                    for block in section.blocks
                      if block.type == 'mega_menu'
                        assign menu_item_downcase = block.settings.menu_item | strip | downcase
                        assign menu_matches = false
                        if menu_item_downcase != '' and menu_item_downcase == link_title_downcase
                          assign menu_matches = true
                        elsif menu_item_downcase == 'products' and link_title_downcase == 'product'
                          assign menu_matches = true
                        elsif menu_item_downcase == 'product' and link_title_downcase == 'products'
                          assign menu_matches = true
                        endif
                        if menu_matches
                          assign mega_menu_block = block
                          break
                        endif
                      endif
                    endfor

                    assign has_grandchild_links = false
                    if mega_menu_block == ''
                      for sub_link in link.links
                        if sub_link.links.size > 0
                          assign has_grandchild_links = true
                          break
                        endif
                      endfor
                    endif

                    comment
                      仍有三级导航但未命中名称时：menu_item 留空通配；或 Header 内仅一个 mega_menu 时作为默认。
                    endcomment
                    if mega_menu_block == '' and has_grandchild_links
                      assign mega_blocks_count = 0
                      assign sole_mega_menu_block = ''
                      assign wildcard_mega_menu_block = ''
                      for block in section.blocks
                        if block.type == 'mega_menu'
                          assign mega_blocks_count = mega_blocks_count | plus: 1
                          if sole_mega_menu_block == ''
                            assign sole_mega_menu_block = block
                          endif
                          if block.settings.menu_item == blank and wildcard_mega_menu_block == ''
                            assign wildcard_mega_menu_block = block
                          endif
                        endif
                      endfor
                      if wildcard_mega_menu_block != ''
                        assign mega_menu_block = wildcard_mega_menu_block
                      elsif mega_blocks_count == 1
                        assign mega_menu_block = sole_mega_menu_block
                      endif
                    endif
                  %}
                  {% assign header_icon = "header_icon_" | append : forloop.index %}

                  <li>
                    {%- if link.levels == 0 and mega_menu_block == '' -%}
                      <a href="{{ link.url }}" class="kiks_nav_fam link-faded-reverse" {% if link.current %}aria-current="page"{% endif %}>{% if section.settings[header_icon] != blank %}<span><img src="{{ section.settings[header_icon] |  img_url: '24x24' }}" loading="lazy" style="object-fit:contain"></span>{% endif %} <span>{{- link.title -}}</span></a>
                    {%- else -%}
                      {%- if mega_menu_block != '' -%}
                        {%- comment -%}
                        Implementation note: the designers had the desire to show a lot of different kind of menus in Impact: one standard
                        mega menu but also a kind of "sidebar" mode when the mega-menu appears in a drawer. Unfortunately, this comes with
                        a lot of extra complexity as we have to go through two different code path: a "details" element for the standard
                        menu, and a full drawer for the other one.
                        {%- endcomment -%}
