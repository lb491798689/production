{%- comment -%}
IMPLEMENTATION NOTE: Impact header with all the menu is an extremely complex piece of code. Due to requirements from design
team, we had to cover over hundred of potential combinations. As a consequence, this part (and all the menu snippets) are
extremely sensitive code that should (if possible) not be touched unless you have spend enough time to study and understand
the underlying logic of the menu.
{%- endcomment -%}
{%- assign section_identifier = '#shopify-section-' | append: section.id -%}
{%- comment -%}
  Header 透明底规范：
  - 透明（rgba(0,0,0,0.8) + blur）：index / page.product-detail / page.product-detail-m6；
    滚过 hero 后由脚本加 .is-filled 切换为纯 #000。
  - 其他模板：始终纯 #000。
{%- endcomment -%}
{%- assign is_transparent_header = false -%}
{%- if template == 'index' or template.suffix == 'product-detail' or template.suffix == 'product-detail-m6' -%}
  {%- assign is_transparent_header = true -%}
{%- endif -%}
{%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
  {%- assign will_show_country_selector = true -%}
{%- endif -%}

{%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
  {%- assign will_show_locale_selector = true -%}
{%- endif -%}

<style>
  :root {
    --sticky-header-enabled: {%- if section.settings.enable_sticky -%}1{% else %}0{% endif %};
  }

  #shopify-section-{{ section.id }} {
    --header-grid-template: "main-nav logo secondary-nav" / minmax(0, 1fr) auto minmax(0, 1fr);
    --header-padding-block: {% if section.settings.reduce_padding %}var(--spacing-3){% else %}var(--spacing-4-5){% endif %};
    
    --header-background-blur-radius: {{ section.settings.background_blur_radius }}px;
    --header-transparent-text-color: {{ section.settings.transparent_header_text_color.rgb }};

    {%- if section.settings.logo != blank -%}
      --header-logo-width: {{ section.settings.logo_mobile_max_width }}px;
      --header-logo-height: {{ section.settings.logo_mobile_max_width | divided_by: section.settings.logo.aspect_ratio | round }}px;
    {%- endif -%}

    position: {% if section.settings.enable_sticky %}sticky{% else %}relative{% endif %};
    top: 0;
    z-index: 103;
    --header-background-opacity: {{ section.settings.background_opacity | divided_by: 100.0 }};

    {% if is_transparent_header %}
      --header-background-opacity: 0;
      --text-color: 255 255 255;
      {%- comment -%}
        勿再用 height:0：区块高度为 0 时与公告条 sibling 之间易透出 body/首屏底色缝。
        实际占位高度在下方 max-width:1279 / min-width:1280 中与 .header__wrapper（56px / 64px）对齐。
      {%- endcomment -%}
      margin: 0 !important;
      padding: 0 !important;
    {% endif %}
  
  }
  #shopify-section-{{ section.id }}  .header__wrapper{
    {% if is_transparent_header %}
      --text-color: 255 255 255;
      background: rgba(0, 0, 0, 0.8) !important;
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      position: absolute !important;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      z-index: 103;
    {% else %}
      background: #000 !important;
    {% endif %}
  }
  {% if is_transparent_header %}
   #shopify-section-{{ section.id }}  .header__logo-image--transparent{
    opacity: 1;
   }
   #shopify-section-{{ section.id }}  .header__wrapper:hover .header__logo-image--transparent{
    opacity: 0;
   }

   /* 首页的时候导航栏是隐藏 */


  {% else %}
  /* 非透明 Header 模板（collection 等）：Logo 始终可见，不受首屏 allow-transparent-header 区块影响 */
  #shopify-section-{{ section.id }} .header .header__logo-image {
    --header-logo-opacity: 1;
    opacity: 1 !important;
  }
  #shopify-section-{{ section.id }} .header:not(.is-filled) {
    --header-logo-opacity: 1;
    --header-background-opacity: {{ section.settings.background_opacity | divided_by: 100.0 }};
  }
  {% if section.settings.enable_sticky %}
  #shopify-section-{{ section.id }} {
    position: sticky !important;
    top: 0 !important;
  }
  {% endif %}
  {% endif %}
  {% if is_transparent_header %}
  #shopify-section-{{ section.id }} .header__wrapper:hover {
    --text-color: 255, 255, 255;
    --header-background-opacity: 1;
    background: #000 !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }
  {% endif %}

  /* 滚过首屏 KV 后主导航背景纯黑 #000（首页 + 产品页 / Page 等同脚本加 is-filled 的模板） */
  #shopify-section-{{ section.id }} .header.is-filled .header__wrapper,
  #shopify-section-{{ section.id }} .header.is-filled .header__wrapper:hover {
    background: #000 !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border-bottom: none !important;
  }

  /* 菜单展开（mega menu hover 打开）时 header 也保持纯 #000，避免 hover 时背景色变动 */
  #shopify-section-{{ section.id }} .header:has(details[open]) .header__wrapper,
  #shopify-section-{{ section.id }} .header:has(details[open]) .header__wrapper:hover {
    background: #000 !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border-bottom: none !important;
  }
  /* theme.css .header:has([open]) { --header-background-opacity: 1 } — 避免与子元素其它 [open] 叠加把变量拉满 */
  #shopify-section-{{ section.id }} .header:has(details[open]) {
    --header-background-opacity: {{ section.settings.background_opacity | divided_by: 100.0 }};
  }

  /* AF Header — 规范：PC/PAD 64px，Mobile 56px；Figma 节点 1391:123637 (PC) / 1769:5779 (Mobile) */
  
  /* Mobile (375~1279px): 高度 56px，padding 8px 16px */
  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} .header__wrapper {
      height: 56px;
      min-height: 56px;
      padding: 8px 16px;
      margin: 0 !important;
      {%- if is_transparent_header -%}
        background: transparent;
      {%- else -%}
        background: #000 !important;
      {%- endif -%}
    }

    #shopify-section-{{ section.id }} {
      margin: 0 !important;
      padding: 0 !important;
    }

    /* 全站：header 区块占位与 .header__wrapper 同高，避免 aside 与导航之间透出底色（首页曾 height:0；其它模板如 page + view=product-detail 也会缝） */
    #shopify-section-{{ section.id }} {
      min-height: 56px;
      height: auto;
      box-sizing: border-box;
    }

    #shopify-section-{{ section.id }} .header.is-filled .header__wrapper,
    #shopify-section-{{ section.id }} .header.is-filled .header__wrapper:hover {
      background: #000 !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      border-bottom: none !important;
    }

    /*
      手机全屏菜单打开时：仅顶栏条改为纯黑；下方抽屉内容仍为 theme 浅灰稿（勿把整页菜单打成黑底）。
      抽屉宿主在 body 下，故用 body:has(#header-sidebar-menu[open]) 选中。
    */
    body:has(#header-sidebar-menu[open]) #shopify-section-{{ section.id }} .header__wrapper,
    body:has(#header-sidebar-menu[open]) #shopify-section-{{ section.id }} .header__wrapper:hover {
      background: #000 !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      border-bottom: none !important;
      --header-background-opacity: 1 !important;
    }
  }
  
  /* PAD + PC (1280px+): 高度 64px，padding 0 48px */
  @media screen and (min-width: 1280px) {
    #shopify-section-{{ section.id }} .header__wrapper {
      height: 64px;
      min-height: 64px;
      padding: 0 48px;
      {%- if is_transparent_header -%}
        background: transparent;
      {%- else -%}
        background: #000 !important;
      {%- endif -%}
    }

    #shopify-section-{{ section.id }} {
      min-height: 64px;
      height: auto;
      box-sizing: border-box;
    }

    {%- if section.settings.logo != blank -%}
    #shopify-section-{{ section.id }} .header__logo-image {
      width: 150px !important;
      max-width: 150px !important;
      max-height: 26px !important;
      height: auto !important;
      object-fit: contain !important;
    }
    {%- endif -%}
  }

  /* 移动端 Logo 尺寸 118.75×20px */
  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} {
      {%- if section.settings.logo != blank -%}
        --header-logo-width: {{ section.settings.logo_mobile_max_width }}px;
        --header-logo-height: {{ section.settings.logo_mobile_max_width | divided_by: section.settings.logo.aspect_ratio | round }}px;
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .header__logo-image {
      width: 118.75px !important;
      height: auto !important;
      max-width: 118.75px !important;
      max-height: none !important;
      object-fit: contain !important;
    }
  }

  {%- if section.settings.logo_mobile != blank -%}
  /* 手机端独立 Logo 显示控制 */
  @media screen and (min-width: 1280px) {
    #shopify-section-{{ section.id }} .header__logo-image--mobile {
      display: none !important;
    }
  }
  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} .header__logo-image--pc {
      display: none !important;
    }
  }
  {%- endif -%}

  /* 移动端主导航区图标按钮 40×40，图标 20×20 */
  @media screen and (max-width: 1279px) {
    #shopify-section-{{ section.id }} .header__main-nav .header__icon-list .tap-area {
      width: 40px;
      height: 40px;
    }
    #shopify-section-{{ section.id }} .header__main-nav .header__icon-list svg {
      width: 20px;
      height: 20px;
    }
  }

  {%- if section.settings.enable_sticky -%}
    .shopify-section--announcement-bar ~ #shopify-section-{{ section.id }} {
      top: calc(var(--sticky-announcement-bar-enabled, 0) * var(--announcement-bar-height, 0px));
    }
  {%- endif -%}

  {%- if section.settings.opening_from == 'left' -%}
    /* develop.md: MOB 375~1279（原 699 为遗留 Dawn sm 断点） */
    @media screen and (max-width: 1279px) {
      .navigation-drawer {
        --drawer-content-max-height: 100vh;
        padding: 0;
        width:80vw;
      }
    }
  {%- endif -%}

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      {%- if section.settings.logo != blank -%}
        --header-logo-width: {{ section.settings.logo_max_width }}px;
        --header-logo-height: {{ section.settings.logo_max_width | divided_by: section.settings.logo.aspect_ratio | round }}px;
      {%- endif -%}

      --header-padding-block: {% if section.settings.reduce_padding %}var(--spacing-6){% else %}12px{% endif %};
    }
  }


  {%- if section.settings.layout contains 'logo_left' -%}
    @media screen and (min-width: 1150px) {
      {%- if section.settings.secondary_menu != blank or will_show_country_selector or will_show_locale_selector -%}
        {%- assign max_percent = '55%' -%}
      {%- else -%}
        {%- assign max_percent = '70%' -%}
      {%- endif -%}

      #shopify-section-{{ section.id }} {
        --header-grid-template: "logo main-nav secondary-nav" / {% if section.settings.layout == 'logo_left_navigation_inline' %}auto minmax(0, 1fr) minmax(0, max-content){% else %}minmax(0, 1fr) fit-content({{ max_percent }}) minmax(0, 1fr){% endif %};
      }
    }
  {%- endif -%}

  {%- if is_transparent_header -%}
  /* 抵消透明 header 区块 min-height，避免首屏 KV 整体下移 */
  @media screen and (max-width: 1279px) {
    body.template-index main#main > .shopify-section:first-child,
    body.template-page-product-detail main#main > .shopify-section:first-child,
    body.template-page-product-detail-m6 main#main > .shopify-section:first-child {
      margin-top: -56px !important;
    }
  }
  @media screen and (min-width: 1280px) {
    body.template-index main#main > .shopify-section:first-child,
    body.template-page-product-detail main#main > .shopify-section:first-child,
    body.template-page-product-detail-m6 main#main > .shopify-section:first-child {
      margin-top: -64px !important;
    }
  }
  {%- endif -%}

</style>
{% if section.settings.enbale_custom %}
{%- style -%}
   ul.mega-menu__nav.custom-class li a.h5 {
      font-size: 16px;
      font-weight: 600;
      line-height: normal;
  }
  ul.mega-menu__nav.custom-class li a:hover {
    color : #ED1C24;
  }
  ul.mega-menu__nav.custom-class li:hover img.mega-menu__image.zoom-image,
  img.mega-menu__image.zoom-image:hover {
      transform: scale(1.06) !important;
