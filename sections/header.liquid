<script>
  (function () {
    var sec = document.getElementById('shopify-section-{{ section.id }}');
    if (!sec) return;
    var wrap = sec.querySelector('.header__wrapper');
    var h = 0;
    if (wrap) {
      h = Math.round(wrap.getBoundingClientRect().height);
    }
    if (!h) {
      h = Math.round(sec.clientHeight);
    }
    document.documentElement.style.setProperty('--header-height', h + 'px');
  })();
</script>
<script>
  (function () {
    var mq = window.matchMedia('(max-width: 1279px)');
    var drawer = document.getElementById('header-sidebar-menu');
    if (!drawer) return;

    /** Figma：主导航栏底边到首项菜单之间的固定空隙（原实现约 14px） */
    var GAP_PX = 14;

    function syncMobileNavPanelOffset() {
      if (!mq.matches || !drawer.open) return;
      var hdr = document.querySelector('.shopify-section--header');
      if (!hdr) return;
      /* margin-top 在抽屉内部：须减去抽屉自身 top（公告存在时抽屉从公告下方开始），否则会重复计入公告高度 */
      var hdrBottom = hdr.getBoundingClientRect().bottom;
      var drawerTop = drawer.getBoundingClientRect().top;
      var margin = hdrBottom + GAP_PX - drawerTop;
      document.documentElement.style.setProperty(
        '--mobile-nav-panel-offset',
        Math.round(margin) + 'px'
      );
    }

    drawer.addEventListener('dialog:after-show', function () {
      syncMobileNavPanelOffset();
      requestAnimationFrame(syncMobileNavPanelOffset);
    });
    drawer.addEventListener('dialog:after-hide', function () {
      document.documentElement.style.removeProperty('--mobile-nav-panel-offset');
    });

    window.addEventListener('resize', syncMobileNavPanelOffset);

    if (typeof mq.addEventListener === 'function') {
      mq.addEventListener('change', syncMobileNavPanelOffset);
    } else if (mq.addListener) {
      mq.addListener(syncMobileNavPanelOffset);
    }

    var hdrSec = document.querySelector('.shopify-section--header');
    var annSec = document.querySelector('.shopify-section--announcement-bar');
    if (window.ResizeObserver) {
      var ro = new ResizeObserver(syncMobileNavPanelOffset);
      if (hdrSec) ro.observe(hdrSec);
      if (annSec) ro.observe(annSec);
    }
  })();
</script>
<style>
  /* PC 菜单红线 + hover 命中区 + 弹窗位置修正 */
  @media screen and (min-width: 1280px) {
    /* summary 提层：让红线浮出在 mega-menu 之上 */
    .header__wrapper details[is="mega-menu-disclosure"] > summary,
    .header__wrapper details[is="dropdown-disclosure"] > summary {
      position: relative;
      z-index: 100;
    }
    /* hover 命中区：覆盖整条 header 垂直高度 */
    .header__wrapper details[is="mega-menu-disclosure"] > summary::after,
    .header__wrapper details[is="dropdown-disclosure"] > summary::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: calc(-1 * var(--summary-top-gap, 0px));
      bottom: calc(-1 * var(--menu-gap, 0px));
      z-index: 0;
      background: transparent;
    }
    /* 红线（高 specificity 防被 summary 子元素规则覆盖） */
    .header__wrapper details > summary > .red-line-pc {
      position: absolute !important;
      left: 0 !important;
      right: 0 !important;
      height: 2px !important;
      background: #D6000C !important;
      top: 100% !important;
      margin-top: var(--menu-gap, 0px) !important;
      pointer-events: none !important;
      z-index: 2 !important;
      opacity: 0;
      transform: scaleX(.6);
      transform-origin: center;
      transition: none;
    }
    .header__wrapper details[open] > summary > .red-line-pc,
    .header__wrapper details:hover > summary > .red-line-pc {
      opacity: 1 !important;
      transform: scaleX(1) !important;
    }
    /* 切换悬浮时：强制立即隐藏兄弟红线（覆盖 details[open] / :hover 的显示规则） */
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > details > summary > .red-line-pc,
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > a.kiks_nav_fam::after,
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > a::after {
      opacity: 0 !important;
      transform: scaleX(0.6) !important;
    }
    /* 同步立即隐藏被抑制项的下拉/大菜单内容（不动 [open] 状态机，仅视觉隐藏） */
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > details[open] > .mega-menu,
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > details[open] > .dropdown-menu,
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > details[open] > [slot="content"],
    #shopify-section-{{ section.id }} .header__wrapper li.kik-redline-suppress > details[open] > div {
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
      transition: none !important;
    }
    /* 隐藏 theme.css 自带的 ::before 红线（避免重复 / 错位） */
    .header__wrapper details[is="mega-menu-disclosure"][open] > summary::before {
      display: none !important;
    }
    /* summary hover 不变色不变透明（排除 .red-line-pc 避免擦掉红线背景）
       勿用 color:inherit：会继承 body/--text-color 深灰，覆盖 .kiks_nav_fam 白字，仅 details 项变黑 */
    .header__wrapper details[is="mega-menu-disclosure"] > summary,
    .header__wrapper details[is="mega-menu-disclosure"] > summary:hover,
    .header__wrapper details[is="dropdown-disclosure"] > summary,
    .header__wrapper details[is="dropdown-disclosure"] > summary:hover {
      color: #ffffff !important;
      background-color: transparent !important;
      text-decoration: none !important;
      opacity: 1 !important;
    }
    .header__wrapper details[is="mega-menu-disclosure"] > summary > *:not(.red-line-pc),
    .header__wrapper details[is="dropdown-disclosure"] > summary > *:not(.red-line-pc),
    .header__wrapper details[is="mega-menu-disclosure"] > summary:hover > *:not(.red-line-pc),
    .header__wrapper details[is="dropdown-disclosure"] > summary:hover > *:not(.red-line-pc) {
      color: #ffffff !important;
      background-color: transparent !important;
      text-decoration: none !important;
      opacity: 1 !important;
    }
    /* 非 PRODUCT dropdown 弹窗容器样式 */
    .header__wrapper details[is="dropdown-disclosure"] > .dropdown-menu {
      display: inline-flex !important;
      flex-direction: column !important;
      align-items: stretch !important;
      padding: 8px !important;
      gap: 4px !important;
      border-radius: 12px !important;
      background: #F0F0F0 !important;
      box-shadow: 0 4px 20px rgba(0, 0, 0, .08) !important;
      width: max-content !important;
      max-width: 350px !important;
    }
    /* dropdown 内 ul 也用 column flex 布局 */
    .header__wrapper details[is="dropdown-disclosure"] > .dropdown-menu > ul.contents {
      display: flex !important;
      flex-direction: column !important;
      gap: 4px !important;
    }
    /* dropdown item 默认样式 */
    .header__wrapper details[is="dropdown-disclosure"] .dropdown-menu__item {
      display: flex !important;
      padding: 4px 8px !important;
      align-items: center !important;
      gap: 10px !important;
      align-self: stretch !important;
      border-radius: 8px !important;
      background: transparent !important;
      color: #0A0A0A !important;
      font-family: Gabarito, sans-serif !important;
      font-size: 16px !important;
      font-style: normal !important;
      font-weight: 500 !important;
      line-height: normal !important;
      opacity: 1 !important;
      transition: background-color .15s ease !important;
    }
    /* dropdown item hover */
    .header__wrapper details[is="dropdown-disclosure"] .dropdown-menu__item:hover,
    .header__wrapper details[is="dropdown-disclosure"] [open] > .dropdown-menu__item {
      background: rgba(26, 26, 26, 0.10) !important;
      color: #0A0A0A !important;
    }
    /* item 内 span 文字也强制颜色一致 */
    .header__wrapper details[is="dropdown-disclosure"] .dropdown-menu__item *,
    .header__wrapper details[is="dropdown-disclosure"] .dropdown-menu__item:hover * {
      color: #0A0A0A !important;
    }
  }
</style>
<script>
  // PC 菜单：注入红线 + 计算 --menu-gap / --summary-top-gap
  (function() {
    if (window.innerWidth < 1280) return;

    function fixMenu() {
      const header = document.querySelector('.header__wrapper');
      if (!header) return;
      const headerRect = header.getBoundingClientRect();

      document.querySelectorAll('details[is="mega-menu-disclosure"], details[is="dropdown-disclosure"]').forEach(function(details) {
        const summary = details.querySelector('summary');
        if (!summary) return;

        const summaryRect = summary.getBoundingClientRect();
        const gap = Math.max(0, Math.round(headerRect.bottom - summaryRect.bottom));
        const topGap = Math.max(0, Math.round(summaryRect.top - headerRect.top));

        summary.style.setProperty('--menu-gap', gap + 'px');
        summary.style.setProperty('--summary-top-gap', topGap + 'px');

        /* 仅顶级主导航（summary 与 header 条带相交）；mega 内嵌套下拉不能用 header 底对齐 */
        const overlapsHeader =
          summaryRect.top < headerRect.bottom && summaryRect.bottom > headerRect.top;

        if (!summary.querySelector('.red-line-pc')) {
          const redLine = document.createElement('div');
          redLine.className = 'red-line-pc';
          summary.appendChild(redLine);
        }

        const redLineEl = summary.querySelector('.red-line-pc');
        if (redLineEl) {
          if (overlapsHeader) {
            const sr = summary.getBoundingClientRect();
            var redTop = Math.round(headerRect.bottom - sr.top - 2);
            redLineEl.style.setProperty('top', redTop + 'px', 'important');
            redLineEl.style.setProperty('margin-top', '0', 'important');
          } else {
            redLineEl.style.removeProperty('top');
            redLineEl.style.removeProperty('margin-top');
          }
        }

        const megaPanel = details.querySelector(':scope > .mega-menu');
        if (megaPanel && details.matches('[is="mega-menu-disclosure"]') && redLineEl && overlapsHeader) {
          const detailsRectMega = details.getBoundingClientRect();
          var rbMega = redLineEl.getBoundingClientRect();
          /* mega_collections（PRODUCT）紧贴 header 底部，无 4px 间隔；其他 mega-menu 保留 4px */
          var extraGap = megaPanel.classList.contains('mega_collections') ? 0 : 4;
          var megaTopPx = Math.round(rbMega.bottom - detailsRectMega.top + extraGap);
          megaPanel.style.setProperty('top', megaTopPx + 'px', 'important');
          megaPanel.style.setProperty('margin-top', '0', 'important');
        } else if (megaPanel && details.matches('[is="mega-menu-disclosure"]') && !overlapsHeader) {
          megaPanel.style.removeProperty('top');
          megaPanel.style.removeProperty('margin-top');
        }

        const dropdown = details.querySelector(':scope > .dropdown-menu');
        if (dropdown && details.matches('[is="dropdown-disclosure"]')) {
          if (overlapsHeader) {
            const detailsRect = details.getBoundingClientRect();
            const redLine = summary.querySelector('.red-line-pc');
            var topPx;
            if (redLine) {
              var rb = redLine.getBoundingClientRect();
              topPx = rb.height > 0 ? Math.round(rb.bottom - detailsRect.top + 4) : Math.round(headerRect.bottom - detailsRect.top + 4);
            } else {
              topPx = Math.round(headerRect.bottom - detailsRect.top + 4);
            }
            dropdown.style.setProperty('top', topPx + 'px', 'important');
            dropdown.style.setProperty('margin-top', '0', 'important');
          } else {
            dropdown.style.removeProperty('top');
            dropdown.style.removeProperty('margin-top');
          }
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { setTimeout(fixMenu, 50); });
    } else {
      setTimeout(fixMenu, 50);
    }

    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        if (window.innerWidth >= 1280) fixMenu();
      }, 120);
    });

    if (window.ResizeObserver) {
      const header = document.querySelector('.header__wrapper');
      if (header) {
        new ResizeObserver(function() {
          if (window.innerWidth >= 1280) fixMenu();
        }).observe(header);
      }
    }
  })();

  /* PC 顶部导航：切换悬浮时立即视觉抑制兄弟红线，避免出现同时两条红线 */
  (function() {
    function bind() {
      if (window.innerWidth < 1280) return;
      var navs = document.querySelectorAll(
        '#shopify-section-{{ section.id }} .header__main-nav .header__link-list > ul.contents,' +
        '#shopify-section-{{ section.id }} .header__secondary-nav .header__link-list > ul.contents'
      );
      navs.forEach(function(ul) {
        if (ul.dataset.kikInstantSwitch === '1') return;
        ul.dataset.kikInstantSwitch = '1';
        function setActive(li) {
          for (var i = 0; i < ul.children.length; i++) {
            var sib = ul.children[i];
            if (sib === li) sib.classList.remove('kik-redline-suppress');
            else sib.classList.add('kik-redline-suppress');
          }
        }
        function clearAll() {
          for (var i = 0; i < ul.children.length; i++) {
            ul.children[i].classList.remove('kik-redline-suppress');
          }
        }
        ul.addEventListener('mouseover', function(e) {
          var node = e.target;
          while (node && node.parentNode !== ul) node = node.parentNode;
          if (!node || node.tagName !== 'LI') return;
          setActive(node);
          /* 1280+ 桌面导航：悬浮当前项时立即展开（与 theme.js hover trigger 一致） */
          if (window.innerWidth >= 1280) {
            var activeDetails = node.querySelector(':scope > details[is="mega-menu-disclosure"], :scope > details[is="dropdown-disclosure"]');
            if (activeDetails && activeDetails.getAttribute('trigger') === 'hover') {
              activeDetails.open = true;
            }
          }
          /* fb5abc2：强制立即关闭兄弟 details，绕过 Shopify 500ms mouseOverDelayTolerance */
          for (var i = 0; i < ul.children.length; i++) {
            var sib = ul.children[i];
            if (sib === node) continue;
            var d = sib.querySelector(':scope > details[open]');
            if (!d) continue;
            if (d._hoverTimer) { clearTimeout(d._hoverTimer); d._hoverTimer = null; }
            d.open = false;
          }
        });
        ul.addEventListener('mouseleave', clearAll);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bind);
    } else {
      bind();
    }
    window.addEventListener('resize', bind);
  })();


  
  document.querySelectorAll('#shopify-section-{{ section.id }} .mega-menu.mega_collections').forEach(function (mega) {
    function activateSeries(item) {
      if (item.classList.contains('active')) return;
      mega.querySelectorAll('.kik_collections_title_text').forEach(function (el) {
        el.classList.remove('active');
      });
      mega.querySelectorAll('.kik_menu_collection').forEach(function (el) {
        el.classList.remove('active');
      });
      item.classList.add('active');
      var collectionId = item.getAttribute('data-open');
      var panel = mega.querySelector('.kik_menu_collection[data-open="' + collectionId + '"]');
      if (panel) panel.classList.add('active');
    }

    // 仅在能精确指向（PC 鼠标）时启用 hover 切换；触摸端依旧靠 click
    var supportsHover = window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    mega.querySelectorAll('.kik_collections_title_text').forEach(function (item) {
      item.addEventListener('click', function () {
        activateSeries(item);
      });
      if (supportsHover) {
        item.addEventListener('mouseenter', function () {
          activateSeries(item);
        });
      }
    });
  });

  // 控制移动端置顶的关闭按钮显示和隐藏closeButton
  const navigationDrawer = document.querySelector('navigation-drawer');
  const closeButtonLink2 = navigationDrawer.querySelectorAll('button.link2-close-btn');  //关闭按钮
  const closeButtonSub = navigationDrawer.querySelectorAll('button.link2-sub-btn'); //返回按钮
  const topContent = navigationDrawer.querySelector('.panel__title_content');
  navigationDrawer.querySelectorAll('.link1-nav-li').forEach((item) => {

    if (item.querySelector('.link1-nav__wrapper') == null && item.querySelector('a') == null) {
      item.addEventListener('click', function() {
        topContent.style.display = 'none';
      });
    }

  });
  closeButtonSub.forEach((item) => {
    item.onclick = function() {
      topContent.style.display = 'flex';
    }
  })
  closeButtonLink2.forEach((item) => {
    item.onclick = function() {
      topContent.style.display = 'flex';
    }
  })

  // 控制二级菜单显示或隐藏
  document.querySelectorAll('.jingva-sub-link2-item').forEach((item) => {
    item.addEventListener('click', function() {
      item.classList.toggle('sub-active');
    });
  });

  // 优化后的产品列表显示与样式控制逻辑
  document.querySelectorAll('.link1-nav-li .link1-nav__wrapper .link-nav-title').forEach((item) => {
    item.addEventListener('click', function() {
      // 切换当前点击项的“active”类
      item.classList.toggle('active');
      var reversed = item.querySelector('.reversed-link');
      var isJingvaDrawerProduct = item.closest('.jingva-drawer-product');
      var inHeaderSidebarMenu = item.closest('#header-sidebar-menu');
      if (reversed) {
        if (inHeaderSidebarMenu) {
          reversed.style.removeProperty('color');
        } else if (isJingvaDrawerProduct) {
          reversed.style.color = '#1a1a1a';
        } else if (item.classList.contains('active')) {
          reversed.style.color = '#e1040f';
        } else {
          reversed.style.color = '#000';
        }
      }

      // 查找当前二级产品盒子
      const proBox = item.closest('.product-list-box');
      if (!proBox) return;

      // 找到父级.link1-nav-li元素
      const parent = proBox.closest('.link1-nav-li');
      if (!parent) return;

      // 通过class判断和直接设置样式
      if (item.classList.contains('active')) {
        parent.style.paddingBottom = '0';
       
      } else {
      
        // 使用getComputedStyle安全获取变量
        const rootStyle = window.getComputedStyle(document.documentElement);
        let paddingValue = rootStyle.getPropertyValue('--spacing-4');
        // 如果未定义变量，提供后备值
        paddingValue = paddingValue || '16px';
        parent.style.paddingBottom = paddingValue.trim();
        
      }
    });
  });

  document.querySelectorAll('.link1-nav-li .link1-nav__wrapper .link-nav-title2').forEach((item) => {
    item.addEventListener('click', function() {
      item.classList.toggle('active');
    });
  });


  {% comment %}首页滚动变实心由下方 is-filled class 统一处理，此处无需额外逻辑{% endcomment %}
</script>

{%- comment -%}
  说明：原来此处有一段「向下滚动隐藏一级 nav」的脚本，会无条件作用于所有页面（含首页、移动端），
  并通过 inline transform/opacity 与 sticky + height:0 叠加导致首页公告条与 nav 之间出现视觉间隙。
  根据需求 #48：只有出现次级导航且该 subnav 固定贴顶（documentElement 上 data-jingva-subnav-fixed）时，
  才允许通过向下滚动收起一级 nav（theme.js → StoreHeader._onScroll + hide）。
  jingva-g7-subnav / jingva-m6-subnav 在固定时设置该属性并 force 收起主导航；无 subnav 的页面不会触发收起。
{%- endcomment -%}

{%- comment -%}
  滚过首屏 KV 后导航变实心（.header.is-filled）。
  触发区块：
  - 首页（index）：.jingva-section-container（jingva-slideshow_hero.liquid）
  - 产品页 / Page：.jingva-g7-hero（jingva-g7-hero.liquid），兜底 .shopify-section--main-product
  - Contact 页：.jingva-contact-hero-section（jingva-contact-hero.liquid）
{%- endcomment -%}
{% if template == 'index' or request.page_type == 'product' or request.page_type == 'page' %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var header = document.querySelector('.header');
    if (!header) return;

    var isIndex = {{ template | json }} === 'index';
    var heroSection;

    if (isIndex) {
      // 首页：以 jingva-slideshow_hero.liquid 的容器为基准
      heroSection = document.querySelector('.jingva-section-container');
    } else {
      // 产品页 / 自定义 Page：以 jingva-g7-hero.liquid 为基准
      heroSection = document.querySelector('.jingva-g7-hero');
      if (!heroSection) {
        // Contact 页：以 jingva-contact-hero 为基准
        heroSection = document.querySelector('.jingva-contact-hero-section');
      }
      if (!heroSection) {
        heroSection = document.querySelector('.shopify-section--main-product');
      }
    }

    function getThreshold() {
      if (!heroSection) return 0;
      var hh = header.offsetHeight;
      var y = window.pageYOffset || document.documentElement.scrollTop;
      var top = heroSection.getBoundingClientRect().top + y;
      var bottom = top + heroSection.offsetHeight;
      return Math.max(0, bottom - hh);
    }

    function checkScroll() {
      if (window.scrollY > getThreshold()) {
        header.classList.add('is-filled');
      } else {
        header.classList.remove('is-filled');
      }
    }

    window.addEventListener('scroll', checkScroll, { passive: true });
    window.addEventListener('resize', checkScroll, { passive: true });
    checkScroll();
  });
</script>
{% endif %}

