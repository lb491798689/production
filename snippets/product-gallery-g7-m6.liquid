{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
PRODUCT GALLERY COMPONENT
----------------------------------------------------------------------------------------------------------------------

This component is used to show the product gallery (used in product page and featured product section)

********************************************
Supported variables
********************************************

* product: the product to render (if empty, renders placeholder content)
* product_form_id: the product form id
{%- endcomment -%}

{%- assign default_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
{%- capture product_gallery_id -%}product-gallery-{{ product.id }}-{{ section.id }}{%- endcapture -%}

{%- comment -%}
IMPLEMENTATION NOTE: Shopify does not natively offer a way to create a set of images per variant. This is often
pretty limited when you have a lot of colors and would like to only see the images specific to a given color. To
goes around that, Impact offers a hack using alt tags whose usage is described here: https://support.maestrooo.com/article/187-product-creating-variant-image-set
The implementation is rather complex and inefficient due to a lot of string parsings, but it is, unfortunately, the
only way to do it on Shopify right now.
{%- endcomment -%}
{% assign image_size = 0 %}
{% assign video_size = 0 %}
{% assign model_size = 0 %}
{%- liquid
  assign filtered_indexes = '' | split: ''

  if product.variants.size > 1
    for media in product.media
      if media.alt contains '#' and media.alt != product.title
        assign alt_parts = media.alt | split: '#'

        assign media_group_parts = alt_parts.last | split: '_'
        assign option = product.options_by_name[media_group_parts.first]
        assign option_value = option.selected_value | downcase

        assign downcase_group_value = media_group_parts.last | strip | downcase

        if option and option_value != downcase_group_value and media != default_media
          assign media_position = media.position | append: '' | split: ','
          assign filtered_indexes = filtered_indexes | concat: media_position
        endif
      endif
    endfor
  endif
-%}

{%- liquid
  assign g7_has_360 = false
  if custom_metafield != blank
    assign g7_has_360 = true
  endif
  if g7_has_360 == false
    for m in product.media
      if m.media_type == 'model'
        assign g7_has_360 = true
      endif
    endfor
  endif
  assign g7_first_model = product.media | where: 'media_type', 'model' | first
-%}

<product-gallery form="{{ product_form_id }}" filtered-indexes="{{ filtered_indexes | json }}" {%- if section.settings.enable_image_zoom -%}allow-zoom="{{ section.settings.max_image_zoom_level }}"{% endif %} class="product-gallery {% if section.settings.mobile_carousel_control contains 'dots' %}product-gallery--mobile-dots{% endif %} {% if section.settings.desktop_media_layout contains 'grid' %}product-gallery--desktop-grid{% else %}product-gallery--desktop-carousel{% endif %} {% if section.settings.desktop_media_layout == 'carousel_thumbnails_left' %}product-gallery--desktop-thumbnails-left{% endif %} {% if section.settings.mobile_media_size == 'expanded' %}product-gallery--mobile-expanded{% endif %}">

  <style>
    /* ========== G7-M6 产品图片组件 - 严格对照 Figma ========== */

    /* 确保 product-gallery 元素不限制宽度 - 填满左列 */
    product-gallery {
      width: 100% !important;
      max-width: none !important;
      display: block !important;
    }

    /* Figma: 媒体橱窗 → Frame 1973771384: bg rgba(240,240,240,1.0), r=12, padding 24/0/24/0
       超大屏下容器跟随左列自适应宽度，图片固定 607.69 居中 */
    .jingva-product-gallery-box {
      position: relative !important;
      width: 100% !important;
      max-width: none !important;
      margin: 0 !important;
      background-color: rgba(240, 240, 240, 1.0) !important;
      border: none !important;
      border-radius: 12px !important;
      padding: 24px 0 !important;
      box-sizing: border-box !important;
    }

    /* Figma: Frame 1973771402: padding 0/40/0/40 */
    .product-gallery__media-list-wrapper {
      position: relative !important;
      padding: 0 40px !important;
      margin-bottom: 0 !important;
    }

    /* Figma: product image 607.69x607.69 @ 1920 设计稿；保持 1:1。
       用 min(56vh, 32vw) 让 ≥1920 的大屏（如 2560/4K）按视口等比放大，
       矮屏（vh 小）也不会撑爆。
       1920x1080 → min(605, 614) ≈ 607（还原 Figma）
       2560x1440 → min(806, 819) = 806（按比例放大）*/
    .product-gallery__media-list {
      margin: 0 auto !important;
      max-width: 100% !important;
    }

    .product-gallery__media {
      width: 100% !important;
      height: calc(70vh - 54px) !important;
      border-radius: 0 !important;
      margin: 0 auto !important;
    }
    .product-gallery__media img,
    .product-gallery__media video {
      width: 100% !important;
      height: 100% !important;
      object-fit: contain !important;
    }

    /* 隐藏原始导航箭头 */
    .product-gallery__nav { display: none !important; }

    /* Figma: Frame 1973771420: 控制条, horizontal, gap=24, h=56 */
    .jingva-gallery-controls-bar {
      display: flex !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 24px !important;
      height: 56px !important;
      padding: 0 20px !important;
      margin-top: 16px !important;
      position: relative !important;
    }

    /* Figma: 内容 408x56, border 1px #1A1A1A, padding 0/24/0/24, gap=16 */
    .jingva-gallery-controls-inner {
      display: flex !important;
      align-items: center !important;
      gap: 16px !important;
      border-radius: 0 !important;
      padding: 0 24px !important;
      height: 56px !important;
      width: 408px !important;
      box-sizing: border-box !important;
    }

    /* Figma: function Botton kit 40x40, bg #E90202, r=8, padding 6 */
    .jingva-gallery-arrow-btn {
      width: 40px !important;
      height: 40px !important;
      border-radius: 8px !important;
      border: none !important;
      background: #E90202 !important;
      color: #fff !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      cursor: pointer !important;
      padding: 6px !important;
      flex-shrink: 0 !important;
    }
    .jingva-gallery-arrow-btn:hover { background: #C51100 !important; }
    .jingva-gallery-arrow-btn svg { width: 7px !important; height: 11px !important; }

    /* Figma: Frame 1973771590 缩略图容器, horizontal, gap=8, width 248px */
    .jingva-gallery-thumbnails {
      display: flex !important;
      align-items: center !important;
      gap: 6px !important;
      padding: 0 !important;
      margin: 0 !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      width: 248px !important;
      scroll-behavior: smooth !important;
      -webkit-overflow-scrolling: touch !important;
    }
    .jingva-gallery-thumbnails::-webkit-scrollbar {
      display: none !important;
    }

    /* Figma: 缩略图 56x56, r=8, border 1px #1A1A1A */
    .jingva-gallery-thumbnail {
      width: 56px !important;
      height: 56px !important;
      border-radius: 8px !important;
      border: 1px solid transparent !important;
      overflow: hidden !important;
      cursor: pointer !important;
      flex-shrink: 0 !important;
      padding: 0 !important;
      background: #fff !important;
    }
    .jingva-gallery-thumbnail:hover { border-color: #E51300 !important; }
    .jingva-gallery-thumbnail.active,
    .jingva-gallery-thumbnail[aria-current="true"] { border-color: #E51300 !important; }
    .jingva-gallery-thumbnail img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }

    /* Figma: Base Botton Kit 40x40, bg #0A0A0A, 圆形 */
    /* PC 端先隐藏 rotate 按钮（按用户要求） */
    .jingva-gallery-rotate-btn {
      display: none !important;
      width: 40px !important;
      height: 40px !important;
      border-radius: 50% !important;
      background: #0A0A0A !important;
      color: #fff !important;
      border: none !important;
      align-items: center !important;
      justify-content: center !important;
      cursor: pointer !important;
      flex-shrink: 0 !important;
      padding: 0 !important;
      position: absolute !important;
      right: 20px !important;
    }
    .jingva-gallery-rotate-btn:hover { background: #333 !important; }
    .jingva-gallery-rotate-btn svg { width: 20px !important; height: 20px !important; }

    /* Figma: Frame 1973771401: 1264x109, bg rgba(0,0,0,1.0), padding 16/0/16/0, gap=8 */
    .jingva-gallery-benefits {
      background-color: #F0F0F0 !important;
      border-top: 1px solid rgba(26, 26, 26, 0.20) !important;
      padding: 16px 0 !important;
      display: flex;
      flex-direction: column !important;
      align-items: center !important;
      gap: 8px !important;
      margin-top: 16px !important;
    }

    /* Figma: 权益 row: horizontal, gap=24, padding 8/40/8/40, h=40 */
    .jingva-gallery-benefits__row {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 24px !important;
      padding: 8px 40px !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }

    /* 权益 item: horizontal, gap=8 */
    .jingva-gallery-benefits__item {
      display: flex !important;
      align-items: center !important;
      gap: 8px !important;
      white-space: nowrap !important;
    }
    .jingva-gallery-benefits__item svg {
      width: 24px !important;
      height: 24px !important;
      flex-shrink: 0 !important;
    }
    .jingva-gallery-benefits__item span {
      font-family: 'Gabarito', sans-serif !important;
      font-size: 14px !important;
      font-style: normal !important;
      font-weight: 400 !important;
      line-height: normal !important;
      text-transform: capitalize !important;
      text-align: center !important;
      color: rgba(26, 26, 26, 0.80) !important;
    }

    /* Figma: 支付 row: horizontal, gap=6, h=29 */
    .jingva-gallery-payments {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 6px !important;
    }
    .jingva-gallery-payments img {
      width: 34.76px !important;
      height: 24px !important;
      display: block !important;
      object-fit: contain !important;
      flex-shrink: 0 !important;
    }

    /* Figma 中不存在的元素，全部隐藏 */
    .jingva-product-gallery-box .page-dots,
    .jingva-product-gallery-box page-dots,
    .jingva-product-gallery-box .product-gallery__zoom,
    .jingva-product-gallery-box .product-gallery__cursor,
    .jingva-product-gallery-box [data-shopify-xr] {
      display: none !important;
    }

    /* 移动端 360 面板内允许 kiks-3d-product 显示（勿全局 display:none） */
    .jingva-gallery-mobile-360-panel[hidden] {
      display: none !important;
    }

    /*
     * Image / 360° 切换 — 与 get_figma_data.py 拉取 AutoFull G7 (Copy) 节点一致：
     * 5726:3770 Frame 1973771419：横向 itemSpacing 8。
     * 5726:3771 Base Botton Kit（样式=品牌色, 尺寸=M）：h40、r8、pad12、gap6、字 Orbitron 14/700 lh120%、字色 #F4F4F4、填充 #E90202、无描边。
     * 5726:3773 Base Botton Kit（样式=线框, 尺寸=M）：同上盒模型、无填充+描边 1 #0A0A0A、字 #0A0A0A。
     * Hover：线框 5726:3015 填充 rgba(26,26,26,0.1) 且描边 hidden；品牌色 5726:3067 填充约 #FF1F0A。
     */
    .jingva-gallery-mobile-mode {
      display: none;
      width: 100%;
      box-sizing: border-box;
      padding: 0 16px;
      margin-top: 16px;
      /* theme 里 button 为 color:inherit，父级不设色会继承到灰字；与 Figma gy1 一致 */
      color: #0a0a0a;
    }
    .jingva-gallery-mobile-mode__track {
      {% comment %} display: flex; {% endcomment %}
      display: none;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      box-sizing: border-box;
      background: transparent;
      border-radius: 0;
      overflow: visible;
      color: #0a0a0a;
    }
    .jingva-gallery-mobile-mode__btn {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
      height: 40px;
      min-height: 40px;
      /* Figma layout 记 pad 12；与 h40 + 24px 图标叠合为竖直 8px + 横向 12px */
      padding: 8px 12px;
      gap: 6px;
      margin: 0;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      font-style: normal;
      font-weight: 700;
      font-size: 14px;
      line-height: 1.2;
      letter-spacing: 0;
      text-align: center;
      text-transform: uppercase;
      border-radius: 8px;
      border-style: solid;
      border-width: 1px;
      transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }
    /* 5726:3771 品牌色 M / 常规 */
    .jingva-gallery-mobile-mode__btn.is-active {
      background: #e90202;
      color: #f4f4f4;
      border-color: #e90202;
    }
    /* 5726:3773 线框 M / 常规：无填充（实现为白底）+ 1px gy1（!important 压过 theme 里 button 的 color:inherit 链） */
    .jingva-gallery-mobile-mode__btn:not(.is-active) {
      background: #ffffff;
      color: #0a0a0a !important;
      border-color: #0a0a0a !important;
    }
    .jingva-gallery-mobile-mode__btn:not(.is-active) span {
      color: #0a0a0a !important;
    }
    /* 5726:3015 线框 M / hover */
    .jingva-gallery-mobile-mode__btn:not(.is-active):not(:disabled):hover {
      background: rgba(26, 26, 26, 0.1);
      border-color: transparent;
      color: #0a0a0a !important;
    }
    /* 5726:3067 品牌色 M / hover */
    .jingva-gallery-mobile-mode__btn.is-active:not(:disabled):hover {
      background: #ff1f0a;
      border-color: #ff1f0a;
      color: #f4f4f4;
    }
    .jingva-gallery-mobile-mode__btn:disabled,
    .jingva-gallery-mobile-mode__btn.jingva-gallery-mobile-mode__btn--disabled {
      cursor: not-allowed;
      pointer-events: none;
    }
    /* 无 360 数据时仍保持 Figma gy1 #0A0A0A，勿用整钮 opacity 把字/图标洗灰 */
    .jingva-gallery-mobile-mode__btn--360:disabled,
    .jingva-gallery-mobile-mode__btn--360.jingva-gallery-mobile-mode__btn--disabled {
      opacity: 1 !important;
      color: #0a0a0a !important;
      background: #ffffff !important;
      border-color: #0a0a0a !important;
    }
    .jingva-gallery-mobile-mode__btn--360:disabled span,
    .jingva-gallery-mobile-mode__btn--360.jingva-gallery-mobile-mode__btn--disabled span {
      color: #0a0a0a !important;
    }
    .jingva-gallery-mobile-mode__btn svg {
      width: 24px;
      height: 24px;
      flex-shrink: 0;
    }
    .jingva-gallery-mobile-mode__btn svg path {
      fill: currentColor;
    }
    .jingva-gallery-mobile-mode__btn--360:not(.is-active) svg path,
    .jingva-gallery-mobile-mode__btn--360:disabled svg path,
    .jingva-gallery-mobile-mode__btn--360.jingva-gallery-mobile-mode__btn--disabled svg path {
      fill: #0a0a0a !important;
    }

    .jingva-gallery-mobile-360-panel {
      display: none;
      width: 100%;
      box-sizing: border-box;
      min-height: min(100vw, 520px);
      position: relative;
      background: #f0f0f0;
    }
    .jingva-gallery__mobile-stage.is-g7-360-mode .product-gallery__media-list-wrapper {
      display: none !important;
    }
    .jingva-gallery__mobile-stage.is-g7-360-mode .jingva-gallery-mobile-360-panel {
      display: block !important;
    }
    .jingva-gallery-mobile-model-host {
      width: 100%;
      min-height: min(100vw, 520px);
    }
    .jingva-gallery-mobile-model-host model-media,
    .jingva-gallery-mobile-model-host .model-viewer {
      width: 100% !important;
      min-height: min(100vw, 520px) !important;
    }
    .jingva-product-gallery-box.is-g7-360-mode .jingva-mobile-arrow {
      display: none !important;
    }

    /* Figma 5726:3750～3751：主图底部居中「当前/总数」药丸 */
    .jingva-gallery-mobile-counter {
      display: none !important;
    }
    .jingva-gallery-mobile-counter[hidden] {
      display: none !important;
    }

    /* 清除主题默认边框 */
    .jingva-product-gallery-box,
    .jingva-product-gallery-box.rounded-sm,
    .jingva-product-gallery-box .product-gallery__ar-wrapper,
    .jingva-product-gallery-box .product-gallery__media-list-wrapper,
    product-gallery.product-gallery {
      border: none !important;
      outline: none !important;
      box-shadow: none !important;
    }

    /* ========== 移动端: Figma 390x430 ========== */
    @media screen and (max-width: 1279px) {
      /* 确保画廊容器充满屏幕 */
      product-gallery.product-gallery {
        width: 100% !important;
        max-width: none !important;
      }
      .jingva-product-gallery-box {
        max-width: none !important;
        width: 100% !important;
        background-color: transparent !important;
        border-radius: 0 !important;
        padding: 0 !important;
        margin: 0 !important;
      }
      .product-gallery__ar-wrapper {
        padding: 0 !important;
        margin: 0 !important;
        width: 100% !important;
        max-width: none !important;
        display: flex !important;
        flex-direction: column !important;
        gap: 0 !important;
        grid-template-columns: unset !important;
      }
      /* Figma 5726:3730 Frame 1973771402 — 移动图片容器：与 header 底边贴齐，不设顶部 padding（否则会多出 DevTools 里绿色那块空隙） */
      .product-gallery__media-list-wrapper {
        padding: 0 !important;
        position: relative !important;
        width: 100% !important;
        margin: 0 !important;
        max-width: none !important;
        background-color: #f0f0f0 !important;
        box-sizing: border-box !important;
      }
      media-carousel.product-gallery__media-list {
        padding: 0 !important;
        margin: 0 !important;
        width: 100% !important;
        max-width: none !important;
      }
      .product-gallery__media-list {
        max-width: none !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
      }
      /* 手机端图片：Figma mob 390 设计下图片是全宽方形（390x390）。
         在更大的 mob 视口（如 1024）下用 max-width: 480px 卡住，避免图片像 1024x1024 那样
         占满整屏，让滚动可以正常划过图片。绝对像素 cap，不受 vh/vw 影响。*/
      .product-gallery__media-list,
      media-carousel.product-gallery__media-list {
        max-width: 480px !important;
        margin: 0 auto !important;
      }
      /* 覆盖桌面规则 max-width: min(56vh, 32vw)，否则手机 390px 下 32vw≈125px，主图会被压成小块 */
      .product-gallery__media {
        width: 100% !important;
        max-width: 100% !important;
        /* MOB 端固定为 1:1 槽位（与 Figma 设计稿一致），让所有图等高，避免 16:10 等矮图底部留白 */
        aspect-ratio: 1 / 1 !important;
        height: auto !important;
        min-height: 0 !important;
        max-height: none !important;
        border-radius: 0 !important;
        padding: 0 !important;
        margin: 0 auto !important;
      }
      .product-gallery__media img,
      .product-gallery__media video,
      .product-gallery__media video-media,
      .product-gallery__media .product-media__img {
        width: 100% !important;
        height: 100% !important;
        /* 用户反馈：MOB 端场景图填充容器（避免 16:10 图在 1:1 槽位下方留白） */
        object-fit: cover !important;
        object-position: center center !important;
        aspect-ratio: auto !important;
        display: block !important;
      }
      /* 移动端隐藏控制条和缩略图 */
      .jingva-gallery-controls-bar { display: none !important; }
      .jingva-gallery-thumbnails { display: none !important; }
      .jingva-gallery-rotate-btn { display: none !important; }

      /* 移动端隐藏桌面箭头 */
      .jingva-desktop-arrow { display: none !important; }

      /* 移动端箭头按钮定位到图片中间 */
      .jingva-mobile-arrow {
        position: absolute !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        width: 36px !important;
        height: 36px !important;
        border-radius: 6px !important;
        padding: 6px !important;
        z-index: 10 !important;
        display: flex !important;
      }
      .jingva-mobile-arrow.jingva-gallery-arrow-prev {
        left: 12px !important;
      }
      .jingva-mobile-arrow.jingva-gallery-arrow-next {
        right: 12px !important;
      }
      /* Figma 节点 913-6778: 移动端权益区 - 单列垂直布局 */
      .jingva-gallery-benefits--desktop { display: none !important; visibility: hidden !important; height: 0 !important; overflow: hidden !important; }
      .jingva-gallery-benefits--mobile { display: flex !important; visibility: visible !important; height: auto !important; }
      /* Figma 节点 5726-4016: 移动端 Frame 1973771412 strokeTopWeight=1, color rgba(26,26,26,0.20), 线宽 358（屏宽 390 内缩 16/16） */
      .jingva-gallery-benefits {
        background-color: transparent !important;
        border-top: 1px solid rgba(26, 26, 26, 0.20) !important;
        padding: 16px 0 0 !important;
        margin: 32px 16px 0 !important;
        display: flex;
        flex-direction: column !important;
        align-items: stretch !important;
        gap: 16px !important;
      }
      .jingva-gallery-benefits__row {
        display: flex !important;
        flex-direction: column !important;
        align-items: stretch !important;
        justify-content: flex-start !important;
        gap: 12px !important;
        padding: 0 !important;
        width: 100% !important;
      }
      .jingva-gallery-benefits__item {
        justify-content: flex-start !important;
        white-space: normal !important;
      }
      .jingva-gallery-benefits__item svg {
        width: 16px !important;
        height: 16px !important;
      }
      .jingva-gallery-benefits__item span {
        font-size: 16px !important;
        line-height: 19.2px !important;
        letter-spacing: -0.32px !important;
        text-align: left !important;
