<script>
/* 移动端：把权益区移动到 product-info 末尾（即 Add-Ons 模块下方） */
(function () {
  function relocateBenefits() {
    var benefitsMobile = document.querySelector('.jingva-gallery-benefits--mobile');
    var benefitsDesktop = document.querySelector('.jingva-gallery-benefits--desktop');
    var isMobile = window.matchMedia('(max-width: 1279px)').matches;
    var productInfo = document.querySelector('safe-sticky.product-info') || document.querySelector('.product-info');
    var galleryBox = document.querySelector('.jingva-product-gallery-box');

    if (isMobile && productInfo && benefitsMobile) {
      if (benefitsMobile.parentElement !== productInfo || benefitsMobile !== productInfo.lastElementChild) {
        productInfo.appendChild(benefitsMobile);
      }
    } else if (!isMobile && galleryBox && benefitsDesktop) {
      if (benefitsDesktop.parentElement !== galleryBox) {
        galleryBox.appendChild(benefitsDesktop);
      }
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', relocateBenefits);
  } else {
    relocateBenefits();
  }
  window.addEventListener('resize', relocateBenefits);
})();
</script>

<script>
// G7-M6 缩略图导航 + 左右箭头切换（统一脚本）
document.addEventListener('DOMContentLoaded', function() {
  const galleryEl = document.getElementById('{{ product_gallery_id }}');
  if (!galleryEl) return;

  const prevBtns = document.querySelectorAll('.jingva-gallery-arrow-prev');
  const nextBtns = document.querySelectorAll('.jingva-gallery-arrow-next');
  const counterEl = galleryEl.closest('.product-gallery__media-list-wrapper') && galleryEl.closest('.product-gallery__media-list-wrapper').querySelector('[data-g7-gallery-counter]');
  const counterTextEl = counterEl && counterEl.querySelector('.jingva-gallery-mobile-counter__text');
  let currentIndex = 0;
  let isScrolling = false;

  // ===== 移动端自动循环滚动（4s） =====
  const AUTOPLAY_INTERVAL = 4000;
  const AUTOPLAY_RESUME_DELAY = 6000;
  let autoplayTimer = null;
  let autoplayResumeTimer = null;

  function isMobile() {
    return window.matchMedia('(max-width: 1279px)').matches;
  }

  function isStageIn360Mode() {
    const stage = galleryEl.closest('[data-g7-mobile-stage]');
    return !!(stage && stage.classList.contains('is-g7-360-mode'));
  }

  function shouldAutoplay() {
    if (!isMobile()) return false;
    if (isStageIn360Mode()) return false;
    if (getVisibleMedia().length <= 1) return false;
    if (document.hidden) return false;
    return true;
  }

  function startAutoplay() {
    stopAutoplayTimer();
    if (!shouldAutoplay()) return;
    autoplayTimer = setInterval(() => {
      if (!shouldAutoplay()) { stopAutoplayTimer(); return; }
      goToIndex(currentIndex + 1, { loop: true });
    }, AUTOPLAY_INTERVAL);
  }

  function stopAutoplayTimer() {
    if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
  }

  function pauseAutoplay() {
    stopAutoplayTimer();
    if (autoplayResumeTimer) { clearTimeout(autoplayResumeTimer); }
    autoplayResumeTimer = setTimeout(startAutoplay, AUTOPLAY_RESUME_DELAY);
  }

  function getVisibleMedia() {
    return Array.from(galleryEl.querySelectorAll('.product-gallery__media')).filter(m => !m.hidden && m.offsetParent !== null);
  }

  function updateGalleryCounter(idx) {
    if (!counterEl || !counterTextEl) return;
    const visible = getVisibleMedia();
    if (!visible || visible.length <= 1) {
      counterEl.setAttribute('hidden', '');
      return;
    }
    counterEl.removeAttribute('hidden');
    counterTextEl.textContent = (idx + 1) + '/' + visible.length;
  }
  function getVisibleThumbnails() {
    return Array.from(document.querySelectorAll('.jingva-gallery-thumbnail')).filter(t => !t.hidden && t.offsetParent !== null);
  }

  function updateThumbnails(idx) {
    const visThumb = getVisibleThumbnails();
    visThumb.forEach((t, i) => {
      const isActive = i === idx;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-current', isActive ? 'true' : 'false');
    });

    // 缩略图轮播：固定显示 4 个，每次滚动一个位置（64px = 56px + 8px gap）
    const thumbContainer = document.querySelector('.jingva-gallery-thumbnails');
    if (thumbContainer && visThumb[idx]) {
      const THUMB_WIDTH = 56;
      const THUMB_GAP = 8;
      const THUMB_STEP = THUMB_WIDTH + THUMB_GAP; // 64px
      const VISIBLE_COUNT = 4; // 固定显示 4 个缩略图

      // 计算当前应该显示的起始索引（每 4 个为一组）
      const startIndex = Math.floor(idx / VISIBLE_COUNT) * VISIBLE_COUNT;

      // 但如果当前索引在当前可见范围内，不需要滚动
      const currentScrollLeft = thumbContainer.scrollLeft;
      const currentStartIndex = Math.round(currentScrollLeft / THUMB_STEP);
      const currentEndIndex = currentStartIndex + VISIBLE_COUNT - 1;

      // 如果当前索引不在可见范围内，需要滚动
      if (idx < currentStartIndex) {
        // 向左滚动一个位置
        thumbContainer.scrollTo({
          left: (currentStartIndex - 1) * THUMB_STEP,
          behavior: 'smooth'
        });
      } else if (idx > currentEndIndex) {
        // 向右滚动一个位置
        thumbContainer.scrollTo({
          left: (currentStartIndex + 1) * THUMB_STEP,
          behavior: 'smooth'
        });
      }
    }
    updateGalleryCounter(idx);
  }

  function goToIndex(idx, opts) {
    const visible = getVisibleMedia();
    if (visible.length === 0) return;
    const allowLoop = !!(opts && opts.loop);
    if (allowLoop) {
      // 循环切换：最后 → 第一；第一 → 最后
      if (idx < 0) idx = visible.length - 1;
      else if (idx >= visible.length) idx = 0;
    } else {
      if (idx < 0) idx = 0;
      if (idx >= visible.length) idx = visible.length - 1;
    }
    currentIndex = idx;

    // 滚动主图到指定位置
    isScrolling = true;
    const el = visible[idx];
    const target = el.offsetLeft - (galleryEl.clientWidth - el.clientWidth) / 2;
    galleryEl.scrollTo({ left: target, behavior: 'smooth' });

    // 立即更新缩略图 active 状态（不等滚动完成）
    updateThumbnails(idx);

    // 滚动完成后重置标记
    setTimeout(() => { isScrolling = false; }, 600);
  }

  // 缩略图点击
  document.querySelectorAll('.jingva-gallery-thumbnail').forEach((thumb, index) => {
    thumb.addEventListener('click', function() {
      pauseAutoplay();
      const visThumb = getVisibleThumbnails();
      const realIdx = visThumb.indexOf(this);
      if (realIdx >= 0) {
        currentIndex = realIdx;
        updateThumbnails(realIdx);
        
        // 切换主图
        const visible = getVisibleMedia();
        if (visible[realIdx]) {
          isScrolling = true;
          const el = visible[realIdx];
          const target = el.offsetLeft - (galleryEl.clientWidth - el.clientWidth) / 2;
          galleryEl.scrollTo({ left: target, behavior: 'smooth' });
          setTimeout(() => { isScrolling = false; }, 600);
        }
      }
    });
  });

  // 左右箭头点击 → 切换主图 + 同步缩略图（支持移动端和桌面端多个按钮）
  // 移动端支持循环切换：最后一张 → 第一张
  prevBtns.forEach(btn => btn.addEventListener('click', () => {
    pauseAutoplay();
    goToIndex(currentIndex - 1, { loop: isMobile() });
  }));
  nextBtns.forEach(btn => btn.addEventListener('click', () => {
    pauseAutoplay();
    goToIndex(currentIndex + 1, { loop: isMobile() });
  }));

  // 监听主图滚动 → 同步缩略图（手动滑动时）
  let scrollT;
  galleryEl.addEventListener('scroll', function() {
    if (isScrolling) return; // 忽略程序触发的滚动
    clearTimeout(scrollT);
    scrollT = setTimeout(() => {
      const visible = getVisibleMedia();
      const rect = galleryEl.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      let best = 0, minD = Infinity;
      visible.forEach((m, i) => {
        const mr = m.getBoundingClientRect();
        const d = Math.abs(mr.left + mr.width / 2 - center);
        if (d < minD) { minD = d; best = i; }
      });
      currentIndex = best;
      updateThumbnails(best);
    }, 100);
  }, { passive: true });

  // 初始化：设置第一张图为 active，缩略图容器保持在起始位置
  requestAnimationFrame(() => {
    currentIndex = 0;
    updateThumbnails(0);
    const thumbContainer = document.querySelector('.jingva-gallery-thumbnails');
    if (thumbContainer) {
      thumbContainer.scrollLeft = 0;
    }
  });

  // 用户触摸/拖动 → 暂停自动播放，6s 后恢复
  ['touchstart', 'pointerdown', 'mousedown', 'wheel'].forEach(evt => {
    galleryEl.addEventListener(evt, pauseAutoplay, { passive: true });
  });

  // 标签页切换：隐藏时停止，显示时恢复
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopAutoplayTimer();
    else startAutoplay();
  });

  // 视口变化（PC ↔ MOB 切换）时重新评估
  window.addEventListener('resize', () => {
    if (shouldAutoplay()) {
      if (!autoplayTimer) startAutoplay();
    } else {
      stopAutoplayTimer();
    }
  });

  // 监听 360° 模式切换：进入 360 模式时停止
  const stageEl = galleryEl.closest('[data-g7-mobile-stage]');
  if (stageEl && 'MutationObserver' in window) {
    new MutationObserver(() => {
      if (isStageIn360Mode()) stopAutoplayTimer();
      else startAutoplay();
    }).observe(stageEl, { attributes: true, attributeFilter: ['class'] });
  }

  // 启动自动播放
  startAutoplay();
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var modeRoot = document.querySelector('[data-g7-mobile-mode]');
  var stage = document.querySelector('[data-g7-mobile-stage]');
  var box = document.querySelector('.jingva-product-gallery-box');
  if (!modeRoot || !stage || !box) return;
  var btnImage = modeRoot.querySelector('.jingva-gallery-mobile-mode__btn--image');
  var btn360 = modeRoot.querySelector('.jingva-gallery-mobile-mode__btn--360');
  var panel = document.getElementById('jingva-g7-360-panel-{{ product.id }}-{{ section.id }}');
  var has360 = modeRoot.getAttribute('data-g7-has-360') === 'true';
  if (!btnImage || !btn360) return;

  function setMode(which) {
    if (which === '360' && (!has360 || !panel)) return;
    var is360 = which === '360';
    stage.classList.toggle('is-g7-360-mode', is360);
    box.classList.toggle('is-g7-360-mode', is360);
    btnImage.classList.toggle('is-active', !is360);
    btn360.classList.toggle('is-active', is360);
    btnImage.setAttribute('aria-selected', is360 ? 'false' : 'true');
    btn360.setAttribute('aria-selected', is360 ? 'true' : 'false');
    if (panel) {
      if (is360) panel.removeAttribute('hidden');
      else panel.setAttribute('hidden', '');
    }
  }

  btnImage.addEventListener('click', function () { setMode('image'); });
  btn360.addEventListener('click', function () { if (!btn360.disabled) setMode('360'); });
  window.addEventListener('resize', function () {
    if (window.matchMedia('(min-width: 1280px)').matches) setMode('image');
  });
});
</script>