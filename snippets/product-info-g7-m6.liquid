  {{ qty_sel_scope }} .quantity-selector__button--minus::after,
  {{ qty_sel_scope }} .quantity-selector__button--plus::before,
  {{ qty_sel_scope }} .quantity-selector__button--plus::after,
  {{ qty_buy_scope }} .quantity-selector__button--minus::before,
  {{ qty_buy_scope }} .quantity-selector__button--minus::after,
