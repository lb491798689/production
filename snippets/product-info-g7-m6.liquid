    /* Tab 条：Figma 3337:84492 — pt 8px、px 24px、gap 24px、items-center */
    /* 底边灰线用 ::before 单独一层（z-index:0），避免父级 border-bottom 盖住子级红线约 1px */
    .product-tabs-header {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      gap: 24px;
      width: 100%;
      margin-left: 0;
      margin-right: 0;
      padding: 8px 0 0;
      border-bottom: none;
      margin-bottom: 24px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      position: relative;
      box-sizing: border-box;
    }

    .product-tabs-header::-webkit-scrollbar {
