    }
  }

  /* 可点击 fill → currentColor #0A0A0A；不可点击 → rgba(26,26,26,.2)（脚本在 min/max 时 disabled） */
  {{ qty_sel_scope }} .quantity-selector__button .quantity-step-svg {
    display: block !important;
    flex-shrink: 0 !important;
    vertical-align: middle !important;
  }
  {{ qty_sel_scope }} .quantity-selector__button--minus:not(:disabled),
  {{ qty_sel_scope }} .quantity-selector__button--plus:not(:disabled) {
    color: #0A0A0A !important;
  }
  {{ qty_sel_scope }} .quantity-selector__button--minus:disabled,
  {{ qty_sel_scope }} .quantity-selector__button--plus:disabled {
    color: rgba(26, 26, 26, 0.2) !important;
  }
