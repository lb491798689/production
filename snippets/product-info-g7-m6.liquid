    --product-info-block-spacing: var(--spacing-4) !important;
  }
{% endstyle %}

<safe-sticky class="product-info">
  {%- assign inside_block_group_context = false -%}
  {%- assign current_block_group_name = '' -%}

  {%- for block in section.blocks -%}
    {%- liquid
      assign previous_block_index = forloop.index0 | minus: 1
      assign next_block_index = forloop.index0 | plus: 1
      assign previous_block = section.blocks[previous_block_index]
      assign next_block = section.blocks[next_block_index]

      comment
        You can use your own condition to create smart grouping. When two or more blocks match the condition, they are
        automatically grouped by a div that will take the desired class. This can even work for more than 2 elements
        (for instance if you specify accordion follow by an accordion). The theme takes care of properly opening and
        closing the group for proper HTML. In order to make it work, you need to create one condition explaining when
        to enter into the group, and you need to indicate a block_group_class and block_group_name. Most of the time,
        the two will be identical. However, the block_group_name must be unique. This means that as long as the block_group_name
        stays the same, then another group will not be created as long as the conditions match.
      endcomment

      assign allow_block_group = true

      if block.type == 'offer' and next_block.type == 'offer'
        assign block_group_class = 'product-info__offer-list'
        assign block_group_name = 'product-info__offer-list'
      elsif block.type == 'collapsible_text' and next_block.type == 'collapsible_text'
        assign block_group_class = 'accordion-group'
        assign block_group_name = 'accordion-group'
      elsif block.type == 'collapsible_text' and next_block.type == 'description' and product.description != blank and next_block.settings.collapse_content
        assign block_group_class = 'accordion-group'
        assign block_group_name = 'accordion-group'
      elsif block.type == 'description' and product.description != blank and block.settings.collapse_content and next_block.type == 'collapsible_text'
        assign block_group_class = 'accordion-group'
        assign block_group_name = 'accordion-group'
      else
        assign allow_block_group = false
        assign block_group_class = ''
        assign current_block_group_name = ''
      endif

      if allow_block_group
        assign new_block_group_name = block_group_name

        if inside_block_group_context == true and new_block_group_name != current_block_group_name
          assign allow_block_group = false
        else
          assign current_block_group_name = new_block_group_name
        endif
      endif
    -%}
    {%- if block.type == 'collapsible_text' and next_block.type == 'collapsible_text' -%}
      {%- if block.settings.enable_group -%}
        {%- style -%}
          .product-info__block-group.accordion-group[data-group-type="accordion-group"] {
              background: {{ block.settings.background_group }};
              padding: 24px;
              border-radius: 4px;
          }
          .product-info__block-group.accordion-group[data-group-type="accordion-group"] .text-with-icon span {
              text-transform: {{ block.settings.font_transform }};
          }
        {%- endstyle -%}
      {%- endif -%}
    {%- endif -%}

    {%- capture block_content -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {%- render block -%}

        {%- when 'vendor' -%}
          {%- if product.vendor != blank -%}
            <div class="product-info__vendor">
              {%- render 'vendor' with product.vendor -%}
            </div>
          {%- endif -%}

        {%- when 'title' -%}
          {%- comment -%}
            与菜单卡片同一数据源：`custom.badges`（单值或列表）或无上架徽章时的 `new` 标签。
            列表型 badges 必须用循环判断，否则会间歇识别失败。
          {%- endcomment -%}
          {%- liquid
            assign show_product_new_badge = false
            assign badges_mf = product.metafields.custom.badges
            if badges_mf != blank
              if badges_mf.type != blank and badges_mf.type contains 'list'
                for entry in badges_mf.value
                  assign eu = entry | strip | upcase
                  if eu == 'NEW'
                    assign show_product_new_badge = true
                  endif
                endfor
              else
                assign bv_one = badges_mf.value | strip | upcase
                if bv_one == 'NEW'
                  assign show_product_new_badge = true
                endif
              endif
              unless show_product_new_badge
                if badges_mf.value.first != blank
                  for entry in badges_mf.value
                    assign eu = entry | strip | upcase
                    if eu == 'NEW'
                      assign show_product_new_badge = true
                    endif
                  endfor
                endif
              endunless
            else
              for t in product.tags
                assign td = t | strip | downcase
                if td == 'new'
                  assign show_product_new_badge = true
                endif
              endfor
            endif
          -%}
          <div class="product-info__title-row">
            {%- if request.page_type == 'product' -%}
              <h1 class="product-info__title {{ block.settings.heading_tag }}">
                {{- product.title -}}
              </h1>
            {%- else -%}
              <h2 class="product-info__title {{ block.settings.heading_tag }}">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h2>
            {%- endif -%}
            {%- if show_product_new_badge -%}
              <span class="product-info__new-badge" role="status" aria-label="New"><span class="product-info__new-badge__text">New</span></span>
            {%- endif -%}
          </div>

        {%- when 'badges' -%}
          {%- render 'product-badges', product: product, context: 'product', types: 'custom', class: 'product-info__badge-list' -%}

        {%- when 'sku' -%}
          {% if product.selected_or_first_available_variant.sku != blank %}
            <variant-sku class="product-info__sku text-xs text-subdued">
              {{- 'product.general.sku' | t }} {{ product.selected_or_first_available_variant.sku -}}
            </variant-sku>
          {%- endif -%}

        {%- when 'price' -%}
          {%- if product.selected_or_first_available_variant != nil -%}
            <div class="product-info__price custom-price-style">
              <div class="rating-with-text">
                {%- render 'price-list', variant: product.selected_or_first_available_variant, size: 'lg' -%}
                {%- render 'product-badges', types: 'sold_out', product: product, context: 'product', class: 'product-info__badge-list' -%}

                {%- comment -%}If the next block is a rating block, then we add it as part of this one to have it inline{%- endcomment -%}
                {%- if next_block.type == 'rating' -%}
                  {%- render 'product-rating', product: product, show_empty: next_block.settings.show_empty, block: next_block -%}
                {%- endif -%}
              </div>

              {%- if block.settings.show_taxes_notice -%}
                <p class="text-sm text-subdued">
                  {%- if cart.taxes_included -%}
                    {{ 'product.general.taxes_included' | t }}
                  {%- else -%}
                    {{ 'product.general.taxes_excluded' | t }}
                  {%- endif -%}

                  {%- if shop.shipping_policy.body != blank -%}
                    {{ 'product.general.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- endif -%}
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- when 'rating' -%}
          {%- comment -%}If the previous block is of type price, then the rating has been rendered inside it so we do not render it twice{%- endcomment -%}

          {%- if previous_block.type != 'price' -%}
            <div class="product-info__rating">
              <style>
                /* 局部样式，只影响当前组件 */
                .product-info__rating .rating__star svg path {
                  fill: #E90202 !important;
                  stroke: #E90202 !important;
                }
                .product-info__rating .text-xs {
                  color: rgba(26, 26, 26, 0.60) !important;
                  text-align: center;
                  font-family: Gabarito, inherit !important;
                  font-size: 14px !important;
                  font-style: normal !important;
                  font-weight: 400 !important;
                  line-height: normal !important;
                  text-transform: capitalize !important;
                  text-decoration-line: underline !important;
                  text-decoration-style: solid !important;
                  text-decoration-skip-ink: auto !important;
                  text-decoration-thickness: auto !important;
                  text-underline-offset: auto !important;
                  text-underline-position: from-font !important;
                }
              </style>
              {%- render 'product-rating', product: product, show_empty: block.settings.show_empty, block: block -%}
            </div>
          {%- endif -%}

        {%- when 'payment_terms' -%}
          <payment-terms class="product-info__payment-terms">
            {%- capture product_installment_form_id -%}{{ product_form_id }}-product-installment-form{%- endcapture -%}

            {%- form 'product', product, id: product_installment_form_id -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {{- form | payment_terms -}}
            {%- endform -%}
          </payment-terms>

        {%- when 'separator' -%}
          <hr class="product-info__separator">

        {%- when 'product_tabs' -%}
          <div class="product-tabs-container">
            <div class="product-tabs-header">
              <button type="button" class="product-tab active" data-tab="tab-1"><span class="product-tab__label">{{ block.settings.tab_1_title }}</span></button>
              <button type="button" class="product-tab" data-tab="tab-2"><span class="product-tab__label">{{ block.settings.tab_2_title }}</span></button>
              <button type="button" class="product-tab" data-tab="tab-3"><span class="product-tab__label">{{ block.settings.tab_3_title }}</span></button>
            </div>
            <div class="product-tabs-content">
              <div class="product-tab-pane active" id="tab-1">
                {%- if block.settings.tab_1_heading != blank -%}
                  <p class="product-tab-content-heading">{{ block.settings.tab_1_heading }}</p>
                {%- endif -%}
                <div class="product-tab-main-content" data-tab-content="tab-1">{{ block.settings.tab_1_main_content }}</div>
                <button type="button" class="product-tab-view-more" data-view-more="tab-1">
                  <span class="product-tab-view-more-label">VIEW MORE</span>
                  <svg class="view-more-icon" xmlns="http://www.w3.org/2000/svg" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                    <path d="M5.13867 6.08105L0 0.942383L0.943359 0L5.13867 4.19531L9.33398 0L10.2764 0.942383L5.13867 6.08105Z" fill="#3180FF"/>
                  </svg>
                </button>
                <div class="product-tab-tags">
                  {%- assign tags = block.settings.tab_1_tags | newline_to_br | strip -%}
                  {%- assign tag_array = tags | split: '<br />' -%}
                  {%- for tag in tag_array -%}
                    {%- assign clean_tag = tag | strip -%}
                    {%- if clean_tag != blank -%}
                      <span class="product-tab-tag">{{ clean_tag }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
              <div class="product-tab-pane" id="tab-2">
                {%- if block.settings.tab_2_heading != blank -%}
                  <p class="product-tab-content-heading">{{ block.settings.tab_2_heading }}</p>
                {%- endif -%}
                <div class="product-tab-main-content" data-tab-content="tab-2">{{ block.settings.tab_2_main_content }}</div>
                <button type="button" class="product-tab-view-more" data-view-more="tab-2">
                  <span class="product-tab-view-more-label">VIEW MORE</span>
                  <svg class="view-more-icon" xmlns="http://www.w3.org/2000/svg" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                    <path d="M5.13867 6.08105L0 0.942383L0.943359 0L5.13867 4.19531L9.33398 0L10.2764 0.942383L5.13867 6.08105Z" fill="#3180FF"/>
                  </svg>
                </button>
                <div class="product-tab-list">
                  {%- assign list_items = block.settings.tab_2_list | newline_to_br | strip -%}
                  {%- assign item_array = list_items | split: '<br />' -%}
                  {%- for item in item_array -%}
                    {%- assign clean_item = item | strip -%}
                    {%- if clean_item != blank -%}
                      <div class="product-tab-list-item">
                        <svg class="product-tab-list-icon" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none">
                          <path d="M8.50001 0C13.1945 0 17 3.8055 17 8.50001C17 13.1945 13.1945 17 8.50001 17C3.8055 17 0 13.1945 0 8.50001C0 3.8055 3.8055 0 8.50001 0ZM12.462 4.4775L7.1715 9.92152L5.04 7.71052L3.96 8.75152L7.167 12.0785L13.538 5.52251L12.462 4.4775Z" fill="#E90202"/>
                        </svg>
                        <span class="product-tab-list-text">{{ clean_item }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
              <div class="product-tab-pane" id="tab-3">
                <div class="product-tab-images-grid">
                  {%- if block.settings.tab_3_image_1 != blank -%}
                    <div class="product-tab-image-item">
                      <img src="{{ block.settings.tab_3_image_1 | image_url: width: 800 }}" alt="{{ block.settings.tab_3_title }}" width="800" height="auto" loading="lazy">
                    </div>
                  {%- endif -%}
                  {%- if block.settings.tab_3_image_2 != blank -%}
                    <div class="product-tab-image-item">
                      <img src="{{ block.settings.tab_3_image_2 | image_url: width: 800 }}" alt="{{ block.settings.tab_3_title }}" width="800" height="auto" loading="lazy">
                    </div>
                  {%- endif -%}
                  {%- if block.settings.tab_3_image_3 != blank -%}
                    <div class="product-tab-image-item">
                      <img src="{{ block.settings.tab_3_image_3 | image_url: width: 800 }}" alt="{{ block.settings.tab_3_title }}" width="800" height="auto" loading="lazy">
                    </div>
                  {%- endif -%}
                  {%- if block.settings.tab_3_image_4 != blank -%}
                    <div class="product-tab-image-item">
                      <img src="{{ block.settings.tab_3_image_4 | image_url: width: 800 }}" alt="{{ block.settings.tab_3_title }}" width="800" height="auto" loading="lazy">
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>

        {%- when 'description' -%}
          {%- if block.settings.collapse_content -%}
            {%- if product.description != blank -%}
              {%- capture accordion_title -%}{{ 'product.general.description' | t }}{%- endcapture -%}
              {%- capture accordion_content -%}<div class="prose">{{ product.description }}</div>{%- endcapture -%}

              {%- assign icon = block.settings.custom_icon | default: block.settings.icon -%}
              {%- render 'accordion', title: accordion_title, content: accordion_content, icon: icon, icon_width: block.settings.icon_width, class: 'product-info__accordion', block: block -%}
            {%- endif -%}
          {%- else -%}
            {%- if product.description != blank -%}
              <div class="product-info__description">
                <div class="prose">
                  {{- product.description -}}
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}

        {%- when 'variant_picker' -%}
          {% style %}
              {%- assign _g7_vp_scope = '#shopify-section-' | append: section.id | append: ' .product-info__variant-picker' -%}
              .product-info__variant-picker{
                position:relative;
              }
              .product-info__variant-picker .variants_comparors{
                {%- unless product.has_only_default_variant -%}
                position:absolute;
                {% endunless %}
                top:0;
                right:0;
              }
              .product-info__variant-picker .variants_comparors .size_guide .black{
                color:#000;
              }

              /* Select 标题字体已在顶部全局 style 与 Quantity 对齐，此处不再覆盖为 20px */

              /* Figma 节点 1045-18432: variant picker - 移动端精确还原 */
              @media screen and (max-width: 999px) {
                /* Figma 5726-3877: 移动端一行 2 个，自动换行；itemSpacing 12 → gap 12px；单项宽 (100% − 1×gap) / 2 */
                {{ _g7_vp_scope }} .variant-picker__option-values {
                  display: flex !important;
                  flex-wrap: wrap !important;
                  gap: 12px !important;
                  width: 100%;
                }

                /* 卡片：min-height 对齐 Figma；height auto 避免长文案（如 Purple With RGB）被死高裁切 */
                .product-info__variant-picker .block-swatch {
                  width: calc((100% - 12px) / 2) !important;
                  min-width: 0 !important;
                  max-width: calc((100% - 12px) / 2) !important;
                  height: auto !important;
                  min-height: 107px !important;
                  flex: 0 0 calc((100% - 12px) / 2) !important;
                  padding: 24px 16px 16px 16px !important;
                  gap: 8px !important;
                  border-radius: 8px !important;
                  border: 2px solid #E6E6E6 !important;
                  outline: none !important;
                  background: #fff !important;
                  box-sizing: border-box !important;
                  display: flex !important;
                  flex-direction: column !important;
                  align-items: center !important;
                  justify-content: flex-start !important;
                  overflow: visible !important;
                }

                /* 选中状态: 红色边框 #E90202 (Figma stroke color) */
                .product-info__variant-picker :checked + .block-swatch,
                .product-info__variant-picker .block-swatch.is-selected {
                  outline: none !important;
                  border: 2px solid #E90202 !important;
                }

                /* 色块图片: 40x40 圆形 */
                .product-info__variant-picker .block-swatch__color,
                .product-info__variant-picker .block-swatch__svg,
                .product-info__variant-picker .block-swatch img {
                  width: 40px !important;
                  height: 40px !important;
                }

                /* 长选项名：最多两行；字号固定 16px (Figma 5726-3877) */
                .product-info__variant-picker .block-swatch__label {
                  color: #1A1A1A !important;
                  font-family: Gabarito !important;
                  font-size: 16px !important;
                  font-weight: 500 !important;
                  line-height: 1.2 !important;
                  letter-spacing: 0 !important;
                  text-align: center !important;
                  width: 100% !important;
                  max-width: 100% !important;
                  display: -webkit-box !important;
                  -webkit-box-orient: vertical !important;
                  -webkit-line-clamp: 2 !important;
                  overflow: hidden !important;
                  word-break: break-word !important;
                  hyphens: none !important;
                }
              }

              /* 桌面 PDP 右栏：与 MOB 同款 block 网格 + 红框选中，避免仅主题默认样式导致与参考页不一致 */
              @media screen and (min-width: 1000px) {
                {{ _g7_vp_scope }} .variant-picker__option-values {
                  display: flex !important;
                  flex-wrap: wrap !important;
                  gap: 12px !important;
                  width: 100%;
                }

                .product-info__variant-picker .block-swatch {
                  width: calc((100% - 48px) / 4) !important;
                  min-width: 0 !important;
                  max-width: calc((100% - 48px) / 4) !important;
                  height: auto !important;
                  min-height: 107px !important;
                  flex: 0 0 calc((100% - 48px) / 4) !important;
                  padding: 24px 16px 16px 16px !important;
                  gap: 8px !important;
                  border-radius: 12px !important;
                  border: 2px solid #E6E6E6 !important;
                  outline: none !important;
                  background: #fff !important;
                  box-sizing: border-box !important;
                  display: flex !important;
                  flex-direction: column !important;
                  align-items: center !important;
                  justify-content: flex-start !important;
                  overflow: visible !important;
                }

                .product-info__variant-picker :checked + .block-swatch,
                .product-info__variant-picker .block-swatch.is-selected {
                  outline: none !important;
                  border: 2px solid #E90202 !important;
                }

                .product-info__variant-picker .block-swatch__color,
                .product-info__variant-picker .block-swatch__svg,
                .product-info__variant-picker .block-swatch img {
                  width: 40px !important;
                  height: 40px !important;
                }

                .product-info__variant-picker .block-swatch__label {
                  color: #1A1A1A !important;
                  font-family: Gabarito !important;
                  font-size: clamp(11px, 1.25vw, 16px) !important;
                  font-weight: 500 !important;
                  line-height: 1.2 !important;
                  letter-spacing: 0 !important;
                  text-align: center !important;
                  width: 100% !important;
                  max-width: 100% !important;
                  display: -webkit-box !important;
                  -webkit-box-orient: vertical !important;
                  -webkit-line-clamp: 2 !important;
                  overflow: hidden !important;
                  word-break: break-word !important;
                  hyphens: none !important;
                }
              }

              @media screen and (max-width: 700px) {
                .product-info__variant-picker .variants_comparors{
                  position:relative;
                  flex-direction: row !important;
                  align-items: center;
                  justify-content: flex-start;
                  margin-bottom: 20px;
                }
              }
          {% endstyle %}
          <div class="product-info__variant-picker">
            
            <div class="variants_comparors">
              {% if product.metafields.custom.size_guide_image != blank %}
                <div class="size_guide">
                  <img alt="Size Guide" class="lazyloaded" data-widths="[360, 540, 750, 900, 1080, 1600]" data-aspectratio="auto" data-sizes="auto" src="https://cdn.shopify.com/s/files/1/0615/6684/5144/files/size.png?v=1757128306" width="18" height="18">
                  <span class="text-subdued black">Size Guide</span>
                </div>
              {% endif %}
              {% if section.settings.compare_link != blank %} 
                <div class="size_guide compare">
                  <img alt="Size Guide" class="lazyloaded" data-widths="[360, 540, 750, 900, 1080, 1600]" data-aspectratio="auto" data-sizes="auto" src="https://cdn.shopify.com/s/files/1/0615/6684/5144/files/compare.png?v=1757128306" width="18" height="18">
                  <a class="black" href="{{section.settings.compare_link}}">{{ section.settings.compare_link_text }}</a>
                </div>
              {% endif %}
            </div>

            {%- render 'variant-picker', 
              product: product, 
              form_id: product_form_id,
              update_url: update_url, 
              hide_sold_out_variants: block.settings.hide_sold_out_variants, 
              block: block,
              prefer_block_swatch_layout: true,
              force_first_option_legend: 'Select'
            -%}
          </div>

        {%- when 'product_variations' -%}
          {%- assign contains_product = false -%}

          {%- for product_variation in block.settings.products -%}
            {%- if product_variation == product -%}
              {%- assign contains_product = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if contains_product -%}
            {%- comment -%}
              IMPLEMENTATION NOTE: this feature allows to connect different products on the same page. It is therefore
              visually similar to a variant picker, although it does not share the functionality
            {%- endcomment -%}

            <div class="product-info__product-picker">
              <div class="variant-picker">
                <fieldset class="variant-picker__option">
                  {%- assign metafield_parts = block.settings.option_value_metafield | split: '.' -%}
                  {%- assign metafield_namespace = metafield_parts | first -%}
                  {%- assign metafield_key = metafield_parts | last -%}

                  {%- if block.settings.option_name != blank -%}
                    <div class="variant-picker__option-info">
                      <div class="h-stack gap-2">
                        <legend class="text-subdued">{{ block.settings.option_name }}:</legend>
                        <span>{{ product.metafields[metafield_namespace][metafield_key].value | escape }}</span>
                      </div>
                    </div>
                  {%- endif -%}

                  <div class="variant-picker__option-values wrap gap-2">
                    {%- for product_variation in block.settings.products -%}
                      {%- assign label = product_variation.metafields[metafield_namespace][metafield_key].value -%}

                      {%- if product_variation == product -%}
                        {%- assign selected = true -%}
                      {%- else -%}
                        {%- assign selected = false -%}
                      {%- endif -%}

                      {%- case block.settings.selector_style -%}
                        {%- when 'swatch' -%}
                          {%- render 'option-value', type: 'swatch', url: product_variation.url, label: label, selected: selected -%}

                        {%- when 'variant_image' -%}
                          {%- render 'option-value', type: 'thumbnail', url: product_variation.url, label: label, image: product_variation.featured_media, selected: selected, bordered: true -%}

                        {%- when 'block' -%}
                          {%- render 'option-value', type: 'block', url: product_variation.url, label: label, selected: selected -%}

                        {%- when 'block_swatch' -%}
                          {%- render 'option-value', type: 'block', url: product_variation.url, label: label, selected: selected, show_swatch: true -%}
                      {%- endcase -%}
                    {%- endfor -%}
                  </div>
                </fieldset>
              </div>
            </div>
          {%- endif -%}

        {%- when 'line_item_property' -%}
          {%- if block.settings.label != blank -%}
            {%- capture name -%}properties[{{ block.settings.label | escape }}]{%- endcapture -%}

            <div class="product-info__property">
              {%- if block.settings.type == 'text' -%}
                {%- if block.settings.allow_long_text -%}
                  {%- render 'input', label: block.settings.label, name: name, form: product_form_id, multiline: 4, required: block.settings.required, maxlength: block.settings.max_length -%}
                {%- else -%}
                  {%- render 'input', type: 'text', label: block.settings.label, name: name, form: product_form_id, required: block.settings.required, maxlength: block.settings.max_length -%}
                {%- endif -%}
              {%- else -%}
                {%- render 'checkbox', label: block.settings.label, name: name, required: block.settings.required, form: product_form_id -%}
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- when 'quantity_selector' -%}
          {%- if product.available -%}
            {%- assign variant = product.selected_or_first_available_variant -%}

            <div class="product-info__quantity-selector">
              <div class="form-control">
                <label for="{{ product_form_id }}-quantity" aria-label="quantity" class="block-label text-subdued">{{- 'product.quantity.label' | t -}}</label>

                <quantity-selector class="quantity-selector">
                  <button type="button" class="quantity-selector__button quantity-selector__button--minus" aria-label="{{ 'product.quantity.decrease_quantity' | t }}">{% render 'quantity-step-icon-g7', step: 'minus' %}</button>
                  <input id="{{ product_form_id }}-quantity" type="number" is="quantity-input" inputmode="numeric" class="quantity-selector__input" name="quantity" form="{{ product_form_id }}" value="{{ variant.quantity_rule.min | default: 1 }}" step="{{ variant.quantity_rule.increment }}" min="{{ variant.quantity_rule.min }}" {% if variant.quantity_rule.max != nil %}max="{{ variant.quantity_rule.max }}"{% endif %} autocomplete="off">
                  <button type="button" class="quantity-selector__button quantity-selector__button--plus" aria-label="{{ 'product.quantity.increase_quantity' | t }}">{% render 'quantity-step-icon-g7', step: 'plus' %}</button>
                </quantity-selector>
              
              </div>

              {%- comment -%} 数量 −/+ 与最小值态：由 sections/main-product-g7-m6.liquid 底部委托脚本同步（variant 区块 AJAX 替换后仍有效）{%- endcomment -%}

              {%- liquid
                assign quantity_rules = ''

                if variant.quantity_rule.min > 1
                  assign rule = 'product.quantity.minimum_of' | t: min: variant.quantity_rule.min
                  assign quantity_rules = quantity_rules | append: ' / ' | append: rule
                endif

                if variant.quantity_rule.max != nil
                  assign rule = 'product.quantity.maximum_of' | t: max: variant.quantity_rule.max
                  assign quantity_rules = quantity_rules | append: ' / ' | append: rule
                endif

                if variant.quantity_rule.increment > 1
                  assign rule = 'product.quantity.increment_of' | t: step: variant.quantity_rule.increment
                  assign quantity_rules = quantity_rules | append: ' / ' | append: rule
                endif
              -%}

              {%- if quantity_rules != blank -%}
                <p class="text-subdued text-sm">{{ quantity_rules | remove_first: ' / ' | capitalize }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- when 'volume_pricing' -%}
          {%- render 'volume-pricing-table', variant: product.selected_or_first_available_variant -%}

        {%- when 'inventory' -%}
          {% style %}
            .product-info__inventory span.text-with-icon {
                  color: currentColor;
              }
              .enable_pulse.pulse {
                  width: 20px;
                  height: 20px;
                  border-radius: 50%;
                  animation-duration: 2s;
                  animation-iteration-count: infinite;
                }

                /* Warning Pulse */
                .pulse-warning-color {
                  background-color: {{ block.settings.warning_color }};
                  animation-name: pulseAnimationWarning;
                }

                @keyframes pulseAnimationWarning {
                  0% {
                    box-shadow: 0 0 0 0 {{ block.settings.warning_color | color_modify: 'alpha', 0.4 }};
                  }
                  70% {
                    box-shadow: 0 0 0 15px {{ block.settings.warning_color | color_modify: 'alpha', 0 }};
                  }
                  100% {
                    box-shadow: 0 0 0 0 {{ block.settings.warning_color | color_modify: 'alpha', 0 }};
                  }
                }

                /* Success Pulse */
                .pulse-success-color {
                  background-color: {{ block.settings.success_color }};
                  animation-name: pulseAnimationSuccess;
                }

                @keyframes pulseAnimationSuccess {
                  0% {
                    box-shadow: 0 0 0 0 {{ block.settings.success_color | color_modify: 'alpha', 0.4 }};
                  }
                  70% {
                    box-shadow: 0 0 0 15px {{ block.settings.success_color | color_modify: 'alpha', 0 }};
                  }
                  100% {
                    box-shadow: 0 0 0 0 {{ block.settings.success_color | color_modify: 'alpha', 0 }};
                  }
                }

                /* Error Pulse */
                .pulse-error-color {
                  background-color: {{ block.settings.error_color }};
                  animation-name: pulseAnimationError;
                }

                @keyframes pulseAnimationError {
                  0% {
                    box-shadow: 0 0 0 0 {{ block.settings.error_color | color_modify: 'alpha', 0.4 }};
                  }
                  70% {
                    box-shadow: 0 0 0 15px {{ block.settings.error_color | color_modify: 'alpha', 0 }};
                  }
                  100% {
                    box-shadow: 0 0 0 0 {{ block.settings.error_color | color_modify: 'alpha', 0 }};
                  }
                }
           {% endstyle %}
          <div class="product-info__inventory">
            {%- render 'kiks-inventory', enable_pulse: block.settings.enable_pulse, variant: product.selected_or_first_available_variant, low_threshold: block.settings.low_inventory_threshold, form_id: product_form_id -%}
            {% comment %} DEFAULT CODE HERE
            
            {%- render 'inventory', enable_pulse: block.settings.enable_pulse, variant: product.selected_or_first_available_variant, low_threshold: block.settings.low_inventory_threshold, form_id: product_form_id -%} 
            {% endcomment %}
          </div>

        {%- when 'countdown' -%}
          {% if block.settings.show_countdown %}
            {%- render 'countdown-block', block: block -%}
          {% endif %}

        {%- when 'selling_points_titles' -%}

          {%- if product.metafields.custom.selling_points_titles.value != blank -%}
            <style>
              .product-info__selling-points h6{
                font-size: 20px;
                font-weight: 700;
                margin-bottom: 16px;
                font-family: 'HarmonyOS Sans SC';
                text-transform: none !important;
              }
              .product-info__selling-points p{
                line-height: 1.5;
                margin-bottom: 5px;
              }
              @media screen and (max-width: 700px) {
                .product-info__selling-points h6{
                  font-size: 18px;
                  margin-bottom: 12px;
                }
                .product-info__selling-points p{
                  color: #777777;
                }
              }
            </style>
            <div class="product-info__selling-points">
              <h6>{{ block.settings.title }}</h6>
              {% for title in product.metafields.custom.selling_points_titles.value %}
                <p>- {{ title }}</p>
              {% endfor %}
            </div>
          {%- endif -%} 

        {%- when 'buy_buttons' -%}
          
            {%- assign main_form_exists = true -%}

            {%- if request.page_type != 'password' -%}

              <style>
                .product-info__buy-buttons .custom-group{
                  display: grid; 
                  
                  {% if block.settings.show_payment_button %}
                    grid-template-columns: 1fr 1fr;
                  {% else %}
                    grid-template-columns: auto 1fr;
                  {% endif %}
                }

                
               
                {{ qty_buy_scope }} .form-control{
                  max-width: 150px;
                  height: 44px;
                  box-shadow: 0px 0px 2px 1px #AAAAAA inset !important;
                  clip-path: polygon(
                    0% 7px,            /* top-left corner cut */
                    7px 0%, 
                    calc(100% - 7px) 0%, /* top-right corner cut */
                    100% 7px,
                    100% calc(100% - 7px), /* bottom-right corner cut */
                    calc(100% - 7px) 100%,
                    7px 100%,          /* bottom-left corner cut */
                    0% calc(100% - 7px)
                  );
                  display: flex;
                  justify-content: center;
                  align-items: center;
                  border-radius: 10px;
                }

                {{ qty_buy_scope }} .form-control quantity-selector{
                  max-width: 150px;
                  height: 44px;
                }

                /* Figma 1182:3193 — 移动端数量条为药丸形；移除 buy 区 clip-path/内阴影，避免底部被裁切 */
                @media screen and (max-width: 999px) {
                  {{ qty_buy_scope }} .form-control {
                    max-width: none !important;
                    height: auto !important;
                    box-shadow: none !important;
                    clip-path: none !important;
                    border-radius: 0 !important;
                    padding: 0 !important;
                    overflow: visible !important;
                    background: transparent !important;
                    align-items: center !important;
                  }

