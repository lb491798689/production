<script>
(function() {
  const container = document.querySelector('.product-tabs-container');
  if (!container) return;

  const tabs = container.querySelectorAll('.product-tab');
  const panes = container.querySelectorAll('.product-tab-pane');

  const tabsHeader = container.querySelector('.product-tabs-header');

  function scrollTabIntoView(tabEl) {
    if (!tabsHeader || !tabEl) return;
    // 仅在横向可滚动时执行（移动端）
    if (tabsHeader.scrollWidth <= tabsHeader.clientWidth) return;
    const targetLeft = tabEl.offsetLeft - (tabsHeader.clientWidth - tabEl.offsetWidth) / 2;
    tabsHeader.scrollTo({
      left: Math.max(0, targetLeft),
      behavior: 'smooth'
    });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', function() {
      const tabId = this.getAttribute('data-tab');

      tabs.forEach(t => t.classList.remove('active'));
      panes.forEach(p => p.classList.remove('active'));

      this.classList.add('active');
      container.querySelector('#' + tabId).classList.add('active');

      scrollTabIntoView(this);
    });
  });

  // View More：展开全文后隐藏按钮（无 View Less）
  container.querySelectorAll('.product-tab-view-more').forEach(function (button) {
    button.addEventListener('click', function () {
      const tabId = this.getAttribute('data-view-more');
      const content = container.querySelector('.product-tab-main-content[data-tab-content="' + tabId + '"]');
      if (!content) return;
      content.classList.add('expanded');
      this.hidden = true;
    });
  });
})();
</script>

  
