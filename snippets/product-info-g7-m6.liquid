  /*
    「Select:」标题行与 Quantity 标签同一套 Figma 字体（G7 / M6 / 同一 PDP 组件完全一致）
    Gabarito 24px / font-weight 600 / line-height 120% / #0A0A0A
    加强层级与显式可见性，避免绝对定位 comparors / fieldset 排版导致标题「看不见」
  */
  .product-info .product-info__variant-picker .variant-picker__option-info {
    position: relative !important;
    z-index: 2 !important;
  }

  .product-info .product-info__variant-picker .variant-picker__option-info > .h-stack {
    align-items: center !important;
    gap: 8px !important;
    position: relative !important;
    z-index: 2 !important;
  }

  .product-info .product-info__variant-picker .variant-picker__option-info > .h-stack .variant-picker__option-heading,
  .product-info .product-info__variant-picker .variant-picker__option-info > .h-stack > span {
    font-family: Gabarito, sans-serif !important;
    font-size: 24px !important;
    font-style: normal !important;
    font-weight: 600 !important;
    line-height: 120% !important;
    letter-spacing: 0 !important;
    color: #0A0A0A !important;
    margin: 0 !important;
    padding: 0 !important;
    display: inline-block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }

  /* 手机端（≤999）Select: 标题与 Quantity 标签同字号：20px */
