                    display: flex;
                    align-items: center;
                    justify-content: {{ block.settings.allow_flex }};
                    gap: {{ block.settings.allow_gap }}px;
                }
              {%- endstyle -%}
            {% endif %}
            <div class="custom_logos_container">
              <div class="logo-items">
                {%- for i in (1..3) -%}
                  <div class="logo-item">
                    {%- capture image_key -%}image{{ i }}{%- endcapture -%}
                    {%- capture max_width_key -%}max_width{{ i }}{%- endcapture -%}
                    {%- capture alignment_key -%}alignment{{ i }}{%- endcapture -%}
                
                    {%- assign image = block.settings[image_key] -%}
                    {%- assign max_width = block.settings[max_width_key] -%}
                    {%- assign alignment = block.settings[alignment_key] -%}
                
                    {%- if image != blank -%}
                      <div class="product-info__image">
                        {%- capture sizes -%}{{ max_width }}px{%- endcapture -%}
                        {%- capture widths -%}{{ max_width }}, {{ max_width | times: 2 | at_most: image.width }}{%- endcapture -%}
                        {%- capture style -%}
                          width: {{ max_width }}px;
                          {%- if alignment == 'center' -%}
                            margin-inline: auto;
                          {%- elsif alignment == 'end' -%}
                            margin-inline-start: auto;
                          {%- endif -%}
                        {%- endcapture -%}
                        {{- image | image_url: width: image.width | image_tag: style: style, sizes: sizes, widths: widths -}}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
                                
              </div>
            </div>
          
        {%- when 'offer' -%}
          {%- if block.settings.title != blank or block.settings.content != blank -%}
            {%- render 'offer', block: block -%}
          {%- endif -%}
          {% comment %} {%- when 'bottom_policy' -%}
            <div class="kik_policy">
              {% if block.settings.add_link %}
              <a href="{{ block.settings.add_link }}">
              {% endif %}
              <img src="{{ block.settings.icon | img_url: '48x48' }}" alt="{{ block.settings.icon.alt | escape }}" loading="lazy" width="24" height="24">
              <p>{{ block.settings.title }}</p>
              {% if block.settings.add_link %}
              </a>
              {% endif %}
            </div> {% endcomment %}
        {%- when 'share_buttons' -%}
          <div class="product-form__share justify-items-{{ block.settings.alignment | replace: 'left', 'start' | replace: 'right', 'end' }}">
            <div class="product-info__share-buttons">
              <div class="share-buttons">
                <span class="text-subdued">{{- 'general.social.share' | t -}}</span>

                <ul class="h-stack" role="list">
                  <li><a href="{% render 'share-link', host: 'facebook', title: product.title, description: product.description, url: product.url %}" class="share-buttons__item" aria-label="{{ 'general.social.share_on' | t: social_media: 'Facebook' }}">{%- render 'icon' with 'facebook', width: 20, height: 20 -%}</a></li>
