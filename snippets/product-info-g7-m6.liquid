{%- liquid
  assign qty_sel_scope = '#shopify-section-' | append: section.id | append: ' .product-info__quantity-selector'
  assign qty_buy_scope = '#shopify-section-' | append: section.id | append: ' .product-info__buy-buttons .product-info__quantity-selector'
-%}
