{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
LOCALIZATION SELECTOR COMPONENT
----------------------------------------------------------------------------------------------------------------------

This component renders a selector for a localization component (either country or locale).

********************************************
Supported variables
********************************************

* type: can be either "country" or "locale" (required)
* show_country_name: for type "country" if set to true the country/currency name are shown
* show_country_flag: for type "country" if set to true the country flags are shown
* popover_horizontal_position: an optional vertical position
* popover_vertical_position: an optional horizontal position (start if none is passed)
* nav_compact: optional, locale only — globe asset + short language code (header Figma); omit everywhere else
* footer_compact: optional — footer pill (Figma): globe + «Country / Language» (Gabarito 16px)
* mobile_popover_center: optional — mobile: bottom sheet + viewport horizontal center（页脚等）
* mobile_popover_adjacent: optional — mobile: 紧贴触发按钮附近（侧滑菜单 EN/$USD 一行）
* mobile_popover_near_trigger: optional — mobile: 贴底 + 相对顶栏语言按钮水平对齐（顶栏紧凑）
* popover_id_suffix: optional — disambiguate ids when multiple selectors share one section (e.g. `nav` vs `drawer`)
{%- endcomment -%}

{%- assign nav_compact = nav_compact | default: false -%}
{%- assign footer_compact = footer_compact | default: false -%}
{%- assign mobile_popover_center = mobile_popover_center | default: false -%}
{%- assign mobile_popover_adjacent = mobile_popover_adjacent | default: false -%}
{%- assign mobile_popover_near_trigger = mobile_popover_near_trigger | default: false -%}
{%- assign popover_vertical_position = popover_vertical_position | default: 'start' -%}
{%- assign popover_horizontal_position = popover_horizontal_position | default: 'end' -%}
{%- assign popover_id_suffix = popover_id_suffix | default: '' | strip -%}

{%- capture localization_form_id -%}localization-form-{{ type }}-{{ popover_vertical_position }}{%- if popover_id_suffix != blank -%}-{{ popover_id_suffix }}{%- endif -%}-{{ section.id }}{%- endcapture -%}
{%- capture localization_popover_id -%}popover-localization-form-{{ type }}-{{ popover_vertical_position }}{%- if popover_id_suffix != blank -%}-{{ popover_id_suffix }}{%- endif -%}-{{ section.id }}{%- endcapture -%}

{%- case type -%}
  {%- when 'country' -%}
    {%- comment -%}
    ----------------------------------------------------------------------------------------------
    COUNTRY SELECTOR
    ----------------------------------------------------------------------------------------------
    {%- endcomment -%}

    {%- if show_country_flag -%}
      <link rel="stylesheet" href="{{ 'country-flags.css' | asset_url }}" media="print" onload="this.media='all'; this.onload = null">
    {%- endif -%}

    <div class="relative localization-selector">
      <button type="button" class="text-with-icon {% if footer_compact %}gap-2 af-footer-locale-btn{% elsif nav_compact %}gap-2 af-nav-locale-btn{% else %}gap-2.5{% endif %} group" aria-label="{{ 'general.localization.change_country_accessibility_text' | t | escape }}" aria-controls="{{ localization_popover_id }}" aria-expanded="false">
        {%- if footer_compact -%}
          {%- render 'af-footer-globe-icon' -%}
          <span class="af-footer-locale-code">
            {{- localization.country.name -}}
            <span class="af-footer-locale-sep"> / </span>
            {{- localization.language.endonym_name | capitalize -}}
          </span>
        {%- elsif nav_compact -%}
          {%- render 'af-nav-globe-icon' -%}
          <span class="bold text-sm af-nav-locale-code">{{ localization.language.iso_code | split: '-' | first | upcase }}</span>
        {%- else -%}
          <div class="h-stack gap-2">
            {%- if show_country_flag -%}
              <span class="country-flags country-flags--{{ localization.country.iso_code }}"></span>
            {%- endif -%}

            <span class="bold text-sm">
              {%- if show_country_name -%}
                {{ localization.country.name }} ({{ localization.country.currency.iso_code }} {% if localization.country.currency.symbol %}{{ localization.country.currency.symbol }}){%- endif -%}
              {%- else -%}
                {{ localization.country.currency.iso_code }} {% if localization.country.currency.symbol %}{{ localization.country.currency.symbol }}{%- endif -%}
              {%- endif -%}
            </span>
          </div>

          {%- render 'icon' with 'chevron-bottom' -%}
        {%- endif -%}
      </button>

      <x-popover id="{{ localization_popover_id }}" initial-focus="[aria-selected='true']" anchor-horizontal="{{ popover_horizontal_position }}" anchor-vertical="{{ popover_vertical_position }}" class="popover" {% if footer_compact %}mobile-anchor="center"{% elsif mobile_popover_adjacent %}mobile-anchor="adjacent"{% elsif mobile_popover_near_trigger %}mobile-anchor="trigger"{% elsif mobile_popover_center %}mobile-anchor="center"{% endif %}>
        <p class="h5" slot="title">{{ 'general.localization.country' | t }}</p>

        {%- form 'localization', id: localization_form_id -%}
          <x-listbox class="popover-listbox popover-listbox--sm" role="listbox">
            {%- for country in localization.available_countries -%}
              <button type="submit" class="popover-listbox__option" name="country_code" role="option" value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}aria-selected="true"{% endif %}>
                <span class="country-flags country-flags--{{ country.iso_code }}"></span>
                <span>{{- country.name }} ({{ country.currency.iso_code }} {% if country.currency.symbol %}{{ country.currency.symbol }}{%- endif -%})</span>
              </button>
            {%- endfor -%}
          </x-listbox>
        {%- endform -%}
      </x-popover>
    </div>

  {%- when 'locale' -%}
    {%- comment -%}
    ----------------------------------------------------------------------------------------------
    LOCALE SELECTOR
    ----------------------------------------------------------------------------------------------
    {%- endcomment -%}

    <div class="relative localization-selector">
      <button type="button" class="text-with-icon {% if footer_compact %}gap-2 af-footer-locale-btn{% elsif nav_compact %}gap-2 af-nav-locale-btn{% else %}gap-2.5{% endif %} group" aria-label="{{ 'general.localization.change_language_accessibility_text' | t | escape }}" aria-controls="{{ localization_popover_id }}" aria-expanded="false">
        {%- if footer_compact -%}
          {%- render 'af-footer-globe-icon' -%}
          <span class="af-footer-locale-code">
            {{- localization.country.name -}}
            <span class="af-footer-locale-sep"> / </span>
            {{- localization.language.endonym_name | capitalize -}}
          </span>
        {%- elsif nav_compact -%}
          {%- render 'af-nav-globe-icon' -%}
          <span class="bold text-sm af-nav-locale-code">{{ localization.language.iso_code | split: '-' | first | upcase }}</span>
        {%- else -%}
          <span class="bold text-sm">{{- localization.language.endonym_name | capitalize -}}</span>
          {%- render 'icon' with 'chevron-bottom' -%}
        {%- endif -%}
      </button>

      <x-popover id="{{ localization_popover_id }}" initial-focus="[aria-selected='true']" anchor-horizontal="{{ popover_horizontal_position }}" anchor-vertical="{{ popover_vertical_position }}" class="popover" {% if footer_compact %}mobile-anchor="center"{% elsif mobile_popover_adjacent %}mobile-anchor="adjacent"{% elsif mobile_popover_near_trigger %}mobile-anchor="trigger"{% elsif mobile_popover_center %}mobile-anchor="center"{% endif %}>
        <p class="h5" slot="title">{{ 'general.localization.language' | t }}</p>

        {%- form 'localization', id: localization_form_id -%}
          <x-listbox class="popover-listbox popover-listbox--sm" role="listbox">
            {%- for language in localization.available_languages -%}
              <button type="submit" class="popover-listbox__option" name="locale_code" role="option" value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}aria-selected="true"{% endif %}>
                {{- language.endonym_name | capitalize -}}
              </button>
            {%- endfor -%}
          </x-listbox>
        {%- endform -%}
      </x-popover>
    </div>
{%- endcase -%}