{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MEGA MENU PANEL
----------------------------------------------------------------------------------------------------------------------

This component is used to show the different links in different panel for the menu drawer

********************************************
Supported variables
********************************************

* main_menu: the menu to show for the primary menu
* secondary_menu: the secondary menu (shown on mobile)
* mega_menu_block: use when mega menu is set to drawer
* is_mega_menu: set to true if mega menu is set to drawer
* layout
{%- endcomment -%}

<div class="panel-list__wrapper">
  <div class="panel panel-one">
    <div class="panel__wrapper" {% if mega_menu_block.settings.promo_content_layout == 'grid' or mega_menu_block.settings.promo_content_layout == 'collage' %}style="--panel-wrapper-justify-content: flex-start"{% endif %}>
      <div class="panel__scroller v-stack gap-8">

        {%- if is_mega_menu -%}
           <button is="close-button" aria-label="{{ 'general.accessibility.close' | t | escape }}" {%- if section.settings.opening_from == 'bottom' -%}class="sm-max:hidden"{%- endif -%}>
              {%- render 'icon' with 'close', width: 19, height: 19 -%}
            </button>
        {%- endif -%}

        <ul class="v-stack menu-list-box">
          {%- for link in main_menu.links -%}
            {%- unless is_mega_menu -%}
              {% liquid
                assign link_title_downcase = link.title | strip | downcase
                assign mega_menu_block = ''
                assign is_image_shown = false

                comment
                  与 header.liquid 一致的容错匹配：
                  - product ↔ products 互通
                  - menu_item 留空作为通配
                  - 仅 1 个 mega_menu 区块时直接使用
                endcomment
                for block in section.blocks
                  if block.type == 'mega_menu'
                    assign menu_item_downcase = block.settings.menu_item | strip | downcase
                    assign menu_matches = false
                    if menu_item_downcase != '' and menu_item_downcase == link_title_downcase
                      assign menu_matches = true
                    elsif menu_item_downcase == 'products' and link_title_downcase == 'product'
                      assign menu_matches = true
                    elsif menu_item_downcase == 'product' and link_title_downcase == 'products'
                      assign menu_matches = true
                    endif
                    if menu_matches
                      assign mega_menu_block = block
                      if block.settings.drawer_link_image == 'show'
                        assign is_image_shown = true
                      endif
                      break
                    endif
                  endif
                endfor

                assign has_grandchild_links = false
                if mega_menu_block == ''
                  for sub_link in link.links
                    if sub_link.links.size > 0
                      assign has_grandchild_links = true
                      break
                    endif
                  endfor
                endif

                if mega_menu_block == '' and has_grandchild_links
                  assign mega_blocks_count = 0
                  assign sole_mega_menu_block = ''
                  assign wildcard_mega_menu_block = ''
                  for block in section.blocks
                    if block.type == 'mega_menu'
                      assign mega_blocks_count = mega_blocks_count | plus: 1
                      if sole_mega_menu_block == ''
                        assign sole_mega_menu_block = block
                      endif
                      if block.settings.menu_item == blank and wildcard_mega_menu_block == ''
                        assign wildcard_mega_menu_block = block
                      endif
                    endif
                  endfor
                  if wildcard_mega_menu_block != ''
                    assign mega_menu_block = wildcard_mega_menu_block
                  elsif mega_blocks_count == 1
                    assign mega_menu_block = sole_mega_menu_block
                  endif
                  if mega_menu_block != '' and mega_menu_block.settings.drawer_link_image == 'show'
                    assign is_image_shown = true
                  endif
                endif
              %}

            {%- else -%}
              {%- assign is_image_shown = false -%}

              {%- if mega_menu_block.settings.drawer_link_image == 'show' -%}
                {%- assign is_image_shown = true -%}
              {%- endif -%}

            {%- endunless -%}

            <li class="h3 sm:h4 link1-nav-li ">
              {%- if link.links.size > 0 and mega_menu_block != '' and is_mega_menu == false -%}
                {%- comment -%} Figma 765:1870：一级展开后 = 多系列纵向排列 + 每系列横向滚动 3 卡 + Compare / Learn {%- endcomment -%}
                <div class="link1-nav__wrapper product-list-box jingva-drawer-product">
                  <div class="text-with-icon w-full group justify-between link-nav-title jingva-drawer-nav-row">
                    <span><span class="reversed-link">{{ link.title }}</span></span>
                    <span class="jingva-drawer-tab-icon" aria-hidden="true">
                      <svg class="jingva-drawer-icon-plus" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10.833 9.17057L16.6647 9.16731L16.6663 10.834L10.833 10.8372V16.6673H9.16634V10.838L3.33464 10.8421L3.33301 9.17545L9.16634 9.17138V3.33398H10.833V9.17057Z" fill="#1A1A1A"/>
                      </svg>
                      <svg class="jingva-drawer-icon-minus" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M16.667 10.8327L3.33366 10.8408L3.33203 9.17415L16.6654 9.16602L16.667 10.8327Z" fill="#1A1A1A"/>
                      </svg>
                    </span>
                  </div>
                  <div class="link1-nav__content jingva-drawer-product__sheet">
                    <div class="jingva-drawer-product__stack">
                      {%- for sub_link in link.links -%}
                        <div class="jingva-drawer-series">
                          <p class="jingva-drawer-series__label">{{ sub_link.title | upcase }}</p>
                          <div class="jingva-drawer-series__track">
                            {% liquid
                              assign jingva_m = 0
                            %}
                            {% if sub_link.links.size > 0 %}
                              {% for product_link in sub_link.links %}
                                {% if jingva_m < 3 and product_link.type == 'product_link' and product_link.object %}
                                  {% render 'jingva-drawer-product-card', product: product_link.object %}
                                  {% assign jingva_m = jingva_m | plus: 1 %}
                                {% endif %}
                              {% endfor %}
                            {% elsif sub_link.type == 'collection_link' and sub_link.object != blank %}
                              {% for card_product in sub_link.object.products limit: 3 %}
                                {% render 'jingva-drawer-product-card', product: card_product %}
                              {% endfor %}
                            {% endif %}
                          </div>
                        </div>
                      {%- endfor -%}
                    </div>
                    {%- liquid
                      assign m_learn_url = mega_menu_block.settings.mega_footer_mobile_learn_url
                      assign m_learn_label = mega_menu_block.settings.mega_footer_mobile_learn_label
                      if m_learn_url == blank
                        assign m_learn_url = mega_menu_block.settings.mega_footer_learn_url
                      endif
                      if m_learn_label == blank
                        assign m_learn_label = mega_menu_block.settings.mega_footer_learn_label
                      endif
                      if m_learn_label == blank
                        assign m_learn_label = 'Learn more'
                      endif
                      assign m_compare_url = mega_menu_block.settings.mega_footer_mobile_compare_url
                      assign m_compare_label = mega_menu_block.settings.mega_footer_mobile_compare_label
                      if m_compare_url == blank
                        assign m_compare_url = mega_menu_block.settings.mega_footer_compare_url
                      endif
                      if m_compare_label == blank
                        assign m_compare_label = mega_menu_block.settings.mega_footer_compare_label | default: 'Compare option'
                      endif
                    -%}
                    {%- if m_compare_url != blank or m_learn_url != blank -%}
                      <div class="jingva-drawer-product__actions jingva-drawer-product__actions--footer">
                        {%- if m_compare_url != blank -%}
                          <a href="{{ m_compare_url }}" class="jingva-drawer-pill jingva-drawer-pill--dark">
                            <span>{{ m_compare_label }}</span>
                            <span class="jingva-drawer-pill__suffix">(3)</span>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="5" width="7" height="14" rx="1" stroke="currentColor" stroke-width="2"/><rect x="13" y="5" width="7" height="14" rx="1" stroke="currentColor" stroke-width="2"/></svg>
                          </a>
                        {%- endif -%}
                        {%- if m_learn_url != blank -%}
                          <a href="{{ m_learn_url }}" class="jingva-drawer-pill jingva-drawer-pill--outline">
                            <span>{{ m_learn_label }}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17.4141 12L9.70703 19.707L8.29297 18.293L14.5859 12L8.29297 5.70703L9.70703 4.29297L17.4141 12Z" fill="#E90202"/></svg>
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- elsif link.links.size == 0 and mega_menu_block != '' and is_mega_menu == false -%}
                {% comment %} 这是banner {% endcomment %}
                <div class="link1-nav__wrapper">
                  <div class="text-with-icon w-full group justify-between link-nav-title">
                    <span><span class="reversed-link">{{ link.title }}</span></span>
                    <span class="link1-nav__chevron">{%- render 'icon' with 'chevron-right', direction_aware: true -%}</span>
                  </div>
                  <div class="link1-nav__content banner-content">
                    {% comment %} 添加banner内容 {% endcomment %}
                    {%- render 'navigation-promo-block',link:link, navigation_layout: layout, mega_menu_block: mega_menu_block, is_navigation_drawer: true, link_col: link.links.size -%}
                  </div>
                </div>
              {%- elsif link.links.size > 0 -%}
                <div class="link1-nav__wrapper">
                  <div class="text-with-icon w-full group justify-between link-nav-title">
                    <span><span class="reversed-link">{{ link.title }}</span></span>
                    <span class="jingva-drawer-tab-icon" aria-hidden="true">
                      <svg class="jingva-drawer-icon-plus" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10.833 9.17057L16.6647 9.16731L16.6663 10.834L10.833 10.8372V16.6673H9.16634V10.838L3.33464 10.8421L3.33301 9.17545L9.16634 9.17138V3.33398H10.833V9.17057Z" fill="#1A1A1A"/>
                      </svg>
                      <svg class="jingva-drawer-icon-minus" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M16.667 10.8327L3.33366 10.8408L3.33203 9.17415L16.6654 9.16602L16.667 10.8327Z" fill="#1A1A1A"/>
                      </svg>
                    </span>
                  </div>
                  <div class="link1-nav__content">
                    <ul class="v-stack gap-4">
                      {%- for sub_link in link.links -%}
                        <li class="link2-nav-li">
                          <a href="{{ sub_link.url }}" class="text-with-icon w-full group justify-between link2-nav-a">
                            <span><span class="reversed-link">{{ sub_link.title }}</span></span>
                            {% comment %} <span>{%- render 'icon' with 'chevron-right', direction_aware: true -%}</span> {% endcomment %}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              {%- else -%}
                <a href="{{ link.url }}" class="text-with-icon w-full group justify-between">
                  <span><span class="reversed-link">{{ link.title }}</span></span>
                  <span class="link1-nav__chevron" aria-hidden="true">
                    <svg class="jingva-drawer-icon-chevron" width="8" height="13" viewBox="0 0 8 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.60059 6.42285L1.17773 12.8457L0 11.667L5.24414 6.42285L0 1.17871L1.17773 0L7.60059 6.42285Z" fill="#0A0A0A"/>
                    </svg>
                  </span>
                </a>
              {%- endif -%}
            </li>

            {%- if link.links.size > 0 or mega_menu_block != '' and is_mega_menu == false -%}
              {%- capture link_level_2 -%}
                {{- link_level_2 -}}

                <div class="panel__wrapper" {% if mega_menu_block.settings.promo_content_layout == 'grid' or mega_menu_block.settings.promo_content_layout == 'collage' %}style="--panel-wrapper-justify-content: flex-start"{% endif %} hidden>
                    {% comment %} <ul class="v-stack {% if is_mega_menu and is_image_shown == 'show' %}gap-3{% else %}gap-4{% endif %}">
                        <li class="{% if layout != 'drawer' %}lg:hidden{% endif %}">
                            <button class="text-with-icon h6 text-subdued" data-panel="0">
                              {%- render 'icon' with 'chevron-left', direction_aware: true -%} {{ link.title }}
                            </button>
                          </li>
                    </ul> {% endcomment %}
                    {% assign sub_ul_class = '' %}
                      {% unless is_mega_menu %}
                        {% if mega_menu_block != '' %}
                          {% assign sub_ul_class = 'has-promo ' %}
                        {% endif %}
                      {% endunless %}
                      {% style %}
                        .close-button:not(.link2-close-btn){
                          display: none;
                        }
                      {% endstyle %}
                       <div class="link2-sub-btn-box">
                          <button class="link2-sub-btn text-with-icon h6 text-subdued" data-panel="0">
                            {%- render 'icon' with 'chevron-left', direction_aware: true -%} {{ link.title }}
                          </button>
                          <button class="link2-close-btn" is="close-button" aria-label="Close"><svg role="presentation" stroke-width="2" focusable="false" width="19" height="19" class="icon icon-close" viewBox="0 0 24 24">
                            <path d="M17.658 6.343 6.344 17.657M17.658 17.657 6.344 6.343" stroke="currentColor"></path>
                          </svg></button>
                       </div>
                    <ul class="{{ sub_ul_class }}sub-link-container v-stack {% if is_mega_menu and is_image_shown == 'show' %}gap-3{% endif %}
                        {% if is_mega_menu %} is-mega-menu{% endif %}
                        {% for sub_link in link.links %}
                          {% assign matched_image = '' %}
                          {% for i in (1..8) %}
                            {% assign sub_link_id = 'target_sub_link' | append: i %}
                            {% assign sub_image_id = 'sub_link_image' | append: i %}
                            {% assign current_sub_link = mega_menu_block.settings[sub_link_id] %}
                            {% assign current_sub_image = mega_menu_block.settings[sub_image_id] %}
                            {% if sub_link.title == current_sub_link %}
                              {% assign matched_image = current_sub_image %}
                            {% endif %}
                          {% endfor %}
                          {% if matched_image != blank %}
                            have-image
                            {% break %}
                          {% endif %}
                        {% endfor %}
                      ">
                    
                      {%- if link.links.size > 0 -%}
                        {%- for sub_link in link.links -%}
                        {% assign matched_image = '' %}  {%- comment -%} Reset before each sub_link iteration {%- endcomment -%}
                      
                        <li class="bold {% if is_mega_menu %}sm:h5{% else %}sm:h4{% endif %} jingva-sub-link2-item sub-link-items custom-css-mobile">
                          {%- if sub_link.links.size > 0 -%}
                            
                            {% for i in (1..8) %}
                              {% assign sub_link_id = 'target_sub_link' | append: i %}
                              {% assign sub_image_id = 'sub_link_image' | append: i %}
                              {% assign current_sub_link = mega_menu_block.settings[sub_link_id] %}
                              {% assign current_sub_image = mega_menu_block.settings[sub_image_id] %}
                      
                              {% if sub_link.title == current_sub_link %}
                                {% assign matched_image = current_sub_image %}
                              {% endif %}
                            {% endfor %}
                            
                            {% comment %} {% if matched_image != blank %}
                              {{ matched_image | image_url: width: 300 | image_tag: loading: 'lazy', sizes: image_sizes, widths: '200,300,400,500,600,800,1000', class: "mega-menu__image zoom-image" }}
                            {% endif %} {% endcomment %}
                            
                      
                            <button class="text-with-icon w-full justify-between" aria-expanded="false" data-panel="2-{% increment level_2 %}">
                              <span>{{ sub_link.title }}</span>
                              <span class="circle-chevron group-hover:colors group-expanded:colors">{%- render 'icon' with 'chevron-right-small', direction_aware: true -%}</span>
                            </button>
                            {% comment %} Custom Added {% endcomment %}
                            
                            <ul class="sub-link2-content v-stack {% if is_image_shown %}gap-3{% else %}gap-4{% endif %}">
                                  {% comment %} <li class="text-with-icon {% if layout != 'drawer' %}lg:hidden{% endif %}">
                                  <button class="text-with-icon h6 text-subdued" data-panel="1">
                                      {%- render 'icon' with 'chevron-left', direction_aware: true -%} {{ sub_link.title }}
                                  </button>
                                  </li> {% endcomment %}

                                  {%- for sub_sub_link in sub_link.links -%}
                                  <li class="{% if mobile_opening == 'left' %}h3{% else %}h5-unset{% endif %} sm:h5-unset">
                                      
                                    
                                    <a class="group {% if is_image_shown %}h-stack gap-4{% else %}block w-full{% endif %}"
                                      href="{{ sub_sub_link.url }}">


                                      {%- if is_image_shown and sub_sub_link.object != blank -%}
                                          {%- assign sub_sub_link_image = '' -%}

                                          {%- case sub_sub_link.type -%}
                                          {%- when 'collection_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.products.first.featured_media -%}

                                          {%- when 'product_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.featured_media -%}

                                          {%- when 'blog_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.articles.first.image -%}

                                          {%- when 'article_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.image -%}
                                          {%- endcase -%}

                                          {%- if sub_sub_link_image != blank -%}
                                          {{- sub_sub_link_image | image_url: width: 104 | image_tag: loading: 'lazy', sizes: '52px', widths: '52,104', class: 'panel-link__image rounded' -}}
                                          {%- endif -%}
                                      {%- endif -%}
                                      {% comment %} 如果是产品链接 就显示一张产品图片 {% endcomment %}
                                      {% if sub_sub_link.type == 'product_link' %}
                                        {% comment %} <img src="{{ sub_sub_link.object.featured_media | image_url: width: 104 }}" alt="{{ sub_sub_link.object.title }}" /> {% endcomment %}
                                        {{ sub_sub_link.object.featured_media | image_url: width: 70 | image_tag: loading: 'lazy', sizes: image_sizes, widths: '200,300,400,500,600,800,1000', class: "" }}
                                      {% endif %}

                                        <span class="title-box">
                                          <span class="reversed-link">{{ sub_sub_link.title }}</span>
                                          {% if sub_sub_link.object.tags.first %}
                                            <span class="tag">{{ sub_sub_link.object.tags.first }}</span>
                                          {% endif %}
                                        </span>
                                      </a>
                                  </li>
                                  {%- endfor -%}
                                  <li class="{% if mobile_opening == 'left' %}h3{% else %}h5-unset{% endif %} sm:h5-unset">
                                      <a class="jingva-more-btn" href="{{ sub_link.url }}">
                                        View All
                                      </a>
                                  </li>
                              </ul>
                          {% comment %} Custom Added {% endcomment %}
                            {%- else -%}
                              <a class="group {% if is_image_shown and is_mega_menu %}h-stack gap-4{% else %}block w-full{% endif %}" href="{{ sub_link.url }}">
                                {%- if is_image_shown and sub_link.object != blank and is_mega_menu -%}
                                  {%- assign sub_link_image = '' -%}

                                  {%- case sub_link.type -%}
                                    {%- when 'collection_link' -%}
                                      {%- assign sub_link_image = sub_link.object.products.first.featured_media -%}

                                    {%- when 'product_link' -%}
                                      {%- assign sub_link_image = sub_link.object.featured_media -%}

                                    {%- when 'blog_link' -%}
                                      {%- assign sub_link_image = sub_link.object.articles.first.image -%}

                                    {%- when 'article_link' -%}
                                      {%- assign sub_link_image = sub_link.object.image -%}
                                  {%- endcase -%}

                                  {%- if sub_link_image != blank -%}
                                    {{- sub_link_image | image_url: width: 120 | image_tag: loading: 'lazy', sizes: '60px', widths: '120', class: 'panel-link__image rounded' -}}
                                  {%- endif -%}
                                {%- endif -%}

                                <span><span class="reversed-link">{{ sub_link.title }}</span></span>
                              </a>
                            {%- endif -%}
                          </li>

                          {%- if sub_link.links.size > 0 -%}
                            {%- capture link_level_3 -%}
                              {{- link_level_3 -}}

                              <div class="panel__wrapper" hidden>
                                {% comment %} <ul class="v-stack {% if is_image_shown %}gap-3{% else %}gap-4{% endif %}">
                                  <li class="text-with-icon {% if layout != 'drawer' %}lg:hidden{% endif %}">
                                    <button class="text-with-icon h6 text-subdued" data-panel="1">
                                      {%- render 'icon' with 'chevron-left', direction_aware: true -%} {{ sub_link.title }}
                                    </button>
                                  </li>

                                  {%- for sub_sub_link in sub_link.links -%}
                                    <li class="{% if mobile_opening == 'left' %}h3{% else %}h5{% endif %} sm:h5">
                                      <a class="group {% if is_image_shown %}h-stack gap-4{% else %}block w-full{% endif %}"
                                        href="{{ sub_sub_link.url }}">
                                        {%- if is_image_shown and sub_sub_link.object != blank -%}
                                          {%- assign sub_sub_link_image = '' -%}

                                          {%- case sub_sub_link.type -%}
                                            {%- when 'collection_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.products.first.featured_media -%}

                                            {%- when 'product_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.featured_media -%}

                                            {%- when 'blog_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.articles.first.image -%}

                                            {%- when 'article_link' -%}
                                              {%- assign sub_sub_link_image = sub_sub_link.object.image -%}
                                          {%- endcase -%}

                                          {%- if sub_sub_link_image != blank -%}
                                            {{- sub_sub_link_image | image_url: width: 104 | image_tag: loading: 'lazy', sizes: '52px', widths: '52,104', class: 'panel-link__image rounded' -}}
                                          {%- endif -%}
                                        {%- endif -%}

                                        <span><span class="reversed-link">{{ sub_sub_link.title }}</span></span>
                                      </a>
                                    </li>
                                  {%- endfor -%}
                                </ul> {% endcomment %}
                              </div>
                            {%- endcapture -%}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    
                  </ul>

                  {%- unless is_mega_menu -%}
                    {% comment %} 图片 {% endcomment %}
                    {%- if mega_menu_block != '' -%}
                      <style>
                          .new-releases-md{
                            justify-content: center;
                          }
                          .new-releases-md .navigation-promo{
                            display: flex;
                            flex-direction: column;
                          }
                          .new-releases-md a{
                            position: relative;
                            width: 100%;
                          }
                          .new-releases-md a img{
                            aspect-ratio: 16 / 9;
                            object-fit: cover;
                            width: 100% !important;
                          }
                          .new-releases-md a .new-releases-a-content{
                            position: absolute;
                            top: 50%;
                            transform: translateY(-50%);
                            left: 26px;
                            width: 100%;
                          }
                          .new-releases-md a .new-releases-a-content p{
                            font-size: 16px;
                          }
                          .new-releases-md a .new-releases-a-content .new-r-btn{
                            background: #fff;
                            color: #000;
                            padding: 8px 16px;
                            border-radius: 24px;
                            margin-top: 18px;
                            font-size: 12px;
                            transition: all 0.3s ease-in-out;
                          }
                          .new-releases-md a .new-releases-a-content .new-r-btn:hover{
                            background: #E1040F;
                            color: #fff;
                          }
                        </style>
