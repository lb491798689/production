{%- comment -%}
Optimized product media loading snippet
Usage: {% render 'optimized-product-media' with media: media_object, sizes: 'optional-sizes', priority: 'optional-priority', group: 'optional-group', enable_zoom: true %}
{%- endcomment -%}

{%- liquid
  assign loading = 'lazy'
  assign fetchpriority = 'low'
  assign default_sizes = '(max-width: 699px) 100vw, 800px'
  assign max_width = 1400
  assign mobile_max_width = 600
  
  if priority == 'high'
    assign loading = 'eager'
    assign fetchpriority = 'high'
  endif
  
  assign sizes = sizes | default: default_sizes
  assign desktop_widths = '400,600,800,1000,1200,1400'
  assign mobile_widths = '300,400,600'
-%}

{%- case media.media_type -%}
  {%- when 'image' -%}
    <div class="product-gallery__media" data-media-type="{{ media.media_type }}" data-media-id="{{ media.id }}">
      <picture>
        <source
          media="(max-width: 699px)"
          srcset="{{ media | image_url: width: 300, format: 'webp' }} 300w,
                  {{ media | image_url: width: 400, format: 'webp' }} 400w,
                  {{ media | image_url: width: 600, format: 'webp' }} 600w"
          type="image/webp"
          sizes="(max-width: 699px) 95vw, 600px"
        >
        <source
          srcset="{{ media | image_url: width: 400, format: 'webp' }} 400w,
                  {{ media | image_url: width: 600, format: 'webp' }} 600w,
                  {{ media | image_url: width: 800, format: 'webp' }} 800w,
                  {{ media | image_url: width: 1000, format: 'webp' }} 1000w,
                  {{ media | image_url: width: 1200, format: 'webp' }} 1200w,
                  {{ media | image_url: width: 1400, format: 'webp' }} 1400w"
          type="image/webp"
          sizes="{{ sizes }}"
        >
        <img
          src="{{ media | image_url: width: media.width }}"
          loading="{{ loading }}"
          fetchpriority="{{ fetchpriority }}"
          sizes="{{ sizes }}"
          srcset="{{ media | image_url: width: 400 }} 400w,
                  {{ media | image_url: width: 600 }} 600w,
                  {{ media | image_url: width: 800 }} 800w,
                  {{ media | image_url: width: 1000 }} 1000w,
                  {{ media | image_url: width: 1200 }} 1200w,
                  {{ media | image_url: width: 1400 }} 1400w"
          class="rounded product-media__img {% if enable_zoom %}zoom-image__image{% endif %}"
          width="{{ media.width }}"
          height="{{ media.height }}"
          data-media-type="image"
          data-media-id="{{ media.id }}"
          {% if enable_zoom %}data-zoomable="true"{% endif %}
          alt="{{ media.alt | escape }}"
        >
      </picture>
      
      {%- if enable_zoom -%}
        <button type="button" is="product-zoom-button" class="circle-button circle-button--fill ring">
          <span class="sr-only">{{ 'product.gallery.zoom' | t }}</span>
          {%- render 'icon' with 'image-zoom' -%}
        </button>
      {%- endif -%}
    </div>

  {%- when 'video', 'external_video' -%}
    <video-media {% if media.host %}host="{{ media.host }}"{% endif %} {% unless show_play_button %}show-play-button{% endunless %} {% if group != blank %}group="{{ group | escape }}"{% endif %} style="--aspect-ratio: {{ media.aspect_ratio }}" class="product-media">
      <picture class="product-media__poster">
        <source
          media="(max-width: 699px)"
          srcset="{{ media.preview_image | image_url: width: 300, format: 'webp' }} 300w,
                  {{ media.preview_image | image_url: width: 400, format: 'webp' }} 400w,
                  {{ media.preview_image | image_url: width: 600, format: 'webp' }} 600w"
          type="image/webp"
          sizes="(max-width: 699px) 95vw, 600px"
        >
        <source
          srcset="{{ media.preview_image | image_url: width: 400, format: 'webp' }} 400w,
                  {{ media.preview_image | image_url: width: 600, format: 'webp' }} 600w,
                  {{ media.preview_image | image_url: width: 800, format: 'webp' }} 800w,
                  {{ media.preview_image | image_url: width: 1000, format: 'webp' }} 1000w"
          type="image/webp"
          sizes="{{ sizes }}"
        >
        {{- media.preview_image | image_url: width: media.preview_image.width | image_tag: 
          loading: loading,
          fetchpriority: fetchpriority,
          sizes: sizes,
          widths: desktop_widths,
          class: 'rounded product-media__img',
          height: media.preview_image.height,
          width: media.preview_image.width
        -}}
      </picture>

      {%- if media.media_type == 'video' -%}
        {{- media | video_tag: controls: true, playsinline: true, preload: 'metadata', poster: media.preview_image | image_url: width: 1000, class: 'product-media__video' -}}
      {%- else -%}
        <template>
          {%- if media.host == 'youtube' -%}
            {{- media | external_video_url: enablejsapi: true, loop: loop, controls: 1, modestbranding: 1 | external_video_tag -}}
          {%- elsif media.host == 'vimeo' -%}
            {{- media | external_video_url: autopause: true, loop: loop, controls: 1, transparent: 1 | external_video_tag -}}
          {%- endif -%}
        </template>
      {%- endif -%}
    </video-media>

  {%- when 'model' -%}
    <model-media {% if group != blank %}group="{{ group | escape }}"{% endif %} handle="{{ product.handle }}" style="aspect-ratio: {{ media.preview_image.aspect_ratio }}" class="product-media">
      <picture class="product-media__poster">
        <source
          media="(max-width: 699px)"
          srcset="{{ media.preview_image | image_url: width: 300, format: 'webp' }} 300w,
                  {{ media.preview_image | image_url: width: 400, format: 'webp' }} 400w,
                  {{ media.preview_image | image_url: width: 600, format: 'webp' }} 600w"
          type="image/webp"
          sizes="(max-width: 699px) 95vw, 600px"
        >
        <source
          srcset="{{ media.preview_image | image_url: width: 400, format: 'webp' }} 400w,
                  {{ media.preview_image | image_url: width: 600, format: 'webp' }} 600w,
                  {{ media.preview_image | image_url: width: 800, format: 'webp' }} 800w,
                  {{ media.preview_image | image_url: width: 1000, format: 'webp' }} 1000w"
          type="image/webp"
          sizes="{{ sizes }}"
        >
        {{- media.preview_image | image_url: width: media.preview_image.width | image_tag: 
          loading: loading,
          fetchpriority: fetchpriority,
          sizes: sizes,
          widths: desktop_widths,
          class: 'rounded product-media__img',
          height: media.preview_image.height,
          width: media.preview_image.width
        -}}
      </picture>
      {{- media | model_viewer_tag: reveal: 'interaction', toggleable: true, class: 'product-media__model' -}}
    </model-media>
{%- endcase -%} 